index 037b376..0954528 100644
--- a/src-tui/010-prelude.py
+++ b/src-tui/010-prelude.py
@@ -10,3 +10,105 @@ invoked from ``090-main.py``.
 """
 
 __version__ = '0.1.0'
+
+
+# ---- profiling -----------------------------------------------------------
+#
+# Opt-in via ``BROWSE_TUI_PROFILE=1``. When enabled, ``_perf_log`` /
+# ``_perf_section`` append timing lines to a per-PID log file (override
+# the path with ``BROWSE_TUI_PROFILE_LOG``). The helpers are no-ops when
+# the env var is unset — a single boolean check per call. The TUI owns
+# stdout/stderr in raw mode so output MUST go to a file; never print.
+#
+# Log line format (tab-free, grep-friendly):
+#
+#   t=<perf_counter> event=<name> dt=<seconds> k1=v1 k2=v2 ...
+#
+# Two scenarios we want to distinguish from one log:
+#
+#   1. Initial load of a large file — look for ``event=scan_tree``,
+#      ``event=list_messages``, the first ``event=apply_ops``, etc.
+#   2. Expanding a big subtree — look for ``event=do_expand`` followed
+#      by ``event=worker_get_children`` and the subsequent
+#      ``event=update_data_apply`` / ``event=sub_layout``.
+#
+# Recipes can import these via ``from browse_tui import _perf_log,
+# _perf_section`` (the running module is aliased as ``browse_tui``).
+
+import os as _perf_os
+import threading as _perf_threading
+import time as _perf_time
+
+_PERF_ENABLED = bool(_perf_os.environ.get('BROWSE_TUI_PROFILE'))
+_PERF_LOG_PATH = _perf_os.environ.get(
+    'BROWSE_TUI_PROFILE_LOG',
+    f'/tmp/browse-tui-perf-{_perf_os.getpid()}.log',
+)
+_PERF_LOG_FH = None
+_PERF_LOG_LOCK = _perf_threading.Lock()
+
+
+def _perf_open_log():
+    """Lazy-open the log file. Returns the file handle, or False on failure."""
+    global _PERF_LOG_FH
+    if _PERF_LOG_FH is not None:
+        return _PERF_LOG_FH
+    try:
+        _PERF_LOG_FH = open(_PERF_LOG_PATH, 'a', buffering=1)
+    except OSError:
+        _PERF_LOG_FH = False
+    return _PERF_LOG_FH
+
+
+def _perf_log(event, **fields):
+    """Append a perf event line. No-op when profiling is disabled."""
+    if not _PERF_ENABLED:
+        return
+    fh = _perf_open_log()
+    if not fh:
+        return
+    t = _perf_time.perf_counter()
+    parts = [f't={t:.6f}', f'event={event}']
+    for k, v in fields.items():
+        parts.append(f'{k}={v}')
+    line = ' '.join(parts) + '\n'
+    with _PERF_LOG_LOCK:
+        try:
+            fh.write(line)
+        except OSError:
+            pass
+
+
+class _PerfSection:
+    """Context manager — times its body, emits one event with ``dt=``."""
+
+    __slots__ = ('_event', '_fields', '_t0')
+
+    def __init__(self, event, **fields):
+        self._event = event
+        self._fields = fields
+        self._t0 = 0.0
+
+    def __enter__(self):
+        if _PERF_ENABLED:
+            self._t0 = _perf_time.perf_counter()
+        return self
+
+    def __exit__(self, exc_type, exc, tb):
+        if _PERF_ENABLED:
+            dt = _perf_time.perf_counter() - self._t0
+            _perf_log(self._event, dt=f'{dt:.6f}', **self._fields)
+        return False
+
+    def set(self, **fields):
+        """Update fields mid-section (e.g., add ``n=`` once counted)."""
+        self._fields.update(fields)
+
+
+def _perf_section(event, **fields):
+    """Return a context manager that times its body and logs one event."""
+    return _PerfSection(event, **fields)
+
+
+if _PERF_ENABLED:
+    _perf_log('profile_start', pid=_perf_os.getpid(), version=__version__)
