#!/usr/bin/env -S browse-tui --run-py
"""browse-ps — interactive process tree.

Builds a hierarchy from ``ps -eo pid=,ppid=,user=,pcpu=,rss=,time=,args=``.
Each process is an Item; children are processes whose ``ppid == this pid``.
The root of the tree is PID 1 (init / systemd) on Linux; everything else is
descendants. Kernel threads (ppid == 0, except PID 1) are skipped to keep the
tree readable.

A single ``_snapshot`` per reload fetches the whole process table once and
builds a ``{pid: ProcInfo}`` map (pid, ppid, user, cpu%, private/RSS memory,
cumulative CPU time, full command line). Each Item carries display columns
(``col_pid`` / ``col_user`` / ``col_cpu`` / ``col_mem``); the row title is the
full command line. CPU% is the instantaneous cumulative-time delta between the
current and previous snapshot, falling back to the ``ps pcpu`` lifetime average
on the first sample or for a freshly-appeared pid.

Reload with ctrl-r; a background daemon thread also auto-reloads every ``-d``
seconds (default ``4.0``; ``-d 0`` disables it). ``t`` toggles between the ppid
tree (default) and a flat list of every process (``--tree`` / ``--no-tree`` set
the initial mode). The
htop-style capitals ``N`` / ``P`` / ``M`` / ``T`` / ``U`` sort by pid / CPU% /
memory / CPU time / user (re-press the active key to reverse it; each key
remembers its own direction). Custom action ``k:Kill`` sends SIGTERM to the
selected pid (with a y/n confirmation). A right-click context menu (``on_context_menu``) re-invokes
``ctx.menu`` for a flat signal submenu and pages auxiliary process data
(lsof / ss / /proc/<pid>/{environ,status}).

Demonstrates: live system data, hierarchical children built from an
external CLI, /proc-based preview, a destructive custom Action, and a
context menu with a re-invoked submenu.
"""

import os
import shutil
import signal
import subprocess
import sys
import threading
import time

from browse_tui import (
    Action, Browser, BrowserConfig, Item,
    cell_ljust, cell_rjust, default_row_expander, default_row_indent,
    default_row_selection, recipe_argv, style,
)


# --- Process data layer -----------------------------------------------------

# How wide to ask ``ps`` to render the user column on Linux (procps). Default is
# 8 chars and truncates long account names; the ``user:<w>`` form widens it.
# Verified honoured on this box (procps); a variant that ignores it triggers the
# uid+pwd fallback in ``_snapshot`` (see ``_PS_USER_WIDTH_OK``).
_PS_USER_WIDTH = 32

# Linux only: when ``ps -o user:<w>`` is NOT honoured (the column still truncates
# at 8), fall back to ``ps -o uid=`` + this per-UID pwd cache. ``None`` until the
# first snapshot probes the width; thereafter ``True``/``False``.
_PS_USER_WIDTH_OK = None
_UID_NAMES = {}

# Two most-recent snapshots, kept module-level so CPU% can diff cumulative CPU
# time across reloads. Each is ``(wall_clock, {pid: ProcInfo})`` or ``None``.
_PREV_SNAPSHOT = None
_CUR_SNAPSHOT = None

# View mode: ``True`` = the ppid hierarchy (default), ``False`` = one flat list
# (ordered by the active sort key — pid by default). The ``t`` action flips it;
# the ``--tree`` / ``--no-tree`` CLI flags set it before launch. ``get_children``
# dispatches on it (see B4).
_TREE_MODE = True

# Sort state (B5, htop-style capitals). ``_SORT_KEY`` is the active ``ProcInfo``
# field; ``_SORT_DIR`` remembers each key's last direction (``False`` = ascending,
# ``True`` = descending) so switching away and back restores it. Pressing the
# active key reverses its direction. Seeded with the spec defaults: pid/user
# ascending, cpu%/mem/cpu_secs descending. ``_sort_procs`` applies the active
# key to whichever list ``get_children`` is about to return (a parent's children
# in tree mode, the whole table in flat mode), tie-breaking by pid.
_SORT_KEY = 'pid'
_SORT_DIR = {
    'pid': False,        # ascending
    'cpu_pct': True,     # descending
    'mem_bytes': True,   # descending
    'cpu_secs': True,    # descending
    'user': False,       # ascending
}

# Per-sort-key display label, for the ``sort: <label> <arrow>`` flash.
_SORT_LABELS = {
    'pid': 'pid',
    'cpu_pct': 'cpu%',
    'mem_bytes': 'mem',
    'cpu_secs': 'time',
    'user': 'user',
}

# Background updater (B8). ``-d <seconds>`` sets the refresh interval; the
# default is auto-update ON every 4 s, and a value <= 0 disables it (no thread
# started). The daemon worker ticks every interval and calls ``b.refresh()``
# (thread-safe — it ``post``s ``_do_refresh`` onto the UI thread), which
# re-samples the process snapshot (CPU% deltas + the new/finished diff ride that
# same sample). ``_UPDATE_STOP`` / ``_UPDATE_THREAD`` are created in ``main`` and
# torn down in its ``finally``. Mirrors browse-claude's tail-worker daemon.
_DEFAULT_UPDATE_INTERVAL = 4.0
_UPDATE_STOP = None    # threading.Event; created in main()
_UPDATE_THREAD = None  # threading.Thread; created in main()


class ProcInfo:
    """One process row from a snapshot.

    Carries the raw fields parsed from ``ps`` (plus Linux private memory) so the
    tree builder and the column/CPU% logic share one source of truth: ``pid`` /
    ``ppid`` (ints), ``user`` (untruncated name), ``pcpu`` (the ps lifetime-
    average percent, the CPU% fallback), ``rss_bytes`` (resident set), ``cpu_secs``
    (cumulative CPU time, the delta input + time sort key), ``mem_bytes`` (the
    chosen memory figure — private on Linux, RSS elsewhere), and ``args`` (the
    full command line → row title).
    """

    def __init__(self, pid, ppid, user, pcpu, rss_bytes, cpu_secs, args):
        self.pid = pid
        self.ppid = ppid
        self.user = user
        self.pcpu = pcpu
        self.rss_bytes = rss_bytes
        self.cpu_secs = cpu_secs
        self.args = args
        # Memory figure shown in the gutter; private on Linux, RSS elsewhere.
        # Defaults to RSS and is upgraded in ``_snapshot`` where smaps applies.
        self.mem_bytes = rss_bytes


def human_size(n):
    """``1536`` → ``'1K'`` — compact binary size (matches browse-fs)."""
    for unit in ('B', 'K', 'M', 'G', 'T'):
        if n < 1024:
            return f'{n}{unit}'
        n //= 1024
    return f'{n}P'


def _parse_time(field):
    """``[[DD-]HH:]MM:SS`` (ps ``time`` column) → integer seconds.

    Accepts the POSIX ``MM:SS``, the ``HH:MM:SS`` and the BSD/long ``DD-HH:MM:SS``
    shapes. Unparseable input yields ``0`` (graceful — the row still renders).
    """
    days = 0
    if '-' in field:
        d, _, field = field.partition('-')
        try:
            days = int(d)
        except ValueError:
            return 0
    parts = field.split(':')
    try:
        nums = [int(p) for p in parts]
    except ValueError:
        return 0
    secs = 0
    for n in nums:                       # left-to-right: …:HH:MM:SS
        secs = secs * 60 + n
    return days * 86400 + secs


def _private_mem_bytes(pid):
    """Linux private memory (``Private_Clean + Private_Dirty``) for ``pid``.

    Reads ``/proc/<pid>/smaps_rollup`` (one small file). Returns ``None`` when
    the file is absent (old kernel), unreadable (permissions), or malformed, so
    the caller can fall back to RSS.
    """
    try:
        with open(f'/proc/{pid}/smaps_rollup') as f:
            text = f.read()
    except OSError:
        return None
    total = 0
    found = False
    for line in text.splitlines():
        if line.startswith(('Private_Clean:', 'Private_Dirty:')):
            try:
                total += int(line.split()[1]) * 1024   # the value is in kB
                found = True
            except (IndexError, ValueError):
                return None
    return total if found else None


def _ps_user_args():
    """``ps`` argv for the user column, probing the ``:width`` form on Linux.

    On Linux (procps) we ask for ``user:<w>`` to defeat the 8-char truncation;
    elsewhere (macOS/BSD) plain ``user=`` is already untruncated. Returns the
    ``-o`` spec string for the user field.
    """
    if sys.platform == 'darwin':
        return 'user='
    return f'user:{_PS_USER_WIDTH}='


def _resolve_uid(uid):
    """Username for a numeric ``uid`` via a per-UID pwd cache (Linux fallback)."""
    if uid in _UID_NAMES:
        return _UID_NAMES[uid]
    try:
        import pwd
        name = pwd.getpwuid(int(uid)).pw_name
    except (KeyError, ValueError, ImportError):
        name = str(uid)
    _UID_NAMES[uid] = name
    return name


def _run_ps(user_field):
    """Run ``ps`` for the snapshot; return stdout or ``''`` on any failure.

    Errors are swallowed (missing ``ps`` / non-zero exit) so the UI degrades to
    an empty tree rather than crashing — the original browse-procs behaviour.
    """
    try:
        return subprocess.run(
            ['ps', '-eo', f'pid=,ppid=,{user_field},pcpu=,rss=,time=,args='],
            check=True, capture_output=True, text=True).stdout
    except (OSError, subprocess.CalledProcessError):
        return ''


def _snapshot(*, reload=False):
    """Return ``{pid: ProcInfo}`` for the current process table.

    Resamples (fresh ``ps`` + a new ``ProcInfo`` map, rotating the previous one
    into ``_PREV_SNAPSHOT``) when ``reload=True`` OR no snapshot exists yet;
    otherwise reuses the cached ``_CUR_SNAPSHOT``. The framework enqueues only
    the root with ``reload=True`` on a full refresh (descendant re-fetches and
    lazy expansions pass ``reload=False``), so this yields exactly one sample
    per reload cycle and every ``get_children`` in that cycle shares it.

    Linux usernames come from ``ps -o user:<w>``; if that variant ignores the
    width and truncates at 8, we re-run with ``uid=`` + a pwd cache (probed once
    per process via ``_PS_USER_WIDTH_OK``). Memory is private (smaps_rollup) on
    Linux where readable, else RSS.
    """
    global _PREV_SNAPSHOT, _CUR_SNAPSHOT, _PS_USER_WIDTH_OK

    if not reload and _CUR_SNAPSHOT is not None:
        return _CUR_SNAPSHOT[1]

    use_uid = sys.platform != 'darwin' and _PS_USER_WIDTH_OK is False
    out = _run_ps('uid=' if use_uid else _ps_user_args())

    # Probe (Linux, once): a procps variant that ignores ``user:<w>`` caps every
    # name at the legacy 8 chars. If the widest user field is exactly 8 we treat
    # the width as unhonoured and latch the uid+pwd fallback (re-running with
    # ``uid=``). The heuristic can't tell a genuine 8-char name from a truncated
    # one, but uid+pwd then yields the same/better name, so a false latch is
    # harmless. Probed against the parsed user column (3rd field).
    if (_PS_USER_WIDTH_OK is None and sys.platform != 'darwin'):
        widths = [len(line.split(None, 3)[2])
                  for line in out.splitlines() if len(line.split(None, 3)) >= 3]
        _PS_USER_WIDTH_OK = not (widths and max(widths) == 8)
        if not _PS_USER_WIDTH_OK:
            use_uid = True
            out = _run_ps('uid=')

    procs = {}
    for line in out.splitlines():
        # Split into exactly 7 fields, KEEPING args (which contains spaces)
        # intact via maxsplit=6.
        parts = line.split(None, 6)
        if len(parts) < 7:
            continue
        try:
            pid = int(parts[0])
            ppid = int(parts[1])
            pcpu = float(parts[3])
            rss_kb = int(parts[4])
        except ValueError:
            continue
        user = _resolve_uid(parts[2]) if use_uid else parts[2]
        info = ProcInfo(pid, ppid, user, pcpu, rss_kb * 1024,
                        _parse_time(parts[5]), parts[6])
        if sys.platform != 'darwin':
            private = _private_mem_bytes(pid)
            if private is not None:
                info.mem_bytes = private
        procs[pid] = info

    _PREV_SNAPSHOT = _CUR_SNAPSHOT
    _CUR_SNAPSHOT = (time.monotonic(), procs)
    return procs


def _cpu_pct(info):
    """Instantaneous CPU% for ``info`` from the cumulative-time delta.

    ``100 * Δcpu_secs / (Δwall_secs * ncpu)`` against the same pid in the
    previous snapshot. With no prior sample (first load or a freshly-appeared
    pid) — or a non-positive wall gap — fall back to ``ps pcpu`` (lifetime
    average). Returned as an integer percent.
    """
    prev = _PREV_SNAPSHOT
    cur = _CUR_SNAPSHOT
    if prev is not None and cur is not None and info.pid in prev[1]:
        dwall = cur[0] - prev[0]
        ncpu = os.cpu_count() or 1
        if dwall > 0:
            dcpu = info.cpu_secs - prev[1][info.pid].cpu_secs
            return int(round(100 * dcpu / (dwall * ncpu)))
    return int(round(info.pcpu))


# Primary sort value for each ``_SORT_KEY``. ``cpu_pct`` is computed by
# ``_cpu_pct`` (not a stored attribute, hence defined after it); ``user`` is
# lower-cased for a case-insensitive ordering; the rest read the ProcInfo field
# straight. The pid tie-break is applied separately by ``_sort_procs``.
_SORT_VALUES = {
    'pid': lambda i: i.pid,
    'cpu_pct': _cpu_pct,
    'mem_bytes': lambda i: i.mem_bytes,
    'cpu_secs': lambda i: i.cpu_secs,
    'user': lambda i: i.user.lower(),
}


def _sort_procs(infos):
    """Order a list of ``ProcInfo`` by the active sort key (B5).

    Applied by ``get_children`` to whichever list it is about to return — a
    parent's children in tree mode, the whole table in flat mode — so the
    ordering is identical in both scopes. A stable two-pass sort (by pid first,
    then by the active key) tie-breaks on ascending pid REGARDLESS of the active
    direction: only the primary key honours ``_SORT_DIR``, so a descending cpu%
    still lists equal-cpu rows in ascending-pid order (deterministic, and what
    htop does). ``infos`` is not mutated (``sorted`` returns a new list).
    """
    by_pid = sorted(infos, key=lambda i: i.pid)
    return sorted(by_pid, key=_SORT_VALUES[_SORT_KEY],
                  reverse=_SORT_DIR[_SORT_KEY])


def _proc_item(info, *, has_children):
    """Build one process ``Item`` carrying the gutter display columns.

    Shared by the tree and flat builders so the ``col_*`` gutter fields
    (``col_pid`` / ``col_user`` / ``col_cpu`` / ``col_mem``) and the title (the
    full command line) are assigned in exactly one place. ``.pid`` / ``.user``
    ride along for the existing signal / preview handlers. ``has_children`` is
    the caller's call: the ppid hierarchy in tree mode, always ``False`` in flat
    mode (every flat row is a leaf).
    """
    item = Item(id=info.pid, title=info.args, has_children=has_children)
    item.user = info.user
    item.pid = info.pid
    item.col_pid = str(info.pid)
    item.col_user = info.user
    item.col_cpu = f'{_cpu_pct(info)}%'
    item.col_mem = human_size(info.mem_bytes)
    return item


def get_children(parent_id, *, reload=False):
    """Children of ``parent_id``, built from the per-reload snapshot.

    Dispatches on ``_TREE_MODE`` (the ``t`` action / ``--tree`` flag):

    - **tree** (default): ``None`` (root) returns the init process — PID 1 on
      Linux. If we somehow can't find it (non-Linux, restricted environment),
      fall back to processes with ppid == 0 minus the kernel-thread PID 2.
      Otherwise the direct children of ``parent_id``.
    - **flat**: ``None`` (root) returns *every* process as one list, each a leaf
      (``has_children=False``); any non-None pid returns ``[]`` (flat rows don't
      expand).

    Whichever list is about to be returned (a parent's children in tree mode,
    the whole table in flat mode) is ordered by ``_sort_procs`` — the active
    sort key (default pid; ``N``/``P``/``M``/``T``/``U`` switch it). Each Item
    carries the gutter display columns (``col_pid`` / ``col_user`` / ``col_cpu``
    / ``col_mem``) and a title of the full command line; ``.pid`` / ``.user`` are
    kept for the existing signal/preview handlers (see ``_proc_item``).
    """
    procs = _snapshot(reload=reload)
    if not procs:
        return []

    if not _TREE_MODE:
        if parent_id is not None:
            return []                            # flat rows are leaves
        return [_proc_item(info, has_children=False)
                for info in _sort_procs(procs.values())]

    by_ppid = {}
    for info in procs.values():
        by_ppid.setdefault(info.ppid, []).append(info)

    if parent_id is None:
        init = procs.get(1)
        if init is not None:
            targets = [init]
        else:
            targets = [info for info in by_ppid.get(0, []) if info.pid != 2]
    else:
        targets = by_ppid.get(parent_id, [])

    return [_proc_item(info, has_children=bool(by_ppid.get(info.pid)))
            for info in _sort_procs(targets)]


# --- Gutter columns (B3) ----------------------------------------------------

def ps_gutter_segments(item, ctx):
    """Fixed ``pid · user · cpu% · mem`` columns for the left gutter.

    Sits between the selection marker and the tree indent (see ``ps_chrome``)
    so the columns don't drift rightward as tree depth grows. pid / cpu% / mem
    are RIGHT-justified, user LEFT-justified, each to its GLOBAL widest loaded
    value (``ctx.max_col_width_global``) so the columns line up across the
    whole tree regardless of each row's depth. A single space separates the
    columns (and trails the last) to match the spec example spacing. All dim.

    A row missing the ``col_*`` fields (no normal process row should) yields an
    empty gutter so the default content still renders.
    """
    if getattr(item, 'col_pid', None) is None:
        return []                                # synthetic/edge row → no gutter
    w = ctx.max_col_width_global
    dfg, dbold = style('dim')
    return [
        (cell_rjust(item.col_pid,  w('col_pid'))  + ' ', dfg, dbold),
        (cell_ljust(item.col_user, w('col_user')) + ' ', dfg, dbold),
        (cell_rjust(item.col_cpu,  w('col_cpu'))  + ' ', dfg, dbold),
        (cell_rjust(item.col_mem,  w('col_mem'))  + ' ', dfg, dbold),
    ]


def ps_chrome(item, ctx):
    """Row chrome with the gutter columns left of the tree indent (B3).

    Composes the framework chrome atoms so the order is
    ``selection · pid · user · cpu% · mem · indent · expander``; the name is
    the default content (the flexible last segment that truncates at the pane
    edge), so it is NOT rendered here.
    """
    return (default_row_selection(item, ctx)
            + ps_gutter_segments(item, ctx)
            + default_row_indent(item, ctx)
            + default_row_expander(item, ctx))


def get_preview(pid):
    """Dump a snippet of ``/proc/<pid>/status``.

    The first ~4 KB is plenty for the interactive case (Name, State,
    Pid, PPid, Uid, Gid, VmRSS, …). Errors (process gone, permissions)
    surface as a short hint.
    """
    if not isinstance(pid, int):
        return ''
    try:
        with open(f'/proc/{pid}/status') as f:
            return f.read(4096)
    except OSError as e:
        return f'[error] {e}'


def _send_signal(ctx, signum, name, *, confirm):
    """Send signal ``signum`` (named ``name``) to the cursor pid.

    Destructive signals pass ``confirm=True`` and gate behind a Yes/No
    dialog (mapped to ``True``/``False`` so the result is used directly);
    benign ones (SIGCONT/SIGINT) send straight away. The single send path
    for every signal — ``kill_proc`` (the ``k`` action) delegates here for
    SIGTERM so its confirm/flash/refresh behaviour stays single-sourced.
    """
    if not ctx.cursor:
        return
    pid = ctx.cursor.id
    if confirm and not ctx.confirm(
            f'send {name} to pid {pid} ({ctx.cursor.title})?',
            [('&Yes', True), ('&No', False)]):
        return
    try:
        os.kill(pid, signum)
        ctx.flash(f'sent {name} to pid {pid}', log=True)
    except OSError as e:
        ctx.error(f'{name} {pid}: {e}')
    ctx.refresh()


def kill_proc(ctx):
    """Send SIGTERM to the cursor pid, behind a Yes/No confirm dialog."""
    _send_signal(ctx, signal.SIGTERM, 'SIGTERM', confirm=True)


def _action_toggle_tree(ctx):
    """Flip flat ↔ tree view; preserve the cursor on the same pid.

    Mirrors browse-claude's ``t``: flip ``_TREE_MODE``, flash the new mode, and
    ``refresh()`` (which refetches the root + every expanded parent). The pid is
    a stable id across both layouts, so re-homing the cursor needs no ancestor
    walk — capture the pid before the refresh wipes the cache and ``cursor_to``
    it once the new root children settle (chained off the refresh ``Pending`` so
    the row exists before the cursor move runs).
    """
    global _TREE_MODE
    target_id = ctx.cursor.id if ctx.cursor else None

    _TREE_MODE = not _TREE_MODE
    ctx.flash(f"view: {'tree' if _TREE_MODE else 'flat'}")

    pending = ctx.refresh()
    if target_id is not None:
        pending.then(lambda: ctx.cursor_to(target_id))


def _set_sort(ctx, key):
    """Switch the active sort to ``key`` (B5), then flash + refresh.

    Pressing the ACTIVE key reverses its remembered direction; switching to a
    different key adopts THAT key's remembered direction (untouched since it was
    last used). Either way the per-key ``_SORT_DIR`` entry is the source of
    truth, so a later return to a key restores the direction it was left at. The
    flash names the column and its arrow (``↓`` descending, ``↑`` ascending);
    ``refresh()`` re-runs ``get_children``, which re-sorts via ``_sort_procs``.
    """
    global _SORT_KEY
    if key == _SORT_KEY:
        _SORT_DIR[key] = not _SORT_DIR[key]
    _SORT_KEY = key
    arrow = '↓' if _SORT_DIR[key] else '↑'
    ctx.flash(f'sort: {_SORT_LABELS[key]} {arrow}')
    ctx.refresh()


def _sort_action(key):
    """Build the ``ctx -> None`` handler that activates sort ``key``.

    A small closure factory so the five htop-style sort actions
    (``N``/``P``/``M``/``T``/``U``) share one body — each just binds a different
    ``ProcInfo`` field. Kept out of a loop-over-Action so the handler captures
    ``key`` by value, not by a late-bound loop variable.
    """
    return lambda ctx: _set_sort(ctx, key)


# Signal menu, in the order shown. Each row is ``(name, signum, destructive)``;
# destructive signals confirm before sending. SIGTERM duplicates the ``k``
# action, so its menu label carries the ``(k)`` hotkey hint (see
# ``signal_menu_options``).
_SIGNALS = [
    ('SIGTERM', signal.SIGTERM, True),
    ('SIGKILL', signal.SIGKILL, True),
    ('SIGINT',  signal.SIGINT,  False),
    ('SIGHUP',  signal.SIGHUP,  True),
    ('SIGSTOP', signal.SIGSTOP, True),
    ('SIGCONT', signal.SIGCONT, False),
]


def signal_menu_options():
    """``(label, value)`` rows for the signal submenu; value is the signal name.

    Pure — opens no modal, takes no ctx (the signal set is the same for every
    process). The SIGTERM row appends ``(k)`` because sending SIGTERM is also
    bound to the ``k`` action, and the menu-row convention is to surface the
    duplicate hotkey.
    """
    rows = []
    for name, _signum, _destructive in _SIGNALS:
        label = f'{name} (k)' if name == 'SIGTERM' else name
        rows.append((label, name))
    return rows


def send_signal_menu(ctx):
    """Open the signal submenu, then send the chosen signal to the cursor pid.

    A submenu is just ``ctx.menu`` re-invoked from the parent entry's handler
    (the menus are flat). Cancelling the submenu is a no-op.
    """
    chosen = ctx.menu(signal_menu_options())
    if chosen is None:
        return
    for name, signum, destructive in _SIGNALS:
        if name == chosen:
            _send_signal(ctx, signum, name, confirm=destructive)
            return


def _page_command(ctx, argv, *, empty_msg):
    """Run ``argv`` and page its output; flash (don't crash) on failure.

    A missing tool (``FileNotFoundError``) or a non-zero exit (no permission,
    nothing to show) surfaces via ``ctx.error`` / ``ctx.flash`` rather than
    tearing down the UI. Empty successful output flashes ``empty_msg`` instead
    of opening an empty pager.
    """
    try:
        result = subprocess.run(argv, capture_output=True, text=True)
    except OSError as e:
        ctx.error(f'{argv[0]}: {e}')
        return
    if result.returncode != 0:
        ctx.error((result.stderr or result.stdout).strip()
                  or f'{argv[0]} exited {result.returncode}')
        return
    if not result.stdout.strip():
        ctx.flash(empty_msg)
        return
    ctx.page(result.stdout)


def show_open_files(ctx):
    """Page ``lsof -p <pid>`` — the files/handles the process holds open."""
    if not ctx.cursor:
        return
    _page_command(ctx, ['lsof', '-p', str(ctx.cursor.id)],
                  empty_msg='no open files')


def show_sockets(ctx):
    """Page this pid's sockets from ``ss`` (falling back to ``netstat``).

    Both tools annotate each socket with its owning process, but in different
    shapes, so the pid filter depends on which tool actually ran: ``ss -tunap``
    writes ``users:(("comm",pid=<n>,fd=…))`` — matched by ``pid=<n>,`` (the
    trailing comma keeps 42 from matching 420); ``netstat -tunp`` writes a
    ``<n>/<program>`` column — matched by ``<n>/``. The first output line is
    kept as a header in both cases. Falls back to ``netstat`` when ``ss`` is
    absent; if neither tool is installed, flashes an error.
    """
    if not ctx.cursor:
        return
    pid = ctx.cursor.id
    if shutil.which('ss'):
        argv = ['ss', '-tunap']
        token = f'pid={pid},'
    elif shutil.which('netstat'):
        argv = ['netstat', '-tunp']
        token = f'{pid}/'
    else:
        ctx.error('neither ss nor netstat found')
        return
    try:
        result = subprocess.run(argv, capture_output=True, text=True)
    except OSError as e:
        ctx.error(f'{argv[0]}: {e}')
        return
    if result.returncode != 0:
        ctx.error((result.stderr or result.stdout).strip()
                  or f'{argv[0]} exited {result.returncode}')
        return
    lines = result.stdout.splitlines()
    header = lines[:1] if lines else []
    matched = [ln for ln in lines[1:] if token in ln]
    if not matched:
        # The owner column is only populated for the caller's own processes
        # unless run as root, so a blank result may just mean "not privileged".
        ctx.flash(f'no sockets for pid {pid} (may need privilege)')
        return
    ctx.page('\n'.join(header + matched) + '\n')


def _page_proc_file(ctx, name, *, transform=None):
    """Page ``/proc/<pid>/<name>``; flash on a missing/unreadable file.

    ``transform`` (optional) post-processes the raw text — used to turn the
    NUL-separated ``environ`` blob into newline-separated rows. A vanished
    process or a permission error (``OSError``) flashes rather than crashes.
    """
    if not ctx.cursor:
        return
    pid = ctx.cursor.id
    try:
        with open(f'/proc/{pid}/{name}') as f:
            text = f.read()
    except OSError as e:
        ctx.error(f'/proc/{pid}/{name}: {e}')
        return
    if transform is not None:
        text = transform(text)
    if not text.strip():
        ctx.flash(f'/proc/{pid}/{name} is empty')
        return
    ctx.page(text)


def show_environ(ctx):
    """Page ``/proc/<pid>/environ`` (NUL-separated → one var per line)."""
    _page_proc_file(ctx, 'environ',
                    transform=lambda t: t.replace('\0', '\n'))


def show_status(ctx):
    """Page the full ``/proc/<pid>/status`` (the preview shows only a snippet)."""
    _page_proc_file(ctx, 'status')


def renice_proc(ctx):
    """Prompt for a nice value and apply it to the cursor pid via setpriority.

    Cancelling the prompt or entering a blank value is a no-op; a non-integer
    or out-of-range value flashes an error, as does a permission failure
    (lowering the nice value needs privilege).
    """
    if not ctx.cursor:
        return
    pid = ctx.cursor.id
    raw = ctx.input(f'New nice value for pid {pid} (-20..19): ')
    if raw is None or not raw.strip():
        return
    try:
        nice = int(raw.strip())
    except ValueError:
        ctx.error(f'not an integer: {raw.strip()!r}')
        return
    try:
        os.setpriority(os.PRIO_PROCESS, pid, nice)
        ctx.flash(f'reniced pid {pid} to {nice}', log=True)
    except (OSError, ValueError) as e:
        ctx.error(f'renice {pid}: {e}')
    ctx.refresh()


def strace_proc(ctx):
    """Attach ``strace -p <pid>`` interactively (suspends the terminal)."""
    if not ctx.cursor:
        return
    ctx.run_external(['strace', '-p', str(ctx.cursor.id)])


# Context-menu dispatch table: value token -> handler. ``context_menu_options``
# emits these tokens as the option values; ``on_context_menu`` looks the chosen
# token up here. Keeping the builder (pure, returns tokens) and the handlers
# (side-effecting) split keeps the option list unit-testable without opening a
# modal.
_MENU_ACTIONS = {
    'signal':  send_signal_menu,
    'lsof':    show_open_files,
    'sockets': show_sockets,
    'environ': show_environ,
    'status':  show_status,
    'renice':  renice_proc,
    'strace':  strace_proc,
}


def context_menu_options(ctx):
    """``(label, value)`` rows for the process context menu (pure — no modal).

    Inspects ``ctx.cursor`` (the pid item) and returns the menu entries; the
    value half is a stable token dispatched by ``on_context_menu`` /
    ``_MENU_ACTIONS``. Returns ``[]`` when there is no cursor item so the hook
    opens nothing. The "Send signal" entry opens the signal submenu (where the
    SIGTERM row carries the ``(k)`` hotkey hint).
    """
    if not ctx.cursor:
        return []
    return [
        ('Send signal…',  'signal'),
        ('Show open files',    'lsof'),
        ('Show sockets',       'sockets'),
        ('Show environment',   'environ'),
        ('Show full status',   'status'),
        ('Renice…',       'renice'),
        ('Strace',             'strace'),
    ]


def on_context_menu(ctx):
    """Open the process context menu and dispatch the chosen entry.

    The hook the framework fires on right-click / `` ` ``-F1: build the (pure)
    option list, open it with ``ctx.menu``, and route the chosen token through
    ``_MENU_ACTIONS``. A cancel (``None``) or an empty list is a no-op.
    """
    sel = ctx.menu(context_menu_options(ctx))
    handler = _MENU_ACTIONS.get(sel)
    if handler is not None:
        handler(ctx)


_HELP_INTRO = """\
browse-ps — interactive process tree.

Builds the hierarchy from ``ps -eo pid,ppid,user,pcpu,rss,time,args``:
each row is a process, children are processes whose ppid equals this
pid. The row title is the full command line; pid / user / CPU% / memory
ride along as columns. Reload the tree with Ctrl-R; a background thread
also auto-reloads every -d seconds (default 4.0; -d 0 disables it).
Preview reads /proc/<pid>/status.

  t       toggle flat / tree view (--tree / --no-tree set the initial
          mode). Flat lists every process; tree groups by ppid.
  N P M T U  sort by pid / CPU% / memory / CPU time / user (htop-style
          capitals). Re-press the active key to reverse it; each key
          remembers its own direction. In tree mode each parent's
          children are sorted; in flat mode the whole list is.

Right-click a process (or the backslash / F1 keys) for a menu: send
a signal (submenu), page its open files / sockets / environment /
full status, renice it, or attach strace.\
"""


def _apply_view_flags():
    """Set ``_TREE_MODE`` from ``--tree`` / ``--no-tree`` on the command line.

    Parsed off ``recipe_argv()`` (framework-owned flags like ``--tty`` already
    stripped) so the recipe's own flags don't collide with the framework's.
    ``--tree`` wins if both are passed; absent either, the default tree mode
    stands.
    """
    global _TREE_MODE
    argv = recipe_argv()
    if '--tree' in argv:
        _TREE_MODE = True
    elif '--no-tree' in argv:
        _TREE_MODE = False


def _update_interval():
    """Background-refresh interval in seconds from ``-d`` (B8).

    Parsed off ``recipe_argv()`` (framework flags already stripped), alongside
    ``_apply_view_flags``. Accepts ``-d <secs>`` and ``-d=<secs>`` with a
    FRACTIONAL value; absent, the default ``4.0`` (auto-update on). A value
    ``<= 0`` disables updates (the caller starts no thread). A malformed value
    falls back to the default rather than aborting launch — a stray ``-d`` should
    not stop the viewer from opening.
    """
    argv = recipe_argv()
    raw = None
    for i, arg in enumerate(argv):
        if arg == '-d':
            raw = argv[i + 1] if i + 1 < len(argv) else None
        elif arg.startswith('-d='):
            raw = arg[len('-d='):]
    if raw is None:
        return _DEFAULT_UPDATE_INTERVAL
    try:
        return float(raw)
    except (TypeError, ValueError):
        return _DEFAULT_UPDATE_INTERVAL


def _update_worker(b, interval):
    """Background loop: every ``interval`` seconds, trigger a full reload.

    Calls ``b.refresh()`` (thread-safe — it ``post``s ``_do_refresh`` onto the
    UI thread), which enqueues the root with ``reload=True`` and re-samples the
    process snapshot (so CPU% deltas and the new/finished diff ride the same
    sample), preserving the cursor by pid.

    The wait is ``_UPDATE_STOP.wait(timeout=interval)`` — NOT ``time.sleep`` — so
    setting the stop event wakes the worker immediately and shutdown stays
    prompt. Marked daemon as a backstop. ``refresh`` failures are swallowed so a
    transient error doesn't kill the worker; the next tick gets a clean shot.
    """
    while not _UPDATE_STOP.wait(timeout=interval):
        try:
            b.refresh()
        except Exception:
            pass


def main():
    _apply_view_flags()
    b = Browser(BrowserConfig(
        title='browse-ps',
        get_children=get_children,
        get_preview=get_preview,
        actions=[
            Action('k', 'Kill cursor pid (SIGTERM, with confirm)',
                   kill_proc, 'cursor'),
            Action('t', 'Toggle flat / tree view', _action_toggle_tree, 'none'),
            # htop-style sort modes (B5): the active key reverses on repeat,
            # otherwise switches to that key's remembered direction.
            Action('N', 'Sort by pid (asc)',   _sort_action('pid'),       'none'),
            Action('P', 'Sort by CPU% (desc)', _sort_action('cpu_pct'),   'none'),
            Action('M', 'Sort by memory (desc)', _sort_action('mem_bytes'), 'none'),
            Action('T', 'Sort by CPU time (desc)', _sort_action('cpu_secs'), 'none'),
            Action('U', 'Sort by user (asc)',  _sort_action('user'),      'none'),
        ],
        # Right-click (or the backslash / F1 keys) on a process row opens a
        # menu: signals (submenu), open files / sockets / environment / status
        # pagers, renice, and strace. See ``on_context_menu``.
        on_context_menu=on_context_menu,
        help_intro=_HELP_INTRO,
        # pid / user / CPU% / memory ride in a fixed left gutter (left of the
        # tree indent) via ps_chrome; the default content renders the name.
        format_row_chrome=ps_chrome,
        # The pid is its own gutter column now (col_pid), so the framework
        # needn't echo it next to the title.
        show_ids='never',
    ))

    # Background updater (B8): a daemon thread ticks every ``-d`` seconds and
    # ``b.refresh()``es (re-sampling the snapshot — CPU% deltas + the
    # new/finished diff ride that reload). ``-d <= 0`` disables it (no thread).
    # Daemon so it never keeps the process alive; ``_UPDATE_STOP`` signals a
    # clean shutdown before sys.exit, joined briefly in the ``finally`` so the
    # worker wakes from its ``wait`` before the process exits (prompt shutdown).
    global _UPDATE_STOP, _UPDATE_THREAD
    interval = _update_interval()
    if interval > 0:
        _UPDATE_STOP = threading.Event()
        _UPDATE_THREAD = threading.Thread(
            target=_update_worker, args=(b, interval),
            name='browse-ps-update', daemon=True,
        )
        _UPDATE_THREAD.start()

    try:
        rc = b.run()
    finally:
        if _UPDATE_STOP is not None:
            _UPDATE_STOP.set()
            _UPDATE_THREAD.join(timeout=1.0)
    sys.exit(rc)


if __name__ == '__main__':
    main()
