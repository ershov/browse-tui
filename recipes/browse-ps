#!/usr/bin/env -S browse-tui --run-py
"""browse-ps — interactive process tree.

Builds a hierarchy from ``ps -eo pid,ppid,user,comm``. Each process is
an Item; children are processes whose ``ppid == this pid``. The root
of the tree is PID 1 (init / systemd) on Linux; everything else is
descendants. Kernel threads (ppid == 0, except PID 1) are skipped to
keep the tree readable.

Reload with ctrl-r. Custom action ``k:Kill`` sends SIGTERM to the
selected pid (with a y/n confirmation). A right-click context menu
(``on_context_menu``) re-invokes ``ctx.menu`` for a flat signal submenu
and pages auxiliary process data (lsof / ss / /proc/<pid>/{environ,status}).

Demonstrates: live system data, hierarchical children built from an
external CLI, /proc-based preview, a destructive custom Action, and a
context menu with a re-invoked submenu.
"""

import os
import shutil
import signal
import subprocess
import sys

from browse_tui import Action, Browser, BrowserConfig, Item


def _list_procs():
    """Return ``[(pid, ppid, user, comm), …]`` from ``ps``.

    Errors are swallowed: on a platform where ``ps`` is missing or the
    output is malformed we return ``[]`` rather than crash the UI.
    """
    try:
        out = subprocess.run(
            ['ps', '-eo', 'pid=,ppid=,user=,comm='],
            check=True, capture_output=True, text=True).stdout
    except (OSError, subprocess.CalledProcessError):
        return []
    procs = []
    for line in out.splitlines():
        parts = line.split(None, 3)
        if len(parts) < 4:
            continue
        try:
            pid = int(parts[0])
            ppid = int(parts[1])
        except ValueError:
            continue
        procs.append((pid, ppid, parts[2], parts[3]))
    return procs


def _by_ppid(procs):
    """Group ``procs`` by parent pid: ``{ppid: [proc, …]}``."""
    out = {}
    for p in procs:
        out.setdefault(p[1], []).append(p)
    return out


def get_children(parent_id, *, reload=False):
    """Children of ``parent_id``.

    ``None`` (root): return the init process — PID 1 on Linux. If
    we somehow can't find it (non-Linux, restricted environment), fall
    back to processes with ppid == 0 minus the kernel-thread PID 2.
    Otherwise: direct children of ``parent_id``.
    """
    procs = _list_procs()
    if not procs:
        return []
    by_ppid = _by_ppid(procs)

    if parent_id is None:
        init = next((p for p in procs if p[0] == 1), None)
        if init is not None:
            targets = [init]
        else:
            targets = [p for p in by_ppid.get(0, []) if p[0] != 2]
    else:
        targets = by_ppid.get(parent_id, [])

    items = []
    for pid, _ppid, user, comm in sorted(targets, key=lambda p: p[0]):
        item = Item(
            id=pid,
            title=comm,
            tag=f'{user} pid={pid}',
            tag_style='dim',
            has_children=bool(by_ppid.get(pid)),
        )
        item.user = user
        item.pid = pid
        items.append(item)
    return items


def get_preview(pid):
    """Dump a snippet of ``/proc/<pid>/status``.

    The first ~4 KB is plenty for the interactive case (Name, State,
    Pid, PPid, Uid, Gid, VmRSS, …). Errors (process gone, permissions)
    surface as a short hint.
    """
    if not isinstance(pid, int):
        return ''
    try:
        with open(f'/proc/{pid}/status') as f:
            return f.read(4096)
    except OSError as e:
        return f'[error] {e}'


def _send_signal(ctx, signum, name, *, confirm):
    """Send signal ``signum`` (named ``name``) to the cursor pid.

    Destructive signals pass ``confirm=True`` and gate behind a Yes/No
    dialog (mapped to ``True``/``False`` so the result is used directly);
    benign ones (SIGCONT/SIGINT) send straight away. The single send path
    for every signal — ``kill_proc`` (the ``k`` action) delegates here for
    SIGTERM so its confirm/flash/refresh behaviour stays single-sourced.
    """
    if not ctx.cursor:
        return
    pid = ctx.cursor.id
    if confirm and not ctx.confirm(
            f'send {name} to pid {pid} ({ctx.cursor.title})?',
            [('&Yes', True), ('&No', False)]):
        return
    try:
        os.kill(pid, signum)
        ctx.flash(f'sent {name} to pid {pid}', log=True)
    except OSError as e:
        ctx.error(f'{name} {pid}: {e}')
    ctx.refresh()


def kill_proc(ctx):
    """Send SIGTERM to the cursor pid, behind a Yes/No confirm dialog."""
    _send_signal(ctx, signal.SIGTERM, 'SIGTERM', confirm=True)


# Signal menu, in the order shown. Each row is ``(name, signum, destructive)``;
# destructive signals confirm before sending. SIGTERM duplicates the ``k``
# action, so its menu label carries the ``(k)`` hotkey hint (see
# ``signal_menu_options``).
_SIGNALS = [
    ('SIGTERM', signal.SIGTERM, True),
    ('SIGKILL', signal.SIGKILL, True),
    ('SIGINT',  signal.SIGINT,  False),
    ('SIGHUP',  signal.SIGHUP,  True),
    ('SIGSTOP', signal.SIGSTOP, True),
    ('SIGCONT', signal.SIGCONT, False),
]


def signal_menu_options():
    """``(label, value)`` rows for the signal submenu; value is the signal name.

    Pure — opens no modal, takes no ctx (the signal set is the same for every
    process). The SIGTERM row appends ``(k)`` because sending SIGTERM is also
    bound to the ``k`` action, and the menu-row convention is to surface the
    duplicate hotkey.
    """
    rows = []
    for name, _signum, _destructive in _SIGNALS:
        label = f'{name} (k)' if name == 'SIGTERM' else name
        rows.append((label, name))
    return rows


def send_signal_menu(ctx):
    """Open the signal submenu, then send the chosen signal to the cursor pid.

    A submenu is just ``ctx.menu`` re-invoked from the parent entry's handler
    (the menus are flat). Cancelling the submenu is a no-op.
    """
    chosen = ctx.menu(signal_menu_options())
    if chosen is None:
        return
    for name, signum, destructive in _SIGNALS:
        if name == chosen:
            _send_signal(ctx, signum, name, confirm=destructive)
            return


def _page_command(ctx, argv, *, empty_msg):
    """Run ``argv`` and page its output; flash (don't crash) on failure.

    A missing tool (``FileNotFoundError``) or a non-zero exit (no permission,
    nothing to show) surfaces via ``ctx.error`` / ``ctx.flash`` rather than
    tearing down the UI. Empty successful output flashes ``empty_msg`` instead
    of opening an empty pager.
    """
    try:
        result = subprocess.run(argv, capture_output=True, text=True)
    except OSError as e:
        ctx.error(f'{argv[0]}: {e}')
        return
    if result.returncode != 0:
        ctx.error((result.stderr or result.stdout).strip()
                  or f'{argv[0]} exited {result.returncode}')
        return
    if not result.stdout.strip():
        ctx.flash(empty_msg)
        return
    ctx.page(result.stdout)


def show_open_files(ctx):
    """Page ``lsof -p <pid>`` — the files/handles the process holds open."""
    if not ctx.cursor:
        return
    _page_command(ctx, ['lsof', '-p', str(ctx.cursor.id)],
                  empty_msg='no open files')


def show_sockets(ctx):
    """Page this pid's sockets from ``ss`` (falling back to ``netstat``).

    Both tools annotate each socket with its owning process, but in different
    shapes, so the pid filter depends on which tool actually ran: ``ss -tunap``
    writes ``users:(("comm",pid=<n>,fd=…))`` — matched by ``pid=<n>,`` (the
    trailing comma keeps 42 from matching 420); ``netstat -tunp`` writes a
    ``<n>/<program>`` column — matched by ``<n>/``. The first output line is
    kept as a header in both cases. Falls back to ``netstat`` when ``ss`` is
    absent; if neither tool is installed, flashes an error.
    """
    if not ctx.cursor:
        return
    pid = ctx.cursor.id
    if shutil.which('ss'):
        argv = ['ss', '-tunap']
        token = f'pid={pid},'
    elif shutil.which('netstat'):
        argv = ['netstat', '-tunp']
        token = f'{pid}/'
    else:
        ctx.error('neither ss nor netstat found')
        return
    try:
        result = subprocess.run(argv, capture_output=True, text=True)
    except OSError as e:
        ctx.error(f'{argv[0]}: {e}')
        return
    if result.returncode != 0:
        ctx.error((result.stderr or result.stdout).strip()
                  or f'{argv[0]} exited {result.returncode}')
        return
    lines = result.stdout.splitlines()
    header = lines[:1] if lines else []
    matched = [ln for ln in lines[1:] if token in ln]
    if not matched:
        # The owner column is only populated for the caller's own processes
        # unless run as root, so a blank result may just mean "not privileged".
        ctx.flash(f'no sockets for pid {pid} (may need privilege)')
        return
    ctx.page('\n'.join(header + matched) + '\n')


def _page_proc_file(ctx, name, *, transform=None):
    """Page ``/proc/<pid>/<name>``; flash on a missing/unreadable file.

    ``transform`` (optional) post-processes the raw text — used to turn the
    NUL-separated ``environ`` blob into newline-separated rows. A vanished
    process or a permission error (``OSError``) flashes rather than crashes.
    """
    if not ctx.cursor:
        return
    pid = ctx.cursor.id
    try:
        with open(f'/proc/{pid}/{name}') as f:
            text = f.read()
    except OSError as e:
        ctx.error(f'/proc/{pid}/{name}: {e}')
        return
    if transform is not None:
        text = transform(text)
    if not text.strip():
        ctx.flash(f'/proc/{pid}/{name} is empty')
        return
    ctx.page(text)


def show_environ(ctx):
    """Page ``/proc/<pid>/environ`` (NUL-separated → one var per line)."""
    _page_proc_file(ctx, 'environ',
                    transform=lambda t: t.replace('\0', '\n'))


def show_status(ctx):
    """Page the full ``/proc/<pid>/status`` (the preview shows only a snippet)."""
    _page_proc_file(ctx, 'status')


def renice_proc(ctx):
    """Prompt for a nice value and apply it to the cursor pid via setpriority.

    Cancelling the prompt or entering a blank value is a no-op; a non-integer
    or out-of-range value flashes an error, as does a permission failure
    (lowering the nice value needs privilege).
    """
    if not ctx.cursor:
        return
    pid = ctx.cursor.id
    raw = ctx.input(f'New nice value for pid {pid} (-20..19): ')
    if raw is None or not raw.strip():
        return
    try:
        nice = int(raw.strip())
    except ValueError:
        ctx.error(f'not an integer: {raw.strip()!r}')
        return
    try:
        os.setpriority(os.PRIO_PROCESS, pid, nice)
        ctx.flash(f'reniced pid {pid} to {nice}', log=True)
    except (OSError, ValueError) as e:
        ctx.error(f'renice {pid}: {e}')
    ctx.refresh()


def strace_proc(ctx):
    """Attach ``strace -p <pid>`` interactively (suspends the terminal)."""
    if not ctx.cursor:
        return
    ctx.run_external(['strace', '-p', str(ctx.cursor.id)])


# Context-menu dispatch table: value token -> handler. ``context_menu_options``
# emits these tokens as the option values; ``on_context_menu`` looks the chosen
# token up here. Keeping the builder (pure, returns tokens) and the handlers
# (side-effecting) split keeps the option list unit-testable without opening a
# modal.
_MENU_ACTIONS = {
    'signal':  send_signal_menu,
    'lsof':    show_open_files,
    'sockets': show_sockets,
    'environ': show_environ,
    'status':  show_status,
    'renice':  renice_proc,
    'strace':  strace_proc,
}


def context_menu_options(ctx):
    """``(label, value)`` rows for the process context menu (pure — no modal).

    Inspects ``ctx.cursor`` (the pid item) and returns the menu entries; the
    value half is a stable token dispatched by ``on_context_menu`` /
    ``_MENU_ACTIONS``. Returns ``[]`` when there is no cursor item so the hook
    opens nothing. The "Send signal" entry opens the signal submenu (where the
    SIGTERM row carries the ``(k)`` hotkey hint).
    """
    if not ctx.cursor:
        return []
    return [
        ('Send signal…',  'signal'),
        ('Show open files',    'lsof'),
        ('Show sockets',       'sockets'),
        ('Show environment',   'environ'),
        ('Show full status',   'status'),
        ('Renice…',       'renice'),
        ('Strace',             'strace'),
    ]


def on_context_menu(ctx):
    """Open the process context menu and dispatch the chosen entry.

    The hook the framework fires on right-click / `` ` ``-F1: build the (pure)
    option list, open it with ``ctx.menu``, and route the chosen token through
    ``_MENU_ACTIONS``. A cancel (``None``) or an empty list is a no-op.
    """
    sel = ctx.menu(context_menu_options(ctx))
    handler = _MENU_ACTIONS.get(sel)
    if handler is not None:
        handler(ctx)


_HELP_INTRO = """\
browse-ps — interactive process tree.

Builds the hierarchy from ``ps -eo pid,ppid,user,comm``: each row is
a process, children are processes whose ppid equals this pid. Reload
the tree with Ctrl-R; preview reads /proc/<pid>/status.

Right-click a process (or the backslash / F1 keys) for a menu: send
a signal (submenu), page its open files / sockets / environment /
full status, renice it, or attach strace.\
"""


def main():
    sys.exit(Browser(BrowserConfig(
        title='browse-ps',
        get_children=get_children,
        get_preview=get_preview,
        actions=[
            Action('k', 'Kill cursor pid (SIGTERM, with confirm)',
                   kill_proc, 'cursor'),
        ],
        # Right-click (or the backslash / F1 keys) on a process row opens a
        # menu: signals (submenu), open files / sockets / environment / status
        # pagers, renice, and strace. See ``on_context_menu``.
        on_context_menu=on_context_menu,
        help_intro=_HELP_INTRO,
    )).run())


if __name__ == '__main__':
    main()
