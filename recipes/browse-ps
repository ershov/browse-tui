def _apply_view_flags():
    """Set ``_TREE_MODE`` from ``--tree`` / ``--no-tree`` on the command line.

    Parsed off ``recipe_argv()`` (framework-owned flags like ``--tty`` already
    stripped) so the recipe's own flags don't collide with the framework's.
    ``--tree`` wins if both are passed; absent either, the default tree mode
    stands.
    """
    global _TREE_MODE
    argv = recipe_argv()
    if '--tree' in argv:
        _TREE_MODE = True
    elif '--no-tree' in argv:
        _TREE_MODE = False


def _update_interval():
    """Background-refresh interval in seconds from ``-d`` (B8).

    Parsed off ``recipe_argv()`` (framework flags already stripped), alongside
    ``_apply_view_flags``. Accepts ``-d <secs>`` and ``-d=<secs>`` with a
    FRACTIONAL value; absent, the default ``4.0`` (auto-update on). A value
    ``<= 0`` disables updates (the caller starts no thread). A malformed value
    falls back to the default rather than aborting launch — a stray ``-d`` should
    not stop the viewer from opening.
    """
    argv = recipe_argv()
    raw = None
    for i, arg in enumerate(argv):
        if arg == '-d':
            raw = argv[i + 1] if i + 1 < len(argv) else None
        elif arg.startswith('-d='):
            raw = arg[len('-d='):]
    if raw is None:
        return _DEFAULT_UPDATE_INTERVAL
    try:
        return float(raw)
    except (TypeError, ValueError):
        return _DEFAULT_UPDATE_INTERVAL


def _new_pid_placement(b, info, cur_procs):
    """``(parent_id, where)`` for inserting a freshly-appeared pid, or ``None``.

    A new pid is placed surgically, in sorted position, under the right parent:

    - **flat** mode: the parent is the list root (``None``); the root children
      are always loaded, so a new pid always places.
    - **tree** mode: the parent is the pid's ``ppid``. We place ONLY when that
      parent's children are already loaded (``cached_children`` is not ``None``);
      under a not-yet-expanded parent we skip — inserting would create a partial
      child list that the framework would then treat as authoritative, hiding the
      real siblings. Such a pid simply appears the normal way (a fresh
      ``get_children``) when the user expands its parent. Mirrors browse-claude's
      ``_push_tail_diffs`` skipping parents absent from the cache.

    ``where`` puts the row in the active sort order: we sort the live siblings
    (the same ``_sort_procs`` the rebuild uses) and anchor ``before`` the new
    pid's immediate successor, falling back to ``last`` when it sorts to the end.
    Only NEW pids carry ``where`` — ``mod`` never repositions an existing row
    (the default pid sort never moves; a changed key re-sorts on the next manual
    refresh), per the ticket.
    """
    parent_id = None if not _TREE_MODE else info.ppid
    loaded = b.cached_children(parent_id)
    if loaded is None:
        return None                    # parent not loaded → appears on expand
    if not _TREE_MODE:
        siblings = list(cur_procs.values())
    else:
        siblings = [s for s in cur_procs.values() if s.ppid == parent_id]
    order = [s.pid for s in _sort_procs(siblings)]
    successors = set(order[order.index(info.pid) + 1:])
    # pids are INT ids, and the ``where`` API reads an int ref as a positional
    # INDEX (not an id) — so anchor ``before`` the loaded-list INDEX of the new
    # pid's first already-loaded successor, falling back to ``last`` when it
    # sorts to the end. The tick emits upserts before removes, so a pre-batch
    # index from ``cached_children`` is still valid when the upsert applies.
    where = ('last', None)
    if successors:                      # else it sorts to the end → append
        for i, child in enumerate(loaded):
            if child.id in successors:
                where = ('before', None, i)
                break
    return parent_id, where


def _tick_ops(b, prev_pids, tomb_before, cur_procs):
    """Build the incremental ``update_data`` batch for one ``-d`` tick.

    Diffs the just-rotated snapshot (``prev_pids`` are the previous sample's
    pids, ``cur_procs`` the new ``{pid: ProcInfo}`` map) against the appeared /
    tombstone bookkeeping ``_install_snapshot`` has already refreshed, and emits
    exactly the ops needed to converge the loaded rows on what a full rebuild
    would show — without tearing the list down:

    - **alive** (prev ∩ cur): ``mod`` carrying the shared ``_proc_fields`` (the
      refreshed cpu%/mem/user/title) plus the ``_row_highlight_fg`` decision.
      ``mod`` is a silent no-op for unloaded pids, so emitting for every alive
      pid is safe — only loaded rows repaint, in place. ``row_fg`` is always
      included (it clears a stale green once a pid's highlight window lapses).
    - **new** (cur − prev): ``upsert`` under the right parent in sorted position
      (see ``_new_pid_placement``); skipped under an unexpanded tree parent.
    - **gone** (prev − cur): if the diff turned it into a tombstone (highlight on
      + was a leaf) ``mod`` it to the soft-red tombstone, kept until the 3.5 s
      retention prunes it; otherwise ``remove`` it at once.
    - **expired tombstones**: pids that WERE tombstones last tick and the diff
      just pruned (window elapsed / parent gone) — ``remove`` them now. Tracked
      via ``tomb_before`` minus the post-diff ``_TOMBSTONES`` (excluding any pid
      that respawned, which the new branch handles).
    """
    cur_pids = set(cur_procs)
    tomb_after = set(_TOMBSTONES)
    ops = []

    for pid in prev_pids & cur_pids:
        ops.append(mod(pid, **_proc_fields(cur_procs[pid]),
                       row_fg=_row_highlight_fg(pid, is_tombstone=False)))

    for pid in cur_pids - prev_pids:
        placement = _new_pid_placement(b, cur_procs[pid], cur_procs)
        if placement is None:
            continue
        parent_id, where = placement
        ops.append(upsert(pid, parent_id, where=where,
                          **_proc_fields(cur_procs[pid]),
                          row_fg=_row_highlight_fg(pid, is_tombstone=False)))

    for pid in prev_pids - cur_pids:
        # A finished leaf becomes a soft-red tombstone ONLY when highlighting is
        # on (it must match ``_scoped_tombstones``, which shows nothing when
        # off); otherwise — or for a non-leaf whose row just vanishes — remove.
        if _HIGHLIGHT_MODE and pid in tomb_after:
            info = _TOMBSTONES[pid][0]
            ops.append(mod(pid, **_proc_fields(info), row_fg=_HL_GONE_FG))
        else:
            ops.append(remove(pid))

    # A tombstone the diff just pruned (3.5 s window elapsed / parent gone, and
    # not respawned) leaves the UI now. Only relevant while highlighting is on —
    # off, the gone branch already removed it the tick it vanished.
    if _HIGHLIGHT_MODE:
        for pid in (tomb_before - tomb_after) - cur_pids:
            ops.append(remove(pid))

    return ops


def _apply_tick(b, procs):
    """UI-thread half of a ``-d`` tick: rotate, diff, then apply the batch.

    Runs via ``b.post`` so it touches the shared snapshot globals
    (``_PREV/_CUR_SNAPSHOT`` + ``_APPEARED_AT`` / ``_TOMBSTONES``) only on the UI
    thread, never racing ``get_children`` / ``ps_gutter_segments`` reads. Reads
    the pre-rotation pids + tombstone set, installs the freshly-fetched ``procs``
    (rotate + ``_diff_snapshot``), builds the incremental op batch, and applies
    it with ONE ``b.update_data`` — no ``b.refresh()``, so the cursor and scroll
    are untouched and the loaded rows update in place (no flicker).
    """
    prev = _CUR_SNAPSHOT
    prev_pids = set(prev[1]) if prev is not None else set()
    tomb_before = set(_TOMBSTONES)
    _install_snapshot(procs)
    ops = _tick_ops(b, prev_pids, tomb_before, procs)
    if ops:
        b.update_data(ops)


def _update_worker(b, interval):
    """Background loop: every ``interval`` seconds, push an incremental update.

    Each tick fetches a fresh process table OFF the UI thread
    (``_fetch_procs`` — the slow ``ps`` + smaps half), then ``b.post``s
    ``_apply_tick`` to rotate the snapshot, run the appeared/vanished diff, and
    apply ONE ``b.update_data`` batch on the UI thread. This replaces the old
    full ``b.refresh()`` tick: loaded rows' cpu%/mem update in place, new/gone
    pids are added/removed surgically, and the cursor + scroll stay put (no
    flicker). The fetch/post split mirrors browse-claude's ``_tail_worker`` and
    keeps the shared snapshot globals single-threaded (see ``_apply_tick``).

    The wait is ``_UPDATE_STOP.wait(timeout=interval)`` — NOT ``time.sleep`` — so
    setting the stop event wakes the worker immediately and shutdown stays
    prompt. Marked daemon as a backstop. A failed tick is swallowed so a
    transient error doesn't kill the worker; the next tick gets a clean shot.
    """
    while not _UPDATE_STOP.wait(timeout=interval):
        try:
            procs = _fetch_procs()
            b.post(lambda procs=procs: _apply_tick(b, procs))
        except Exception:
            pass


def main():
    _apply_view_flags()
    b = Browser(BrowserConfig(
        title='browse-ps',
        get_children=get_children,
        get_preview=get_preview,
        show_children_pane=False,
        actions=[
            Action('k', 'Kill cursor pid (SIGTERM, with confirm)',
                   kill_proc, 'cursor'),
            Action('t', 'Toggle flat / tree view', _action_toggle_tree, 'none'),
            # htop -H-style new/finished highlighting (B9): the snapshot diff
            # always runs; ``h`` toggles the soft green/red display + tombstones.
            Action('h', 'Toggle new/finished highlighting',
                   _action_toggle_highlight, 'none'),
            # Display modes — the gutter column set (see ``ps_gutter_segments``).
            Action('1', 'Display: command line only', lambda c: _set_display_mode(c, 1), 'none'),
            Action('2', 'Display: pid',               lambda c: _set_display_mode(c, 2), 'none'),
            Action('3', 'Display: pid/user/cpu%/mem', lambda c: _set_display_mode(c, 3), 'none'),
            # htop-style sort modes (B5): the active key reverses on repeat,
            # otherwise switches to that key's remembered direction.
            Action('N', 'Sort by pid (asc)',   _sort_action('pid'),       'none'),
            Action('P', 'Sort by CPU% (desc)', _sort_action('cpu_pct'),   'none'),
            Action('M', 'Sort by memory (desc)', _sort_action('mem_bytes'), 'none'),
            Action('T', 'Sort by CPU time (desc)', _sort_action('cpu_secs'), 'none'),
            Action('U', 'Sort by user (asc)',  _sort_action('user'),      'none'),
        ],
        # Right-click (or the backslash / F1 keys) on a process row opens a
        # menu: signals (submenu), open files / sockets / environment / status
        # pagers, renice, and strace. See ``on_context_menu``.
        on_context_menu=on_context_menu,
        help_intro=_HELP_INTRO,
        # pid / user / CPU% / memory ride in a fixed left gutter (left of the
        # tree indent) via ps_chrome; the default content renders the name.
        format_row_chrome=ps_chrome,
        # The pid is its own gutter column now (col_pid), so the framework
        # needn't echo it next to the title.
        show_ids='never',
    ))

    # Background updater (B8): a daemon thread ticks every ``-d`` seconds,
    # fetching a fresh snapshot off-thread and ``b.post``ing an INCREMENTAL
    # ``b.update_data`` batch (CPU% deltas + the new/finished diff ride that
    # sample; loaded rows update in place, no flicker — see ``_update_worker`` /
    # ``_apply_tick``). ``-d <= 0`` disables it (no thread). Daemon so it never
    # keeps the process alive; ``_UPDATE_STOP`` signals a clean shutdown before
    # sys.exit, joined briefly in the ``finally`` so the worker wakes from its
    # ``wait`` before the process exits (prompt shutdown).
    global _UPDATE_STOP, _UPDATE_THREAD
    interval = _update_interval()
    if interval > 0:
        _UPDATE_STOP = threading.Event()
        _UPDATE_THREAD = threading.Thread(
            target=_update_worker, args=(b, interval),
            name='browse-ps-update', daemon=True,
        )
        _UPDATE_THREAD.start()

    try:
        rc = b.run()
    finally:
        if _UPDATE_STOP is not None:
            _UPDATE_STOP.set()
            _UPDATE_THREAD.join(timeout=1.0)
    sys.exit(rc)


if __name__ == '__main__':
    main()
