#!/usr/bin/env -S browse-tui --run-py
"""browse-md — markdown browser supporting one or more files.

Parses each markdown file on argv into a tree of headings (h1..h6);
list items under each section can optionally be surfaced as tree
rows via the ``-l`` / ``--list`` / ``--lists`` flag (default:
headings only). With a single file the per-file Item is the root.
With multiple files a synthetic multi-root sits above the per-file
Items so all files are visible as siblings.

Anchor syntax (``FILE.md#name`` / ``FILE.md#<line>``) seeds the
initial scope so deep links open directly on the targeted section.
When multiple files carry anchors, the FIRST anchored file in argv
order wins — other anchors are ignored, the multi-root still
contains every file.

The preview pane shows the file body (or a byte-slice for non-root
cursor rows), optionally rendered through md2ansi for ANSI-coloured
markdown. Ctrl-R re-slurps every file from disk and rebuilds the
tree in place.

Custom actions on top of the framework defaults:

  m   toggle md2ansi coloring of the preview (only bound when the
      ``md2ansi`` Python module is importable).
  M   page the preview through ``$MD2ANSI`` / external ``md2ansi``.
  V   page the source for cursor/selection in ``$PAGER``. On the
      multi-root opens the first argv file; on a per-file root
      opens that file; on a non-root row pages the byte-slice
      tempfile. Cross-file multi-select takes the FIRST file's
      targets only.
  E   edit the source for cursor/selection in ``$EDITOR``. Same
      multi-root / per-file-root / cross-file rules as V.

Usage:  browse-md [-l] FILE.md[#anchor] [FILE.md[#anchor] ...]
"""

import bisect
import os
import re
import sys

from browse_tui import Action, Browser, BrowserConfig, Item

# Optional md2ansi plugin — gates the colored markdown preview mode.
# Mirrors the gate pattern in browse-fs / browse-claude: import the
# function, fall back to ``None`` if the module is missing or the
# imported name isn't actually callable (defensive against monkey-
# patched stubs in tests / odd vendored copies).
try:
    from md2ansi import md2ansi as _md2ansi_fn
    if not callable(_md2ansi_fn):
        _md2ansi_fn = None
except Exception:
    _md2ansi_fn = None

# Default colored preview on when md2ansi is importable; the ``m``
# action (bound only when ``_md2ansi_fn`` is not ``None``) flips it
# at runtime. ``_BROWSER`` is set in ``main()`` after construction so
# ``get_preview`` can look up the current ``preview_width`` for the
# md2ansi word-wrap.
_MD_COLOR = _md2ansi_fn is not None
_BROWSER = None  # set in main() — used for preview-width lookup

# Sentinel id for the synthetic multi-root that owns the per-file
# subtrees. Distinct from any real abs-path (real paths don't start
# with ``(``) and short enough that ``get_preview`` / classifier
# string-compare against it cheaply. The same constant becomes the
# Browser's ``root_id`` so the framework's reload hook recognises
# "reload at root" via ``node_id == _ROOT_ID``.
_ROOT_ID = '(multi)'

# Per-file state slot — populated by ``_reparse`` from
# ``_INPUT_FILES``. Lookups in ``get_preview`` / classifier resolve
# the right file's text + indexes via this dict; the per-Item
# ``file_path`` back-reference (set in ``_build_nodes``) is the key.
_FILES = {}

# Argv-derived list of ``(abs_path, anchor_or_empty)`` pairs, in argv
# order. Populated by ``main()`` before the first ``_reparse``; used
# by Ctrl-R to know which files to re-slurp.
_INPUT_FILES = []

# Aggregate id-to-Item index — multi-root + per-file roots + every
# heading/list-item across every file. Read by ``get_children`` to
# materialise tree rows on demand and by ``get_preview`` to look up
# an id's owning file via ``item.file_path``.
_BY_ID = {}

# --- Legacy single-file shims --------------------------------------
#
# A handful of existing tests populate these module globals directly
# (e.g. ``self.r._BY_LINE = ...``) and call ``_node_at_line`` /
# ``_resolve_anchor`` / ``get_preview`` against them. To keep those
# tests passing without rewriting every test setUp, ``_reparse``
# mirrors the FIRST input file's state into these globals; helpers
# fall back to them when no explicit file-state is passed in.
#
# ``_FILE_TEXT``: first file's body (or ``''`` if no files).
# ``_BY_LINE``: ``line_offset -> Item`` for the first file.
# ``_LINES_SORTED``: sorted view of ``_BY_LINE`` keys.
# ``_ROOT_PATH``: abs path of the first file (or ``None``).
_FILE_TEXT = ''
_BY_LINE = {}
_LINES_SORTED = []
_ROOT_PATH = None

# Raw anchor string from the first anchored file in argv (after the
# multi-file refactor: "first anchor wins"). Empty when no positional
# carried a ``#``. Resolved to an item id via ``_resolve_anchor`` and
# handed to ``BrowserConfig(initial_scope=...)``.
_ANCHOR = ''

# Tag-style palette per heading level. h1 stays red (md2ansi-ish loud
# top); deeper levels cycle through the named palette ending in gray
# for the deepest h6.
_HEADING_STYLES = {
    1: 'red',
    2: 'yellow',
    3: 'green',
    4: 'blue',
    5: 'magenta',
    6: 'gray',
}

# Per-line list-item regex — lifted verbatim from md2ansi
# (``_m2a_fmt_list``, md2ansi.py:493). Used by ``_walk_list`` to fan
# one ``_MD_LIST`` match out into one event per marker line.
_LIST_ITEM_RE = re.compile(r'^([ \t]*)([-*+]|\d+\.)[ \t]+(.*)$')

# Title-stripping regexes used by ``_build_nodes`` to produce tree-row
# labels free of redundant markers. The kind/tag is already conveyed
# by ``[h1]`` / ``[ul]`` etc. with colour, so the title text drops:
#   * Leading ``#``s + immediate whitespace for headings, e.g.
#     ``## My **bold** heading`` → ``My **bold** heading`` (inline
#     formatting markers are preserved — only the leading sigils go).
#   * Leading list marker (``-`` / ``*`` / ``+`` / ``\d+.``) plus
#     following whitespace for list items, e.g. ``- foo`` → ``foo``
#     and ``1. item`` → ``item``.
# Source-faithful byte slices used by ``get_preview`` are unchanged;
# this only affects what shows in tree rows.
_HEADING_PREFIX_RE = re.compile(r'^#+\s*')
_LIST_PREFIX_RE = re.compile(r'^([-*+]|\d+\.)\s+')


# Gate for emitting list-item events from ``_parse``. Default off:
# the tree shows headings only, which is the common "table of
# contents" view. ``main()`` flips this to ``True`` when ``-l`` /
# ``--list`` / ``--lists`` appears in argv. The flag only controls
# emission — the ``list`` rule in ``_PARSER_RE`` still masks its
# span so code-fence-vs-list-line precedence is unchanged.
_INCLUDE_LISTS = False


_USAGE = 'usage: browse-md [-l] FILE.md[#anchor] [FILE.md[#anchor] ...]'


# ### Section: Markdown block-rule table ##############################
#
# Patterns lifted verbatim from md2ansi.py (lines 697-726). md2ansi
# writes inner captures as ``(?P<*...>...)`` placeholders that its
# ``_m2a_build_context`` rewrites at build time. We don't need those
# inner names — ``_parse`` keys on the outer rule by iterating
# ``_RULES`` and picking the first whose group matched (md2ansi-style;
# see ``_m2a_replace`` in md2ansi.py). Every ``(?P<*...>...)`` is
# converted to a non-capturing ``(?:...)`` group to keep the patterns
# idiomatic ``re`` and avoid name collisions when stitched into the
# combined regex below.
#
# Every alternation has disjoint branches (no-rollback discipline);
# every cross-line span uses tempered-greedy ``(?: (?! STOP ) [\s\S] )*``
# so the engine never backtracks. See the design doc's "Regex
# discipline (no rollback, greedy)" section.

# Headings — exact-count ``#`` followed by space ensures mutual exclusion.
_MD_H1 = r"^ \# [ \t]+ (?: [^\n]+ ) $"
_MD_H2 = r"^ \#{2} [ \t]+ (?: [^\n]+ ) $"
_MD_H3 = r"^ \#{3} [ \t]+ (?: [^\n]+ ) $"
_MD_H4 = r"^ \#{4} [ \t]+ (?: [^\n]+ ) $"
_MD_H5 = r"^ \#{5} [ \t]+ (?: [^\n]+ ) $"
_MD_H6 = r"^ \#{6} [ \t]+ (?: [^\n]+ ) $"

_MD_HR = r"^ (?: -{3,} | ={3,} | _{3,} ) [ \t]* $"

# Frontmatter — anchored to file start via ``\A`` so it never matches
# mid-document. Tempered-greedy body so the closing ``---`` is the
# first one we see. Trailing ``(?:\n|$)`` lets the rule own its closing
# newline (or end-of-file) instead of leaving a stray line for later
# rules.
_MD_FRONTMATTER = r"""
    \A --- \n
    (?: (?! ^ --- [ \t]* $ ) [\s\S] )*
    ^ --- [ \t]* (?: \n | \Z )
"""

# Fenced code blocks — tempered-greedy body so each char has exactly
# one matching branch (the negative lookahead consumes one char per
# iteration). ``(?:```|~~~)`` matches either fence style.
_MD_CODE_GEN = r"""
    ^ (?: [ \t]* ) (?:```|~~~) [ \t]* (?: \w* ) [ \t]* \n
    (?: (?! ^ [ \t]* (?:```|~~~) [ \t]* $ ) [\s\S] )*
    ^ [ \t]* (?:```|~~~) [ \t]* $
"""

_MD_BLOCKQUOTE = r"^ > [ \t]? [^\n]* (?: \n > [ \t]? [^\n]* )*"

_MD_TABLE = r"^ [ \t]* \| [^\n]* (?: \n [ \t]* \| [^\n]* )*"

_MD_LIST = r"""
    ^ [ \t]* (?: [-*+] | \d+\. ) [ \t]+ [^\n]*
    (?: \n [ \t]* (?: [-*+] | \d+\. ) [ \t]+ [^\n]* )*
"""

# Rule order is precedence. Headings/HR are line-bound and need to win
# over the multi-line block rules on a single ``#`` line. ``code``
# precedes ``blockquote/table/list`` so list-looking lines inside a
# fence are masked. ``frontmatter`` MUST precede ``hr``: both can match
# a leading ``---`` line at offset 0, and Python ``re`` alternation is
# leftmost-first, so if ``hr`` came first it would consume only the
# opening fence as an HR and ``\A``-anchored ``frontmatter`` would
# never get a chance.
_RULES = (
    ('h1',          _MD_H1),
    ('h2',          _MD_H2),
    ('h3',          _MD_H3),
    ('h4',          _MD_H4),
    ('h5',          _MD_H5),
    ('h6',          _MD_H6),
    ('frontmatter', _MD_FRONTMATTER),
    ('hr',          _MD_HR),
    ('code',        _MD_CODE_GEN),
    ('blockquote',  _MD_BLOCKQUOTE),
    ('table',       _MD_TABLE),
    ('list',        _MD_LIST),
)

# Combined regex — same shape md2ansi uses in ``_m2a_build_context``
# (md2ansi.py:113). One ``finditer`` pass over the text yields all
# block-level matches in document order; ``_parse`` walks ``_RULES``
# per match to find which outer group matched (see ``_parse`` for why
# we don't use ``m.lastgroup``).
_PARSER_RE = re.compile(
    '|'.join(f'(?P<{n}>{p})' for n, p in _RULES),
    re.VERBOSE | re.MULTILINE | re.DOTALL,
)


class _FileState:
    """Per-file parser state bundle held inside ``_FILES``.

    A plain attribute carrier — every field is filled in by
    ``_reparse`` from a single ``_build_nodes`` invocation plus the
    derived line index. Keeping it on a class rather than a dict gives
    each lookup site (``get_preview``, ``_run_source_command``,
    ``_resolve_anchor``) attribute-level errors when a field is
    missing rather than a silent ``None``.

    Fields:
      * ``path``         — abs path of the file (also the per-file
                          root's Item id).
      * ``text``         — full file body. ``get_preview`` slices
                          this for non-root rows; the root preview
                          is the whole buffer.
      * ``line_starts``  — byte offset of the start of each line.
                          Passed into ``_walk_list`` / ``_line_of``.
      * ``by_id``        — id-to-Item index for THIS file (no
                          multi-root, no other files). Useful when
                          a helper needs to walk only one file's
                          nodes (e.g. anchor resolution).
      * ``by_line``      — ``line_offset -> Item`` for this file.
                          Excludes the per-file root so anchor
                          lookups for offsets in preamble territory
                          fall through to root upstream.
      * ``lines_sorted`` — sorted keys of ``by_line`` for the
                          ``bisect_right`` lookup in
                          ``_node_at_line``.
      * ``file_root``    — the per-file root Item (siblings under
                          the synthetic multi-root in multi-file
                          mode; THE root in single-file mode).
    """

    __slots__ = ('path', 'text', 'line_starts',
                 'by_id', 'by_line', 'lines_sorted', 'file_root')

    def __init__(self, path, text, line_starts,
                 by_id, by_line, lines_sorted, file_root):
        self.path = path
        self.text = text
        self.line_starts = line_starts
        self.by_id = by_id
        self.by_line = by_line
        self.lines_sorted = lines_sorted
        self.file_root = file_root


def _line_starts(text):
    """Byte offset of the start of each line in ``text``.

    Index ``i`` holds the offset of line ``i`` (0-based). Used by
    ``_parse`` to convert a heading's ``m.start()`` byte offset into a
    line number via ``bisect``. Uses ``re.finditer`` so the scan runs
    in the C-level regex engine rather than a Python ``for`` loop.
    """
    return [0] + [m.end() for m in re.finditer(r'\n', text)]


def _line_of(byte_offset, line_starts):
    """0-based line number for ``byte_offset`` given precomputed line starts."""
    # ``bisect_right - 1`` lands on the line whose start is <= offset.
    return bisect.bisect_right(line_starts, byte_offset) - 1


# Rule names that emit a heading node from ``_parse`` — dispatch is
# by exact name, so other rules (code/blockquote/table/hr/frontmatter)
# never reach the heading branch.
_HEADING_KINDS = frozenset(('h1', 'h2', 'h3', 'h4', 'h5', 'h6'))


def _walk_list(match, line_starts):
    """Fan one ``_MD_LIST`` match out into one event per marker line.

    ``_MD_LIST`` already guarantees that every line of the match starts
    with a list marker (continuation lines split the match, see the
    spec's "List parsing details"). So we can split on ``\\n`` and run
    the per-line regex without further line-validity checks.

    ``byte_offset`` is the match's absolute start plus the per-line
    offset within the match (the sum of preceding line lengths + 1 per
    newline). ``line_offset`` is derived via ``_line_of`` against the
    file-wide ``line_starts`` so future reparses don't need a separate
    counter.
    """
    events = []
    base = match.start()
    text = match.group()
    # ``split`` over ``\n`` reconstructs each line; ``offset`` tracks
    # the line's byte position within ``text`` (relative). Each iter
    # adds ``len(line)+1`` (the ``+1`` for the newline ``split``
    # stripped). The final line has no trailing newline; the ``+1``
    # past EOF is harmless because the loop ends right after.
    offset = 0
    for line in text.split('\n'):
        m = _LIST_ITEM_RE.match(line)
        if m is not None:
            indent, marker, _body = m.group(1), m.group(2), m.group(3)
            byte_offset = base + offset
            kind = 'ol' if marker[-1] == '.' else 'ul'
            events.append((kind, {
                'byte_offset': byte_offset,
                'line_offset': _line_of(byte_offset, line_starts),
                'level': len(indent.expandtabs(4)) // 2,
                'source': line,
            }))
        offset += len(line) + 1
    return events


def _parse(text):
    """Flat ordered list of parser events for ``text``.

    Each event is a ``(kind, payload)`` tuple:
      * heading:   ``('h1'..'h6', {'byte_offset', 'line_offset', 'source'})``
      * list item: ``('ul'|'ol', {'byte_offset', 'line_offset', 'level', 'source'})``

    Code/blockquote/table/hr/frontmatter matches emit nothing — they
    exist solely to mask their contents from later rules in the
    combined regex.
    """
    line_starts = _line_starts(text)
    events = []
    for m in _PARSER_RE.finditer(text):
        # Identify the outer rule by walking ``_RULES`` and picking the
        # first whose named group has a non-None match. ``m.lastgroup``
        # would be simpler but returns the *highest-numbered* matching
        # named group — so any future inner ``(?P<...>...)`` group
        # inside a rule pattern would silently misroute dispatch. This
        # mirrors md2ansi's ``_m2a_replace`` (md2ansi.py:863-882).
        groups = m.groupdict()
        kind = next(n for n, _ in _RULES if groups.get(n) is not None)
        if kind in _HEADING_KINDS:
            byte_offset = m.start()
            events.append((kind, {
                'byte_offset': byte_offset,
                'line_offset': _line_of(byte_offset, line_starts),
                'source': m.group(),
            }))
        elif kind == 'list':
            # Fan one multi-line list match into per-marker-line nodes —
            # but only when ``_INCLUDE_LISTS`` is on. With the flag off
            # the regex still consumed the list span (so code-fence vs
            # list-line precedence is unchanged), we just drop the
            # would-be events so list items don't show in the tree.
            if _INCLUDE_LISTS:
                events.extend(_walk_list(m, line_starts))
        # code / blockquote / table / hr / frontmatter: skip. Their
        # only job is to consume their span so later rules can't.
    return events


# Kinds that produce heading-shaped tree rows (h1..h6) — distinct from
# list-item rows ``ul`` / ``ol``. Used by ``_build_nodes`` for the
# boundary-rule branch (heading boundary closes any open list scope).
_HEADING_EVENT_KINDS = _HEADING_KINDS
_LIST_EVENT_KINDS = frozenset(('ul', 'ol'))


def _build_nodes(events, file_text, line_starts, path):
    """Materialise events into a tree of ``Item`` instances.

    Returns ``(root, by_id)``. The per-file root owns every top-level
    heading and every pre-first-heading list item; ``by_id`` is the
    flat id-to-Item index for THIS file (no multi-root, no other
    files). Children lists are pre-populated on each Item as
    ``item._children`` so ``get_children`` can return them without
    re-walking the event stream.

    Every Item carries ``file_path = path`` so multi-file ``get_preview``
    knows which file's ``_FILE_TEXT`` to slice from — even when only
    the id is in hand. The per-file root gets the same back-reference;
    the synthetic multi-root (built later in ``_build_multi_root``) is
    the only Item without one.

    Three passes:

    1. Per-event Item construction (heading kinds → ``heading`` items,
       ``ul``/``ol`` → ``list-item`` items). Each Item carries the
       hidden contract fields (``byte_offset``, ``line_offset``,
       ``kind``, ``level``); ``byte_size`` / ``line_size`` are filled
       in by pass 2.
    2. Boundary rule (single linear pass): for each node at index
       ``i``, find the next sibling-or-shallower node ``j`` and set
       ``byte_size = nodes[j].byte_offset - nodes[i].byte_offset``.
       At EOF, use ``len(file_text)`` / ``len(line_starts)``.
    3. Tree linking via two stacks. Heading stack pops on level-≥
       comparisons (so an h3 attaches under the nearest open h1/h2).
       List stack mirrors that on indent level and resets on every
       heading boundary; orphan list items (no shallower list
       ancestor) attach to the surrounding heading, or to root if no
       heading is open yet.
    """
    file_bytes_eof = len(file_text)
    file_lines_eof = len(line_starts)

    # --- Pass 1: per-event Item construction ---
    nodes = []  # parallel to events; same indexing
    for kind, payload in events:
        bo = payload['byte_offset']
        lo = payload['line_offset']
        source = payload['source']
        if kind in _HEADING_EVENT_KINDS:
            level = int(kind[1])  # 'h3' -> 3
            # Drop leading ``#``s + immediate whitespace; the tag
            # ``[h1]``/``[h2]``/... already conveys the level visually,
            # so the title text shouldn't carry the same marker again.
            # Inline formatting markers (``**bold**`` etc.) are
            # preserved — the regex only touches the sigil prefix.
            line = source.rstrip('\n').lstrip()
            title = _HEADING_PREFIX_RE.sub('', line)
            item = Item(
                id=f'{path}#{lo}',
                title=title,
                tag=kind,
                tag_style=_HEADING_STYLES[level],
            )
            item.kind = 'heading'
            item.level = level
        else:
            # ``ul`` / ``ol`` — list-item node. Drop the leading
            # marker (``-`` / ``*`` / ``+`` / ``\d+.``) plus its
            # trailing whitespace for the same reason as headings —
            # the ``[ul]`` / ``[ol]`` tag already says it's a list.
            line = source.rstrip('\n').lstrip()
            title = _LIST_PREFIX_RE.sub('', line)
            item = Item(
                id=f'{path}#{lo}',
                title=title,
                tag=kind,
                tag_style='dim',
            )
            item.kind = 'list-item'
            item.level = payload['level']
        item.byte_offset = bo
        item.line_offset = lo
        item.file_path = path
        item._children = []
        nodes.append(item)

    # --- Pass 2: boundary rule (byte_size / line_size) ---
    # For node i, find next j > i that is sibling-or-shallower. For
    # headings: next heading at level ≤ L (lists never close a heading
    # scope). For list items: next list-item at indent ≤ L, OR any
    # heading (heading boundary always resets list scope).
    n = len(nodes)
    for i in range(n):
        cur = nodes[i]
        cur_kind = cur.kind
        cur_level = cur.level
        j_bo = file_bytes_eof
        j_lo = file_lines_eof
        for j in range(i + 1, n):
            nxt = nodes[j]
            if cur_kind == 'heading':
                if nxt.kind == 'heading' and nxt.level <= cur_level:
                    j_bo = nxt.byte_offset
                    j_lo = nxt.line_offset
                    break
            else:
                # list-item — any heading closes the list scope, plus
                # any list item at indent ≤ cur_level.
                if nxt.kind == 'heading':
                    j_bo = nxt.byte_offset
                    j_lo = nxt.line_offset
                    break
                if nxt.kind == 'list-item' and nxt.level <= cur_level:
                    j_bo = nxt.byte_offset
                    j_lo = nxt.line_offset
                    break
        cur.byte_size = j_bo - cur.byte_offset
        cur.line_size = j_lo - cur.line_offset

    # --- Pass 3: tree linking via heading + list stacks ---
    root = Item(
        id=path,
        title=os.path.basename(path),
        has_children=bool(nodes),
    )
    root.kind = 'root'
    root.level = 0
    root.byte_offset = 0
    root.byte_size = file_bytes_eof
    root.line_offset = 0
    root.line_size = file_lines_eof
    root.file_path = path
    root._children = []

    # Heading stack: each entry is ``(level, Item)``. Top is the
    # current innermost open heading; an empty stack means "still
    # under root".
    heading_stack = []
    # List stack: each entry is ``(indent_level, Item)``. Reset on
    # every heading boundary so list items don't accidentally nest
    # under a list from a previous section.
    list_stack = []

    for item in nodes:
        if item.kind == 'heading':
            # Headings reset any open list scope — the new section's
            # list items can't be children of the prior section's.
            list_stack = []
            L = item.level
            while heading_stack and heading_stack[-1][0] >= L:
                heading_stack.pop()
            parent = heading_stack[-1][1] if heading_stack else root
            parent._children.append(item)
            heading_stack.append((L, item))
        else:
            L = item.level
            # Pop list-stack entries at indent ≥ L so we attach to the
            # nearest strictly-shallower ancestor.
            while list_stack and list_stack[-1][0] >= L:
                list_stack.pop()
            if list_stack:
                parent = list_stack[-1][1]
            elif heading_stack:
                parent = heading_stack[-1][1]
            else:
                parent = root
            parent._children.append(item)
            list_stack.append((L, item))

    # Propagate has_children now that the tree is wired. Root's
    # ``has_children`` was set at construction (``bool(nodes)``); it
    # stays True if any node exists, which is what we want.
    for item in nodes:
        item.has_children = bool(item._children)

    # Build the by-id index. Last-writer wins on duplicate ids — two
    # nodes can't share a line_offset because parser events are at
    # distinct byte offsets, but in pathological inputs (e.g. ``\r\n``
    # plus the same logical line) we still keep the recipe usable.
    by_id = {root.id: root}
    for item in nodes:
        by_id[item.id] = item
    return root, by_id


def _build_line_index(by_id):
    """Return ``(by_line, lines_sorted)`` for ``_node_at_line`` lookup.

    Walks the ``by_id`` map returned by ``_build_nodes`` and skips the
    synthetic root entry (its ``line_offset`` of 0 would otherwise
    swallow every "line precedes any parsed node" anchor lookup).

    Multiple Items at the same ``line_offset`` resolve to the last
    one inserted; parser events sit at distinct ``byte_offset``\\ s,
    so collisions only happen in pathological inputs (e.g. ``\\r\\n``
    line endings folded onto the same logical line). Whichever wins
    is deterministic given ``by_id`` iteration order.
    """
    by_line = {}
    for item in by_id.values():
        if item.kind == 'root':
            continue
        by_line[item.line_offset] = item
    lines_sorted = sorted(by_line)
    return by_line, lines_sorted


def _build_multi_root(file_states):
    """Synthesise the multi-root Item sitting above the per-file roots.

    ``file_states`` is the argv-ordered list of ``_FileState`` objects
    coming out of ``_reparse``. The returned root carries:

      * ``id == _ROOT_ID``  — the sentinel matching ``_FILES`` lookups
        in ``get_preview`` / classifier.
      * ``title``           — ``"N files"`` so the row reads as a
        compact summary in the visible-tree header.
      * ``kind == 'multi-root'`` — distinct from per-file roots'
        ``'root'`` so the classifier can tell them apart.
      * ``_children``       — the per-file roots in argv order.
      * ``byte_offset/byte_size`` — zero (no underlying text). The
        ``V`` / ``E`` classifier short-circuits BEFORE byte-range
        slicing for multi-root targets, so these are never used.
      * ``file_path = None`` — the multi-root has no owning file;
        callers must classify before reading the attr.

    Single-file callers (and tests that exercise the single-file
    pipeline directly) never reach this helper — ``_reparse`` only
    invokes it when ``_INPUT_FILES`` has more than one entry, so the
    Browser's ``root_id`` is the per-file root's id in that case and
    the multi-root sentinel sits unused.
    """
    root = Item(
        id=_ROOT_ID,
        title=f'{len(file_states)} files',
        has_children=bool(file_states),
    )
    root.kind = 'multi-root'
    root.level = 0
    root.byte_offset = 0
    root.byte_size = 0
    root.line_offset = 0
    root.line_size = 0
    root.file_path = None
    root._children = [fs.file_root for fs in file_states]
    return root


def _classify_id(node_id):
    """Single-source classifier for an Item id.

    Returns one of:
      * ``('multi-root', None)``   — the synthetic multi-root sentinel.
      * ``('file-root', path)``    — a per-file root (id is the file's
                                     abs path; ``_FILES[path]`` exists).
      * ``('content', path)``      — a per-file heading or list-item.
        ``path`` is the file abs path; the rest of the id is
        ``#<line_offset>``.
      * ``('unknown', None)``      — id doesn't fit any of the above.
        Caller decides how to fail (usually empty preview or noop).

    Used by ``get_preview``, ``_run_source_command``, and any other
    surface that needs to distinguish "open the file directly" from
    "slice into a per-file body". Centralising the rule means a future
    id-shape change touches one place.
    """
    if node_id == _ROOT_ID:
        return ('multi-root', None)
    if node_id in _FILES:
        return ('file-root', node_id)
    # Content id shape: ``<path>#<line>``. ``rpartition`` so paths
    # that happen to contain ``#`` (rare) still split on the last one.
    if '#' in node_id:
        path, _, _ = node_id.rpartition('#')
        if path in _FILES:
            return ('content', path)
    return ('unknown', None)


def _node_at_line(n, file_state=None):
    """Return the deepest parsed node whose source range contains line ``n``.

    Contract (per the spec's "Lookup contract" section):
      * Exact-match wins — if a node starts on line ``n``, that node
        is returned regardless of any earlier node whose range also
        covers ``n``.
      * Otherwise return the node with the greatest ``line_offset``
        ≤ ``n``. Since every parsed range encompasses its descendants,
        the deepest-containing node is also the one with the greatest
        ``line_offset`` that doesn't exceed ``n``.
      * ``None`` if ``n`` precedes every parsed node (preamble
        territory — the anchor flow then falls back to root upstream).

    ``file_state`` selects which file's line index to consult. When
    ``None`` (legacy single-file callers / tests that populate
    ``_BY_LINE`` / ``_LINES_SORTED`` directly), the module-level
    globals are used instead — preserving the pre-multi-file API.
    """
    if file_state is not None:
        by_line = file_state.by_line
        lines_sorted = file_state.lines_sorted
    else:
        by_line = _BY_LINE
        lines_sorted = _LINES_SORTED
    item = by_line.get(n)
    if item is not None:
        return item
    i = bisect.bisect_right(lines_sorted, n) - 1
    if i < 0:
        return None
    return by_line[lines_sorted[i]]


def _display_title(item):
    """Return ``item.title`` normalised for anchor matching.

    Stored titles are already pre-stripped at ``_build_nodes`` time —
    headings have their leading ``#``s + whitespace removed, list
    items have their marker + whitespace removed. This helper now
    just trims surrounding whitespace so callers in the anchor-match
    flow get a stable key regardless of any future title-construction
    quirks.

    Example: a heading stored as ``'My **bold** heading'`` returns
    itself unchanged; inline formatting markers are preserved.
    """
    return item.title.strip()


def _resolve_anchor(anchor, file_root_id):
    """Resolve an anchor string to an Item id (for ``initial_scope``).

    Three-way dispatch matching the spec's "Argument parsing" rules:

      * Empty anchor → ``file_root_id``.
      * All-digit anchor → treat as a 0-indexed line number, look up
        via ``_node_at_line``. Fall through silently to ``file_root_id``
        when the lookup returns ``None`` (the anchor precedes every
        parsed node — normal for early-file targets).
      * Non-digit anchor → three-tier scan over headings only, in
        source order: exact ``_display_title`` match, then prefix,
        then substring. First hit in any tier wins. No match in any
        tier emits a stderr warning and falls through to root.

    The tier loop runs each predicate as a separate pass over the
    heading list so a substring hit on heading A can't pre-empt an
    exact match on later heading B — matching the spec's "scan all
    headings before falling through" wording.

    ``file_root_id`` is the per-file root id whose headings are
    searched. In multi-file mode the caller picks the file via
    "first anchored file wins" and passes its root id here; in
    single-file (and legacy-test) mode it's just the lone root id.
    """
    if not anchor:
        return file_root_id
    # Pick the file state to scan. ``_FILES`` is populated by
    # ``_reparse``; legacy single-file tests skip ``_reparse`` and
    # populate the module-level ``_BY_ID`` / ``_BY_LINE`` directly,
    # in which case ``_FILES`` is empty and we fall back to the
    # module-level indexes by passing ``file_state=None`` to the
    # downstream helpers.
    file_state = _FILES.get(file_root_id)
    if anchor.isdigit():
        item = _node_at_line(int(anchor), file_state)
        return item.id if item is not None else file_root_id
    # Non-digit: scan headings in source order. ``_BY_ID`` (per-file
    # in multi-file mode via ``file_state.by_id``, or the module-level
    # aggregate in legacy mode) is built in insertion order (root +
    # parser-event order from ``_build_nodes``), so filtering to
    # headings and sorting by ``line_offset`` yields source order
    # without depending on dict iteration semantics.
    if file_state is not None:
        candidates = file_state.by_id.values()
    else:
        # Legacy: scan ``_BY_ID`` but filter to headings whose
        # ``file_path`` matches ``file_root_id`` when present (so a
        # multi-file aggregate-only test doesn't accidentally match
        # the wrong file's heading). Tests built without ``file_path``
        # (older fixtures) hit the ``getattr(..., None)`` fallback
        # which keeps the heading in scope — preserving pre-#553
        # behaviour.
        candidates = []
        for it in _BY_ID.values():
            fp = getattr(it, 'file_path', None)
            if fp is None or fp == file_root_id:
                candidates.append(it)
    headings = sorted(
        (it for it in candidates if it.kind == 'heading'),
        key=lambda it: it.line_offset,
    )
    # Lower the anchor once; comparison is case-insensitive but the
    # stored title and the stderr warning still echo original casing.
    key = anchor.lower()
    # Tier 1: exact match.
    for h in headings:
        if _display_title(h).lower() == key:
            return h.id
    # Tier 2: prefix match.
    for h in headings:
        if _display_title(h).lower().startswith(key):
            return h.id
    # Tier 3: substring match.
    for h in headings:
        if key in _display_title(h).lower():
            return h.id
    print(
        f'browse-md: no heading matches {anchor!r}, opening at root',
        file=sys.stderr,
    )
    return file_root_id


def _reparse():
    """Re-slurp every input file and rebuild every parser-derived index.

    Wipes ``_FILES``, ``_BY_ID`` (aggregate), and the legacy
    single-file shims (``_FILE_TEXT`` / ``_BY_LINE`` / ``_LINES_SORTED``
    / ``_ROOT_PATH``), then rebuilds them in place from the on-disk
    files listed in ``_INPUT_FILES``. Each file is parsed independently
    with the same ``_parse`` + ``_build_nodes`` pipeline used in
    single-file mode.

    With one input file the Browser root is that file's per-file root
    (legacy behaviour: ``root_id`` = abs path). With two or more, the
    Browser root is the synthetic multi-root sentinel ``_ROOT_ID`` and
    each per-file root becomes a top-level sibling under it.

    Returns the root Item used by ``main()`` to seed ``BrowserConfig``
    and by Ctrl-R callers (the latter discards it — but exposing it
    keeps both code paths symmetric).
    """
    global _FILES, _BY_ID
    global _FILE_TEXT, _BY_LINE, _LINES_SORTED, _ROOT_PATH

    _FILES = {}
    _BY_ID = {}

    # Legacy / test fallback: if ``_INPUT_FILES`` is empty but
    # ``_ROOT_PATH`` was set externally (older test fixtures that
    # populate ``_ROOT_PATH`` directly before calling ``_reparse``),
    # treat it as a one-file input list. Production ``main()`` always
    # populates ``_INPUT_FILES`` before reaching here.
    input_files = _INPUT_FILES
    if not input_files and _ROOT_PATH is not None:
        input_files = [(_ROOT_PATH, '')]

    file_states = []
    for path, _anchor in input_files:
        with open(path, 'r', encoding='utf-8', errors='replace') as f:
            text = f.read()
        ls = _line_starts(text)
        events = _parse(text)
        file_root, by_id = _build_nodes(events, text, ls, path)
        by_line, lines_sorted = _build_line_index(by_id)
        fs = _FileState(
            path=path,
            text=text,
            line_starts=ls,
            by_id=by_id,
            by_line=by_line,
            lines_sorted=lines_sorted,
            file_root=file_root,
        )
        _FILES[path] = fs
        file_states.append(fs)
        # Aggregate id-to-Item — every per-file by_id contributes.
        _BY_ID.update(by_id)

    # Build the synthetic multi-root only when we have >1 files; the
    # single-file path keeps the per-file root AS the Browser root so
    # the visible-tree header reads as the file's basename rather than
    # ``"1 files"``.
    if len(file_states) > 1:
        multi_root = _build_multi_root(file_states)
        _BY_ID[_ROOT_ID] = multi_root
        root = multi_root
    elif file_states:
        root = file_states[0].file_root
    else:
        # Defensive: ``main()`` rejects zero-positional argv, so this
        # branch is unreachable in production. Tests that call
        # ``_reparse`` with an empty ``_INPUT_FILES`` get an empty
        # placeholder rather than a NameError.
        root = None

    # Mirror the FIRST file's state into the legacy single-file
    # globals so tests / call sites that haven't been updated still
    # see a consistent view. In single-file mode this is the only
    # file's state; in multi-file mode the first file is the
    # well-defined choice (matches "first file wins" for V/E on
    # multi-root and ``_INPUT_FILES`` ordering).
    if file_states:
        first = file_states[0]
        _FILE_TEXT = first.text
        _BY_LINE = first.by_line
        _LINES_SORTED = first.lines_sorted
        _ROOT_PATH = first.path
    else:
        _FILE_TEXT = ''
        _BY_LINE = {}
        _LINES_SORTED = []
        _ROOT_PATH = None

    return root


def get_children(node_id, *, reload=False):
    """Return cached children for ``node_id``.

    The tree is built once in ``main()`` (``_build_nodes`` walks each
    file's flat event stream and pre-populates ``item._children``,
    then ``_reparse`` aggregates per-file roots under the synthetic
    multi-root), so this is a dict lookup — no per-call parsing.
    Unknown ids return ``[]`` so a stale anchor or scope id doesn't
    surface as a traceback.

    ``reload=True`` is honoured only at the Browser root (``node_id``
    is ``None`` or matches the current root id — ``_ROOT_ID`` in
    multi-file mode, the single per-file root's path in single-file
    mode): the framework's Ctrl-R hook calls
    ``get_children(current_root, reload=True)``, and we use that as
    the trigger to re-slurp every file and rebuild every index.
    Non-root reloads return cached children unchanged — full reparse
    is cheap but pointless when the request targets a sub-node.
    """
    if reload:
        # Treat ``None`` and either flavour of root (multi-root id or
        # the single-file root path) as the "reload-at-root" trigger.
        # ``_ROOT_PATH`` is the first file's abs path; in single-file
        # mode it IS the Browser root id, in multi-file mode it's a
        # per-file root and a reload there shouldn't reparse — but the
        # ticket says "treat as root" so we keep the wider gate.
        if node_id is None or node_id == _ROOT_ID or node_id == _ROOT_PATH:
            _reparse()
    if node_id is None:
        # Pick the Browser root: multi-root sentinel if it's in the
        # aggregate index, else the single-file root path.
        node_id = _ROOT_ID if _ROOT_ID in _BY_ID else _ROOT_PATH
    item = _BY_ID.get(node_id)
    if item is None:
        return []
    return list(item._children)


def _multi_root_preview():
    """Return the summary text shown when the cursor is on the multi-root.

    Lists each input file with the count of heading-kind items in its
    subtree, one per line — a compact "what's loaded" view that
    doesn't concatenate every file's body (which is the footgun the
    ticket calls out). Falls back to a bare count if ``_FILES`` is
    empty (defensive — ``main()`` rejects zero-positional argv).
    """
    if not _FILES:
        return ''
    lines = [f'{len(_FILES)} files:']
    # Iterate in argv order so the summary lines match the visible
    # tree order — ``_INPUT_FILES`` is the argv-derived list of
    # ``(path, anchor)`` pairs.
    for path, _anchor in _INPUT_FILES:
        fs = _FILES.get(path)
        if fs is None:
            continue
        n_headings = sum(
            1 for it in fs.by_id.values() if it.kind == 'heading'
        )
        lines.append(f'  {os.path.basename(path)}  ({n_headings} headings)')
    return '\n'.join(lines) + '\n'


def get_preview(node_id):
    """Return the preview slice for ``node_id``.

    Four dispatch paths (via ``_classify_id`` when ``_FILES`` is
    populated; legacy single-file callsites fall through to the
    module-level ``_FILE_TEXT`` / ``_BY_LINE`` shims):

    1. Multi-root (``node_id == _ROOT_ID``) → ``_multi_root_preview``
       short summary, NOT a concatenation of every file body.
    2. Per-file root → the corresponding ``_FILES[path].text`` (the
       whole file body).
    3. Per-file content (``<path>#<n>``) → byte-range slice from the
       right file's text. Resolved via ``_BY_ID[node_id].file_path``
       to find the owning file, then ``_node_at_line`` against that
       file's line index for off-grid anchors.
    4. Anything else (unresolvable id) → ``''``. Defensive: a stale
       cursor id from a previous scope mustn't crash the preview.

    When ``_MD_COLOR`` is on (and md2ansi is importable), the slice
    runs through ``_md2ansi_fn(text, line_width=…)`` for ANSI-coloured
    rendering. The call is wrapped in a broad ``except Exception`` so
    pathological markdown can't crash the preview pane — we just fall
    back to the raw slice.
    """
    kind, path = _classify_id(node_id)
    if kind == 'multi-root':
        text = _multi_root_preview()
    elif kind == 'file-root':
        text = _FILES[path].text
    elif kind == 'content':
        fs = _FILES[path]
        # ``<path>#<n>`` — parse the line number and resolve to a node
        # in the right file's line index.
        _, _, line_str = node_id.rpartition('#')
        try:
            line_no = int(line_str)
        except ValueError:
            return ''
        item = fs.by_line.get(line_no)
        if item is None:
            item = _node_at_line(line_no, fs)
        if item is None:
            return ''
        bo = item.byte_offset
        text = fs.text[bo:bo + item.byte_size]
    else:
        # Classifier returned ``unknown``. If ``_FILES`` is populated
        # (multi-file mode is live), an unknown id is genuinely
        # unresolvable — return empty rather than hand back the
        # legacy ``_FILE_TEXT`` shim (which would be a footgun:
        # cursor-on-stale-id wouldn't show its old file's body).
        if _FILES:
            return ''
        # Legacy single-file path: classifier failed because
        # ``_FILES`` is empty (tests that populate ``_BY_ID`` /
        # ``_FILE_TEXT`` directly without going through ``_reparse``).
        # Fall back to the module-level shim — same code shape the
        # pre-#553 recipe used.
        if '#' not in node_id:
            text = _FILE_TEXT
        else:
            _, _, line_str = node_id.rpartition('#')
            try:
                line_no = int(line_str)
            except ValueError:
                return ''
            item = _BY_LINE.get(line_no)
            if item is None:
                item = _node_at_line(line_no)
            if item is None:
                return ''
            bo = item.byte_offset
            text = _FILE_TEXT[bo:bo + item.byte_size]

    if _MD_COLOR and _md2ansi_fn is not None:
        try:
            width = (_BROWSER.preview_width if _BROWSER else 0) or 80
            return _md2ansi_fn(text, line_width=width)
        except Exception:
            # Bad markdown / md2ansi blow-up → raw slice. Matches the
            # browse-fs convention: the preview pane stays alive even
            # if the renderer chokes.
            pass
    return text


def _action_toggle_md(ctx):
    """``m`` — flip ``_MD_COLOR`` between rendered and raw markdown.

    Drops the preview cache so the next render runs through (or skips)
    the md2ansi pipe immediately. Only bound when ``_md2ansi_fn`` is
    importable; if md2ansi is missing the action isn't wired into
    ``actions`` at all, so the keystroke falls through to the default
    handler.
    """
    global _MD_COLOR
    _MD_COLOR = not _MD_COLOR
    ctx.drop_preview_cache()
    ctx.message(f'md preview: {"colored" if _MD_COLOR else "raw"}')


def _resolve_md_pager():
    """Return the resolved markdown-pager command, or ``None``.

    Order: ``$MD2ANSI`` (shell-split), then ``md2ansi | less -RS`` if
    both binaries are on PATH, then bare ``md2ansi``. Recipes that
    want a different fallback can set ``$MD2ANSI`` to anything —
    including a piped chain like ``md2ansi | less -R``, which we
    shell out via ``bash -c`` so the pipe works. Lifted verbatim from
    browse-claude's same-named helper.
    """
    import shlex
    import shutil
    env_cmd = os.environ.get('MD2ANSI')
    if env_cmd:
        if '|' in env_cmd or '<' in env_cmd or '>' in env_cmd:
            # User-supplied pipeline — hand to a shell so the pipe runs.
            return ['bash', '-c', f'{env_cmd} "$0"']
        return shlex.split(env_cmd)
    if shutil.which('md2ansi') and shutil.which('less'):
        return ['bash', '-c', 'md2ansi "$0" | less -RS']
    if shutil.which('md2ansi'):
        return ['md2ansi']
    return None


def _action_md_preview(ctx):
    """``M`` — view the preview through a markdown-to-ANSI renderer.

    Resolves the renderer via ``_resolve_md_pager``. Reads the cursor
    row's preview (cached when available, else by calling
    ``get_preview`` synchronously), writes it verbatim to a temp .md
    file, and runs the renderer on it. The temp file is unlinked on
    return regardless of how the external process exited.
    """
    import tempfile
    cmd = _resolve_md_pager()
    if cmd is None:
        ctx.message('no markdown renderer found ($MD2ANSI / md2ansi)')
        return

    item = ctx.cursor
    if item is None:
        return
    text = ctx.get_cached_preview(item.id)
    if text is None:
        try:
            text = get_preview(item.id)
        except Exception as e:
            ctx.error(f'preview: {type(e).__name__}: {e}')
            return
    if text is None:
        ctx.message('No preview available')
        return

    tmp = tempfile.NamedTemporaryFile(
        'w', suffix='.md', delete=False,
        encoding='utf-8', errors='surrogateescape',
    )
    try:
        tmp.write(text)
        tmp.close()
        ctx.run_external(cmd + [tmp.name])
    finally:
        try:
            os.unlink(tmp.name)
        except OSError:
            pass


def _split_cmd(s):
    """Shell-split a command env var like ``less -R`` or ``bat --paging=always``.

    Lifted verbatim from browse-claude (lines 4395-4398). Used by
    ``_run_source_command`` to turn ``$PAGER`` / ``$EDITOR`` into an
    argv list ready for ``ctx.run_external``.
    """
    import shlex
    return shlex.split(s)


def _merge_ranges(ranges):
    """Sort + merge overlapping/adjacent ``(byte_offset, byte_size)`` ranges.

    Returns a new list, sorted by ``byte_offset`` ascending, with no
    overlaps and no adjacent ranges (adjacent ranges are merged into
    one). Adjacency means ``next.byte_offset == current_end`` — the
    next range starts exactly where the current ends, so concatenation
    is byte-perfect with no gap.

    Algorithm: stable sort by ``byte_offset``, then a single linear
    walk. For each next range, if its start is ``<= current_end``,
    extend ``current_end`` to ``max(current_end, next_end)``;
    otherwise emit the current range and start a new one. The
    ``<= current_end`` test covers both overlap and adjacency in one
    branch.

    Edge cases:
      * Empty input → empty output.
      * Single range → list with that one range.
      * Identical ranges → deduped to one.
      * A range fully contained in another → the outer survives.
    """
    if not ranges:
        return []
    ordered = sorted(ranges, key=lambda r: r[0])
    merged = []
    cur_bo, cur_bs = ordered[0]
    cur_end = cur_bo + cur_bs
    for nxt_bo, nxt_bs in ordered[1:]:
        nxt_end = nxt_bo + nxt_bs
        if nxt_bo <= cur_end:
            # Overlap or adjacency — extend the current range's end.
            if nxt_end > cur_end:
                cur_end = nxt_end
        else:
            merged.append((cur_bo, cur_end - cur_bo))
            cur_bo = nxt_bo
            cur_end = nxt_end
    merged.append((cur_bo, cur_end - cur_bo))
    return merged


def _write_range_excerpts(ranges, file_text=None):
    """Write merged byte-range slices to a temp .md file.

    ``ranges`` is the output of ``_merge_ranges`` — sorted,
    non-overlapping ``(byte_offset, byte_size)`` tuples. Each slice is
    ``file_text[bo:bo+bs]``; when the previous slice doesn't end with
    ``\\n`` and there's a next slice, an explicit ``\\n`` is inserted
    so the boundary between two adjacent-but-not-adjacent ranges still
    reads as a line break. (Truly adjacent ranges — the kind
    ``_merge_ranges`` already coalesces — never reach this branch.)

    ``file_text`` defaults to ``_FILE_TEXT`` so legacy callers (and
    tests that populate the module-level shim directly) keep working
    without explicit plumbing. Multi-file callers should pass the
    right file's text in explicitly — the per-file
    ``_FILES[path].text`` is the source of truth in that mode.

    Returns the path to the written file; the caller is responsible
    for ``os.unlink`` in a ``finally``. ``errors='surrogateescape'``
    matches the convention used by ``_action_md_preview`` so stray
    non-UTF-8 bytes round-trip rather than raising.
    """
    import tempfile
    if file_text is None:
        file_text = _FILE_TEXT
    tmp = tempfile.NamedTemporaryFile(
        'w', suffix='.md', delete=False,
        encoding='utf-8', errors='surrogateescape',
    )
    try:
        prev_slice = ''
        for bo, bs in ranges:
            piece = file_text[bo:bo + bs]
            if prev_slice and not prev_slice.endswith('\n'):
                tmp.write('\n')
            tmp.write(piece)
            prev_slice = piece
    finally:
        tmp.close()
    return tmp.name


def _run_source_command(ctx, env_var, default):
    """Shared body of ``V`` / ``E``: resolve targets, dispatch external tool.

    Strategy (lifted from browse-claude:4323-4392, swapping the
    per-line extractor for byte-range merging):

      * ``ctx.targets`` handles "selection-or-cursor".
      * Any target is the multi-root → open the FIRST argv file in
        place. Multi-root has no underlying body so a byte-range
        slice isn't meaningful; the first-file rule is documented
        in ``_HELP_INTRO``.
      * Any target is a per-file root → open THAT file in place
        (``root_target.id`` is the abs path). Edits via ``E``
        persist naturally. Mirrors the pre-multi-file single-root
        contract.
      * Cross-file multi-select (non-root targets spanning more than
        one file) → take the FIRST file's targets only and ignore
        the rest. Spec-pinned to the simpler option; documented in
        ``_HELP_INTRO``.
      * Otherwise (all targets non-root + same file) → collect
        ``(byte_offset, byte_size)`` ranges, merge them (sort +
        dedupe + coalesce adjacent), concatenate the slices into a
        temp .md file, run the external tool on it, unlink in
        ``finally``.

    Empty ``targets`` (no cursor, no selection) is a no-op.

    Root detection logic — there are now THREE "open the file
    directly" shapes:
      * Real per-file root: ``kind == 'root'``.
      * Real multi-root: ``kind == 'multi-root'``.
      * Framework's synthetic scope-root pseudo-Item (#552): no
        ``kind`` attr at all; id matches the Browser's current root.
    The id-based branch in ``_is_root`` covers the pseudo-row in
    both single-file mode (id is the per-file root path) and
    multi-file mode (id is ``_ROOT_ID``).
    """
    targets = ctx.targets
    if not targets:
        return

    def _is_root(it):
        # Real-root attrs first — they're the common case.
        k = getattr(it, 'kind', None)
        if k == 'root' or k == 'multi-root':
            return True
        # Framework's scope-root pseudo-Item lacks ``kind`` but its
        # id matches the Browser's root. We accept either the
        # multi-root sentinel or any per-file root id (= a key in
        # ``_FILES``). Legacy single-file callers fall through to
        # ``_ROOT_PATH`` when ``_FILES`` is empty (tests don't go
        # through ``_reparse``).
        return (
            it.id == _ROOT_ID
            or it.id in _FILES
            or it.id == _ROOT_PATH
        )

    cmd = _split_cmd(os.environ.get(env_var) or default)

    # Find any root in the target set — root-wins on mixed input.
    root_target = next((it for it in targets if _is_root(it)), None)
    if root_target is not None:
        path = _pick_path_for_root(root_target)
        ctx.run_external(cmd + [path])
        return

    # All targets non-root: figure out which file(s) they come from.
    # Cross-file → first-file-only rule. Same-file → merge and write
    # a single tempfile.
    # ``getattr`` with a default keeps the legacy single-file tests
    # (which build Items without ``file_path``) on the ``_FILE_TEXT``
    # branch via ``_write_range_excerpts``'s default arg.
    paths_seen = []
    for t in targets:
        fp = getattr(t, 'file_path', None)
        if fp is not None and fp not in paths_seen:
            paths_seen.append(fp)

    if len(paths_seen) <= 1:
        # Single-file (or legacy fileless): all targets share one
        # buffer.
        file_text = None
        if paths_seen:
            fs = _FILES.get(paths_seen[0])
            if fs is not None:
                file_text = fs.text
        same_file_targets = targets
    else:
        # Cross-file: keep only the first file's targets. The first
        # file is determined by argv order (``_INPUT_FILES``) — pick
        # whichever of ``paths_seen`` appears earliest there.
        order = [p for p, _ in _INPUT_FILES]
        first_path = min(
            paths_seen, key=lambda p: order.index(p) if p in order else 1 << 31,
        )
        same_file_targets = [
            t for t in targets if getattr(t, 'file_path', None) == first_path
        ]
        fs = _FILES.get(first_path)
        file_text = fs.text if fs is not None else None

    ranges = [(t.byte_offset, t.byte_size) for t in same_file_targets]
    merged = _merge_ranges(ranges)
    tmp_path = _write_range_excerpts(merged, file_text=file_text)
    try:
        ctx.run_external(cmd + [tmp_path])
    finally:
        try:
            os.unlink(tmp_path)
        except OSError:
            pass


def _pick_path_for_root(root_target):
    """Resolve a root-classified target to the file path to open.

    Cases:
      * Multi-root (real or pseudo, id == ``_ROOT_ID``): take the
        FIRST input file. Documented in ``_HELP_INTRO``.
      * Per-file root: ``root_target.id`` IS the file path.
      * Legacy single-file pseudo-root (id == ``_ROOT_PATH``,
        ``_FILES`` empty): fall through to ``_ROOT_PATH``.
    """
    if root_target.id == _ROOT_ID:
        if _INPUT_FILES:
            return _INPUT_FILES[0][0]
        # Defensive: multi-root without an input list shouldn't
        # happen — but if it does, open the legacy single-file shim.
        return _ROOT_PATH
    if root_target.id in _FILES:
        return root_target.id
    # Legacy / scope-root pseudo-item in single-file mode.
    return _ROOT_PATH if _ROOT_PATH is not None else root_target.id


def _action_view_source(ctx):
    """``V`` — page the source for the cursor row (or selection) in $PAGER.

    On a root row this pages the original file; on non-root rows it
    pages a temp .md file containing the merged byte-range slices for
    every targeted item (or the first file's slices when the selection
    spans multiple files). Pairs with the framework's built-in ``v``
    (which pages the *preview* text, not the on-disk source).
    """
    _run_source_command(ctx, 'PAGER', 'less -R')


def _action_edit_source(ctx):
    """``E`` — open the source for the cursor row (or selection) in $EDITOR.

    On a root row this edits the original file in place; on non-root
    rows it opens a throwaway temp .md file with the merged slice
    contents. Separate from the framework's built-in ``e`` (which
    opens the *preview text* in $EDITOR with edits discarded).
    """
    _run_source_command(ctx, 'EDITOR', 'vim')


_HELP_INTRO = """\
browse-md — markdown browser for one or more files.

Usage: browse-md [-l] FILE.md[#anchor] [FILE.md[#anchor] ...]
  -l, --list, --lists  Also surface list items (default: headings).
  FILE.md   One or more markdown files. Multi-root row sits above
            per-file subtrees when >1 file is given.
  #anchor   Deep-link target — 0-based line number or heading name
            (exact / prefix / substring tiers; first hit wins). When
            multiple files carry anchors, the FIRST anchored file in
            argv order wins.

  m       Toggle md2ansi coloring (requires md2ansi).
  M       Render the preview through ``$MD2ANSI`` / md2ansi.
  V       Page source for cursor/selection in ``$PAGER``. Multi-root
          / per-file root opens the file directly; cross-file
          multi-select takes the first file's targets only.
  E       Edit source for cursor/selection in ``$EDITOR`` (same
          root / cross-file rules as V).
  Ctrl-R  Re-slurp every input file and rebuild the tree.\
"""


def _die(msg, *, with_usage=True):
    """Emit ``browse-md: <msg>`` (and optionally the usage line) and exit 2.

    Centralises the stderr-write + ``sys.exit(2)`` pattern shared by
    every argv-validation error path in ``main()``. ``with_usage`` is
    ``True`` by default — most argv errors benefit from a reminder of
    the expected shape — but the file-not-found path passes
    ``with_usage=False`` since the user already got the positional
    shape syntactically right.
    """
    print(f'browse-md: {msg}', file=sys.stderr)
    if with_usage:
        print(_USAGE, file=sys.stderr)
    sys.exit(2)


def _pop_flag(name, alts=()):
    """Pop the bare flag ``name`` (or any ``alts``) from ``sys.argv``.

    Walks ``sys.argv`` from index 1; the first literal match (against
    ``name`` or any entry in ``alts``) is deleted in place. Continues
    scanning so repeated occurrences (e.g. ``-l --list``) are all
    removed. Returns ``True`` if at least one match was found.

    Patterned after ``_pop_flag`` in browse-claude — small enough to
    duplicate rather than share. Used by ``main()`` to extract
    ``-l`` / ``--list`` / ``--lists`` before the positional is read.
    """
    found = False
    i = 1
    while i < len(sys.argv):
        if sys.argv[i] == name or sys.argv[i] in alts:
            del sys.argv[i]
            found = True
            continue
        i += 1
    return found


def main():
    global _ANCHOR, _BROWSER, _INCLUDE_LISTS, _INPUT_FILES
    # Pop the lists-on flag BEFORE reading the positionals so order in
    # argv is flexible: ``browse-md -l FILE.md`` and
    # ``browse-md FILE.md -l`` both work. The aliases are accepted
    # interchangeably (``--list`` / ``--lists``); the flag has no
    # arguments — its mere presence flips emission on.
    _INCLUDE_LISTS = _pop_flag('-l', alts=('--list', '--lists'))
    # After ``_pop_flag`` consumed every known flag, anything starting
    # with ``-`` left in argv is an unrecognised option. Surface those
    # first (most useful diagnostic) before positional-count checks.
    # We intentionally don't support ``--`` as end-of-options here:
    # ``-``-prefixed filenames can be passed as ``./-strange-name.md``.
    leftover = sys.argv[1:]
    for tok in leftover:
        if tok.startswith('-') and tok != '-':
            _die(f'unrecognised option: {tok}')
    positionals = [t for t in leftover if not (t.startswith('-') and t != '-')]
    if not positionals:
        _die('missing FILE.md[#anchor]')

    # Walk every positional, split into (file_part, anchor) at the
    # first ``#``, validate the file exists, and collect into the
    # argv-ordered ``_INPUT_FILES`` list of (abs_path, anchor) pairs.
    # The first anchored entry (if any) seeds ``_ANCHOR`` for the
    # initial-scope resolution downstream.
    input_files = []
    first_anchor = ''
    first_anchor_path = None
    for raw in positionals:
        # Split once on the first ``#`` — anything after is the anchor.
        file_part, sep, anchor = raw.partition('#')
        anchor = anchor if sep else ''
        path = os.path.abspath(os.path.expanduser(file_part))
        if not os.path.isfile(path):
            # Echo the user's INPUT (pre-expanduser, pre-abspath) so
            # the error names exactly what they typed.
            _die(f'no such file: {file_part}', with_usage=False)
        input_files.append((path, anchor))
        # "First anchor wins" — record the first non-empty anchor and
        # its owning path; subsequent anchors are ignored.
        if anchor and first_anchor_path is None:
            first_anchor = anchor
            first_anchor_path = path

    _INPUT_FILES = input_files
    _ANCHOR = first_anchor

    # First parse runs through the shared ``_reparse`` helper — same
    # path that Ctrl-R uses, so any rebuild bug surfaces at startup
    # not at first reload.
    root = _reparse()

    # Resolve the initial scope:
    #   * No anchors anywhere → multi-root (or the single per-file
    #     root in single-file mode), i.e. ``root.id``.
    #   * Some anchor → resolve against the first anchored file's
    #     state. Result is either a content id (heading/line hit) or
    #     the file's own root id (anchor missed → fallthrough).
    if first_anchor_path is not None:
        initial_scope = _resolve_anchor(_ANCHOR, first_anchor_path)
    else:
        initial_scope = root.id

    # ``M`` is always available — it errors gracefully when no
    # renderer is found, so users discover the env-var hook even on
    # boxes without md2ansi installed. ``m`` only makes sense when
    # md2ansi is importable; otherwise the toggle can't do anything
    # useful (the preview is already raw). Matches the conditional
    # build-up pattern in browse-claude / browse-fs.
    actions = [Action('M', 'View preview via $MD2ANSI / md2ansi',
                      _action_md_preview, 'cursor')]
    if _md2ansi_fn is not None:
        actions.insert(0, Action('m', 'Toggle markdown coloring',
                                 _action_toggle_md, 'none'))
    # ``V`` / ``E`` operate on ``ctx.targets`` (selection-or-cursor),
    # including the synthetic root row where ``ctx.cursor`` is None
    # but a scope_root target is still resolvable — hence the
    # ``'none'`` gate.
    actions.append(Action('V', 'View source for cursor/selection in $PAGER',
                          _action_view_source, 'none'))
    actions.append(Action('E', 'Edit source for cursor/selection in $EDITOR',
                          _action_edit_source, 'none'))
    b = Browser(BrowserConfig(
        title='browse-md',
        show_children_pane=False,
        show_ids='never',
        root_id=root.id,
        get_children=get_children,
        get_preview=get_preview,
        initial_scope=initial_scope,
        actions=actions,
        help_intro=_HELP_INTRO,
    ))
    # Stash the Browser on the module so ``get_preview`` can read
    # ``preview_width`` for md2ansi word-wrap. Matches the pattern in
    # browse-fs / browse-claude.
    _BROWSER = b
    sys.exit(b.run())


if __name__ == '__main__':
    main()
