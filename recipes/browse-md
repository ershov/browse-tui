#!/usr/bin/env -S browse-tui --run-py
"""browse-md — single-file markdown browser. Lists headings + fences as
a tree, preview shows the file body. Anchor (``FILE.md#name`` or
``FILE.md#<line>``) seeds the initial scope so deep links land directly
on the requested section.

Usage:  browse-md FILE.md[#anchor]
"""

import bisect
import os
import re
import sys

from browse_tui import Browser, BrowserConfig, Item

# Raw anchor string from the ``FILE.md#anchor`` positional — resolved
# to an item id in a later ticket (see #521). Empty string when the
# positional had no ``#``.
_ANCHOR = ''

# Whole-file slurp populated in main(). Preview returns this verbatim
# until later tickets layer on per-node previews.
_FILE_TEXT = ''

# Item index — ``id`` → ``Item``. Populated by ``_build_nodes`` from
# the synthetic root downward; ``get_children`` reads ``_children``
# off of the matching entry. Cleared / rebuilt on full reparse.
_BY_ID = {}

# Tag-style palette per heading level. h1 stays red (md2ansi-ish loud
# top); deeper levels cycle through the named palette ending in gray
# for the deepest h6.
_HEADING_STYLES = {
    1: 'red',
    2: 'yellow',
    3: 'green',
    4: 'blue',
    5: 'magenta',
    6: 'gray',
}

# Per-line list-item regex — lifted verbatim from md2ansi
# (``_m2a_fmt_list``, md2ansi.py:493). Used by ``_walk_list`` to fan
# one ``_MD_LIST`` match out into one event per marker line.
_LIST_ITEM_RE = re.compile(r'^([ \t]*)([-*+]|\d+\.)[ \t]+(.*)$')


_USAGE = 'usage: browse-md FILE.md[#anchor]'


# ### Section: Markdown block-rule table ##############################
#
# Patterns lifted verbatim from md2ansi.py (lines 697-726). md2ansi
# writes inner captures as ``(?P<*...>...)`` placeholders that its
# ``_m2a_build_context`` rewrites at build time. We don't need those
# inner names — ``_parse`` keys on the outer rule by iterating
# ``_RULES`` and picking the first whose group matched (md2ansi-style;
# see ``_m2a_replace`` in md2ansi.py). Every ``(?P<*...>...)`` is
# converted to a non-capturing ``(?:...)`` group to keep the patterns
# idiomatic ``re`` and avoid name collisions when stitched into the
# combined regex below.
#
# Every alternation has disjoint branches (no-rollback discipline);
# every cross-line span uses tempered-greedy ``(?: (?! STOP ) [\s\S] )*``
# so the engine never backtracks. See the design doc's "Regex
# discipline (no rollback, greedy)" section.

# Headings — exact-count ``#`` followed by space ensures mutual exclusion.
_MD_H1 = r"^ \# [ \t]+ (?: [^\n]+ ) $"
_MD_H2 = r"^ \#{2} [ \t]+ (?: [^\n]+ ) $"
_MD_H3 = r"^ \#{3} [ \t]+ (?: [^\n]+ ) $"
_MD_H4 = r"^ \#{4} [ \t]+ (?: [^\n]+ ) $"
_MD_H5 = r"^ \#{5} [ \t]+ (?: [^\n]+ ) $"
_MD_H6 = r"^ \#{6} [ \t]+ (?: [^\n]+ ) $"

_MD_HR = r"^ (?: -{3,} | ={3,} | _{3,} ) [ \t]* $"

# Frontmatter — anchored to file start via ``\A`` so it never matches
# mid-document. Tempered-greedy body so the closing ``---`` is the
# first one we see. Trailing ``(?:\n|$)`` lets the rule own its closing
# newline (or end-of-file) instead of leaving a stray line for later
# rules.
_MD_FRONTMATTER = r"""
    \A --- \n
    (?: (?! ^ --- [ \t]* $ ) [\s\S] )*
    ^ --- [ \t]* (?: \n | \Z )
"""

# Fenced code blocks — tempered-greedy body so each char has exactly
# one matching branch (the negative lookahead consumes one char per
# iteration). ``(?:```|~~~)`` matches either fence style.
_MD_CODE_GEN = r"""
    ^ (?: [ \t]* ) (?:```|~~~) [ \t]* (?: \w* ) [ \t]* \n
    (?: (?! ^ [ \t]* (?:```|~~~) [ \t]* $ ) [\s\S] )*
    ^ [ \t]* (?:```|~~~) [ \t]* $
"""

_MD_BLOCKQUOTE = r"^ > [ \t]? [^\n]* (?: \n > [ \t]? [^\n]* )*"

_MD_TABLE = r"^ [ \t]* \| [^\n]* (?: \n [ \t]* \| [^\n]* )*"

_MD_LIST = r"""
    ^ [ \t]* (?: [-*+] | \d+\. ) [ \t]+ [^\n]*
    (?: \n [ \t]* (?: [-*+] | \d+\. ) [ \t]+ [^\n]* )*
"""

# Rule order is precedence. Headings/HR are line-bound and need to win
# over the multi-line block rules on a single ``#`` line. ``code``
# precedes ``blockquote/table/list`` so list-looking lines inside a
# fence are masked. ``frontmatter`` MUST precede ``hr``: both can match
# a leading ``---`` line at offset 0, and Python ``re`` alternation is
# leftmost-first, so if ``hr`` came first it would consume only the
# opening fence as an HR and ``\A``-anchored ``frontmatter`` would
# never get a chance.
_RULES = (
    ('h1',          _MD_H1),
    ('h2',          _MD_H2),
    ('h3',          _MD_H3),
    ('h4',          _MD_H4),
    ('h5',          _MD_H5),
    ('h6',          _MD_H6),
    ('frontmatter', _MD_FRONTMATTER),
    ('hr',          _MD_HR),
    ('code',        _MD_CODE_GEN),
    ('blockquote',  _MD_BLOCKQUOTE),
    ('table',       _MD_TABLE),
    ('list',        _MD_LIST),
)

# Combined regex — same shape md2ansi uses in ``_m2a_build_context``
# (md2ansi.py:113). One ``finditer`` pass over the text yields all
# block-level matches in document order; ``_parse`` walks ``_RULES``
# per match to find which outer group matched (see ``_parse`` for why
# we don't use ``m.lastgroup``).
_PARSER_RE = re.compile(
    '|'.join(f'(?P<{n}>{p})' for n, p in _RULES),
    re.VERBOSE | re.MULTILINE | re.DOTALL,
)


def _line_starts(text):
    """Byte offset of the start of each line in ``text``.

    Index ``i`` holds the offset of line ``i`` (0-based). Used by
    ``_parse`` to convert a heading's ``m.start()`` byte offset into a
    line number via ``bisect``. Uses ``re.finditer`` so the scan runs
    in the C-level regex engine rather than a Python ``for`` loop.
    """
    return [0] + [m.end() for m in re.finditer(r'\n', text)]


def _line_of(byte_offset, line_starts):
    """0-based line number for ``byte_offset`` given precomputed line starts."""
    # ``bisect_right - 1`` lands on the line whose start is <= offset.
    return bisect.bisect_right(line_starts, byte_offset) - 1


# Rule names that emit a heading node from ``_parse`` — dispatch is
# by exact name, so other rules (code/blockquote/table/hr/frontmatter)
# never reach the heading branch.
_HEADING_KINDS = frozenset(('h1', 'h2', 'h3', 'h4', 'h5', 'h6'))


def _walk_list(match, line_starts):
    """Fan one ``_MD_LIST`` match out into one event per marker line.

    ``_MD_LIST`` already guarantees that every line of the match starts
    with a list marker (continuation lines split the match, see the
    spec's "List parsing details"). So we can split on ``\\n`` and run
    the per-line regex without further line-validity checks.

    ``byte_offset`` is the match's absolute start plus the per-line
    offset within the match (the sum of preceding line lengths + 1 per
    newline). ``line_offset`` is derived via ``_line_of`` against the
    file-wide ``line_starts`` so future reparses don't need a separate
    counter.
    """
    events = []
    base = match.start()
    text = match.group()
    # ``split`` over ``\n`` reconstructs each line; ``offset`` tracks
    # the line's byte position within ``text`` (relative). Each iter
    # adds ``len(line)+1`` (the ``+1`` for the newline ``split``
    # stripped). The final line has no trailing newline; the ``+1``
    # past EOF is harmless because the loop ends right after.
    offset = 0
    for line in text.split('\n'):
        m = _LIST_ITEM_RE.match(line)
        if m is not None:
            indent, marker, _body = m.group(1), m.group(2), m.group(3)
            byte_offset = base + offset
            kind = 'ol' if marker[-1] == '.' else 'ul'
            events.append((kind, {
                'byte_offset': byte_offset,
                'line_offset': _line_of(byte_offset, line_starts),
                'level': len(indent.expandtabs(4)) // 2,
                'source': line,
            }))
        offset += len(line) + 1
    return events


def _parse(text):
    """Flat ordered list of parser events for ``text``.

    Each event is a ``(kind, payload)`` tuple:
      * heading:   ``('h1'..'h6', {'byte_offset', 'line_offset', 'source'})``
      * list item: ``('ul'|'ol', {'byte_offset', 'line_offset', 'level', 'source'})``

    Code/blockquote/table/hr/frontmatter matches emit nothing — they
    exist solely to mask their contents from later rules in the
    combined regex.
    """
    line_starts = _line_starts(text)
    events = []
    for m in _PARSER_RE.finditer(text):
        # Identify the outer rule by walking ``_RULES`` and picking the
        # first whose named group has a non-None match. ``m.lastgroup``
        # would be simpler but returns the *highest-numbered* matching
        # named group — so any future inner ``(?P<...>...)`` group
        # inside a rule pattern would silently misroute dispatch. This
        # mirrors md2ansi's ``_m2a_replace`` (md2ansi.py:863-882).
        groups = m.groupdict()
        kind = next(n for n, _ in _RULES if groups.get(n) is not None)
        if kind in _HEADING_KINDS:
            byte_offset = m.start()
            events.append((kind, {
                'byte_offset': byte_offset,
                'line_offset': _line_of(byte_offset, line_starts),
                'source': m.group(),
            }))
        elif kind == 'list':
            # Fan one multi-line list match into per-marker-line nodes.
            events.extend(_walk_list(m, line_starts))
        # code / blockquote / table / hr / frontmatter: skip. Their
        # only job is to consume their span so later rules can't.
    return events


# Kinds that produce heading-shaped tree rows (h1..h6) — distinct from
# list-item rows ``ul`` / ``ol``. Used by ``_build_nodes`` for the
# boundary-rule branch (heading boundary closes any open list scope).
_HEADING_EVENT_KINDS = _HEADING_KINDS
_LIST_EVENT_KINDS = frozenset(('ul', 'ol'))


def _build_nodes(events, file_text, line_starts, path):
    """Materialise events into a tree of ``Item`` instances.

    Returns ``(root, by_id)``. The synthetic root owns every top-level
    heading and every pre-first-heading list item; ``by_id`` is the
    flat id-to-Item index. Children lists are pre-populated on each
    Item as ``item._children`` so ``get_children`` can return them
    without re-walking the event stream.

    Three passes:

    1. Per-event Item construction (heading kinds → ``heading`` items,
       ``ul``/``ol`` → ``list-item`` items). Each Item carries the
       hidden contract fields (``byte_offset``, ``line_offset``,
       ``kind``, ``level``); ``byte_size`` / ``line_size`` are filled
       in by pass 2.
    2. Boundary rule (single linear pass): for each node at index
       ``i``, find the next sibling-or-shallower node ``j`` and set
       ``byte_size = nodes[j].byte_offset - nodes[i].byte_offset``.
       At EOF, use ``len(file_text)`` / ``len(line_starts)``.
    3. Tree linking via two stacks. Heading stack pops on level-≥
       comparisons (so an h3 attaches under the nearest open h1/h2).
       List stack mirrors that on indent level and resets on every
       heading boundary; orphan list items (no shallower list
       ancestor) attach to the surrounding heading, or to root if no
       heading is open yet.
    """
    file_bytes_eof = len(file_text)
    file_lines_eof = len(line_starts)

    # --- Pass 1: per-event Item construction ---
    nodes = []  # parallel to events; same indexing
    for kind, payload in events:
        bo = payload['byte_offset']
        lo = payload['line_offset']
        source = payload['source']
        if kind in _HEADING_EVENT_KINDS:
            level = int(kind[1])  # 'h3' -> 3
            title = source.rstrip('\n').lstrip()
            item = Item(
                id=f'{path}#{lo}',
                title=title,
                tag=kind,
                tag_style=_HEADING_STYLES[level],
            )
            item.kind = 'heading'
            item.level = level
        else:
            # ``ul`` / ``ol`` — list-item node.
            title = source.rstrip('\n').lstrip()
            item = Item(
                id=f'{path}#{lo}',
                title=title,
                tag=kind,
                tag_style='dim',
            )
            item.kind = 'list-item'
            item.level = payload['level']
        item.byte_offset = bo
        item.line_offset = lo
        item._children = []
        nodes.append(item)

    # --- Pass 2: boundary rule (byte_size / line_size) ---
    # For node i, find next j > i that is sibling-or-shallower. For
    # headings: next heading at level ≤ L (lists never close a heading
    # scope). For list items: next list-item at indent ≤ L, OR any
    # heading (heading boundary always resets list scope).
    n = len(nodes)
    for i in range(n):
        cur = nodes[i]
        cur_kind = cur.kind
        cur_level = cur.level
        j_bo = file_bytes_eof
        j_lo = file_lines_eof
        for j in range(i + 1, n):
            nxt = nodes[j]
            if cur_kind == 'heading':
                if nxt.kind == 'heading' and nxt.level <= cur_level:
                    j_bo = nxt.byte_offset
                    j_lo = nxt.line_offset
                    break
            else:
                # list-item — any heading closes the list scope, plus
                # any list item at indent ≤ cur_level.
                if nxt.kind == 'heading':
                    j_bo = nxt.byte_offset
                    j_lo = nxt.line_offset
                    break
                if nxt.kind == 'list-item' and nxt.level <= cur_level:
                    j_bo = nxt.byte_offset
                    j_lo = nxt.line_offset
                    break
        cur.byte_size = j_bo - cur.byte_offset
        cur.line_size = j_lo - cur.line_offset

    # --- Pass 3: tree linking via heading + list stacks ---
    root = Item(
        id=path,
        title=os.path.basename(path),
        has_children=bool(nodes),
    )
    root.kind = 'root'
    root.level = 0
    root.byte_offset = 0
    root.byte_size = file_bytes_eof
    root.line_offset = 0
    root.line_size = file_lines_eof
    root._children = []

    # Heading stack: each entry is ``(level, Item)``. Top is the
    # current innermost open heading; an empty stack means "still
    # under root".
    heading_stack = []
    # List stack: each entry is ``(indent_level, Item)``. Reset on
    # every heading boundary so list items don't accidentally nest
    # under a list from a previous section.
    list_stack = []

    for item in nodes:
        if item.kind == 'heading':
            # Headings reset any open list scope — the new section's
            # list items can't be children of the prior section's.
            list_stack = []
            L = item.level
            while heading_stack and heading_stack[-1][0] >= L:
                heading_stack.pop()
            parent = heading_stack[-1][1] if heading_stack else root
            parent._children.append(item)
            heading_stack.append((L, item))
        else:
            L = item.level
            # Pop list-stack entries at indent ≥ L so we attach to the
            # nearest strictly-shallower ancestor.
            while list_stack and list_stack[-1][0] >= L:
                list_stack.pop()
            if list_stack:
                parent = list_stack[-1][1]
            elif heading_stack:
                parent = heading_stack[-1][1]
            else:
                parent = root
            parent._children.append(item)
            list_stack.append((L, item))

    # Propagate has_children now that the tree is wired. Root's
    # ``has_children`` was set at construction (``bool(nodes)``); it
    # stays True if any node exists, which is what we want.
    for item in nodes:
        item.has_children = bool(item._children)

    # Build the by-id index. Last-writer wins on duplicate ids — two
    # nodes can't share a line_offset because parser events are at
    # distinct byte offsets, but in pathological inputs (e.g. ``\r\n``
    # plus the same logical line) we still keep the recipe usable.
    by_id = {root.id: root}
    for item in nodes:
        by_id[item.id] = item
    return root, by_id


def get_children(node_id, *, reload=False):
    """Return cached children for ``node_id``.

    The tree is built once in ``main()`` (``_build_nodes`` walks the
    flat event stream and pre-populates ``item._children``), so this
    is a dict lookup — no per-call parsing. Unknown ids return ``[]``
    so a stale anchor or scope id doesn't surface as a traceback.

    ``reload`` is accepted for API conformance but currently a no-op;
    Ctrl-R reload lands in a later ticket (see the spec's "Reload"
    section, owned by #523+).
    """
    item = _BY_ID.get(node_id)
    if item is None:
        return []
    return list(item._children)


def get_preview(node_id):
    # Single-file recipe: every node previews the whole file body until
    # per-node previews land in later tickets.
    return _FILE_TEXT


def main():
    global _ANCHOR, _FILE_TEXT, _BY_ID
    if len(sys.argv) < 2:
        print(_USAGE, file=sys.stderr)
        sys.exit(2)
    raw = sys.argv[1]
    # Split once on the first ``#`` — anything after is the anchor and
    # gets stashed for ticket #521 to resolve once the tree is built.
    file_part, sep, anchor = raw.partition('#')
    _ANCHOR = anchor if sep else ''
    path = os.path.abspath(os.path.expanduser(file_part))
    if not os.path.isfile(path):
        print(_USAGE, file=sys.stderr)
        sys.exit(2)
    # ``errors='replace'`` keeps the recipe alive on stray non-UTF-8
    # bytes — the preview pane will show the replacement char rather
    # than the read raising.
    with open(path, 'r', encoding='utf-8', errors='replace') as f:
        _FILE_TEXT = f.read()
    # Parse + build the tree once at startup. ``_BY_ID`` becomes the
    # backing index for ``get_children``; ``root.id`` is the path
    # string we hand to ``BrowserConfig`` so root-scope lookups land
    # on the synthetic root entry rather than the empty-dict fallback.
    line_starts = _line_starts(_FILE_TEXT)
    events = _parse(_FILE_TEXT)
    root, _BY_ID = _build_nodes(events, _FILE_TEXT, line_starts, path)
    b = Browser(BrowserConfig(
        title='browse-md',
        show_children_pane=False,
        show_ids='never',
        root_id=root.id,
        get_children=get_children,
        get_preview=get_preview,
    ))
    sys.exit(b.run())


if __name__ == '__main__':
    main()
