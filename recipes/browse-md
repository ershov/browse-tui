#!/usr/bin/env -S browse-tui --run-py
"""browse-md — markdown browser supporting one or more files.

Positionals may be files OR directories: a directory expands to the
``.md`` / ``.MD`` files directly inside it (non-recursive, sorted by
name). With no positionals at all the recipe browses the current
directory (equivalent to ``browse-md .``).

Parses each resulting markdown file into a tree of headings (h1..h6);
list items under each section can optionally be surfaced as tree
rows via the ``-l`` / ``--list`` / ``--lists`` flag (default:
headings only). Per-file roots ARE the top-level entries: with a
single file the browser opens scoped into that file's headings;
with multiple files each file shows as a top-level row and the
framework's ``get_children(None)`` returns the per-file roots in
argv order. Each top-level row is normally labeled by its bare
basename; when the final file list spans more than one directory the
labels go relative to a shared root instead, disambiguating
same-named files across directories.

Anchor syntax (``FILE.md#name`` / ``FILE.md#<line>``) seeds the
initial scope so deep links open directly on the targeted section.
When multiple files carry anchors, the FIRST anchored file in argv
order wins — other anchors are ignored, every file is still listed
at the top level.

The preview pane shows the file body (or a byte-slice for non-root
cursor rows), optionally rendered through md2ansi for ANSI-coloured
markdown. Ctrl-R re-slurps every file from disk and rebuilds the
tree in place.

Custom actions on top of the framework defaults:

  m   toggle md2ansi coloring of the preview.
  M   page the preview through ``$MD2ANSI`` / external ``md2ansi``.
  V   page the source for cursor/selection in ``$PAGER``. On a
      per-file root opens that file; on non-root rows pages a temp
      file containing the merged byte-range slices. Cross-file
      multi-select groups targets by file, merges byte ranges per
      file, and concatenates the resulting slices with a
      ``\\n===== <filename> =====\\n`` separator between groups.
  E   edit the source for cursor/selection in ``$EDITOR``. Same
      per-file-root / cross-file rules as V.
  →   expand the cursor row (overrides the framework default); when
      the row is a file whose only child is a heading, that heading
      is auto-expanded too, so a single-heading document reveals its
      sections in one keystroke. The same cascade runs on the
      single-file startup auto-expand.

Usage:  browse-md [-l] [FILE.md[#anchor] | DIR ...]
"""

import bisect
import os
import sys

from browse_tui import Action, Browser, BrowserConfig, Item

# md2ansi_lib + md_doc — both HARD dependencies. ``md_doc.build_doc_tree``
# derives the heading / list structure from ``md2ansi_scan`` (one source of
# truth with the library grammar), so the recipe cannot build its tree
# without either. ``_md2ansi_fn`` is retained as the colored-preview render
# seam that ``get_preview`` calls and the render-path tests monkeypatch.
# The imports stay wrapped in try/except so the module is still importable
# for unit tests that exercise individual helpers; the absence is enforced
# at runtime by the ``main()`` gate below (which calls ``_die`` when
# ``_md2ansi_scan`` or ``md_doc`` is ``None``), not at import time. All
# names resolve because ``--run-py`` prepends the recipe's directory
# (``recipes/``) to ``sys.path`` and both ``md2ansi_lib.py`` and
# ``md_doc.py`` live there.
try:
    from md2ansi_lib import md2ansi as _md2ansi_fn, md2ansi_scan as _md2ansi_scan
except ImportError:
    _md2ansi_fn = _md2ansi_scan = None
try:
    import md_doc
except ImportError:
    md_doc = None

# Colored preview defaults on — md2ansi_lib is a hard dependency past
# the ``main()`` gate, so ``_md2ansi_fn`` is always present in
# production; the ``m`` action flips it at runtime. ``_BROWSER`` is set
# in ``main()`` after construction so ``get_preview`` can look up the
# current ``preview_width`` for the md2ansi word-wrap.
_MD_COLOR = True
_BROWSER = None  # set in main() — used for preview-width lookup

# Per-file state slot — populated by ``_reparse`` from
# ``_INPUT_FILES``. Lookups in ``get_preview`` / classifier resolve
# the right file's text + indexes via this dict; the per-Item
# ``file_path`` back-reference (set in ``_build_nodes``) is the key.
_FILES = {}

# Argv-derived list of ``(abs_path, anchor_or_empty)`` pairs, in argv
# order. Populated by ``main()`` before the first ``_reparse``; used
# by Ctrl-R to know which files to re-slurp.
_INPUT_FILES = []

# Aggregate id-to-Item index — per-file roots + every heading /
# list-item across every file. Read by ``get_children`` to
# materialise tree rows on demand and by ``get_preview`` to look up
# an id's owning file via ``item.file_path``. There is no synthetic
# multi-root: ``get_children(None)`` returns the per-file roots in
# argv order, so the files ARE the top-level entries.
_BY_ID = {}

# --- Legacy single-file shims --------------------------------------
#
# A handful of existing tests populate these module globals directly
# (e.g. ``self.r._BY_LINE = ...``) and call ``_node_at_line`` /
# ``_resolve_anchor`` / ``get_preview`` against them. To keep those
# tests passing without rewriting every test setUp, ``_reparse``
# mirrors the FIRST input file's state into these globals; helpers
# fall back to them when no explicit file-state is passed in.
#
# ``_FILE_TEXT``: first file's body (or ``''`` if no files).
# ``_BY_LINE``: ``line_offset -> Item`` for the first file.
# ``_LINES_SORTED``: sorted view of ``_BY_LINE`` keys.
# ``_ROOT_PATH``: abs path of the first file (or ``None``).
_FILE_TEXT = ''
_BY_LINE = {}
_LINES_SORTED = []
_ROOT_PATH = None

# Raw anchor string from the first anchored file in argv (after the
# multi-file refactor: "first anchor wins"). Empty when no positional
# carried a ``#``. Resolved to an item id via ``_resolve_anchor`` and
# handed to ``BrowserConfig(initial_scope=...)``.
_ANCHOR = ''

# Tag-style palette per heading level. h1 stays red (md2ansi_lib-ish loud
# top); deeper levels cycle through the named palette ending in gray
# for the deepest h6.
_HEADING_STYLES = {
    1: 'red',
    2: 'yellow',
    3: 'green',
    4: 'blue',
    5: 'magenta',
    6: 'gray',
}

# Gate for emitting list-item events from ``_parse``. Default off:
# the tree shows headings only, which is the common "table of
# contents" view. ``main()`` flips this to ``True`` when ``-l`` /
# ``--list`` / ``--lists`` appears in argv. The flag picks which kind
# set ``_parse`` requests from ``md2ansi_scan`` — list spans are only
# yielded when it is on. The full grammar runs internally either way,
# so code-fence-vs-list-line precedence (and heading detection) is
# unchanged regardless of the flag.
_INCLUDE_LISTS = False


_USAGE = 'usage: browse-md [-l] [FILE.md[#anchor] | DIR ...]'

# Markdown file extensions recognised when a positional names a directory.
# A directory argument expands to every direct child with one of these
# extensions; case is significant, so both spellings are listed.
_MD_EXTS = ('.md', '.MD')


class _FileState:
    """Per-file parser state bundle held inside ``_FILES``.

    A plain attribute carrier — every field is filled in by
    ``_reparse`` from a single ``_build_nodes`` invocation plus the
    derived line index. Keeping it on a class rather than a dict gives
    each lookup site (``get_preview``, ``_run_source_command``,
    ``_resolve_anchor``) attribute-level errors when a field is
    missing rather than a silent ``None``.

    Fields:
      * ``path``         — abs path of the file (also the per-file
                          root's Item id).
      * ``text``         — full file body. ``get_preview`` slices
                          this for non-root rows; the root preview
                          is the whole buffer.
      * ``line_starts``  — byte offset of the start of each line.
                          Its length is the file's EOF line count
                          (fed to ``_build_nodes`` as the boundary
                          rule's last-line sentinel).
      * ``by_id``        — id-to-Item index for THIS file (no
                          other files). Useful when a helper needs
                          to walk only one file's nodes (e.g.
                          anchor resolution).
      * ``by_line``      — ``line_offset -> Item`` for this file.
                          Excludes the per-file root so anchor
                          lookups for offsets in preamble territory
                          fall through to root upstream.
      * ``lines_sorted`` — sorted keys of ``by_line`` for the
                          ``bisect_right`` lookup in
                          ``_node_at_line``.
      * ``file_root``    — the per-file root Item. In multi-file
                          mode it's one of the top-level rows
                          returned by ``get_children(None)``; in
                          single-file mode it's the only one.
    """

    __slots__ = ('path', 'text', 'line_starts',
                 'by_id', 'by_line', 'lines_sorted', 'file_root')

    def __init__(self, path, text, line_starts,
                 by_id, by_line, lines_sorted, file_root):
        self.path = path
        self.text = text
        self.line_starts = line_starts
        self.by_id = by_id
        self.by_line = by_line
        self.lines_sorted = lines_sorted
        self.file_root = file_root


def _line_starts(text):
    """Byte offset of the start of each line in ``text`` (0-based).

    Thin delegation to ``md_doc._line_starts`` — the same offset→line
    index ``build_doc_tree`` stamps nodes with — so there is a single
    source of truth. ``_reparse`` stores the result on each
    ``_FileState`` (and feeds it to ``_build_nodes`` as the EOF line
    count); ``_node_at_line`` reads its sorted derivative.
    """
    return md_doc._line_starts(text)


def _line_of(byte_offset, line_starts):
    """0-based line number for ``byte_offset`` (delegates to ``md_doc``)."""
    return md_doc._line_of(byte_offset, line_starts)


# Heading event-kind tags (``h1``..``h6``) — the heading half of the
# ``(kind, payload)`` vocabulary ``_parse`` emits, distinct from the
# list-item tags ``ul`` / ``ol``. Documents that vocabulary as the
# parser's contract; the recipe's parser tests use it to partition
# ``_parse`` output into headings vs list items.
_HEADING_KINDS = frozenset(('h1', 'h2', 'h3', 'h4', 'h5', 'h6'))


def _walk_list(base, text, line_starts):
    """Fan one ``md2ansi_scan`` list span into one event per marker line.

    Thin delegation to ``md_doc._walk_list`` (the lifted shared
    implementation): each event is ``('ul'|'ol', {'byte_offset',
    'line_offset', 'level', 'source'})``. Kept as a named seam because
    the recipe's parser tests exercise it directly.
    """
    return md_doc._walk_list(base, text, line_starts)


def _parse(text):
    """Flat ordered list of ``(kind, payload)`` parser events for ``text``.

    Each event is a ``(kind, payload)`` tuple:
      * heading:   ``('h1'..'h6', {'byte_offset', 'line_offset', 'source'})``
      * list item: ``('ul'|'ol', {'byte_offset', 'line_offset', 'level', 'source'})``

    Thin delegation to ``md_doc._scan_events`` — one structural-scan
    pass over the same combined grammar the renderer uses (single source
    of truth with the library). ``_INCLUDE_LISTS`` chooses whether list
    spans are yielded; heading events are byte-for-byte identical either
    way because the full grammar runs internally and only filters at
    yield time. ``_build_nodes`` consumes these events alongside the
    structural ``build_doc_tree`` to recover each list item's ``ul`` /
    ``ol`` tag.
    """
    return md_doc._scan_events(text, md_doc._line_starts(text), _INCLUDE_LISTS)


def _build_nodes(events, file_text, line_starts, path):
    """Build a tree of ``Item`` instances from the shared structural tree.

    Returns ``(root, by_id)``. The structural source of truth is
    ``md_doc.build_doc_tree(file_text, include_lists=_INCLUDE_LISTS)`` —
    the same heading/list builder ``browse-claude`` uses — which yields
    nested ``MdNode``s already carrying ``kind`` / ``level`` /
    pre-stripped ``title`` / ``line_offset`` / ``byte_offset`` /
    ``byte_size`` / ``children``. This function maps each ``MdNode`` onto
    a ``browse-md`` ``Item`` (id ``<path>#<line_offset>``, the ``[h1]`` /
    ``[ul]`` / ``[ol]`` tag + style, the recipe's hidden contract fields),
    wires ``item._children`` from ``MdNode.children``, and hangs the
    top-level nodes under a per-file root ``Item``.

    ``events`` is the parallel ``_parse(file_text)`` event stream (same
    document order as a pre-order walk of the structural tree, verified
    1:1 by ``byte_offset``). It supplies the one bit ``MdNode`` doesn't
    carry: a list item's ``ul`` vs ``ol`` tag (the marker kind). It must
    be consistent with ``file_text`` — every caller derives it via
    ``_parse`` under the same ``_INCLUDE_LISTS``.

    The per-file root owns every top-level heading and every
    pre-first-heading list item; ``by_id`` is the flat id-to-Item index
    for THIS file (no other files). Every Item carries ``file_path =
    path`` so multi-file ``get_preview`` can find its owning file's text
    from the id alone — including the root (files ARE the top-level
    entries, so there's no synthetic root above them).

    ``MdNode.byte_size`` is the boundary-rule section length and is used
    verbatim. ``line_size`` (the line-count analogue, which ``MdNode``
    doesn't carry) is recomputed here by the same boundary rule over the
    pre-order node list: for a heading, the next heading at level ≤ L;
    for a list item, the next heading OR list item at indent ≤ L; EOF →
    ``len(line_starts)``.
    """
    file_bytes_eof = len(file_text)
    file_lines_eof = len(line_starts)

    doc_roots = md_doc.build_doc_tree(file_text, include_lists=_INCLUDE_LISTS)

    # Pre-order flatten of the structural tree — document order, which
    # is exactly the order of ``events`` (both come from the same
    # ``md2ansi_scan`` spans). Used to recompute ``line_size`` by the
    # boundary rule and to align each node with its event tag.
    flat = []

    def _flatten(node):
        flat.append(node)
        for child in node.children:
            _flatten(child)

    for r in doc_roots:
        _flatten(r)

    # Per-node ``line_size`` via the boundary rule (mirrors the
    # ``byte_size`` rule ``build_doc_tree`` already applied, but on
    # ``line_offset``). For node i find the next sibling-or-shallower
    # node j; ``line_size = flat[j].line_offset - flat[i].line_offset``,
    # EOF → ``file_lines_eof``.
    n = len(flat)
    line_size = [0] * n
    for i in range(n):
        cur = flat[i]
        cur_is_heading = cur.kind == 'heading'
        cur_level = cur.level
        j_lo = file_lines_eof
        for j in range(i + 1, n):
            nxt = flat[j]
            if cur_is_heading:
                if nxt.kind == 'heading' and nxt.level <= cur_level:
                    j_lo = nxt.line_offset
                    break
            else:
                # list-item — any heading closes the list scope, plus
                # any list item at indent ≤ cur_level.
                if nxt.kind == 'heading':
                    j_lo = nxt.line_offset
                    break
                if nxt.kind == 'list-item' and nxt.level <= cur_level:
                    j_lo = nxt.line_offset
                    break
        line_size[i] = j_lo - cur.line_offset

    # Pre-order index of each structural node, so the recursive mapper
    # can look up its own ``line_size`` and event tag without a running
    # counter. ``id(node)`` keys are stable for the lifetime of this
    # build.
    index_of = {id(node): i for i, node in enumerate(flat)}

    # Per-node tag, indexed by pre-order position. ``MdNode`` only
    # records ``kind`` ('heading' / 'list-item'), so the ``ul`` vs ``ol``
    # distinction comes from the matching event's kind. ``events`` is
    # ``_parse(file_text)``, which walks the same ``md2ansi_scan`` spans
    # as ``build_doc_tree``, so it is 1:1 with the pre-order ``flat`` by
    # construction (``len(events) == n``).
    event_kinds = [k for k, _ in events]

    # Per-file root. Files ARE the top-level entries, so there's no
    # synthetic root above them; this one owns the file's top-level
    # nodes. Seed ``by_id`` with it FIRST (its bare-``path`` id never
    # collides with a ``<path>#<line>`` content id) so the rest of the
    # index then fills in document (pre-order) order.
    root = Item(
        id=path,
        title=os.path.basename(path),
        has_children=bool(flat),
    )
    root.kind = 'root'
    root.level = 0
    root.byte_offset = 0
    root.byte_size = file_bytes_eof
    root.line_offset = 0
    root.line_size = file_lines_eof
    root.file_path = path
    by_id = {root.id: root}

    def _to_item(node):
        index = index_of[id(node)]
        if node.kind == 'heading':
            tag = f'h{node.level}'
            tag_style = _HEADING_STYLES[node.level]
        else:
            # ``ul`` / ``ol`` — the marker kind, taken from the matching
            # event (``MdNode`` doesn't carry it).
            tag = event_kinds[index]
            tag_style = 'dim'
        item = Item(
            id=f'{path}#{node.line_offset}',
            title=node.title,
            tag=tag,
            tag_style=tag_style,
        )
        item.kind = node.kind
        item.level = node.level
        item.byte_offset = node.byte_offset
        item.byte_size = node.byte_size
        item.line_offset = node.line_offset
        item.line_size = line_size[index]
        item.file_path = path
        # Insert BEFORE recursing so the index fills in document
        # (pre-order) order — parent then descendants — exactly as the
        # previous event-stream walk did. Last-writer wins on duplicate
        # ids (distinct byte offsets make a line_offset clash possible
        # only in pathological ``\r\n`` inputs); pre-order insertion
        # keeps which node wins deterministic.
        by_id[item.id] = item
        item._children = [_to_item(c) for c in node.children]
        item.has_children = bool(item._children)
        return item

    root._children = [_to_item(r) for r in doc_roots]
    return root, by_id


def _build_line_index(by_id):
    """Return ``(by_line, lines_sorted)`` for ``_node_at_line`` lookup.

    Walks the ``by_id`` map returned by ``_build_nodes`` and skips the
    synthetic root entry (its ``line_offset`` of 0 would otherwise
    swallow every "line precedes any parsed node" anchor lookup).

    Multiple Items at the same ``line_offset`` resolve to the last
    one inserted; parser events sit at distinct ``byte_offset``\\ s,
    so collisions only happen in pathological inputs (e.g. ``\\r\\n``
    line endings folded onto the same logical line). Whichever wins
    is deterministic given ``by_id`` iteration order.
    """
    by_line = {}
    for item in by_id.values():
        if item.kind == 'root':
            continue
        by_line[item.line_offset] = item
    lines_sorted = sorted(by_line)
    return by_line, lines_sorted


def _classify_id(node_id):
    """Single-source classifier for an Item id.

    Returns one of:
      * ``('file-root', path)``    — a per-file root (id is the file's
                                     abs path; ``_FILES[path]`` exists).
      * ``('content', path)``      — a per-file heading or list-item.
        ``path`` is the file abs path; the rest of the id is
        ``#<line_offset>``.
      * ``('unknown', None)``      — id doesn't fit any of the above.
        Caller decides how to fail (usually empty preview or noop).

    Used by ``get_preview``, ``_run_source_command``, and any other
    surface that needs to distinguish "open the file directly" from
    "slice into a per-file body". Centralising the rule means a future
    id-shape change touches one place.
    """
    if node_id in _FILES:
        return ('file-root', node_id)
    # Content id shape: ``<path>#<line>``. ``rpartition`` so paths
    # that happen to contain ``#`` (rare) still split on the last one.
    if '#' in node_id:
        path, _, _ = node_id.rpartition('#')
        if path in _FILES:
            return ('content', path)
    return ('unknown', None)


def _lone_heading_child_id(file_root_id):
    """Return a file-root's sole child id iff that child is a heading.

    Markdown files usually wrap their whole body under a single
    top-level heading (commonly a ``# Title`` h1), so expanding the
    file row reveals just that one heading — a dead-end that needs a
    second expand before the sections beneath it show. When
    ``file_root_id`` names a file (a key in ``_FILES``) whose per-file
    root has exactly one child and that child is a heading of any level
    (h1..h6), return the child's id so the caller can auto-expand it
    alongside the file row.

    Returns ``None`` for every other shape: an id that isn't a file
    root, a root with zero or multiple children, or a sole child that
    isn't a heading (e.g. a list item surfaced under ``-l``).
    """
    fs = _FILES.get(file_root_id)
    if fs is None:
        return None
    children = fs.file_root._children
    if len(children) == 1 and children[0].kind == 'heading':
        return children[0].id
    return None


def _node_at_line(n, file_state=None):
    """Return the deepest parsed node whose source range contains line ``n``.

    Contract (per the spec's "Lookup contract" section):
      * Exact-match wins — if a node starts on line ``n``, that node
        is returned regardless of any earlier node whose range also
        covers ``n``.
      * Otherwise return the node with the greatest ``line_offset``
        ≤ ``n``. Since every parsed range encompasses its descendants,
        the deepest-containing node is also the one with the greatest
        ``line_offset`` that doesn't exceed ``n``.
      * ``None`` if ``n`` precedes every parsed node (preamble
        territory — the anchor flow then falls back to root upstream).

    ``file_state`` selects which file's line index to consult. When
    ``None`` (legacy single-file callers / tests that populate
    ``_BY_LINE`` / ``_LINES_SORTED`` directly), the module-level
    globals are used instead — preserving the pre-multi-file API.
    """
    if file_state is not None:
        by_line = file_state.by_line
        lines_sorted = file_state.lines_sorted
    else:
        by_line = _BY_LINE
        lines_sorted = _LINES_SORTED
    item = by_line.get(n)
    if item is not None:
        return item
    i = bisect.bisect_right(lines_sorted, n) - 1
    if i < 0:
        return None
    return by_line[lines_sorted[i]]


def _display_title(item):
    """Return ``item.title`` normalised for anchor matching.

    Stored titles are already pre-stripped at ``_build_nodes`` time —
    headings have their leading ``#``s + whitespace removed, list
    items have their marker + whitespace removed. This helper now
    just trims surrounding whitespace so callers in the anchor-match
    flow get a stable key regardless of any future title-construction
    quirks.

    Example: a heading stored as ``'My **bold** heading'`` returns
    itself unchanged; inline formatting markers are preserved.
    """
    return item.title.strip()


def _resolve_anchor(anchor, file_root_id):
    """Resolve an anchor string to an Item id (for ``initial_scope``).

    Three-way dispatch matching the spec's "Argument parsing" rules:

      * Empty anchor → ``file_root_id``.
      * All-digit anchor → treat as a 0-indexed line number, look up
        via ``_node_at_line``. Fall through silently to ``file_root_id``
        when the lookup returns ``None`` (the anchor precedes every
        parsed node — normal for early-file targets).
      * Non-digit anchor → three-tier scan over headings only, in
        source order: exact ``_display_title`` match, then prefix,
        then substring. First hit in any tier wins. No match in any
        tier emits a stderr warning and falls through to root.

    The tier loop runs each predicate as a separate pass over the
    heading list so a substring hit on heading A can't pre-empt an
    exact match on later heading B — matching the spec's "scan all
    headings before falling through" wording.

    ``file_root_id`` is the per-file root id whose headings are
    searched. In multi-file mode the caller picks the file via
    "first anchored file wins" and passes its root id here; in
    single-file mode it's just the lone root id.
    """
    if not anchor:
        return file_root_id
    # Pick the file state to scan. ``_FILES`` is populated by
    # ``_reparse``; legacy single-file tests skip ``_reparse`` and
    # populate the module-level ``_BY_ID`` / ``_BY_LINE`` directly,
    # in which case ``_FILES`` is empty and we fall back to the
    # module-level indexes by passing ``file_state=None`` to the
    # downstream helpers.
    file_state = _FILES.get(file_root_id)
    if anchor.isdigit():
        item = _node_at_line(int(anchor), file_state)
        return item.id if item is not None else file_root_id
    # Non-digit: scan headings in source order. ``_BY_ID`` (per-file
    # in multi-file mode via ``file_state.by_id``, or the module-level
    # aggregate in legacy mode) is built in insertion order (root +
    # parser-event order from ``_build_nodes``), so filtering to
    # headings and sorting by ``line_offset`` yields source order
    # without depending on dict iteration semantics.
    if file_state is not None:
        candidates = file_state.by_id.values()
    else:
        # Legacy: scan ``_BY_ID`` but filter to headings whose
        # ``file_path`` matches ``file_root_id`` when present (so a
        # multi-file aggregate-only test doesn't accidentally match
        # the wrong file's heading). Tests built without ``file_path``
        # (older fixtures) hit the ``getattr(..., None)`` fallback
        # which keeps the heading in scope — preserving pre-#553
        # behaviour.
        candidates = []
        for it in _BY_ID.values():
            fp = getattr(it, 'file_path', None)
            if fp is None or fp == file_root_id:
                candidates.append(it)
    headings = sorted(
        (it for it in candidates if it.kind == 'heading'),
        key=lambda it: it.line_offset,
    )
    # Lower the anchor once; comparison is case-insensitive but the
    # stored title and the stderr warning still echo original casing.
    key = anchor.lower()
    # Tier 1: exact match.
    for h in headings:
        if _display_title(h).lower() == key:
            return h.id
    # Tier 2: prefix match.
    for h in headings:
        if _display_title(h).lower().startswith(key):
            return h.id
    # Tier 3: substring match.
    for h in headings:
        if key in _display_title(h).lower():
            return h.id
    print(
        f'browse-md: no heading matches {anchor!r}, opening at root',
        file=sys.stderr,
    )
    return file_root_id


# --- Markdown reference-following (#md: subtrees) ------------------
#
# A markdown FILE references other ``.md`` files (a relative/absolute/``~``
# path token captured by ``md_doc.find_md_refs``). A document's EXISTING
# referenced files are grouped under one synthetic ``[links]`` References
# umbrella (id ``<docid>#refs``, appended after the document's headings); each
# ref is an expandable ``[md]`` file-doc UNDER that umbrella, drilling into ITS
# headings and ITS refs, recursively. This MIRRORS browse-claude's identical
# feature — the only difference is the base id: browse-md's base is the file's
# bare-path id ``<file>`` (browse-claude's is a message id ``<sess>#<n>``).
# Crucially, browse-md has NO "inline document" segment: the base IS a file, so
# every ``#md:`` chain segment names a real file (browse-claude's empty-chain
# inline-message case never arises here).
#
# Ids use the shared ``md_doc`` codec so routing stays a ``'#md:' in id``
# substring test (``compose_md_id`` / ``parse_md_id``):
#
#   ref child of <F>      <F>#md:<enc(B)>            (file doc, boundary=True)
#   its heading           <F>#md:<enc(B)>#<lineoffset>
#   nested ref            <F>#md:<enc(B)>#md:<enc(A)>
#
# where ``<enc>`` = ``quote('file://' + abspath, safe='')``. browse-md's existing
# heading id ``<F>#<lineoffset>`` already matches the trailing ``#<lineoffset>``
# convention, so heading rows are uniform across the in-file tree and the
# ``#md:`` subtrees.
#
# Build is LAZY: the in-file heading tree is pre-built eagerly in ``_reparse``,
# but the References umbrella's full ref list (and everything under a referenced
# file) is materialised on expand in ``get_children`` — the document-expand only
# short-circuit-detects whether ANY ref exists (to hang the umbrella); the umbrella's
# own expand reads/parses each referenced file (via ``md_doc.get_doc``'s
# process-wide cache, cleared on Ctrl-R). Refs attach at the DOCUMENT level (the
# umbrella sits alongside headings, after them — never under an individual
# heading), so recursion (file → file) falls out of one uniform rule with NO
# cycle/alias detection: lazy materialisation makes a reference cycle expand in
# place rather than loop. The whole section is a no-op when ``md_doc`` is
# unavailable (the ``main()`` gate already fails fast in that case).

# Heading level (1..6) → row tag / colour style — the same palette as the in-file
# heading tree (``_HEADING_STYLES``); a ``#md:`` heading row should look identical
# to an in-file one. Kept as a separate name purely so the mapping reads next to
# the ``#md:`` helpers that use it.
_MD_HEADING_STYLE = _HEADING_STYLES


def _collapse_home(path):
    """Collapse a leading ``$HOME`` to ``~`` for display (else verbatim).

    Lifted from browse-claude's same-named helper — the fallback label for a
    referenced file that lives outside both the project root and the cwd.
    """
    if not path:
        return path
    home = os.environ.get('HOME') or os.path.expanduser('~')
    if home and path == home:
        return '~'
    if home and path.startswith(home + '/'):
        return '~' + path[len(home):]
    return path


def _md_resolution_context(file_path):
    """``(doc_dir, cwd, project_root)`` for resolving refs in ``file_path``.

    The path anchors ``md_doc.resolve_md_ref`` / ``_md_ref_label`` need:

      * ``doc_dir``      — the directory of the file whose text is being
                           scanned (the CommonMark norm for relative refs).
      * ``cwd``          — the process working directory (``os.getcwd()``).
      * ``project_root`` — the git root walked up from ``doc_dir`` (nearest
                           ``.git`` ancestor), else ``doc_dir`` itself when the
                           file isn't inside a git tree.

    browse-md has no sessions (unlike browse-claude, which derives cwd/root from
    a session's recorded ``cwd``): the file's own directory is the only anchor,
    so the walk-up starts there.
    """
    doc_dir = os.path.dirname(file_path)
    cwd = os.getcwd()
    project_root = md_doc.find_git_root(doc_dir) or doc_dir
    return doc_dir, cwd, project_root


def _md_ref_label(abspath, cwd, project_root):
    """Display label for a referenced ``.md`` file, against a single anchor.

    Rendered relative to ONE common anchor so a flat sibling list reads cleanly
    without ``../`` noise: relative to ``project_root`` if the file is inside it,
    else relative to ``cwd`` if inside it, else a ``~``-collapsed absolute path.
    The label lives on the ``Item`` (never in the id — the id is abspath-
    canonical). Lifted verbatim from browse-claude's same-named helper.
    """
    for anchor in (project_root, cwd):
        if anchor and (abspath == anchor or abspath.startswith(anchor.rstrip('/') + '/')):
            return os.path.relpath(abspath, anchor)
    return _collapse_home(abspath)


def _root_label_map(paths):
    """Map each post-expansion input path to its top-level row label.

    ``paths`` is the abs path of every FINAL (post-expansion) input file.
    When they all share ONE directory — the common case, including a lone
    file — labels stay bare basenames (today's single-dir UX). Only once
    the list spans MORE than one directory do labels go relative, so a
    flat top-level list disambiguates same-named files across dirs.

    The relative branch anchors every label against ONE shared origin —
    the cwd's git root (else cwd) — via ``_md_ref_label``, matching how
    referenced ``.md`` siblings are labeled. ``md_doc`` may be unavailable
    (optional import), in which case ``project_root`` falls back to cwd.
    """
    dirs = {os.path.dirname(p) for p in paths}
    if len(dirs) <= 1:
        return {p: os.path.basename(p) for p in paths}
    cwd = os.getcwd()
    project_root = (md_doc.find_git_root(cwd) or cwd) if md_doc else cwd
    return {p: _md_ref_label(p, cwd, project_root) for p in paths}


def _md_resolved_refs(text, doc_dir, cwd, project_root):
    """Resolve the ``.md`` refs in ``text`` to existing ``(abspath, label)`` pairs.

    Each captured token (``md_doc.find_md_refs``) is resolved via
    ``md_doc.resolve_md_ref`` (existing-only — unresolved tokens dropped), deduped
    by abspath (first occurrence wins), and sorted by label so the flat sibling
    list reads stably. ``doc_dir`` is the referencing file's own directory.
    Lifted verbatim from browse-claude's same-named helper.
    """
    seen = set()
    out = []
    for captured in md_doc.find_md_refs(text):
        abspath = md_doc.resolve_md_ref(
            captured, doc_dir=doc_dir, cwd=cwd, project_root=project_root)
        if abspath is None or abspath in seen:
            continue
        seen.add(abspath)
        out.append((abspath, _md_ref_label(abspath, cwd, project_root)))
    out.sort(key=lambda pair: pair[1])
    return out


def _file_has_existing_ref(text, file_path):
    """True iff ``text`` references at least one EXISTING ``.md`` file.

    The cheap ``has_children`` half for a per-file root: short-circuits at the
    FIRST captured ``.md`` token that ``md_doc.resolve_md_ref`` resolves to a
    real path. Used by ``_reparse`` so a heading-less file that nonetheless
    references an existing ``.md`` still carries an expansion arrow. Returns
    ``False`` immediately when ``md_doc`` is unavailable.

    This does read the referencing file's own directory off disk via
    ``resolve_md_ref``'s ``os.path.exists`` probes, but never the referenced
    files themselves — those are read lazily on expand. ``text`` is already in
    ``_FileState`` (no extra read of the primary file).
    """
    if md_doc is None:
        return False
    doc_dir, cwd, project_root = _md_resolution_context(file_path)
    for captured in md_doc.find_md_refs(text):
        if md_doc.resolve_md_ref(
                captured, doc_dir=doc_dir, cwd=cwd,
                project_root=project_root) is not None:
            return True
    return False


def _md_heading_item(base, abspaths, node):
    """Map an ``md_doc`` heading ``MdNode`` to a tree-row ``Item``.

    Id = ``compose_md_id(base, abspaths, node.line_offset)`` — selecting the
    heading by its line within the chain's last document. ``has_children`` is
    authoritative (the node is already parsed), so heading rows never need a
    self-heal. ``boundary`` stays ``False`` — a heading is same-document
    structure, not a foreign subtree. The ``[h1]``..``[h6]`` tag + style match
    the in-file heading rows. Mirrors browse-claude's ``_md_heading_item``.
    """
    item = Item(
        id=md_doc.compose_md_id(base, abspaths, line_offset=node.line_offset),
        title=node.title,
        tag=f'h{node.level}',
        tag_style=_MD_HEADING_STYLE.get(node.level, ''),
        has_children=bool(node.children),
    )
    item.kind = 'md-heading'
    item.md_level = node.level
    return item


def _md_file_item(base, abspaths, label):
    """Map a referenced ``.md`` file to a document tree-row ``Item``.

    ``abspaths`` is the full chain ending in this file (so the id nests under its
    referrer). ``has_children`` is optimistically ``True`` — the file is not read
    until expand; it self-heals to a leaf if the file has neither headings nor
    further refs. ``boundary=True`` marks it a self-contained foreign subtree so
    recursive/multi-expansion stops at it. Mirrors browse-claude's
    ``_md_file_item``.
    """
    item = Item(
        id=md_doc.compose_md_id(base, abspaths),
        title=label,
        tag='md',
        tag_style='blue',          # cross-file / attachment hue
        has_children=True,         # optimistic; self-heals on expand
        boundary=True,
    )
    item.kind = 'md-doc'
    item.md_abspath = abspaths[-1]
    return item


def _md_refs_umbrella_item(docid):
    """The synthetic ``[links]`` References umbrella for a document ``docid``.

    Groups every ``.md`` file a document references under ONE tree parent —
    instead of interleaving the ref rows directly after the document's headings.
    ``docid`` is the document's own id: a per-file root (a bare file path) at the
    file-root level, or a ``#md:`` file-doc id at the referenced-file level. The
    umbrella id appends the ``#refs`` marker (``md_doc.refs_umbrella_id``); the
    ref file-docs UNDER it keep their own ``<docid>#md:<enc>`` ids — the umbrella
    is a grouping parent, not a new hop in the ref chain.

    ``boundary=False`` (same-document grouping — Alt-Right reveals the ref entries
    but each ref file-doc under it stays a boundary). ``has_children=True`` is
    authoritative: the caller only builds this when a ref actually exists (the
    ``_file_has_existing_ref`` short-circuit), so the umbrella is never empty and
    never needs self-heal. Mirrors browse-claude's ``_md_refs_umbrella_item``.
    """
    item = Item(
        id=md_doc.refs_umbrella_id(docid),
        title='References',
        tag='links',
        tag_style='cyan',          # muted cross-file grouping hue
        has_children=True,         # caller built it only when a ref exists
        boundary=False,            # same-document grouping, not a foreign doc
    )
    item.kind = 'md-refs'
    return item


def _md_refs_umbrella_children(item_id):
    """Children of a ``[links]`` References umbrella — the full ref build.

    THIS is the lazy point: ``get_children`` (per-file root) and
    ``_md_subtree_children`` (file-doc) only short-circuit-detect a ref to decide
    whether to hang the umbrella; the full resolve (resolve all, dedup by abspath,
    sort by label) runs here, once, on the umbrella's own expand. Splits the
    ``#refs`` marker back to the grouped document's id
    (``md_doc.split_refs_umbrella``) and recovers that document's text +
    resolution anchors, then builds one ``[md]`` file-doc per existing ref — same
    ids (``<docid>#md:<enc>``) and ``boundary=True`` the direct children carried
    before the umbrella was introduced, so expansion below the umbrella is
    unchanged. Mirrors browse-claude's ``_md_refs_umbrella_children``.

    Two document shapes, mirroring the two callers:

      * **per-file root** (``docid`` is a bare file path in ``_FILES``) → the
        file's cached ``_FileState.text``, anchored on ``_md_resolution_context``
        of that path; refs chain directly off the file-root id.
      * **file-doc id** (``docid`` contains ``#md:``) → the referenced file's own
        text (``_md_chain_doc``), anchored on its own directory; refs nest onto
        the existing ``abspaths`` chain.

    Returns ``[]`` for an unreadable document (the umbrella is only built when a
    ref exists, so an empty result here means the doc became unreadable since).
    """
    if md_doc is None:
        return []
    docid = md_doc.split_refs_umbrella(item_id)
    if docid is None:
        return []
    if '#md:' in docid:
        # File-doc umbrella: resolve the referenced file's own refs, nested onto
        # its chain.
        base, abspaths, _ = md_doc.parse_md_id(docid)
        text, doc_tree = _md_chain_doc(abspaths)
        if doc_tree is None:
            return []
        doc_dir, cwd, project_root = _md_resolution_context(abspaths[-1])
        return [
            _md_file_item(base, abspaths + [ref_abspath], label)
            for ref_abspath, label in _md_resolved_refs(
                text, doc_dir, cwd, project_root)
        ]
    # Per-file-root umbrella: resolve the file's refs off its cached text.
    fs = _FILES.get(docid)
    if fs is None:
        return []
    doc_dir, cwd, project_root = _md_resolution_context(docid)
    return [
        _md_file_item(docid, [ref_abspath], label)
        for ref_abspath, label in _md_resolved_refs(
            fs.text, doc_dir, cwd, project_root)
    ]


def _preview_md_refs_umbrella(item_id):
    """Preview body for a ``[links]`` References umbrella.

    A PLAIN, non-markdown listing of the grouped refs' labels — one per line
    under a short count header — NEVER routed through ``_md_render`` / md2ansi
    (the labels are file paths, not markdown to colorise). Reuses the umbrella's
    own ``get_children`` build so the labels match the rows exactly. Returns
    ``''`` when the document is unreadable / has no resolvable ref left. Mirrors
    browse-claude's ``_preview_md_refs_umbrella``.
    """
    kids = _md_refs_umbrella_children(item_id)
    if not kids:
        return ''
    header = f'{len(kids)} referenced file' + ('s' if len(kids) != 1 else '')
    return '\n'.join([header, ''] + [k.title for k in kids])


def _md_chain_doc(abspaths):
    """Resolve a ``#md:`` chain's *last* document to ``(text, doc_tree)``.

    The chain's terminal file is what both the subtree build and the preview
    route operate on. Unlike browse-claude (whose empty chain is the base
    message's inline content), EVERY browse-md chain segment names a file, so
    ``abspaths`` is non-empty for any valid browse-md ``#md:`` id: read + parse
    its last entry once via ``md_doc.get_doc``'s process-wide cache. Returns
    ``(None, None)`` on an unreadable file or a (malformed) empty chain — the
    callers treat that as "no children / empty preview".
    """
    if not abspaths:
        return None, None
    try:
        return md_doc.get_doc(abspaths[-1])
    except OSError:
        return None, None


def _md_subtree_children(item_id):
    """Children for a ``#md:`` node — the lazy, authoritative build.

    Routes on the parsed id shape (``md_doc.parse_md_id`` → ``(base, abspaths,
    line_offset)``; ``base`` is browse-md's per-file root id, ``abspaths`` the
    referenced-file chain):

      * **heading** (``line_offset`` set) → the sub-headings nested under it
        (walk the chain's last-document tree to the node at ``line_offset``,
        return its children as heading rows). No ref children — refs live at the
        document level, not under a heading.
      * **file document** (``abspaths`` non-empty, no ``line_offset``) → the
        top-level heading rows of that file PLUS a single ``[links]`` References
        umbrella when THAT file references ≥1 existing ``.md`` (resolved against
        the file's own directory). The umbrella groups the nested refs; building
        the full ref list is deferred to its own expand, so here we only run the
        ``_file_has_existing_ref`` short-circuit. Recursion (file → file) falls
        out of this uniform rule once the umbrella expands; expand-in-place, no
        cycle/alias detection.

    File text + tree come from ``md_doc.get_doc`` (process-wide cache). Returns
    ``[]`` for an unreadable/heading-less-and-ref-less document (which self-heals
    the optimistic arrow). Mirrors browse-claude's ``_md_subtree_children`` minus
    its inline-document branch (browse-md has no inline segment).
    """
    base, abspaths, line_offset = md_doc.parse_md_id(item_id)
    text, doc_tree = _md_chain_doc(abspaths)
    if doc_tree is None:
        return []

    # Heading node → its nested sub-headings (no ref children).
    if line_offset is not None:
        node = md_doc.node_at_line(doc_tree, line_offset)
        if node is None:
            return []
        return [_md_heading_item(base, abspaths, ch) for ch in node.children]

    # File-document node → top-level headings, then (when the file references at
    # least one existing ``.md``) a single References umbrella grouping the file's
    # own refs. The full resolve is deferred to the umbrella's expand; here we
    # just short-circuit on the first one.
    out = [_md_heading_item(base, abspaths, node) for node in doc_tree]
    if _file_has_existing_ref(text, abspaths[-1]):
        out.append(_md_refs_umbrella_item(item_id))
    return out


def _md_render(text):
    """Render preview ``text`` through md2ansi when ``_MD_COLOR`` is on.

    The colored-preview render seam shared with the existing ``get_preview``
    path: when the ``m`` toggle is on (and a renderer is present) the text goes
    through ``_md2ansi_fn`` at the current preview width, otherwise the raw text
    is returned. Any md2ansi blow-up falls back to the raw text so the preview
    pane stays alive. Mirrors browse-claude's ``_md_voice``.
    """
    if not _MD_COLOR or _md2ansi_fn is None or not text:
        return text
    try:
        width = (_BROWSER.preview_width if _BROWSER else 0) or 80
        return _md2ansi_fn(text, line_width=width)
    except Exception:
        return text


def _preview_md_node(item_id):
    """Preview body for a ``#md:`` document or heading node.

    Reads ONLY the node's own document — never a cross-item cascade:

      * **file-document node** (no ``line_offset``) → that referenced file's full
        text (``md_doc.get_doc`` cache).
      * **heading node** (``…#<lineoffset>``) → just that heading's section,
        sliced ``text[byte_offset : byte_offset + byte_size]`` from the cached
        ``doc_tree`` (the boundary rule includes the heading's own sub-sections
        and stops at the next sibling-or-shallower heading).

    Both render through ``_md_render`` (md2ansi when ``_MD_COLOR`` is on, raw
    otherwise). Returns ``''`` for an unreadable document or a line offset that
    matches no heading. Mirrors browse-claude's ``_preview_md_node`` minus its
    inline-document case (browse-md has no inline segment).
    """
    _base, abspaths, line_offset = md_doc.parse_md_id(item_id)
    text, doc_tree = _md_chain_doc(abspaths)
    if text is None:
        return ''
    if line_offset is None:
        return _md_render(text)
    node = md_doc.node_at_line(doc_tree, line_offset)
    if node is None:
        return ''
    return _md_render(text[node.byte_offset:node.byte_offset + node.byte_size])


def _reparse():
    """Re-slurp every input file and rebuild every parser-derived index.

    Wipes ``_FILES``, ``_BY_ID`` (aggregate), and the legacy
    single-file shims (``_FILE_TEXT`` / ``_BY_LINE`` / ``_LINES_SORTED``
    / ``_ROOT_PATH``), then rebuilds them in place from the on-disk
    files listed in ``_INPUT_FILES``. Each file is parsed independently
    with the same ``_parse`` + ``_build_nodes`` pipeline used in
    single-file mode.

    Files ARE the top-level entries: the Browser's ``root_id`` is
    always ``None`` and ``get_children(None)`` returns the per-file
    roots in argv order. There is no synthetic multi-root above
    them — single-file and multi-file mode share the same tree
    shape, the difference is just how many top-level rows there are.

    Returns ``None`` for symmetry with the previous signature — the
    callers that used it (Ctrl-R) ignored the return value, and
    ``main()`` no longer needs a "root" object because there is none.
    """
    global _FILES, _BY_ID
    global _FILE_TEXT, _BY_LINE, _LINES_SORTED, _ROOT_PATH

    _FILES = {}
    _BY_ID = {}

    # Legacy / test fallback: if ``_INPUT_FILES`` is empty but
    # ``_ROOT_PATH`` was set externally (older test fixtures that
    # populate ``_ROOT_PATH`` directly before calling ``_reparse``),
    # treat it as a one-file input list. Production ``main()`` always
    # populates ``_INPUT_FILES`` before reaching here.
    input_files = _INPUT_FILES
    if not input_files and _ROOT_PATH is not None:
        input_files = [(_ROOT_PATH, '')]

    # Per-file root labels: bare basenames when every input shares one
    # directory (today's UX), else relative paths that disambiguate
    # same-named files across dirs. Computed once over the final file list.
    labels = _root_label_map([p for p, _ in input_files])

    file_states = []
    for path, _anchor in input_files:
        with open(path, 'r', encoding='utf-8', errors='replace') as f:
            text = f.read()
        ls = _line_starts(text)
        events = _parse(text)
        file_root, by_id = _build_nodes(events, text, ls, path)
        # Override ``_build_nodes``'s basename default with the resolved
        # per-root label (basename when single-dir, relative otherwise).
        file_root.title = labels[path]
        # The per-file root carries an expansion arrow when it has headings
        # (set by ``_build_nodes``) OR references at least one existing ``.md``
        # file — so a heading-less file that links to a real ``.md`` is still
        # expandable into its References umbrella. The ref half is computed
        # cheaply here (no referenced file is read — only existence-probed); the
        # umbrella (and the ref file-docs under it) is built lazily on expand in
        # ``get_children``.
        if not file_root.has_children and _file_has_existing_ref(text, path):
            file_root.has_children = True
        by_line, lines_sorted = _build_line_index(by_id)
        fs = _FileState(
            path=path,
            text=text,
            line_starts=ls,
            by_id=by_id,
            by_line=by_line,
            lines_sorted=lines_sorted,
            file_root=file_root,
        )
        _FILES[path] = fs
        file_states.append(fs)
        # Aggregate id-to-Item — every per-file by_id contributes.
        _BY_ID.update(by_id)

    # Mirror the FIRST file's state into the legacy single-file
    # globals so tests / call sites that haven't been updated still
    # see a consistent view. In single-file mode this is the only
    # file's state; in multi-file mode the first file is the
    # well-defined choice (matches ``_INPUT_FILES`` ordering).
    if file_states:
        first = file_states[0]
        _FILE_TEXT = first.text
        _BY_LINE = first.by_line
        _LINES_SORTED = first.lines_sorted
        _ROOT_PATH = first.path
    else:
        _FILE_TEXT = ''
        _BY_LINE = {}
        _LINES_SORTED = []
        _ROOT_PATH = None

    return None


def get_children(node_id, *, reload=False):
    """Return children for ``node_id``.

    The in-file heading tree is built once in ``main()`` (``_build_nodes`` walks
    each file's flat event stream and pre-populates ``item._children``;
    ``_reparse`` collects the per-file roots into ``_FILES`` in argv order), so
    the in-file paths are a dict lookup — no per-call parsing. Markdown reference
    children are built LAZILY here (referenced files are read/parsed only on
    expand). Unknown ids return ``[]`` so a stale anchor or scope id doesn't
    surface as a traceback.

    Dispatch:

      * ``node_id is None`` — the framework's "top-level entries" probe (Browser
        ``root_id=None``): the per-file roots in argv order. Files ARE the
        top-level rows; there is no synthetic multi-root above them.
      * ``…#md:…`` — a node inside a referenced-file subtree (a referenced ``.md``
        document or one of its headings). Built lazily + authoritatively by
        ``_md_subtree_children``. No-op when ``md_doc`` is unavailable.
      * ``…#refs`` — a ``[links]`` References umbrella. Checked BEFORE the
        ``#md:`` branch: a file-doc umbrella id ``<base>#md:<enc>#refs`` contains
        ``#md:`` too, so the ``#refs`` test MUST come first or the ``#md:`` branch
        would steal it. THIS is the lazy point — the full ref resolve happens
        here, on umbrella expand (``_md_refs_umbrella_children``).
      * a per-file root (``node_id in _FILES``) — its eager top-level headings
        PLUS a single ``[links]`` References umbrella (appended AFTER the
        headings) when the file references ≥1 existing ``.md``.
      * any other in-file id (``<path>#<line>``) — the cached ``_children`` off
        ``_BY_ID`` (headings have only sub-heading / list children — refs attach
        at the document level, never under a heading).

    ``reload=True`` is honoured at the top-level probe (``node_id is None``) — the
    framework's Ctrl-R hook calls ``get_children(None, reload=True)``, and we use
    that as the trigger to re-slurp every file, rebuild every index, AND drop the
    shared ``md_doc`` parse cache (so edited referenced files are re-read).
    Non-root reloads return cached children unchanged — full reparse is cheap but
    pointless when the request targets a sub-node.
    """
    if reload and node_id is None:
        if md_doc is not None:
            # Drop the shared markdown parse cache so a Ctrl-R re-reads any
            # referenced ``.md`` files edited on disk (they live outside the
            # per-file ``_FILES`` index, so ``_reparse`` alone can't reach them).
            md_doc.clear_cache()
        _reparse()
    if node_id is None:
        # Top-level: per-file roots in argv order. ``_INPUT_FILES``
        # preserves argv order; ``_FILES`` is keyed by abs path so we
        # consult ``_INPUT_FILES`` for the ordering and pull each
        # file's root out of ``_FILES`` by path.
        return [_FILES[p].file_root for p, _ in _INPUT_FILES if p in _FILES]
    if (md_doc is not None and isinstance(node_id, str)
            and md_doc.split_refs_umbrella(node_id) is not None):
        # ``<docid>#refs`` — a ``[links]`` References umbrella. Checked BEFORE the
        # ``#md:`` branch: a file-doc umbrella id ``<base>#md:<enc>#refs`` contains
        # ``#md:`` too, so the ``#refs`` test MUST come first or the ``#md:``
        # branch would steal it. THIS is the lazy point — the full ref resolve
        # happens here, on umbrella expand.
        return _md_refs_umbrella_children(node_id)
    if md_doc is not None and isinstance(node_id, str) and '#md:' in node_id:
        # A node inside a referenced-file subtree — built lazily here. Routing
        # stays a substring test; ``_md_subtree_children`` parses the chain.
        return _md_subtree_children(node_id)
    if node_id in _FILES:
        # Per-file root: its eager in-file headings, then a single ``[links]``
        # References umbrella when the file references ≥1 existing ``.md``. The
        # full ref list is built lazily on the umbrella's own expand; here we just
        # short-circuit on the first existing ref.
        fs = _FILES[node_id]
        out = list(fs.file_root._children)
        if md_doc is not None and _file_has_existing_ref(fs.text, node_id):
            out.append(_md_refs_umbrella_item(node_id))
        return out
    item = _BY_ID.get(node_id)
    if item is None:
        return []
    return list(item._children)


def get_preview(node_id):
    """Return the preview slice for ``node_id``.

    Three dispatch paths (via ``_classify_id`` when ``_FILES`` is
    populated; legacy single-file callsites fall through to the
    module-level ``_FILE_TEXT`` / ``_BY_LINE`` shims):

    1. ``node_id is None`` → empty string. The framework asks for a
       preview at the "top-level entries" pseudo-row in some shells;
       we have no aggregate content to show (files ARE the top-level
       rows, each with its own preview).
    2. Per-file root → the corresponding ``_FILES[path].text`` (the
       whole file body).
    3. Per-file content (``<path>#<n>``) → byte-range slice from the
       right file's text. Resolved via ``_BY_ID[node_id].file_path``
       to find the owning file, then ``_node_at_line`` against that
       file's line index for off-grid anchors.
    4. Anything else (unresolvable id) → ``''``. Defensive: a stale
       cursor id from a previous scope mustn't crash the preview.

    A ``#md:`` id (a referenced-file document or heading node) is routed FIRST,
    before ``_classify_id`` / the generic ``<path>#<line>`` path: an md
    file-document node ends in an encoded segment (and a heading node in
    ``…#<line>``), so the generic ``rpartition('#')`` would otherwise mis-read it.
    ``_preview_md_node`` renders the referenced file's body / heading section.

    When ``_MD_COLOR`` is on, the slice runs through
    ``_md2ansi_fn(text, line_width=…)`` for ANSI-coloured rendering. The
    call is wrapped in a broad ``except Exception`` so pathological
    markdown can't crash the preview pane — we just fall back to the raw
    slice.
    """
    if node_id is None:
        return ''
    if (md_doc is not None and isinstance(node_id, str)
            and md_doc.split_refs_umbrella(node_id) is not None):
        # ``[links]`` References umbrella. Checked BEFORE the ``#md:`` path (a
        # file-doc umbrella id ``<base>#md:<enc>#refs`` contains ``#md:``) and the
        # in-file ``_classify_id`` path: render a PLAIN label list, not a document
        # body (never routed through md2ansi).
        return _preview_md_refs_umbrella(node_id)
    if md_doc is not None and isinstance(node_id, str) and '#md:' in node_id:
        # Referenced-file document / heading node — its own document's text or
        # heading section, never a cross-item cascade. Checked before the
        # in-file ``_classify_id`` path so the trailing ``#<line>`` / encoded
        # segment isn't mis-parsed as an in-file line number.
        return _preview_md_node(node_id)
    kind, path = _classify_id(node_id)
    if kind == 'file-root':
        text = _FILES[path].text
    elif kind == 'content':
        fs = _FILES[path]
        # ``<path>#<n>`` — parse the line number and resolve to a node
        # in the right file's line index.
        _, _, line_str = node_id.rpartition('#')
        try:
            line_no = int(line_str)
        except ValueError:
            return ''
        item = fs.by_line.get(line_no)
        if item is None:
            item = _node_at_line(line_no, fs)
        if item is None:
            return ''
        bo = item.byte_offset
        text = fs.text[bo:bo + item.byte_size]
    else:
        # Classifier returned ``unknown``. If ``_FILES`` is populated
        # (multi-file mode is live), an unknown id is genuinely
        # unresolvable — return empty rather than hand back the
        # legacy ``_FILE_TEXT`` shim (which would be a footgun:
        # cursor-on-stale-id wouldn't show its old file's body).
        if _FILES:
            return ''
        # Legacy single-file path: classifier failed because
        # ``_FILES`` is empty (tests that populate ``_BY_ID`` /
        # ``_FILE_TEXT`` directly without going through ``_reparse``).
        # Fall back to the module-level shim — same code shape the
        # pre-#553 recipe used.
        if '#' not in node_id:
            text = _FILE_TEXT
        else:
            _, _, line_str = node_id.rpartition('#')
            try:
                line_no = int(line_str)
            except ValueError:
                return ''
            item = _BY_LINE.get(line_no)
            if item is None:
                item = _node_at_line(line_no)
            if item is None:
                return ''
            bo = item.byte_offset
            text = _FILE_TEXT[bo:bo + item.byte_size]

    if _MD_COLOR:
        try:
            width = (_BROWSER.preview_width if _BROWSER else 0) or 80
            return _md2ansi_fn(text, line_width=width)
        except Exception:
            # Bad markdown / md2ansi blow-up → raw slice. Matches the
            # browse-fs convention: the preview pane stays alive even
            # if the renderer chokes.
            pass
    return text


def _action_toggle_md(ctx):
    """``m`` — flip ``_MD_COLOR`` between rendered and raw markdown.

    Drops the preview cache so the next render runs through (or skips)
    the md2ansi pipe immediately.
    """
    global _MD_COLOR
    _MD_COLOR = not _MD_COLOR
    ctx.drop_preview_cache()
    ctx.message(f'md preview: {"colored" if _MD_COLOR else "raw"}')


def _resolve_md_pager():
    """Return the resolved markdown-pager command, or ``None``.

    Order: ``$MD2ANSI`` (shell-split), then ``md2ansi | less -RS`` if
    both binaries are on PATH, then bare ``md2ansi``. Recipes that
    want a different fallback can set ``$MD2ANSI`` to anything —
    including a piped chain like ``md2ansi | less -R``, which we
    shell out via ``bash -c`` so the pipe works. Lifted verbatim from
    browse-claude's same-named helper.
    """
    import shlex
    import shutil
    env_cmd = os.environ.get('MD2ANSI')
    if env_cmd:
        if '|' in env_cmd or '<' in env_cmd or '>' in env_cmd:
            # User-supplied pipeline — hand to a shell so the pipe runs.
            return ['bash', '-c', f'{env_cmd} "$0"']
        return shlex.split(env_cmd)
    if shutil.which('md2ansi') and shutil.which('less'):
        return ['bash', '-c', 'md2ansi "$0" | less -RS']
    if shutil.which('md2ansi'):
        return ['md2ansi']
    return None


def _action_md_preview(ctx):
    """``M`` — view the preview through a markdown-to-ANSI renderer.

    Resolves the renderer via ``_resolve_md_pager``. Reads the cursor
    row's preview (cached when available, else by calling
    ``get_preview`` synchronously), writes it verbatim to a temp .md
    file, and runs the renderer on it. The temp file is unlinked on
    return regardless of how the external process exited.
    """
    import tempfile
    cmd = _resolve_md_pager()
    if cmd is None:
        ctx.message('no markdown renderer found ($MD2ANSI / md2ansi)')
        return

    item = ctx.cursor
    if item is None:
        return
    text = ctx.get_cached_preview(item.id)
    if text is None:
        try:
            text = get_preview(item.id)
        except Exception as e:
            ctx.error(f'preview: {type(e).__name__}: {e}')
            return
    if text is None:
        ctx.message('No preview available')
        return

    tmp = tempfile.NamedTemporaryFile(
        'w', suffix='.md', delete=False,
        encoding='utf-8', errors='surrogateescape',
    )
    try:
        tmp.write(text)
        tmp.close()
        ctx.run_external(cmd + [tmp.name])
    finally:
        try:
            os.unlink(tmp.name)
        except OSError:
            pass


def _split_cmd(s):
    """Shell-split a command env var like ``less -R`` or ``bat --paging=always``.

    Lifted verbatim from browse-claude (lines 4395-4398). Used by
    ``_run_source_command`` to turn ``$PAGER`` / ``$EDITOR`` into an
    argv list ready for ``ctx.run_external``.
    """
    import shlex
    return shlex.split(s)


def _merge_ranges(ranges):
    """Sort + merge overlapping/adjacent ``(byte_offset, byte_size)`` ranges.

    Returns a new list, sorted by ``byte_offset`` ascending, with no
    overlaps and no adjacent ranges (adjacent ranges are merged into
    one). Adjacency means ``next.byte_offset == current_end`` — the
    next range starts exactly where the current ends, so concatenation
    is byte-perfect with no gap.

    Algorithm: stable sort by ``byte_offset``, then a single linear
    walk. For each next range, if its start is ``<= current_end``,
    extend ``current_end`` to ``max(current_end, next_end)``;
    otherwise emit the current range and start a new one. The
    ``<= current_end`` test covers both overlap and adjacency in one
    branch.

    Edge cases:
      * Empty input → empty output.
      * Single range → list with that one range.
      * Identical ranges → deduped to one.
      * A range fully contained in another → the outer survives.
    """
    if not ranges:
        return []
    ordered = sorted(ranges, key=lambda r: r[0])
    merged = []
    cur_bo, cur_bs = ordered[0]
    cur_end = cur_bo + cur_bs
    for nxt_bo, nxt_bs in ordered[1:]:
        nxt_end = nxt_bo + nxt_bs
        if nxt_bo <= cur_end:
            # Overlap or adjacency — extend the current range's end.
            if nxt_end > cur_end:
                cur_end = nxt_end
        else:
            merged.append((cur_bo, cur_end - cur_bo))
            cur_bo = nxt_bo
            cur_end = nxt_end
    merged.append((cur_bo, cur_end - cur_bo))
    return merged


def _write_range_excerpts(ranges, file_text=None):
    """Write merged byte-range slices to a temp .md file.

    ``ranges`` is the output of ``_merge_ranges`` — sorted,
    non-overlapping ``(byte_offset, byte_size)`` tuples. Each slice is
    ``file_text[bo:bo+bs]``; when the previous slice doesn't end with
    ``\\n`` and there's a next slice, an explicit ``\\n`` is inserted
    so the boundary between two adjacent-but-not-adjacent ranges still
    reads as a line break. (Truly adjacent ranges — the kind
    ``_merge_ranges`` already coalesces — never reach this branch.)

    ``file_text`` defaults to ``_FILE_TEXT`` so legacy callers (and
    tests that populate the module-level shim directly) keep working
    without explicit plumbing. Multi-file callers should pass the
    right file's text in explicitly — the per-file
    ``_FILES[path].text`` is the source of truth in that mode.

    Returns the path to the written file; the caller is responsible
    for ``os.unlink`` in a ``finally``. ``errors='surrogateescape'``
    matches the convention used by ``_action_md_preview`` so stray
    non-UTF-8 bytes round-trip rather than raising.
    """
    import tempfile
    if file_text is None:
        file_text = _FILE_TEXT
    tmp = tempfile.NamedTemporaryFile(
        'w', suffix='.md', delete=False,
        encoding='utf-8', errors='surrogateescape',
    )
    try:
        prev_slice = ''
        for bo, bs in ranges:
            piece = file_text[bo:bo + bs]
            if prev_slice and not prev_slice.endswith('\n'):
                tmp.write('\n')
            tmp.write(piece)
            prev_slice = piece
    finally:
        tmp.close()
    return tmp.name


def _write_range_excerpts_grouped(groups):
    """Write per-file merged byte-range slices to a single temp .md file.

    ``groups`` is an ordered list of ``(path, file_text, merged_ranges)``
    tuples — typically produced by ``_run_source_command`` grouping
    targets by ``file_path`` (in argv order) and running
    ``_merge_ranges`` per file.

    When ``groups`` contains MORE THAN ONE file, every group is
    prefixed with a ``===== <basename(path)> =====\\n`` header —
    including the FIRST group — so the reader can tell where each
    file's content begins. When ``groups`` contains a single file,
    no header is emitted (the user already knows which file they
    selected from). Within a group, slices are written via the same
    ``\\n``-insertion logic used by ``_write_range_excerpts`` —
    boundaries between non-adjacent ranges get an explicit newline.

    Returns the path to the written file; caller unlinks in
    ``finally``.
    """
    import tempfile
    multi = len(groups) > 1
    tmp = tempfile.NamedTemporaryFile(
        'w', suffix='.md', delete=False,
        encoding='utf-8', errors='surrogateescape',
    )
    try:
        for path, file_text, ranges in groups:
            if multi:
                # Header before every group, including the first, so
                # the first file's boundary is just as visible as the
                # subsequent ones.
                tmp.write(f'===== {os.path.basename(path)} =====\n')
            prev_slice = ''
            for bo, bs in ranges:
                piece = file_text[bo:bo + bs]
                if prev_slice and not prev_slice.endswith('\n'):
                    tmp.write('\n')
                tmp.write(piece)
                prev_slice = piece
    finally:
        tmp.close()
    return tmp.name


def _run_source_command(ctx, env_var, default):
    """Shared body of ``V`` / ``E``: resolve targets, dispatch external tool.

    Strategy:

      * ``ctx.targets`` handles "selection-or-cursor".
      * **Exactly one target, and it is a file-root** → open the
        original file directly (no tempfile). Edits via ``E``
        persist naturally. Covers both "cursor on a file row, no
        selection" and "one file row space-marked, nothing else".
      * **Anything else** (any multi-target situation, including
        roots mixed with content) → produce a temp file. Every
        target contributes a byte range to be sliced out of its
        file's text:
          * a file-root expands to that file's whole text
            ``(0, len(file_text))``;
          * a content target uses its own
            ``(byte_offset, byte_size)``.
        Ranges are grouped by file in argv order, merged per file
        (so a whole-file range naturally absorbs any sub-ranges
        from the same file), then concatenated into one temp ``.md``
        passed to ``$PAGER`` / ``$EDITOR``. When more than one file
        contributes, every group is prefixed with a
        ``===== <basename> =====`` header — including the first —
        so the reader can spot file boundaries.

    Empty ``targets`` (no cursor, no selection) is a no-op.

    Root detection — there are two "open the file directly" shapes:
      * Real per-file root: ``kind == 'root'``.
      * Framework's synthetic scope-root pseudo-Item (#552): no
        ``kind`` attr at all; id matches a key in ``_FILES`` (or
        ``_ROOT_PATH`` in the legacy single-file test path).
    """
    targets = ctx.targets
    if not targets:
        return

    def _is_root(it):
        # Real per-file root attr first — common case.
        if getattr(it, 'kind', None) == 'root':
            return True
        # Framework's scope-root pseudo-Item lacks ``kind`` but its
        # id matches a file path (any key in ``_FILES`` is a per-file
        # root id). Legacy single-file callers fall through to
        # ``_ROOT_PATH`` when ``_FILES`` is empty (tests don't go
        # through ``_reparse``).
        return it.id in _FILES or it.id == _ROOT_PATH

    def _root_path(it):
        # Real per-file root or pseudo-Item with a known path.
        return it.id if it.id in _FILES else (_ROOT_PATH or it.id)

    cmd = _split_cmd(os.environ.get(env_var) or default)

    # Single-target shortcut: cursor or sole-selection on a file row
    # → open the file directly. Edits via E persist. This is the ONLY
    # path that bypasses the tempfile pipeline — any larger selection
    # (even if it contains one file-root and one heading) flows
    # through the unified expansion below.
    if len(targets) == 1 and _is_root(targets[0]):
        ctx.run_external(cmd + [_root_path(targets[0])])
        return

    # Otherwise: expand every target into a (file_path, byte_offset,
    # byte_size) triple. File-root targets expand to the file's full
    # byte range so when merged with sibling content targets the
    # whole-file range naturally absorbs them.
    expanded = []
    for t in targets:
        if _is_root(t):
            path = _root_path(t)
            fs = _FILES.get(path)
            if fs is not None:
                expanded.append((path, 0, len(fs.text)))
            elif path == _ROOT_PATH:
                # Legacy single-file fixture path (no ``_FILES``
                # entry — tests populate ``_FILE_TEXT`` / ``_ROOT_PATH``
                # directly). Fall through with ``file_path=None`` so
                # the grouping branch picks up ``_FILE_TEXT``.
                expanded.append((None, 0, len(_FILE_TEXT)))
        else:
            fp = getattr(t, 'file_path', None)
            bo = getattr(t, 'byte_offset', None)
            bs = getattr(t, 'byte_size', None)
            if bo is None or bs is None:
                # Defensive: skip targets we can't slice.
                continue
            expanded.append((fp, bo, bs))

    if not expanded:
        return

    # Group by file in argv order. Files not in ``_INPUT_FILES``
    # (legacy single-file tests where ``file_path`` is None) go last
    # and fall through to ``_FILE_TEXT``.
    by_path = {}
    for path, bo, bs in expanded:
        by_path.setdefault(path, []).append((bo, bs))
    groups = []
    seen = set()
    for p, _ in _INPUT_FILES:
        if p in by_path and p not in seen:
            seen.add(p)
            fs = _FILES.get(p)
            if fs is not None:
                groups.append((p, fs.text, _merge_ranges(by_path[p])))
    if None in by_path:
        groups.append(
            (_ROOT_PATH or '', _FILE_TEXT, _merge_ranges(by_path[None]))
        )

    if not groups:
        return
    tmp_path = _write_range_excerpts_grouped(groups)
    try:
        ctx.run_external(cmd + [tmp_path])
    finally:
        try:
            os.unlink(tmp_path)
        except OSError:
            pass


def _action_view_source(ctx):
    """``V`` — page the source for the cursor row (or selection) in $PAGER.

    On a per-file root row this pages the original file directly; on
    non-root rows it pages a temp .md file containing the merged
    byte-range slices for every targeted item. Cross-file selections
    group ranges by file and concatenate the per-file slices with a
    ``\\n===== <filename> =====\\n`` separator. Pairs with the
    framework's built-in ``v`` (which pages the *preview* text, not
    the on-disk source).
    """
    _run_source_command(ctx, 'PAGER', 'less -R')


def _action_edit_source(ctx):
    """``E`` — open the source for the cursor row (or selection) in $EDITOR.

    On a per-file root row this edits the original file in place; on
    non-root rows it opens a throwaway temp .md file with the merged
    slice contents (cross-file selections use the same per-file
    grouping + separator as ``V``). Separate from the framework's
    built-in ``e`` (which opens the *preview text* in $EDITOR with
    edits discarded).
    """
    _run_source_command(ctx, 'EDITOR', 'vim')


def _on_expand(ctx, ids):
    """Auto-expand a file whose only child is a heading.

    Registered as the ``on_expand`` lifecycle hook, so it fires on the
    collapse→expand transition from EVERY source — the ``→`` key, a
    programmatic ``ctx.expand``, and the startup ``b.expand`` issued
    before ``run()`` — not just keyboard input. For each id that just
    entered the expanded set, if it names a file whose sole child is a
    heading (see ``_lone_heading_child_id``), that heading is expanded
    too, so a single-heading document reveals its real sections in one
    gesture instead of two.

    The cascade is self-terminating: the lone heading's own child is a
    section (never itself a lone-heading file), so the follow-on expand
    of ``cascade_id`` re-fires ``on_expand`` once more and then stops.
    The child id comes from the pre-built tree, so the expand can be
    issued without waiting on the file-root's children to be cached —
    the final expanded-set / render is order-independent.
    """
    for id in ids:
        cascade_id = _lone_heading_child_id(id)
        if cascade_id is not None:
            ctx.expand(cascade_id)


