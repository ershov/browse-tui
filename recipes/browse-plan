#!/usr/bin/env -S browse-tui --run-py
"""browse-plan — drop-in replacement for plan-tui on the browse-tui core.

Targets parity with plan-tui's keybindings: status picker becomes
``ctx.pick``, edit/view become ``ctx.run_external`` / ``ctx.page``,
create/move become ``ctx.insert``. The recipe shells out to the
``plan`` CLI (matching plan-tui's pattern) so the on-disk format and
business logic stay single-sourced.

Usage:  browse-plan [TICKET_ID]   # TICKET_ID drills into a subtree.
"""

import os
import shutil
import subprocess
import sys

from browse_tui import Action, Browser, BrowserConfig, Item, mod, recipe_argv, upsert

# Optional md2ansi_lib plugin — colors ticket previews when available.
try:
    from md2ansi_lib import md2ansi as _md2ansi_fn
    if not callable(_md2ansi_fn):
        _md2ansi_fn = None
except Exception:
    _md2ansi_fn = None

# Optional md_doc plugin — gates the markdown launcher rows: a ticket whose
# BODY references one or more existing ``.md`` files gains a ``[md] References``
# umbrella child (alongside its subtasks), whose launcher rows open each
# referenced file in browse-md. Inert when md_doc isn't importable, exactly
# like the md2ansi_lib gate above — tickets then carry only their subtasks and
# leaf tickets stay plain leaves. md_doc owns the launcher Item shapes + the
# embedding flags / launch policy in ``md_doc.launch``.
try:
    import md_doc as _md_doc
except Exception:
    _md_doc = None

_MD_COLOR = _md2ansi_fn is not None  # default on when available
_BROWSER = None  # set in main() — used for preview-width lookup


# ``plan`` is on PATH in normal use; fall back to the sandvault
# binary so the recipe still runs in the test fixture / CI environment
# where PATH may not include it.
PLAN_BIN = (
    shutil.which('plan')
    or shutil.which('plan.py')
    or '/home/ubuntu/sandvault/bin/plan'
)

# Status -> tag style, mirroring plan-tui's _STATUS_STYLE.
_STATUS_TAG_STYLE = {
    'in-progress': 'green',
    'open':        'green',
    'blocked':     'red',
    'assigned':    'cyan',
    'reviewing':   'magenta',
    'testing':     'magenta',
    'backlog':     'yellow',
    'deferred':    'yellow',
    'paused':      'yellow',
    'on-hold':     'yellow',
    'future':      'yellow',
    'someday':     'yellow',
    'wishlist':    'yellow',
    'done':        'gray',
    'wontfix':     'gray',
}

# fzf-style status options — same order plan-tui uses (active first).
_KNOWN_STATUSES = [
    'in-progress', 'open', 'blocked', 'assigned', 'reviewing', 'testing',
    'backlog', 'deferred', 'paused', 'on-hold', 'future', 'someday', 'wishlist',
    'done', 'wontfix',
]

# Tab-separated ticket format — id, parent, status, has_children, depth, title.
_LIST_FORMAT = (
    'f"{id}\\t{parent}\\t{status}\\t'
    '{1 if children() else 0}\\t{depth}\\t{title}"'
)


# ---- subprocess helpers --------------------------------------------------


# Plan file selector. Set by ``main`` from ``-f FILE`` / ``--file FILE`` on
# the recipe argv; ``None`` means the plan CLI picks the file itself
# (PLAN_MD env var, .PLAN.md auto-discovery — see ``plan --help``).
_PLAN_FILE = None

# Audit-log sink. ``main`` points this at ``Browser.log`` (thread-safe)
# once the Browser exists; ``_run_plan`` then records every mutation and
# every failed call so the framework ``~`` viewer surfaces a plan-CLI
# audit trail. ``None`` (headless helpers, unit tests) means no logging.
_log_sink = None


def _plan_argv():
    """Base ``plan`` argv with ``-f FILE`` prepended when set."""
    return [PLAN_BIN] + (['-f', _PLAN_FILE] if _PLAN_FILE else [])


def _run_plan(*args, capture=True):
    """Run ``plan`` with argv ``args`` and return ``CompletedProcess``.

    A 30s timeout matches plan-tui; in the rare timeout case we return
    a synthetic non-zero result so callers can surface the error
    uniformly via the ``ctx.error`` channel.

    Every failed call (incl. the timeout fallback) and every successful
    DB-mutating call is recorded to ``_log_sink`` for the framework ``~``
    audit viewer; successful reads are not logged. See ``_log_plan_call``.
    """
    full = _plan_argv() + list(args)
    try:
        result = subprocess.run(
            full,
            capture_output=capture,
            text=True,
            stdin=subprocess.DEVNULL,
            timeout=30,
        )
    except Exception as e:
        result = subprocess.CompletedProcess(
            args=full, returncode=1, stdout='', stderr=str(e),
        )
    if _log_sink is not None:
        _log_plan_call(args, result)
    return result


def _is_read(args):
    """True iff ``args`` is a read-only ``plan`` call (not worth an audit row).

    Reads carry the ``list`` or ``get`` verb — covering ``list``,
    ``-r list``, ``get``, ``project get``. Everything else (create /
    status / close / move / comment / edit / add / …) mutates the DB.
    """
    return 'list' in args or 'get' in args


def _log_plan_call(args, result):
    """Record one ``plan`` call to ``_log_sink`` per the audit policy.

    Any non-zero return (incl. the timeout/exception fallback) is logged
    as an ``[error]`` line even for reads; otherwise only mutations are
    logged. ``args`` is the meaningful subcommand portion (no ``plan``
    binary / ``-f FILE`` prefix), rendered space-joined for the pager.
    """
    argv = ' '.join(str(a) for a in args)
    if result.returncode != 0:
        # ``stderr`` is None on a ``capture=False`` run — guard it.
        _log_sink(f'[error] plan {argv}: {(result.stderr or "").strip()}')
    elif not _is_read(args):
        _log_sink(f'plan {argv}')


def _parse_ticket_line(line):
    """Parse one line of ``_LIST_FORMAT`` into an ``Item`` (or None).

    A ticket with subtasks always carries an expansion arrow. When ``md_doc``
    is importable, a *leaf* ticket (no subtasks) gets an OPTIMISTIC arrow too —
    its body is not in hand at listing time, so we cannot yet know whether it
    references any ``.md`` file. ``get_children`` fetches + scans the body on
    expand; if neither subtasks nor refs come back the arrow self-heals away
    (``_on_children_loaded`` → ``mod(id, has_children=False)``), mirroring the
    browse-claude / browse-fs optimistic-arrow idea. With ``md_doc`` absent the
    arrow reflects the real subtask flag exactly as before.
    """
    parts = line.split('\t', 5)
    if len(parts) < 6:
        return None
    try:
        tid = int(parts[0])
    except ValueError:
        return None
    status = parts[2]
    title = parts[5]
    has_subtasks = parts[3] == '1'
    return Item(
        id=tid,
        title=title,
        tag=status,
        tag_style=_STATUS_TAG_STYLE.get(status, ''),
        has_children=has_subtasks or _md_doc is not None,
    )


# ---- data callbacks ------------------------------------------------------
#
# ``parent_id`` maps as follows:
#   - ``None`` (Browser root)        -> the synthetic Project + root tickets.
#   - ``0`` (Project synthetic id)   -> all root-level tickets via plan list.
#   - any positive int               -> direct children of ticket ``parent_id``.


def get_children(parent_id, *, reload=False):
    """Lazy children fetch via the ``plan`` CLI.

    Plan-tui's behaviour for the root scope: synthesize a "Project" entry
    at id=0 above the real root tickets so the user can ``view`` /
    ``edit`` the project preamble. We do the same — see ``visible_tickets``
    in plan-source/src-tui/040-state.py.

    A ticket row (positive int id) drills into its direct subtasks; when its
    BODY references one or more existing ``.md`` files a ``[md] References``
    umbrella (``_ticket_md_prefix``) is prepended above them. The umbrella's
    own id is the tuple ``('md-refs', tid)`` — expanding it yields the
    per-file launcher rows (``_ticket_md_children``).
    """
    # The ``[md] References`` umbrella under a ticket — its launcher rows.
    # id = ('md-refs', tid). Distinct from the int ticket ids so the two route
    # apart here and in ``get_preview`` / ``on_enter``.
    if isinstance(parent_id, tuple) and parent_id and parent_id[0] == 'md-refs':
        return _ticket_md_children(parent_id[1])

    if parent_id is None:
        # Top of the Browser tree: insert the synthetic Project entry as
        # a non-expandable header, followed by every root-level ticket.
        # Plan-tui renders the Project this way — the row exists so the
        # user can ``v``/``e`` (view/edit) the project preamble, but the
        # actual root tickets render as flat siblings beneath it (they
        # are NOT children of the Project entry).
        items = [Item(
            id=0,
            title='Project',
            tag='',
            tag_style='',
            has_children=False,
        )]
        items.extend(_list_root_tickets())
        return items

    # Real ticket id — its subtasks, with the body-References umbrella (if any)
    # prepended. The umbrella is decided by re-scanning the body here on expand
    # (the body is not in hand at listing time), so a leaf ticket's optimistic
    # arrow either reveals the umbrella or self-heals away.
    return _ticket_md_prefix(parent_id) + _list_subtasks(parent_id)


def _list_subtasks(parent_id):
    """The direct subtasks of ticket ``parent_id`` as ``Item``s.

    plan-tui uses ``-r list`` and post-filters by depth (the parent always sits
    at the smallest depth in the result; direct children are at
    parent_depth + 1).
    """
    result = _run_plan(str(parent_id), '-r', 'list', '--format', _LIST_FORMAT)
    if result.returncode != 0:
        return []
    lines = [ln for ln in result.stdout.splitlines() if ln.strip()]
    if not lines:
        return []
    parsed = [(_parse_ticket_line(ln), _depth_of(ln)) for ln in lines]
    parsed = [(it, d) for (it, d) in parsed if it is not None]
    if not parsed:
        return []
    parent_depth = parsed[0][1]
    child_depth = parent_depth + 1
    return [it for (it, d) in parsed if d == child_depth and it.id != parent_id]


def _depth_of(line):
    """Return the depth column from a ``_LIST_FORMAT`` line, or -1."""
    parts = line.split('\t', 5)
    if len(parts) < 6:
        return -1
    try:
        return int(parts[4])
    except ValueError:
        return -1


def _list_root_tickets():
    """Return the root-level tickets as ``Item`` objects."""
    result = _run_plan('list', '--format', _LIST_FORMAT)
    if result.returncode != 0:
        return []
    items = []
    for line in result.stdout.splitlines():
        line = line.strip()
        if not line:
            continue
        # Filter to the topmost depth — plan list emits the entire tree
        # and we only want the roots here. Any deeper rows are reachable
        # via expansion (which calls get_children with the real id).
        try:
            depth = int(line.split('\t', 5)[4])
        except (ValueError, IndexError):
            continue
        if depth != 0:
            continue
        it = _parse_ticket_line(line)
        if it is not None:
            items.append(it)
    return items


def get_preview(item_id):
    """Preview pane content for a row.

    A ticket / Project (int id) previews its ``plan get`` body. The markdown
    launcher rows carry tuple ids and preview what Enter would open: the
    ``[md] References`` umbrella (``('md-refs', tid)``) shows the ticket body
    (the source of the refs); a ``[md ↗]`` launcher row (``('launch', tid,
    'file', abspath)``) shows the referenced file's own contents. Both render
    through the same ``_render_md`` markdown-coloring path as a ticket body.
    """
    if isinstance(item_id, tuple) and item_id:
        kind = item_id[0]
        if kind == 'md-refs':
            return _render_md(_ticket_body(item_id[1]) or '(no preview)')
        if kind == 'launch':
            return _md_file_preview(item_id)
        return ''
    if item_id == 0:
        result = _run_plan('project', 'get')
    else:
        result = _run_plan(str(item_id), 'get')
    if result.returncode != 0:
        return result.stderr.strip() or '(no preview)'
    return _render_md(result.stdout)


def _render_md(text):
    """Colorize ``text`` as markdown when md2ansi is on, else return it raw."""
    if _MD_COLOR and _md2ansi_fn is not None:
        try:
            width = (_BROWSER.preview_width if _BROWSER else 0) or 80
            return _md2ansi_fn(text, line_width=width)
        except Exception:
            pass
    return text


def _action_toggle_md(ctx):
    global _MD_COLOR
    _MD_COLOR = not _MD_COLOR
    ctx.drop_preview_cache()
    ctx.flash(f'preview: {"colored" if _MD_COLOR else "raw"}')


# ---- markdown launcher rows ----------------------------------------------
#
# When a ticket's BODY references one or more existing ``.md`` files, the
# ticket gains a ``[md] References`` umbrella child (``md_doc.references_umbrella``)
# alongside its subtasks; expanding the umbrella reveals one ``[md ↗]`` launcher
# row per referenced file, and Enter on a launcher row opens that real file in
# browse-md by PATH (``md_doc.launch(ctx, path=…)``).
#
# Detection is DEFERRED to expansion: the body is not in hand at listing time
# (it costs a ``plan N get`` per row), so a leaf ticket carries an OPTIMISTIC
# arrow (``_parse_ticket_line``) that self-heals away on expand if neither
# subtasks nor refs come back (``_on_children_loaded``).
#
# The launcher-row id is md_doc's generic ``('launch', anchor, *spec)``: the
# anchor is the ticket id and the opaque spec this recipe encodes is
# ``('file', abspath)`` — plan refs are real on-disk files, so ``on_enter``
# opens them by path. Refs are resolved on the FILESYSTEM (plan refs are
# repo-relative) anchored on the git root (``md_doc.find_git_root``). Inert
# unless ``md_doc`` is importable.


def _git_root():
    """The git root anchoring filesystem ref resolution, or ``None``.

    Plan refs are repo-root-relative, so the git root containing the plan file
    (``find_git_root`` walking up from the cwd) is the resolution anchor passed
    as ``doc_dir`` / ``cwd`` / ``project_root`` to ``md_doc.resolve_refs``.
    ``None`` only when md_doc is absent or no ``.git`` is found.
    """
    if _md_doc is None:
        return None
    return _md_doc.find_git_root(os.getcwd())


def _ticket_body(tid):
    """The raw ``plan TID get`` body text, or ``None`` on failure.

    The same call ``get_preview`` makes — the ticket's full rendered record,
    which is what we scan for ``.md`` references.
    """
    result = _run_plan(str(tid), 'get')
    return result.stdout if result.returncode == 0 else None


def _ticket_md_refs(tid):
    """Distinct existing ``.md`` refs in ticket ``tid``'s body, on the filesystem.

    Fetches the body (``_ticket_body``) and resolves its ``.md`` tokens via
    ``md_doc.resolve_refs`` against the git root (plan refs are repo-relative).
    Returns ordered ``(abspath, label)`` pairs (deduped by canonical abspath,
    sorted by display label), or ``[]`` when the body has no resolving refs or
    md_doc / the git root is unavailable.
    """
    if _md_doc is None:
        return []
    root = _git_root()
    if not root:
        return []
    body = _ticket_body(tid)
    if not body:
        return []
    return _md_doc.resolve_refs(body, doc_dir=root, cwd=root, project_root=root)


def _ticket_md_prefix(tid):
    """The ``[md] References`` umbrella for ticket ``tid``, or ``[]``.

    Prepended above the ticket's subtasks when its body references any existing
    ``.md`` file (``_ticket_md_refs``). The umbrella is an expandable grouping
    row (``md_doc.references_umbrella``); its launcher children are built lazily
    when it expands (``_ticket_md_children``) — the body is scanned once here to
    decide whether to show it and again on expand to build the rows.
    """
    if _md_doc is None or not _ticket_md_refs(tid):
        return []
    return [_md_doc.references_umbrella(tid)]


def _ticket_md_children(tid):
    """Launcher rows under a ticket's ``[md] References`` umbrella.

    One ``[md ↗]`` row per resolving body ref (``_ticket_md_refs``), each
    carrying a ``('file', abspath)`` spec so ``on_enter`` opens the real file
    by path. Titled by the ref's display label; the anchor is the ticket id.
    """
    if _md_doc is None:
        return []
    return [_md_doc.launcher_row(tid, ('file', ab), label)
            for ab, label in _ticket_md_refs(tid)]


def _md_file_preview(launch_id):
    """Preview for a ``[md ↗]`` launcher row — the referenced file's contents.

    ``launch_id`` is ``('launch', tid, 'file', abspath)``; the file is read and
    rendered through the same markdown-coloring path as a ticket body. A
    spec we don't recognise, or an unreadable file, previews empty.
    """
    spec = launch_id[2:]
    if len(spec) != 2 or spec[0] != 'file':
        return ''
    try:
        with open(spec[1], encoding='utf-8', errors='replace') as f:
            return _render_md(f.read())
    except OSError as e:
        return f'(cannot read {spec[1]}: {e})'


# ---- actions -------------------------------------------------------------


def _selected_real_ids(ctx):
    """Return the targets, dropping the synthetic Project (id=0) entry.

    Status / move / etc. don't apply to the Project pseudo-ticket; we
    silently strip it so a stray space-select on row 0 doesn't cause
    a "no such ticket" error.
    """
    return [t.id for t in ctx.targets if t.id != 0]


def _action_status(ctx):
    """Pop a fzf-style picker, then run ``plan IDS status NEW`` on targets."""
    ids = _selected_real_ids(ctx)
    if not ids:
        return
    options = list(_KNOWN_STATUSES) + ['custom...']
    chosen = ctx.pick('status', options)
    if chosen is None:
        return
    if chosen == 'custom...':
        custom = ctx.input('Status: ')
        if custom is None:
            return
        custom = custom.strip()
        if not custom:
            return
        chosen = custom
    args = [str(i) for i in ids] + ['status', chosen]
    result = _run_plan(*args)
    if result.returncode != 0:
        ctx.error(result.stderr.strip() or 'status command failed')
        return
    # Patch the affected rows in place — preserves cursor + expansion.
    style = _STATUS_TAG_STYLE.get(chosen, '')
    ctx.update_data([upsert(i, None, tag=chosen, tag_style=style) for i in ids])


def _action_edit(ctx, recursive=False):
    """Open ``$EDITOR`` on the cursor ticket via ``plan edit``."""
    if ctx.cursor is None:
        return
    target = 'project' if ctx.cursor.id == 0 else str(ctx.cursor.id)
    cmd = _plan_argv() + ['edit']
    if recursive:
        cmd.append('-r')
    cmd.append(target)
    rc = ctx.run_external(cmd)
    if rc != 0:
        ctx.error(f'edit exited {rc}')
    elif _log_sink is not None:
        # ``edit`` shells out to ``$EDITOR`` (not ``_run_plan``), so log the
        # successful mutation here — concisely, without the noisy ``-e``.
        _log_sink(f'plan edit {"-r " if recursive else ""}{target}')
    ctx.refresh()


def _action_view(ctx, recursive=False):
    """Pipe ``plan get`` output into ``ctx.page`` (bat/less)."""
    if ctx.cursor is None:
        return
    cid = ctx.cursor.id
    if cid == 0:
        args = ('project', 'get')
    elif recursive:
        args = (str(cid), '-r', 'get')
    else:
        args = (str(cid), 'get')
    result = _run_plan(*args)
    if result.returncode != 0:
        ctx.error(result.stderr.strip() or 'view command failed')
        return
    ctx.page(result.stdout, lang='md')


def _action_create(ctx, recursive=False):
    """Enter insert mode; on confirm, ``plan create -e`` at the chosen position."""
    if ctx.cursor is None:
        return
    label = 'create -r' if recursive else 'create'

    def on_confirm(relation, dest_id):
        cmd = _plan_argv() + ['create', '-e']
        if recursive:
            cmd.append('-r')
        cmd.append(f'title="New ticket", move="{relation} {dest_id}"')
        rc = ctx.run_external(cmd)
        if rc != 0:
            ctx.error(f'create exited {rc}')
        elif _log_sink is not None:
            # ``create -e`` shells out to ``$EDITOR`` (not ``_run_plan``), so
            # log the successful mutation here — using the concise ``label``
            # rather than the noisy ``title=…, move=…`` expr.
            _log_sink(f'plan {label}')
        ctx.refresh()

    ctx.insert(label, on_confirm)


def _action_move(ctx):
    """Enter insert mode; on confirm, ``plan IDS move RELATION DEST``."""
    ids = _selected_real_ids(ctx)
    if not ids:
        return

    def on_confirm(relation, dest_id):
        if dest_id in ids:
            ctx.error('cannot move into self')
            return
        args = [str(i) for i in ids] + ['move', relation, str(dest_id)]
        result = _run_plan(*args)
        if result.returncode != 0:
            ctx.error(result.stderr.strip() or 'move command failed')
            return
        ctx.refresh()

    ctx.insert('move', on_confirm)


def _action_close(ctx):
    """``plan IDS close`` — closes the targets to status ``done``."""
    ids = _selected_real_ids(ctx)
    if not ids:
        return
    args = [str(i) for i in ids] + ['close']
    result = _run_plan(*args)
    if result.returncode != 0:
        ctx.error(result.stderr.strip() or 'close command failed')
        return
    # ``close`` (no resolution arg) always sets status to ``done``.
    style = _STATUS_TAG_STYLE.get('done', '')
    ctx.update_data([upsert(i, None, tag='done', tag_style=style) for i in ids])


def _action_reopen(ctx):
    """``plan IDS reopen`` — sets status back to ``open``."""
    ids = _selected_real_ids(ctx)
    if not ids:
        return
    args = [str(i) for i in ids] + ['reopen']
    result = _run_plan(*args)
    if result.returncode != 0:
        ctx.error(result.stderr.strip() or 'reopen command failed')
        return
    # ``reopen`` always sets status to ``open`` (per ``plan --help``).
    style = _STATUS_TAG_STYLE.get('open', '')
    ctx.update_data([upsert(i, None, tag='open', tag_style=style) for i in ids])


def _action_close_wontfix(ctx):
    """``plan IDS close wontfix`` behind a value-mapped Yes/No confirm.

    The destructive-class sibling of ``_action_close``: closing as ``wontfix``
    abandons the ticket, so it gates on a confirm (mapped to ``True``/``False``
    so the result is used directly) where the plain ``close`` does not. On
    confirm it reuses the same ``plan … close RESOLUTION`` mutation +
    ``update_data`` patch so the row's tag flips to ``wontfix`` in place.
    """
    ids = _selected_real_ids(ctx)
    if not ids:
        return
    n = len(ids)
    subject = f'ticket {ids[0]}' if n == 1 else f'{n} tickets'
    if not ctx.confirm(f'Close {subject} as wontfix?',
                       [('&Yes', True), ('&No', False)]):
        return
    args = [str(i) for i in ids] + ['close', 'wontfix']
    result = _run_plan(*args)
    if result.returncode != 0:
        ctx.error(result.stderr.strip() or 'close command failed')
        return
    style = _STATUS_TAG_STYLE.get('wontfix', '')
    ctx.update_data(
        [upsert(i, None, tag='wontfix', tag_style=style) for i in ids])


def _action_set_assignee(ctx):
    """Prompt for a name, then ``plan IDS mod set(assignee=…)`` on the targets.

    Assignee is a ticket attribute set via the ``mod`` (``~``) DSL verb —
    ``plan N mod 'set(assignee="alice")'`` (see ``plan help mod``). Cancelling
    the prompt is a no-op; an empty name CLEARS the assignee (``set(assignee="")``)
    rather than erroring. The tag column shows status (not assignee), so there
    is nothing to ``update_data`` — a ``refresh`` re-reads the affected rows so
    a later ``v``/preview reflects the change.
    """
    ids = _selected_real_ids(ctx)
    if not ids:
        return
    raw = ctx.input('Assignee (blank to clear): ')
    if raw is None:
        return
    name = raw.strip()
    args = [str(i) for i in ids] + ['mod', f'set(assignee="{name}")']
    result = _run_plan(*args)
    if result.returncode != 0:
        ctx.error(result.stderr.strip() or 'set assignee failed')
        return
    ctx.flash(f'assignee = {name!r}' if name else 'assignee cleared', log=True)
    ctx.refresh()


def _action_add_comment(ctx):
    """Prompt for comment text, then ``plan IDS comment add TEXT`` on the targets.

    Reuses the recipe's ``plan`` mutation path (``plan N comment add "…"`` — see
    ``plan help comment``). Cancelling the prompt, or entering blank/whitespace,
    is a no-op (no empty comment). Comments don't show in the row, so a
    ``refresh`` (not ``update_data``) is enough for the body/preview to pick the
    new comment up.
    """
    ids = _selected_real_ids(ctx)
    if not ids:
        return
    raw = ctx.input('Comment: ')
    if raw is None or not raw.strip():
        return
    args = [str(i) for i in ids] + ['comment', 'add', raw.strip()]
    result = _run_plan(*args)
    if result.returncode != 0:
        ctx.error(result.stderr.strip() or 'add comment failed')
        return
    ctx.flash('comment added', log=True)
    ctx.refresh()


def _one_other_ticket(ctx):
    """The id of the single OTHER selected ticket, or ``None``.

    Gates the menu's "Move under selected" entry: enabled only when exactly one
    ticket OTHER than the cursor's is selected (the synthetic Project id=0 is
    excluded). Zero or two-plus other tickets (ambiguous) yields ``None`` and
    the entry is omitted. Mirrors browse-git's ``_one_other_commit`` gate.
    """
    if ctx.cursor is None:
        return None
    cursor_id = ctx.cursor.id
    others = [it.id for it in ctx.selected if it.id not in (0, cursor_id)]
    return others[0] if len(others) == 1 else None


def _action_move_under_selected(ctx):
    """Re-parent the cursor ticket as the last child of the one selected ticket.

    Reuses the recipe's ``plan … move`` mutation (``plan N move last DEST`` —
    reparent, see ``plan help move``) rather than insert mode: the destination
    is already chosen (the single OTHER selected ticket, ``_one_other_ticket``),
    so no placement marker is needed. A guarded no-op when the gate no longer
    holds (selection changed between menu-build and dispatch).
    """
    if ctx.cursor is None:
        return
    dest = _one_other_ticket(ctx)
    if dest is None:
        ctx.flash('select exactly one other ticket to move under')
        return
    result = _run_plan(str(ctx.cursor.id), 'move', 'last', str(dest))
    if result.returncode != 0:
        ctx.error(result.stderr.strip() or 'move command failed')
        return
    ctx.refresh()


# ---- context menu --------------------------------------------------------
#
# Following the committed recipe convention (browse-ps pilot, browse-git /
# browse-claude): a PURE ``context_menu_options(ctx)`` builds the ``(label,
# token)`` rows (opening no modal, so it is unit-testable), a flat ``{token:
# handler}`` table (``_MENU_ACTIONS``) dispatches the chosen token, and a thin
# ``on_context_menu(ctx)`` ties the two together. The per-row actions REUSE the
# recipe's existing action handlers (``_action_status`` / ``_action_close`` /
# … — each reads ``ctx.cursor`` / ``ctx.targets`` itself), so the menu rows
# stay single-sourced with the keybindings; the rows that duplicate a hotkey
# carry the LITERAL hint in parens (menus don't parse ``&``). The Move row's
# hint tracks the same md2ansi gating as the ``m``/``M`` keybinding (``m`` is
# the move key by default, ``M`` when md2ansi rebinds ``m`` to the coloring
# toggle). "Close as wontfix" is the one destructive addition — it confirms.
# "Move under selected" appears only when exactly one OTHER ticket is selected.


def _move_hotkey():
    """The literal hotkey the Move action is bound to: ``M`` or ``m``.

    Mirrors ``main``'s keybinding gate — when md2ansi_lib is importable ``m``
    is the markdown-coloring toggle and Move shifts to ``M``; otherwise Move
    keeps ``m``. Kept in lock-step so the menu hint never disagrees with the
    real keybinding.
    """
    return 'M' if _md2ansi_fn is not None else 'm'


_MENU_ACTIONS = {
    'status':       _action_status,
    'assignee':     _action_set_assignee,
    'comment':      _action_add_comment,
    'close':        _action_close,
    'reopen':       _action_reopen,
    'wontfix':      _action_close_wontfix,
    'edit':         lambda ctx: _action_edit(ctx),
    'edit.sub':     lambda ctx: _action_edit(ctx, True),
    'view':         lambda ctx: _action_view(ctx),
    'view.sub':     lambda ctx: _action_view(ctx, True),
    'child':        lambda ctx: _action_create(ctx),
    'children':     lambda ctx: _action_create(ctx, True),
    'move':         _action_move,
    'move.under':   _action_move_under_selected,
}


def context_menu_options(ctx):
    """``(label, token)`` rows for the browse-plan ticket context menu (pure).

    Opens no modal — it inspects ``ctx.cursor`` / ``ctx.selected`` and returns
    the entries; the token half is dispatched by ``_MENU_ACTIONS`` /
    ``on_context_menu``. Returns ``[]`` for a non-ticket row: no cursor, the
    synthetic Project (id=0), or a markdown launcher / umbrella (tuple id) —
    those have no ticket mutations. Rows duplicating a keybinding carry the
    literal hotkey in parens (``s`` / ``x`` / ``o`` / ``e`` / ``E`` / ``v`` /
    ``V`` / ``c`` / ``C`` and Move's ``m``/``M`` per ``_move_hotkey``). The
    final "Move under selected" row is added only when exactly one OTHER ticket
    is selected (``_one_other_ticket``).
    """
    item = ctx.cursor
    if item is None or not isinstance(item.id, int) or item.id == 0:
        return []
    move = _move_hotkey()
    rows = [
        ('Change status… (s)', 'status'),
        ('Set assignee…', 'assignee'),
        ('Add comment…', 'comment'),
        ('Close (x)', 'close'),
        ('Reopen (o)', 'reopen'),
        ('Close as wontfix', 'wontfix'),
        ('Edit body (e)', 'edit'),
        ('Edit subtree (E)', 'edit.sub'),
        ('View (v)', 'view'),
        ('View subtree (V)', 'view.sub'),
        ('Add child… (c)', 'child'),
        ('Add children… (C)', 'children'),
        (f'Move… ({move})', 'move'),
    ]
    if _one_other_ticket(ctx) is not None:
        rows.append(('Move under selected', 'move.under'))
    return rows


def on_context_menu(ctx):
    """Open the ticket context menu and dispatch the chosen entry.

    The hook the framework fires on right-click / `` ` ``-F1: build the (pure)
    option list, open it with ``ctx.menu``, and route the chosen token through
    ``_MENU_ACTIONS``. A cancel (``None``) or an empty list is a no-op; the
    handlers read ``ctx.cursor`` / ``ctx.targets`` themselves.
    """
    token = ctx.menu(context_menu_options(ctx))
    handler = _MENU_ACTIONS.get(token)
    if handler is not None:
        handler(ctx)


# ---- key handlers --------------------------------------------------------


def on_enter(ctx):
    """Launch a ``[md ↗]`` row, else flip expand/collapse; NEVER prints the id.

    browse-plan is a BROWSER, not a picker — without this handler the framework
    default (``print-exit``) would print the cursor id and quit on Enter. Here
    a launcher row (id ``('launch', tid, 'file', abspath)``) opens its target
    file in browse-md via ``md_doc.launch`` (anchored ``--root`` on the git
    root so links inside the opened document resolve against the repo); every
    other row keeps the expand/collapse toggle (mirroring browse-git's
    ``on_enter``): leaves are a no-op, and a second Enter on an open row folds
    it back up (``ctx.state.expanded`` is the open-id set in the current scope).
    """
    item = ctx.cursor
    if item is None:
        return
    if isinstance(item.id, tuple) and item.id and item.id[0] == 'launch':
        _md_launch(ctx, item.id[2:])
        return
    if not item.has_children:
        return
    if item.id in ctx.state.expanded:
        ctx.collapse(item.id)
    else:
        # User-driven navigation — autoscroll the newly-revealed children
        # into view, matching the built-in Right-arrow handler.
        ctx.expand(item.id, autoscroll=True)


def _md_launch(ctx, spec):
    """Open the document a launcher-row ``spec`` points at in browse-md.

    ``spec`` is the opaque tuple this recipe encoded onto the launcher id
    (``id[2:]``): ``('file', abspath)`` — a plan ref is a real on-disk file, so
    it opens by path. ``--root`` is the git root so references inside the
    opened document resolve the same way they do in the repo. A guarded no-op
    when md_doc is unavailable or the spec is unrecognised.
    """
    if _md_doc is None or len(spec) != 2 or spec[0] != 'file':
        return
    root = _git_root()
    roots = (root,) if root else ()
    _md_doc.launch(ctx, path=spec[1], roots=roots)


def _on_children_loaded(ctx, parent_ids):
    """Retract a leaf ticket's optimistic arrow once its expand builds empty.

    A leaf ticket carries an OPTIMISTIC expansion arrow (``_parse_ticket_line``,
    when md_doc is importable) because its body — the only place a ``[md]
    References`` umbrella could come from — is not read at listing time. When
    such a ticket settles to NO children (no subtasks AND no resolving body
    refs), push a ``mod(id, has_children=False)`` so the arrow disappears on
    next render, mirroring the browse-claude / browse-fs self-heal. A ticket
    with real children (subtasks or the umbrella) keeps its arrow; the umbrella
    itself is built only when a ref exists, so it never lands empty. No-op when
    md_doc is absent (no optimistic arrows were set) or the children aren't
    cached / are non-empty.
    """
    if _md_doc is None:
        return
    for pid in parent_ids:
        # Only plain int ticket ids carry the optimistic arrow; the umbrella
        # (a tuple id) is never empty, so leave tuple ids untouched.
        if not isinstance(pid, int):
            continue
        if ctx.cached_children(pid) == []:
            ctx.update_data([mod(pid, has_children=False)])


# ---- entry point ---------------------------------------------------------


_HELP_USAGE = """\
Usage: browse-plan [-f FILE] [TICKET_ID]
  -f FILE      Plan file to operate on (passed through to ``plan -f FILE``).
  --file FILE  Long alias for -f.
  TICKET_ID    Numeric ticket id to drill into on launch (sets the initial
               scope). Without an id, the tree opens at the project root.\
"""


_HELP_INTRO = """\
browse-plan — drop-in replacement for plan-tui on the browse-tui core.

Browse the active plan-CLI tree by status, drill into subtrees, edit
or view tickets, and bulk-pick statuses across selections. The cursor
or selection seeds the actions below; the recipe shells out to the
``plan`` CLI so the on-disk format stays single-sourced.

Right-click a ticket (or the backslash / F1 keys) for a menu mirroring
the keybindings — change status, close / reopen, edit / view (subtree
too), add child / children, move — plus set assignee, add comment,
close as wontfix (confirmed), and, when exactly one other ticket is
selected, move the cursor ticket under it.\
"""


def _pop_file_arg():
    """Pop ``-f FILE`` / ``--file FILE`` (and ``=FILE``) from sys.argv.

    Returns the file path or ``None``. Mutates ``sys.argv`` in place so
    the positional TICKET_ID parser below sees a clean argv.
    """
    i = 1
    while i < len(sys.argv):
        a = sys.argv[i]
        if a in ('-f', '--file'):
            if i + 1 >= len(sys.argv):
                sys.stderr.write(f'browse-plan: {a} requires a FILE argument\n')
                sys.exit(2)
            value = sys.argv[i + 1]
            del sys.argv[i:i + 2]
            return value
        if a.startswith('-f=') or a.startswith('--file='):
            value = a.split('=', 1)[1]
            del sys.argv[i]
            return value
        i += 1
    return None


def main():
    global _BROWSER, _PLAN_FILE, _log_sink
    _PLAN_FILE = _pop_file_arg()
    initial_scope = None
    # Read the ticket-id positional from ``recipe_argv()`` so the framework's
    # ``--tty`` flag (and its value) is dropped first: ``Browser.run()``
    # auto-detects ``--tty`` but leaves it in ``sys.argv``, so a leading
    # ``--tty -`` / ``--tty /dev/pts/N`` would otherwise shadow (or be
    # misread as) the ticket id. A flag-shaped token (e.g. -h / --help) is
    # skipped — Browser.run()'s auto-detect short-circuits to recipe-aware
    # help, and parsing '--help' as an int would give a misleading
    # "invalid ticket id" error.
    args = recipe_argv()
    if args and not args[0].startswith('-'):
        try:
            initial_scope = int(args[0])
        except ValueError:
            sys.stderr.write(f'browse-plan: invalid ticket id {args[0]!r}\n')
            sys.exit(2)

    # 'm' is the move action by default; when md2ansi_lib is available we
    # rebind it to a coloured / raw toggle, and move shifts to 'M'.
    if _md2ansi_fn is not None:
        move_key, move_label = 'M', 'Move (re-parent or reorder)'
        toggle_action = [Action('m', 'Toggle markdown coloring', _action_toggle_md, 'none')]
    else:
        move_key, move_label = 'm', 'Move (re-parent or reorder)'
        toggle_action = []

    b = Browser(BrowserConfig(
        title='browse-plan',
        get_children=get_children,
        get_preview=get_preview,
        root_id=None,
        initial_scope=initial_scope,
        actions=[
            Action('s', 'Change status (fzf-style picker)',     _action_status,                        'targets'),
            Action('e', 'Edit ticket body',                     lambda ctx: _action_edit(ctx),         'cursor'),
            Action('E', 'Edit ticket body (recursive subtree)', lambda ctx: _action_edit(ctx, True),   'cursor'),
            Action('v', 'View ticket (rendered)',               lambda ctx: _action_view(ctx),         'cursor'),
            Action('V', 'View ticket recursively',              lambda ctx: _action_view(ctx, True),   'cursor'),
            Action('c', 'Create child ticket',                  lambda ctx: _action_create(ctx),       'cursor'),
            Action('C', 'Create children in bulk',              lambda ctx: _action_create(ctx, True), 'cursor'),
            Action(move_key, move_label,                        _action_move,                          'targets'),
            Action('x', 'Close ticket',                         _action_close,                         'targets'),
            Action('o', 'Reopen closed ticket',                 _action_reopen,                        'targets'),
        ] + toggle_action,
        # Enter is a browser action here, NOT the picker default: a ``[md ↗]``
        # launcher row opens its file in browse-md, every other row toggles
        # expand/collapse — Enter never prints the id and quits.
        on_enter=on_enter,
        # Right-click (or the backslash / F1 keys) on a ticket row opens a menu
        # mirroring the keybindings (status / close / reopen / edit / view /
        # add child / move) plus set-assignee, add-comment, close-as-wontfix,
        # and (when one other ticket is selected) move-under-selected. See
        # ``on_context_menu``.
        on_context_menu=on_context_menu,
        # Retract a leaf ticket's optimistic arrow when its expand reveals
        # neither subtasks nor body ``.md`` refs (the self-heal).
        on_children_loaded=_on_children_loaded,
        help_usage=_HELP_USAGE,
        help_intro=_HELP_INTRO,
    ))
    _BROWSER = b
    # Route the plan-CLI audit trail (mutations + failures) into the
    # framework message log; ``Browser.log`` is thread-safe. The ``~``
    # default action pages it.
    _log_sink = b.log
    sys.exit(b.run())


if __name__ == '__main__':
    main()
