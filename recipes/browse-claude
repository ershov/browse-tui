# ---- get_preview ---------------------------------------------------------


def get_preview(item_id):
    """Preview-pane content for the cursor item.

    * project (dir):       human-readable summary + session list
    * session (file):      first 20 lines of the .jsonl (truncated)
    * subagent (#agent:X): meta.json + first-prompt preview
    * message (#N):        pretty-printed JSON of the line
    """
    if not isinstance(item_id, str) or item_id.startswith('__err__:'):
        return ''
    if '#agent:' in item_id:
        return _preview_subagent(item_id)
    if '#' in item_id:
        path, _, lineno = item_id.rpartition('#')
        if lineno == '__truncated__':
            return (
                f'(only the first {_message_limit} messages are listed)\n'
                f'press e on this row to open the full file in $EDITOR'
            )
        try:
            n = int(lineno)
        except ValueError:
            return ''
        return _preview_message(path, n)
    if os.path.isdir(item_id):
        return _preview_project(item_id)
    if os.path.isfile(item_id) and item_id.endswith('.jsonl'):
        return _preview_session(item_id)
    return ''


def _preview_project(path):
    try:
        names = sorted(
            n for n in os.listdir(path) if n.endswith('.jsonl')
        )
    except OSError as e:
        return f'[error] {e}'
    header = (
        f'project: {_decode_project_path(os.path.basename(path))}\n'
        f'path:    {path}\n'
        f'\n{len(names)} session(s):'
    )
    body = '\n'.join(f'  {n}' for n in names[:1000])
    if len(names) > 50:
        body += f'\n  … and {len(names) - 50} more'
    return f'{header}\n{body}' if body else header


def _preview_session(path):
    """Structured session preview: metadata card + recent timeline.

    One pass over the .jsonl folds metadata records (titles, modes,
    permission state, PR link, worktree, counts) into a compact card,
    then renders the most recent ``_TIMELINE_TAIL`` events as one-liners.
    """
    try:
        meta, timeline_rows = _scan_session(path)
    except OSError as e:
        return f'[error] {e}'
    if not meta and not timeline_rows:
        return '(empty session)'
    return _fmt_session_card(meta) + '\n\n' + _fmt_timeline(timeline_rows)


# How many events to show in the timeline tail (first/last halves on
# longer sessions). Cheap to bump — the scan already walks the whole
# file; the cost is how much fits in the preview pane.
_TIMELINE_TAIL = 1000


def _scan_session(path):
    """Walk the .jsonl once. Return ``(meta_dict, timeline_rows)``.

    ``meta_dict`` collapses last-wins metadata (title, mode, permission)
    plus aggregates (counts, first/last timestamp, tags, etc.).
    ``timeline_rows`` is a list of ``(line_no, obj)`` for events worth
    showing in the timeline; metadata-only records are excluded so the
    timeline reads as "what happened" rather than "what got bookkept".
    """
    meta = {
        'path': path,
        'session_id': os.path.basename(path)[:-len('.jsonl')]
                      if path.endswith('.jsonl') else os.path.basename(path),
        'tags': [],
        'counts': {
            'total': 0, 'user': 0, 'assistant': 0,
            'tool_use': 0, 'tool_result': 0, 'attachment': 0,
            'system': 0, 'errors': 0, 'subagent_msgs': 0,
        },
    }
    timeline = []
    first_ts = None
    last_ts = None
    with open(path, 'r', encoding='utf-8', errors='replace') as f:
        for n, line in enumerate(f):
            line = line.rstrip('\n')
            if not line.strip():
                continue
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                continue
            if not isinstance(obj, dict):
                continue
            t = obj.get('type')
            ts = obj.get('timestamp')
            if ts:
                first_ts = first_ts or ts
                last_ts = ts
            meta['counts']['total'] += 1
            if obj.get('isSidechain'):
                meta['counts']['subagent_msgs'] += 1

            # Last-wins metadata
            if t == 'custom-title':
                meta['custom_title'] = obj.get('customTitle', '')
            elif t == 'ai-title':
                meta['ai_title'] = obj.get('aiTitle', '')
            elif t == 'last-prompt':
                meta['last_prompt'] = obj.get('lastPrompt', '')
            elif t == 'tag':
                tag = obj.get('tag')
                if tag and tag not in meta['tags']:
                    meta['tags'].append(tag)
            elif t == 'agent-name':
                meta['agent_name'] = obj.get('agentName', '')
            elif t == 'agent-color':
                meta['agent_color'] = obj.get('agentColor', '')
            elif t == 'agent-setting':
                meta['agent_setting'] = obj.get('agentSetting', '')
            elif t == 'permission-mode':
                meta['permission_mode'] = obj.get('permissionMode', '')
            elif t == 'mode':
                meta['mode'] = obj.get('mode', '')
            elif t == 'pr-link':
                meta['pr'] = {
                    'repo':   obj.get('prRepository', ''),
                    'number': obj.get('prNumber', ''),
                    'url':    obj.get('prUrl', ''),
                }
            elif t == 'worktree-state':
                meta['worktree'] = obj.get('worktreeSession')
            elif t == 'task-summary':
                meta['task_summary'] = obj.get('summary', '')
            elif t == 'summary':
                meta['summary'] = obj.get('summary', '')

            # Aggregate counts on conversation records
            if t == 'user':
                meta['counts']['user'] += 1
                content = (obj.get('message') or {}).get('content')
                if isinstance(content, list):
                    if any(isinstance(p, dict) and p.get('type') == 'tool_result'
                           for p in content):
                        meta['counts']['tool_result'] += 1
                timeline.append((n, obj))
            elif t == 'assistant':
                meta['counts']['assistant'] += 1
                content = (obj.get('message') or {}).get('content')
                if isinstance(content, list):
                    if any(isinstance(p, dict) and p.get('type') == 'tool_use'
                           for p in content):
                        meta['counts']['tool_use'] += 1
                timeline.append((n, obj))
            elif t == 'attachment':
                meta['counts']['attachment'] += 1
                timeline.append((n, obj))
            elif t == 'system':
                meta['counts']['system'] += 1
                if obj.get('subtype') == 'api_error':
                    meta['counts']['errors'] += 1
                timeline.append((n, obj))
            # metadata records are NOT added to the timeline — they're
            # already folded into the card above.

    meta['first_ts'] = first_ts
    meta['last_ts'] = last_ts

    # Pick the timeline to display: last N events, since the cursor's
    # most common need is "what happened recently".
    return meta, timeline[-_TIMELINE_TAIL:]


# ---- tree builder (#299) -------------------------------------------------
#
# Tree mode rebuilds the in-session children listing as an actual tree
# instead of a reverse-time flat list. The structure follows ``parentUuid``
# (the only field that gives reliable chain integrity across every
# record type — see /promptId investigation notes), with one wrinkle:
# user prompts get their own ``promptId``; when a child's
# ``inheritedPromptId`` (= own pid OR parent's pid) differs from its
# parent's, the parent link is broken and the child becomes a turn-root
# at the top level. That nests each turn cleanly under its prompt while
# keeping all the non-voice metadata records as siblings at root.
#
# The scan is cached per (path, mtime); subsequent calls within one
# session are O(1). ``_TREE_CACHE`` clears entries whose mtime no longer
# matches so files mutated between calls re-scan transparently.


_TREE_CACHE = {}   # path → (mtime, TreeData)
_TREE_MODE = False  # global view-mode toggle; flipped by --tree / 't' action


_TREE_METADATA_TYPES = frozenset([
    # records that show up as their own roots — they carry no
    # parentUuid and don't participate in the conversation chain.
    'summary', 'ai-title', 'custom-title', 'last-prompt', 'task-summary',
    'tag', 'agent-name', 'agent-color', 'agent-setting', 'pr-link',
    'mode', 'permission-mode', 'worktree-state', 'content-replacement',
    'file-history-snapshot', 'attribution-snapshot', 'speculation-accept',
    'queue-operation', 'marble-origami-commit', 'marble-origami-snapshot',
    'progress',
])


class _TreeData:
    """Cached tree-structure view of one ``.jsonl`` file.

    The shape is span-based and ignores ``parentUuid`` for structure.
    ``parentUuid`` is just a write-time linked-list back-pointer (see
    ``sessionStorage.ts:1066`` in claude-code: ``parentUuid =
    message.uuid`` after every chain-participant append). Using it
    literally as a tree parent produces 15-deep cascades of attachments
    under tool_results under attachments. The actual conversation
    structure is way flatter:

      * The session is a flat sequence of "turns" interleaved with
        runs of out-of-turn metadata.
      * A turn opens at a "user voice" record (user record carrying
        text content, not a tool_result; not ``isMeta``) and closes at
        the next ``system/turn_duration`` record (or at the next user
        voice, whichever comes first).
      * Everything between open/close is a turn member.
      * Anything outside a turn — preamble, gaps between turns, file
        tail — gets folded into a synthetic ``<system>`` umbrella span
        so the top level doesn't blow up with one row per metadata
        record.

    Inside a turn, only two semantic relationships are nested:

      * tool execution group: an assistant record with a ``tool_use``
        content part becomes the parent of (a) the matching user
        tool_result (paired via ``tool_use_id``), (b) any attachment
        records carrying a matching ``toolUseID`` (PreToolUse/
        PostToolUse hook outputs), and (c) for Agent/Task tool_uses,
        the subagent pseudo-row.
      * subagent inline: the subagent's own ``.jsonl`` becomes a
        recursive subtree under the assistant's tool_use row.

    Fields:

    * ``records``         — parsed records in file order, indices
                            align with line numbers.
    * ``by_uuid``         — ``{uuid: record}``.
    * ``line_of``         — ``{uuid: line_number}``.
    * ``roots_in_order``  — list of root-entry dicts in file order:
                            ``{'kind':'turn','rec':<r>,'line':n}`` or
                            ``{'kind':'span','start':n,'records':[…]}``.
    * ``turn_direct``     — ``{turn_root_uuid: [recs]}`` — turn members
                            that render directly under the turn (i.e.,
                            NOT records that got re-parented under a
                            tool_use as part of the tool execution group).
    * ``tool_children``   — ``{assistant_uuid: [recs]}`` — the
                            tool_result + hook attachments + isMeta
                            back-pointers that pair with this assistant
                            record's tool_use part. Drives the second
                            layer of nesting inside a turn.
    * ``span_records``    — ``{span_start_line: [recs]}`` — members of
                            each ``<system>`` umbrella.
    * ``agent_link``      — ``{tool_use_id: {agent_id, agent_path,
                            assistant_uuid}}`` for every Agent/Task
                            tool_use whose tool_result resolved a
                            subagent .jsonl on disk.

    Per-record attrs:
      * ``rec['_tree_forked_from']`` — record explicitly forked from
        an earlier uuid (``forkedFrom`` field).
    """

    __slots__ = ('records', 'by_uuid', 'line_of', 'roots_in_order',
                 'turn_direct', 'tool_children', 'span_records',
                 'agent_link', 'records_line', 'parent_id_of')

    def __init__(self):
        self.records = []
        self.by_uuid = {}
        self.line_of = {}
        self.roots_in_order = []
        self.turn_direct = {}
        self.tool_children = {}
        self.span_records = {}
        self.agent_link = {}
        # id(rec) → line_no — looking up the line of a record without
        # needing a uuid (metadata records often have none).
        self.records_line = {}
        # line_no → parent_id (``<jsonl>#<n>`` or ``<jsonl>#span:<n>``)
        # for tree-ancestor walks. Top-level rows (turn-roots, span
        # umbrellas) are absent.
        self.parent_id_of = {}


def _is_turn_root(rec):
    """A turn root is a fresh user prompt — text content, not synthetic."""
    if not isinstance(rec, dict):
        return False
    if rec.get('type') != 'user':
        return False
    if rec.get('isMeta'):
        return False
    return _is_voice(rec)


def _is_turn_close(rec):
    """``system/turn_duration`` is the post-turn marker."""
    return (isinstance(rec, dict)
            and rec.get('type') == 'system'
            and rec.get('subtype') == 'turn_duration')


def _scan_tree(path):
    """Return cached ``_TreeData`` for ``path``; (re)scan on mtime change."""
    try:
        mtime = os.stat(path).st_mtime
    except OSError:
        return _TreeData()
    cached = _TREE_CACHE.get(path)
    if cached and cached[0] == mtime:
        return cached[1]

    td = _TreeData()
    try:
        f = open(path, 'r', encoding='utf-8', errors='replace')
    except OSError:
        _TREE_CACHE[path] = (mtime, td)
        return td
    with f:
        for n, line in enumerate(f):
            line = line.rstrip('\n')
            if not line.strip():
                td.records.append(None)
                continue
            try:
                rec = json.loads(line)
            except json.JSONDecodeError:
                td.records.append(None)
                continue
            if not isinstance(rec, dict):
                td.records.append(None)
                continue
            td.records.append(rec)
            td.records_line[id(rec)] = n
            uuid = rec.get('uuid')
            if uuid:
                td.by_uuid[uuid] = rec
                td.line_of[uuid] = n
            if rec.get('forkedFrom'):
                rec['_tree_forked_from'] = rec['forkedFrom']

    # Walk file order; partition records into spans (no open turn) vs
    # turn members.
    turn_open_uuid = None
    turn_members_buf = {}    # turn_uuid → [recs] (collected here, later
                             #   split into turn_direct + tool_children)
    span_start = None
    span_buf = []

    def _close_span():
        nonlocal span_start, span_buf
        if span_buf:
            td.span_records[span_start] = list(span_buf)
            td.roots_in_order.append({
                'kind': 'span',
                'start': span_start,
                'records': list(span_buf),
            })
        span_start = None
        span_buf = []

    for n, rec in enumerate(td.records):
        if rec is None:
            continue
        if _is_turn_root(rec):
            _close_span()
            turn_open_uuid = rec.get('uuid')
            if turn_open_uuid:
                turn_members_buf[turn_open_uuid] = []
            td.roots_in_order.append({
                'kind': 'turn', 'rec': rec, 'line': n,
            })
        elif turn_open_uuid is not None:
            turn_members_buf[turn_open_uuid].append(rec)
            if _is_turn_close(rec):
                turn_open_uuid = None
        else:
            if span_start is None:
                span_start = n
            span_buf.append(rec)
    _close_span()

    # Tool execution grouping inside each turn. For every turn, build
    # ``tool_owner: tool_use_id → assistant_uuid`` from the assistant
    # records with tool_use content parts. Then partition members:
    # records that back-point at a known tool_use get re-parented;
    # everything else stays as a direct child of the turn root.
    for turn_uuid, members in turn_members_buf.items():
        tool_owner = {}
        for m in members:
            if m.get('type') != 'assistant':
                continue
            msg = m.get('message')
            if not isinstance(msg, dict):
                continue
            content = msg.get('content')
            if not isinstance(content, list):
                continue
            for p in content:
                if (isinstance(p, dict)
                        and p.get('type') == 'tool_use'
                        and p.get('id')):
                    tool_owner[p['id']] = m.get('uuid')

        direct = []
        for m in members:
            owner = None

            # (1) user tool_result content: tool_use_id back-pointer.
            mmsg = m.get('message')
            if isinstance(mmsg, dict):
                mcontent = mmsg.get('content')
                if isinstance(mcontent, list):
                    for p in mcontent:
                        if (isinstance(p, dict)
                                and p.get('type') == 'tool_result'):
                            tu = p.get('tool_use_id')
                            if tu in tool_owner:
                                owner = tool_owner[tu]
                                break

            # (2) attachment with toolUseID — hook outputs.
            if owner is None and m.get('type') == 'attachment':
                att = m.get('attachment')
                if isinstance(att, dict):
                    tu = att.get('toolUseID')
                    if tu in tool_owner:
                        owner = tool_owner[tu]

            # (3) records with explicit back-pointer fields (synthetic
            # tool-followup user rows etc).
            if owner is None:
                tu = m.get('sourceToolUseID')
                if tu in tool_owner:
                    owner = tool_owner[tu]

            if owner is not None:
                td.tool_children.setdefault(owner, []).append(m)
            else:
                direct.append(m)
        td.turn_direct[turn_uuid] = direct

    # Subagent link: for every assistant record with an Agent/Task
    # tool_use whose tool_children contain a matching tool_result whose
    # toolUseResult.agentId resolves to a sibling subagent .jsonl,
    # record the join. Used by ``_list_tree_children`` to attach the
    # subagent pseudo-row under the assistant.
    sub_dir = _subagents_dir(path)
    for rec in td.records:
        if rec is None or rec.get('type') != 'assistant':
            continue
        msg = rec.get('message')
        if not isinstance(msg, dict):
            continue
        content = msg.get('content')
        if not isinstance(content, list):
            continue
        for p in content:
            if not (isinstance(p, dict)
                    and p.get('type') == 'tool_use'
                    and p.get('name') in ('Agent', 'Task')):
                continue
            tu_id = p.get('id')
            for child in td.tool_children.get(rec.get('uuid'), []):
                cmsg = child.get('message')
                if not isinstance(cmsg, dict):
                    continue
                ccontent = cmsg.get('content')
                if not isinstance(ccontent, list):
                    continue
                for cp in ccontent:
                    if (isinstance(cp, dict)
                            and cp.get('type') == 'tool_result'
                            and cp.get('tool_use_id') == tu_id):
                        tur = child.get('toolUseResult')
                        agent_id = (tur.get('agentId')
                                    if isinstance(tur, dict) else None)
                        if agent_id:
                            agent_path = os.path.join(
                                sub_dir, f'agent-{agent_id}.jsonl',
                            )
                            if os.path.isfile(agent_path):
                                td.agent_link[tu_id] = {
                                    'agent_id': agent_id,
                                    'agent_path': agent_path,
                                    'assistant_uuid': rec.get('uuid'),
                                }

    # parent_id_of: maps each record's line → its tree-parent id.
    # Used by ``_ancestor_ids_for`` for cursor-on-open and t-toggle's
    # walk-up-and-expand. Top-level entries (turn-roots, span umbrellas)
    # are absent from this map by design (they have no parent).
    for turn_uuid, members in td.turn_direct.items():
        turn_line = td.line_of.get(turn_uuid)
        if turn_line is None:
            continue
        parent_id = f'{path}#{turn_line}'
        for m in members:
            line = td.records_line.get(id(m))
            if line is not None:
                td.parent_id_of[line] = parent_id
    for owner_uuid, kids in td.tool_children.items():
        owner_line = td.line_of.get(owner_uuid)
        if owner_line is None:
            continue
        parent_id = f'{path}#{owner_line}'
        for k in kids:
            line = td.records_line.get(id(k))
            if line is not None:
                td.parent_id_of[line] = parent_id
    for span_start, recs in td.span_records.items():
        parent_id = f'{path}#span:{span_start}'
        for r in recs:
            line = td.records_line.get(id(r))
            if line is not None:
                td.parent_id_of[line] = parent_id

    _TREE_CACHE[path] = (mtime, td)
    return td


def _last_voice_id(jsonl_path):
    """Return ``<jsonl>#<n>`` id of the most-recent voice record, or None.

    "Voice" matches ``_is_voice`` (user prompt or assistant text). Walks
    records in REVERSE file order so the latest wins. Used for the
    cursor-on-open and the t-toggle landing point.
    """
    td = _scan_tree(jsonl_path)
    for n in range(len(td.records) - 1, -1, -1):
        rec = td.records[n]
        if rec is not None and _is_voice(rec):
            return f'{jsonl_path}#{n}'
    return None


def _list_tree_roots(jsonl_path):
    """Tree-mode listing for a session: root-level rows in file order.

    Each entry is either a turn-root (user voice) or a ``<system>``
    umbrella collapsing a contiguous run of metadata records.
    """
    td = _scan_tree(jsonl_path)
    out = []
    for entry in td.roots_in_order:
        if entry['kind'] == 'turn':
            it = _tree_item(jsonl_path, entry['rec'], td)
            if it is not None:
                out.append(it)
        else:   # 'span'
            out.append(_span_umbrella_item(
                jsonl_path, entry['start'], entry['records'],
            ))
    return out


def _list_tree_children(jsonl_path, line_no):
    """Children of one record in tree mode.

    Three cases, dispatched on ``rec``'s role in the structure:

    * **Turn root** (user voice) — children are ``turn_direct[uuid]``,
      i.e. the turn's flat members minus anything re-parented under a
      tool_use call.
    * **Assistant carrying a tool_use** — children are
      ``tool_children[uuid]`` (matched tool_result + hook attachments)
      plus a subagent pseudo-row if any Agent/Task tool_use in this
      assistant has a resolvable subagent.
    * **Everything else** — leaf, no children.
    """
    td = _scan_tree(jsonl_path)
    if not (0 <= line_no < len(td.records)):
        return []
    rec = td.records[line_no]
    if rec is None:
        return []
    out = []
    uuid = rec.get('uuid')

    # Case 1: turn root.
    if uuid and uuid in td.turn_direct:
        for child in td.turn_direct[uuid]:
            it = _tree_item(jsonl_path, child, td)
            if it is not None:
                out.append(it)
        return out

    # Case 2: assistant row whose tool_use(s) own paired children
    # and/or subagent dispatches.
    if rec.get('type') == 'assistant':
        for child in td.tool_children.get(uuid, []):
            it = _tree_item(jsonl_path, child, td)
            if it is not None:
                out.append(it)
        msg = rec.get('message') or {}
        if isinstance(msg, dict):
            content = msg.get('content') or []
            if isinstance(content, list):
                for p in content:
                    if (isinstance(p, dict)
                            and p.get('type') == 'tool_use'
                            and p.get('name') in ('Agent', 'Task')):
                        link = td.agent_link.get(p.get('id'))
                        if link:
                            out.append(_subagent_pseudo_item(
                                jsonl_path,
                                link['agent_id'], link['agent_path'],
                            ))
        return out

    return []


def _list_span_records(jsonl_path, start_line):
    """Children of a ``<system>`` umbrella: the records of one span."""
    td = _scan_tree(jsonl_path)
    out = []
    for rec in td.span_records.get(start_line, []):
        it = _tree_item(jsonl_path, rec, td)
        if it is not None:
            out.append(it)
    return out


def _tree_item(jsonl_path, rec, td):
    """Build a list-row ``Item`` for ``rec`` in tree mode.

    ``has_children`` is True iff the record is a turn root with members,
    or an assistant row that owns tool_children / a subagent dispatch.
    """
    n = td.line_of.get(rec.get('uuid'))
    if n is None:
        for i, r in enumerate(td.records):
            if r is rec:
                n = i
                break
    if n is None:
        return None
    kind = _kind_of(rec)
    uuid = rec.get('uuid')

    has_children = False
    if uuid and td.turn_direct.get(uuid):
        has_children = True
    elif rec.get('type') == 'assistant':
        if td.tool_children.get(uuid):
            has_children = True
        else:
            msg = rec.get('message') or {}
            if isinstance(msg, dict):
                content = msg.get('content') or []
                if isinstance(content, list):
                    for p in content:
                        if (isinstance(p, dict)
                                and p.get('type') == 'tool_use'
                                and p.get('name') in ('Agent', 'Task')
                                and p.get('id') in td.agent_link):
                            has_children = True
                            break

    item = Item(
        id=f'{jsonl_path}#{n}',
        title=_oneline(_summarise_message(rec)),
        tag=kind,
        tag_style=_TAG_STYLE_FOR_KIND.get(kind, ''),
        has_children=has_children,
    )
    item.kind = 'message'
    item.line_no = n
    item.session_path = jsonl_path
    item.message_kind = kind
    if _is_voice(rec):
        bg = _ROW_BG_FOR_KIND.get(kind)
        if bg is not None:
            item.row_bg = bg
    return item


def _span_umbrella_item(jsonl_path, start_line, records):
    """Synthetic ``<system>`` row collapsing a metadata span.

    Id shape: ``<jsonl>#span:<start_line>``. ``get_children`` routes
    that id to ``_list_span_records`` which returns the span's records
    as flat children. Title shows the count + dominant types so the
    row's still informative when collapsed.
    """
    from collections import Counter
    type_counts = Counter()
    for r in records:
        if not isinstance(r, dict):
            continue
        t = r.get('type', '?')
        if t == 'attachment':
            att = r.get('attachment') or {}
            sub = att.get('type', '') if isinstance(att, dict) else ''
            type_counts[f'att:{sub}'] += 1
        elif t == 'system':
            sub = r.get('subtype', '')
            type_counts[f'sys:{sub}' if sub else 'system'] += 1
        else:
            type_counts[t] += 1
    types_summary = ', '.join(
        f'{n}× {t}' if n > 1 else t
        for t, n in type_counts.most_common(4)
    )
    if len(type_counts) > 4:
        types_summary += ', …'

    item = Item(
        id=f'{jsonl_path}#span:{start_line}',
        title=f'<system>  {types_summary}',
        tag=f'{len(records)} records',
        tag_style='dim',
        has_children=len(records) > 0,
    )
    item.kind = 'span'
    item.span_start = start_line
    item.span_count = len(records)
    item.session_path = jsonl_path
    return item


def _subagent_pseudo_item(parent_jsonl, agent_id, agent_path):
    """Single-row Item representing a subagent under an assistant row.

    Same fields as the rows produced by ``_list_subagents_for_session``
    so the existing preview/edit handlers Just Work — only the parent
    in the tree changes.
    """
    sub_dir = _subagents_dir(parent_jsonl)
    meta = _read_subagent_meta(
        os.path.join(sub_dir, f'agent-{agent_id}.meta.json'),
    )
    agent_type = meta.get('agentType') or 'agent'
    description = meta.get('description') or ''
    title = description or f'agent {agent_id}'
    try:
        st = os.stat(agent_path)
        mtime = st.st_mtime
    except OSError:
        mtime = 0
    try:
        with open(agent_path, 'rb') as f:
            count = sum(1 for _ in f)
    except OSError:
        count = 0
    item = Item(
        id=f'{parent_jsonl}#agent:{agent_id}',
        title=title,
        tag=f'{agent_type} · {count} msg · {_human_time(mtime)}',
        tag_style='magenta',
        has_children=count > 0,
    )
    item.kind = 'subagent'
    item.agent_id = agent_id
    item.agent_type = agent_type
    item.agent_description = description
    item.session_path = parent_jsonl
    item.subagent_path = agent_path
    item.line_count = count
    item.mtime = mtime
    return item


def _fmt_session_card(m):
    """Compact metadata card for the session preview header.

    Used both for top-level sessions and for subagent transcripts —
    the latter populate ``session_id`` with ``"agent <id>"`` and may
    set ``agent_type`` / ``agent_description`` from the sidecar
    ``meta.json`` so those surface near the top of the card.
    """
    rows = []
    sid = m.get('session_id', '')
    rows.append(('session', f'{WHITE}{sid}{RESET}'))

    if m.get('agent_type'):
        rows.append(('type', f'{MAGENTA}{m["agent_type"]}{RESET}'))
    if m.get('agent_description'):
        rows.append(('desc', f'{WHITE}{m["agent_description"]}{RESET}'))

    title = m.get('custom_title') or m.get('ai_title')
    if title:
        rows.append(('title', f'{WHITE}{BOLD}{title}{RESET}'))

    chips = []
    # View-mode chip — make it obvious which listing the user is looking
    # at, especially since t-toggle silently changes the tree shape.
    view_chip = (f'{GREEN}[tree]{RESET}' if _TREE_MODE
                 else f'{MUTE}[flat]{RESET}')
    chips.append(view_chip)
    mode = m.get('mode')
    if mode:
        col = RED if mode == 'coordinator' else MUTE
        chips.append(f'{col}[{mode}]{RESET}')
    pmode = m.get('permission_mode')
    if pmode:
        col = _PERM_COLOR.get(pmode, MUTE)
        chips.append(f'{col}[{pmode}]{RESET}')
    if chips:
        rows.append(('mode', '  '.join(chips)))

    pr = m.get('pr')
    if pr:
        rows.append(('PR',
                     f'{WHITE}{pr["repo"]}#{pr["number"]}{RESET}  '
                     f'{BLUE}{pr["url"]}{RESET}'))

    wt = m.get('worktree')
    if wt is not None:
        if wt is None or wt == {}:
            rows.append(('worktree', f'{MUTE}(exited){RESET}'))
        elif isinstance(wt, dict):
            wpath = wt.get('worktreePath', '')
            wbranch = wt.get('worktreeBranch', '')
            rows.append(('worktree',
                         f'{CYAN}{wpath}{RESET}  '
                         f'{MUTE}@{RESET} {GREEN}{wbranch}{RESET}'))

    last_prompt = m.get('last_prompt')
    if last_prompt:
        snippet = _trim(last_prompt, 200)
        rows.append(('last', snippet))

    if m.get('tags'):
        rows.append(('tags', f'{YELLOW}{", ".join(m["tags"])}{RESET}'))

    if m.get('agent_name'):
        rows.append(('agent', f'{MAGENTA}{m["agent_name"]}{RESET}'))

    if m.get('task_summary'):
        snippet = _trim(m['task_summary'], 200)
        rows.append(('now', f'{ITAL}{snippet}{RESET}'))

    if m.get('summary'):
        snippet = _trim(m['summary'], 200)
        rows.append(('summary', snippet))

    if m.get('first_ts'):
        rows.append(('started', f'{MUTE}{m["first_ts"]}{RESET}'))
    if m.get('last_ts') and m.get('last_ts') != m.get('first_ts'):
        rows.append(('ended',   f'{MUTE}{m["last_ts"]}{RESET}'))

    c = m['counts']
    counts_line = (
        f'{c["total"]} msg · {c["user"]} user · {c["assistant"]} asst · '
        f'{c["tool_use"]} tool_use · {c["tool_result"]} tool_result · '
        f'{c["attachment"]} attach'
    )
    if c['errors']:
        counts_line += f'  {RED}· {c["errors"]} errors{RESET}'
    rows.append(('counts', counts_line))

    if c['subagent_msgs']:
        rows.append(('sidechain', f'{MUTE}{c["subagent_msgs"]} msgs{RESET}'))

    w = max(len(k) for k, _ in rows)
    indent = ' ' * (w + 2)   # label width + ':' + ' '
    return '\n'.join(
        f'{MUTE}{k.ljust(w)}:{RESET} {_indent_continuations(v, indent)}'
        for k, v in rows
    )


# Visible width of the ``L#### kind             `` prefix that
# ``_fmt_timeline`` emits. Used to indent multi-line titles so
# subsequent lines align under the title column.
#
#  ``L`` + 4-wide line number + ' ' + kind padded to 14 + ' ' = 21.
_TIMELINE_PREFIX_WIDTH = 21


def _fmt_timeline(rows):
    """Render the trailing events.

    Each event is one logical row, but if its summary spans multiple
    lines (multi-paragraph user prompts, tool stdout, structured diffs,
    …) those extra lines render flush-aligned under the title column
    rather than collapsed to a single space-separated blob.
    """
    if not rows:
        return f'{MUTE}(no events){RESET}'
    out = [_rule('timeline')]
    indent = ' ' * _TIMELINE_PREFIX_WIDTH
    for n, obj in rows:
        kind = _kind_of(obj)
        color = _KIND_HEADER_COLOR.get(kind, MUTE)
        title = _indent_continuations(_summarise_message(obj), indent)
        out.append(f'{MUTE}L{n+1:>4}{RESET} '
                   f'{color}{kind:<14}{RESET} {title}')
    return '\n'.join(out)


def _preview_subagent(item_id):
    """Preview a subagent group as a full session.

    The agent's ``.jsonl`` file is structurally identical to a top-level
    session transcript, so we reuse the same ``_scan_session`` +
    ``_fmt_session_card`` + ``_fmt_timeline`` pipeline. The only extras
    are the fields stored in ``agent-<id>.meta.json`` (agentType,
    description) which we layer onto the scanned metadata before
    rendering.
    """
    session_path, _, suffix = item_id.partition('#agent:')
    if not suffix:
        return ''
    agent_id = suffix
    sub_dir = _subagents_dir(session_path)
    agent_path = os.path.join(sub_dir, f'agent-{agent_id}.jsonl')
    sidecar = _read_subagent_meta(
        os.path.join(sub_dir, f'agent-{agent_id}.meta.json'),
    )
    try:
        meta, timeline_rows = _scan_session(agent_path)
    except OSError as e:
        return f'[error] {e}'
    # Surface the subagent-specific identity in the card. ``session_id``
    # for a top-level session is the .jsonl basename; for a subagent the
    # agent_id is what the user actually thinks of as "this thing".
    meta['session_id'] = f'agent {agent_id}'
    if sidecar.get('agentType'):
        meta['agent_type'] = sidecar['agentType']
    if sidecar.get('description'):
        meta['agent_description'] = sidecar['description']
    return _fmt_session_card(meta) + '\n\n' + _fmt_timeline(timeline_rows)


def _preview_message(path, n):
    """Per-line preview: classify the record, dispatch to a renderer.

    Each renderer returns a body str with ANSI inlined. The chrome
    footer (uuid, cwd, timestamp, …) is uniform and appended here.
    """
    obj = _read_jsonl_line(path, n)
    if obj is None:
        return ''
    if '__raw__' in obj:
        return f'{RED}[invalid json]{RESET} {obj["__raw__"]}'
    kind = _classify(obj)
    body = _RENDERERS.get(kind, _render_unknown)(obj)
    chrome = _fmt_chrome(obj)
    return body + ('\n' + chrome if chrome else '')


