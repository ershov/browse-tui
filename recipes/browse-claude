# ---- system rendering ----------------------------------------------------


def _render_system(obj):
    sub = obj.get('subtype') or ''
    if sub == 'turn_duration':
        ms = obj.get('durationMs', 0)
        return (f'{MUTE}⏱ turn{RESET}  '
                f'{WHITE}{ms/1000:.2f}s{RESET}  '
                f'{MUTE}· {obj.get("messageCount", 0)} msgs{RESET}')
    if sub == 'stop_hook_summary':
        return f'{GRAY}■ stop_hook_summary{RESET}'
    if sub == 'local_command':
        cmd = obj.get('content') or obj.get('command') or ''
        return f'{GRAY}$ {cmd}{RESET}'
    if sub == 'scheduled_task_fire':
        return f'{CYAN}⏲ scheduled fire{RESET}'
    if sub == 'api_error':
        try:
            body = json.dumps(obj, indent=2, ensure_ascii=False)
        except (TypeError, ValueError):
            body = str(obj)
        return f'{RED}{BOLD}‼ api_error{RESET}\n\n{RED}{body}{RESET}'
    return f'{GRAY}system{RESET}  {MUTE}{sub or "(no subtype)"}{RESET}'


# ---- metadata rendering --------------------------------------------------


def _render_metadata(obj):
    t = obj.get('type', '?')
    color = _KIND_HEADER_COLOR.get(t, MUTE)
    head = f'{color}{BOLD}{t}{RESET}'

    # Type-specific salient fields. Everything falls through to a generic
    # key/value dump of the remaining fields so power users still get the
    # full record.
    if t in ('ai-title', 'custom-title'):
        title = obj.get('aiTitle') or obj.get('customTitle') or ''
        return f'{head}\n\n{WHITE}{title}{RESET}'
    if t == 'last-prompt':
        return f'{head}\n\n{obj.get("lastPrompt", "")}'
    if t == 'task-summary':
        return f'{head}\n\n{obj.get("summary", "")}'
    if t == 'tag':
        return f'{head}  {YELLOW}{obj.get("tag", "")}{RESET}'
    if t == 'agent-name':
        return f'{head}  {MAGENTA}{obj.get("agentName", "")}{RESET}'
    if t == 'agent-color':
        return f'{head}  {obj.get("agentColor", "")}'
    if t == 'agent-setting':
        return f'{head}  {obj.get("agentSetting", "")}'
    if t == 'permission-mode':
        pm = obj.get('permissionMode', '')
        col = _PERM_COLOR.get(pm, MUTE)
        return f'{head}  {col}[{pm}]{RESET}'
    if t == 'mode':
        return f'{head}  {RED if obj.get("mode") == "coordinator" else MUTE}' \
               f'[{obj.get("mode", "")}]{RESET}'
    if t == 'pr-link':
        return (f'{head}\n\n'
                f'{WHITE}{obj.get("prRepository", "")}'
                f'#{obj.get("prNumber", "")}{RESET}\n'
                f'{BLUE}{obj.get("prUrl", "")}{RESET}\n'
                f'{MUTE}linked: {obj.get("timestamp", "")}{RESET}')
    if t == 'worktree-state':
        ws = obj.get('worktreeSession')
        if ws is None:
            return f'{head}  {MUTE}(exited){RESET}'
        return (f'{head}\n\n'
                f'{CYAN}{ws.get("worktreePath", "")}{RESET}  '
                f'{MUTE}@{RESET} {GREEN}{ws.get("worktreeBranch", "")}{RESET}\n'
                f'{MUTE}original:{RESET} {ws.get("originalCwd", "")} '
                f'{MUTE}(branch {ws.get("originalBranch", "")}){RESET}')
    if t == 'file-history-snapshot':
        snap = obj.get('snapshot') or {}
        n = len(snap) if isinstance(snap, dict) else '?'
        return (f'{head}  {MUTE}{n} files'
                f'{(" (update)" if obj.get("isSnapshotUpdate") else "")}{RESET}')
    if t == 'attribution-snapshot':
        states = obj.get('fileStates') or {}
        chars = sum(s.get('claudeContribution', 0)
                    for s in states.values() if isinstance(s, dict))
        return (f'{head}  {MUTE}{len(states)} files · '
                f'{chars:,} chars by Claude{RESET}')
    if t == 'content-replacement':
        rep = obj.get('replacements') or []
        agent = obj.get('agentId', '')
        return (f'{head}  {MUTE}{len(rep)} replacements'
                f'{(f" (agent={agent[:8]})" if agent else "")}{RESET}')
    if t == 'speculation-accept':
        ms = obj.get('timeSavedMs', 0)
        return f'{head}  {GREEN}+{ms/1000:.1f}s saved{RESET}'
    if t == 'queue-operation':
        op = obj.get('operation', '?')
        return (f'{head}  {WHITE}{op}{RESET}\n\n'
                f'{obj.get("content", "")}')
    if t == 'marble-origami-commit':
        return (f'{head}  {MUTE}id={obj.get("collapseId", "")}{RESET}\n\n'
                f'{obj.get("summary", "")}')
    if t == 'marble-origami-snapshot':
        staged = obj.get('staged') or []
        return (f'{head}  {MUTE}{len(staged)} staged · '
                f'armed={obj.get("armed")} · '
                f'lastSpawnTokens={obj.get("lastSpawnTokens", 0)}{RESET}')
    if t == 'progress':
        d = obj.get('data') or {}
        dt = d.get('type', '?') if isinstance(d, dict) else '?'
        return f'{head}  {MUTE}{dt}{RESET}'
    if t == 'summary':
        return f'{head}\n\n{obj.get("summary", "")}'
    return f'{head}\n{GRAY}{json.dumps(obj, indent=2, ensure_ascii=False)}{RESET}'


def _render_unknown(obj):
    """Forward-compat fallback — unchanged from the pre-refactor preview."""
    try:
        return json.dumps(obj, indent=2, ensure_ascii=False)
    except (TypeError, ValueError):
        return str(obj)


# ---- chrome footer -------------------------------------------------------


def _fmt_chrome(obj):
    """Common metadata footer appended to every per-message preview."""
    if not isinstance(obj, dict):
        return ''
    rows = []
    for key, label in (('uuid', 'uuid'),
                       ('parentUuid', 'parentUuid'),
                       ('sessionId', 'sessionId'),
                       ('promptId', 'promptId'),
                       ('forkedFrom', 'forkedFrom')):
        v = obj.get(key)
        if v:
            rows.append((label, str(v)))
    cwd = obj.get('cwd', '')
    branch = obj.get('gitBranch', '')
    if cwd or branch:
        rows.append(('cwd', f'{cwd}  {MUTE}branch:{RESET} {branch}' if branch else cwd))
    ts = obj.get('timestamp', '')
    ver = obj.get('version', '')
    if ts or ver:
        rows.append(('timestamp', f'{ts}  {MUTE}version:{RESET} {ver}' if ver else ts))
    flags = []
    if obj.get('isSidechain'): flags.append('sidechain')
    if obj.get('isMeta'):      flags.append('meta')
    if flags:
        rows.append(('flags', ', '.join(flags)))

    msg = obj.get('message') if isinstance(obj.get('message'), dict) else {}
    usage = msg.get('usage') or {}

    if not rows and not usage:
        return ''
    keys = [k for k, _ in rows] + (['usage'] if usage else [])
    w = max(len(k) for k in keys)
    parts = [_rule()]
    if rows:
        parts.append('\n'.join(
            f'{MUTE}{k.ljust(w)}:{RESET} {v}' for k, v in rows
        ))
    if usage:
        usage_str = '   '.join([
            f'{MUTE}input:{RESET} {usage.get("input_tokens", 0):,}',
            f'{MUTE}output:{RESET} {usage.get("output_tokens", 0):,}',
            f'{MUTE}cache read:{RESET} {usage.get("cache_read_input_tokens", 0):,}',
            f'{MUTE}cache new:{RESET} {usage.get("cache_creation_input_tokens", 0):,}',
        ])
        parts.append(f'{MUTE}{"usage".ljust(w)}:{RESET} {usage_str}')
    return '\n'.join(parts)


_RENDERERS = {
    'user':       _render_user,
    'assistant':  _render_assistant,
    'attachment': _render_attachment,
    'system':     _render_system,
    'metadata':   _render_metadata,
    'unknown':    _render_unknown,
}


# ---- get_preview ---------------------------------------------------------


def get_preview(item_id):
    """Preview-pane content for the cursor item.

    * project (dir):       human-readable summary + session list
    * session (.jsonl):    concatenated child previews (same machinery
                            as the umbrella previews — uniform body
                            cascade, honours the voice-only filter
                            transparently via ``hidden`` on children).
    * subagent (#agent:X): same uniform cascade against the subagent's
                            own .jsonl.
    * ``<prompt>`` / ``<tool>`` / ``<system>`` umbrella: concatenated
                            bodies of the umbrella's direct children.
    * message (#N):        pretty-printed JSON of the line
    """
    if not isinstance(item_id, str) or item_id.startswith('__err__:'):
        return ''
    if '#agent:' in item_id:
        return _preview_umbrella(item_id)
    if '#prompt:' in item_id or '#tool:' in item_id or '#span:' in item_id:
        return _preview_umbrella(item_id)
    if '#' in item_id:
        path, _, lineno = item_id.rpartition('#')
        if lineno == '__truncated__':
            return (
                f'(only the first {_message_limit} messages are listed)\n'
                f'press e on this row to open the full file in $EDITOR'
            )
        try:
            n = int(lineno)
        except ValueError:
            return ''
        return _preview_message(path, n)
    if os.path.isdir(item_id):
        return _preview_project(item_id)
    if os.path.isfile(item_id) and item_id.endswith('.jsonl'):
        return _preview_umbrella(item_id)
    return ''


def _preview_project(path):
    try:
        names = sorted(
            n for n in os.listdir(path) if n.endswith('.jsonl')
        )
    except OSError as e:
        return f'[error] {e}'
    header = (
        f'project: {_decode_project_path(os.path.basename(path))}\n'
        f'path:    {path}\n'
        f'\n{len(names)} session(s):'
    )
    body = '\n'.join(f'  {n}' for n in names[:1000])
    if len(names) > 50:
        body += f'\n  … and {len(names) - 50} more'
    return f'{header}\n{body}' if body else header


# ---- tree builder (#299) -------------------------------------------------
#
# Tree mode rebuilds the in-session children listing as an actual tree
# instead of a reverse-time flat list. The structure follows ``parentUuid``
# (the only field that gives reliable chain integrity across every
# record type — see /promptId investigation notes), with one wrinkle:
# user prompts get their own ``promptId``; when a child's
# ``inheritedPromptId`` (= own pid OR parent's pid) differs from its
# parent's, the parent link is broken and the child becomes a turn-root
# at the top level. That nests each turn cleanly under its prompt while
# keeping all the non-voice metadata records as siblings at root.
#
# The scan is cached; subsequent calls within one session are O(1).
# Cache eviction is explicit — ``get_children(None)`` (Ctrl-R /
# ``ctx.refresh()``) clears ``_TREE_CACHE`` + ``_TAIL_STATE``; the
# live-tail worker keeps the cached ``_TreeData`` in sync with the
# file as it grows, so no time-based invalidation is needed.


_TREE_CACHE = {}   # path → TreeData
_TREE_MODE = True  # default; --no-tree CLI flag or 't' action flips it.
_FILTER_VOICE_ONLY = False  # default; --no-show-all flag or 'h' flips it.


# Live-tail worker state, keyed by .jsonl path. The worker resumes
# from each entry's byte_offset on its 5s tick and parses new lines
# via _read_new_records (shared between tree + flat modes).
class _TailState:
    """Per-file state for the live-tail worker.

    Persistence semantics:
      * Survives normal navigation (``_scan_tree`` cache hits return
        the existing entry).
      * Cleared by the indirect ``get_children(None)`` reset signal —
        which fires on Ctrl-R / ``ctx.refresh()`` / initial load. The
        next per-file fetch rebuilds from scratch.

    ``error`` latches True on the first malformed complete line OR a
    size shrink (truncation / rotation). The worker skips this file
    thereafter until the user-triggered reset clears
    ``_TAIL_STATE[path]``.

    Fields:
      * ``byte_offset`` — resume point in the file for the next read.
      * ``last_size`` — file size at the previous tick; the worker
        bails when ``current_size == last_size``.
      * ``start_line`` — line index of the byte at ``byte_offset``,
        used when no ``_TREE_CACHE`` entry exists to count from
        (flat-mode lazy bootstrap).
      * ``cursor`` — the open-turn / open-span state machine, shared
        between bulk scan and the tail's incremental fold.
      * ``error`` — latched failure flag.
      * ``lock`` — held by ``_scan_tree`` (blocking) and the worker
        (trylock — bail on contention, matching best-effort).
    """

    __slots__ = ('byte_offset', 'last_size', 'start_line',
                 'cursor', 'error', 'lock')

    def __init__(self, *, byte_offset, last_size, start_line,
                 cursor, error):
        self.byte_offset = byte_offset
        self.last_size = last_size
        self.start_line = start_line
        self.cursor = cursor
        self.error = error
        self.lock = threading.Lock()


_TAIL_STATE = {}    # path → _TailState
_TAIL_STOP = None   # threading.Event; created in main()
_TAIL_THREAD = None # threading.Thread; created in main()


_TREE_METADATA_TYPES = frozenset([
    # records that show up as their own roots — they carry no
    # parentUuid and don't participate in the conversation chain.
    'summary', 'ai-title', 'custom-title', 'last-prompt', 'task-summary',
    'tag', 'agent-name', 'agent-color', 'agent-setting', 'pr-link',
    'mode', 'permission-mode', 'worktree-state', 'content-replacement',
    'file-history-snapshot', 'attribution-snapshot', 'speculation-accept',
    'queue-operation', 'marble-origami-commit', 'marble-origami-snapshot',
    'progress',
])


class _TreeData:
    """Cached tree-structure view of one ``.jsonl`` file.

    The shape is span-based and ignores ``parentUuid`` for structure.
    ``parentUuid`` is just a write-time linked-list back-pointer (see
    ``sessionStorage.ts:1066`` in claude-code: ``parentUuid =
    message.uuid`` after every chain-participant append). Using it
    literally as a tree parent produces 15-deep cascades of attachments
    under tool_results under attachments. The actual conversation
    structure is way flatter:

      * The session is a flat sequence of "turns" interleaved with
        runs of out-of-turn metadata.
      * A turn opens at a "user voice" record (user record carrying
        text content, not a tool_result; not ``isMeta``) and closes at
        the next ``system/turn_duration`` record (or at the next user
        voice, whichever comes first).
      * Everything between open/close is a turn member.
      * Anything outside a turn — preamble, gaps between turns, file
        tail — gets folded into a synthetic ``<system>`` umbrella span
        so the top level doesn't blow up with one row per metadata
        record.

    Inside a turn, only two semantic relationships are nested:

      * tool execution group: an assistant record with a ``tool_use``
        content part becomes the parent of (a) the matching user
        tool_result (paired via ``tool_use_id``), (b) any attachment
        records carrying a matching ``toolUseID`` (PreToolUse/
        PostToolUse hook outputs), and (c) for Agent/Task tool_uses,
        the subagent pseudo-row.
      * subagent inline: the subagent's own ``.jsonl`` becomes a
        recursive subtree under the assistant's tool_use row.

    Fields:

    * ``records``         — parsed records in file order, indices
                            align with line numbers.
    * ``by_uuid``         — ``{uuid: record}``.
    * ``line_of``         — ``{uuid: line_number}``.
    * ``roots_in_order``  — list of root-entry dicts in file order:
                            ``{'kind':'turn','rec':<r>,'line':n}`` or
                            ``{'kind':'span','start':n,'records':[…]}``.
    * ``turn_direct``     — ``{turn_root_uuid: [recs]}`` — turn members
                            that render directly under the turn (i.e.,
                            NOT records that got re-parented under a
                            tool_use as part of the tool execution group).
    * ``tool_children``   — ``{assistant_uuid: [recs]}`` — the
                            tool_result + hook attachments + isMeta
                            back-pointers that pair with this assistant
                            record's tool_use part. Drives the second
                            layer of nesting inside a turn.
    * ``span_records``    — ``{span_start_line: [recs]}`` — members of
                            each ``<system>`` umbrella.
    * ``agent_link``      — ``{tool_use_id: {agent_id, agent_path,
                            assistant_uuid}}`` for every Agent/Task
                            tool_use whose tool_result resolved a
                            subagent .jsonl on disk.
    * ``assistant_has_tool_use`` — ``{assistant_uuid}`` set; True iff the
                            assistant record at this line carries a
                            ``tool_use`` content part (i.e. it should be
                            wrapped in a ``<tool:Name>`` umbrella).
    * ``tool_to_turn_root_line`` — ``{assistant_line: turn_root_line}``
                            — maps a ``<tool:>`` umbrella to its
                            containing ``<prompt>`` umbrella.
    * ``agent_to_assistant_line`` — ``{agent_id: assistant_line}`` —
                            maps a ``<subagent>`` group to its
                            dispatching assistant's line (i.e. the
                            ``<tool:Task>`` umbrella wrapping it).
    * ``tool_use_name_of`` — ``{assistant_uuid: tool_name}`` — first
                            tool_use part's name (for the umbrella
                            title prefix).
    * ``line_offsets``    — ``[int]`` with one **sentinel** entry past
                            the last record. ``line_offsets[n]`` is the
                            byte position where line ``n`` starts in
                            the source file; the length of line ``n``
                            is ``line_offsets[n+1] - line_offsets[n]``.
                            Used by the ``V`` / ``E`` actions to
                            extract per-line bytes without re-reading
                            the whole file.

    Per-record attrs:
      * ``rec['_tree_forked_from']`` — record explicitly forked from
        an earlier uuid (``forkedFrom`` field).
    """

    __slots__ = ('records', 'by_uuid', 'line_of', 'roots_in_order',
                 'turn_direct', 'tool_children', 'span_records',
                 'agent_link', 'records_line', 'parent_id_of',
                 'assistant_has_tool_use', 'tool_to_turn_root_line',
                 'agent_to_assistant_line', 'tool_use_name_of',
                 'line_offsets', 'voice_count')

    def __init__(self):
        self.records = []
        self.by_uuid = {}
        self.line_of = {}
        self.roots_in_order = []
        self.turn_direct = {}
        self.tool_children = {}
        self.span_records = {}
        self.agent_link = {}
        # id(rec) → line_no — looking up the line of a record without
        # needing a uuid (metadata records often have none).
        self.records_line = {}
        # line_no → parent_id — the parent **umbrella** id for that
        # line's leaf row. One of: ``<jsonl>#prompt:<n>``,
        # ``<jsonl>#tool:<n>``, or ``<jsonl>#span:<n>``. Top-level
        # rows (the umbrellas themselves) are absent — their parent
        # link lives in tool_to_turn_root_line / agent_to_assistant_line
        # or is None.
        self.parent_id_of = {}
        # Assistant records that carry at least one tool_use content
        # part. Drives the ``<tool:Name>`` umbrella wrapping.
        self.assistant_has_tool_use = set()
        # ``<tool:>`` → its containing ``<prompt>`` umbrella.
        self.tool_to_turn_root_line = {}
        # ``<subagent>`` → its dispatching assistant (which becomes
        # the ``<tool:Task>`` umbrella).
        self.agent_to_assistant_line = {}
        # assistant_uuid → name of first tool_use content part, for the
        # ``<tool:Name>`` umbrella's title prefix.
        self.tool_use_name_of = {}
        # Byte offsets of each line, with a sentinel past the end so
        # ``line_offsets[n+1] - line_offsets[n]`` always gives line n's
        # length. Starts as ``[0]`` (sentinel-only, no lines yet) and
        # grows by one entry per appended line.
        self.line_offsets = [0]
        # Cached count of voice-bearing records — populated lazily by
        # ``_fmt_scope_card`` and invalidated by tail appends that
        # bring in new voice records.
        self.voice_count = None


def _is_turn_root(rec):
    """A turn root is a fresh user prompt — text content, not synthetic."""
    if not isinstance(rec, dict):
        return False
    if rec.get('type') != 'user':
        return False
    if rec.get('isMeta'):
        return False
    return _is_voice(rec)


def _is_turn_close(rec):
    """``system/turn_duration`` is the post-turn marker."""
    return (isinstance(rec, dict)
            and rec.get('type') == 'system'
            and rec.get('subtype') == 'turn_duration')


class _ScanCursor:
    """Mutable per-file state-machine cursor for the bulk + tail fold.

    Holds the open-turn / open-span context plus the per-turn
    ``tool_use_id → assistant_uuid`` registry so each newly-arrived
    record can be classified online (no second pass over a buffered
    turn). Persists in ``_TAIL_STATE`` between worker ticks so a
    record arriving in tick 2 sees the same registry the bulk scan
    or tick 1 was building.
    """

    __slots__ = ('turn_open_uuid', 'tool_owner', 'span_start')

    def __init__(self):
        self.turn_open_uuid = None
        # tool_use_id → owning assistant_uuid (within the open turn).
        # Cleared on turn close.
        self.tool_owner = {}
        # Line number of the first record of the currently-open span,
        # or None when not inside a span.
        self.span_start = None


def _fold_record(td, cur, rec, n, path, sub_dir):
    """Fold one record at line ``n`` into ``td`` using ``cur``.

    Returns a set of parent umbrella ids whose visible child list grew
    (caller turns these into ``update_data`` patches). Bulk scan
    ignores the return value; the tailer consumes it.
    """
    dirty = set()
    if rec is None:
        return dirty
    if not isinstance(rec, dict):
        return dirty

    # Basic record bookkeeping (parallels the bulk scan's first pass).
    td.records_line[id(rec)] = n
    uuid = rec.get('uuid')
    if uuid:
        td.by_uuid[uuid] = rec
        td.line_of[uuid] = n
    if rec.get('forkedFrom'):
        rec['_tree_forked_from'] = rec['forkedFrom']

    # --- turn root: opens a new <prompt> umbrella, closes any open span.
    if _is_turn_root(rec):
        if cur.span_start is not None:
            # Span closed by this turn root; the records list stored
            # in td.span_records is live-shared with td.roots_in_order
            # so no copy needed here.
            cur.span_start = None
        cur.turn_open_uuid = uuid
        cur.tool_owner = {}
        if uuid is not None:
            td.turn_direct[uuid] = []
        td.roots_in_order.append({'kind': 'turn', 'rec': rec, 'line': n})
        td.parent_id_of[n] = f'{path}#prompt:{n}'
        dirty.add(path)   # new root-level umbrella
        return dirty

    # --- record inside an open turn.
    if cur.turn_open_uuid is not None:
        turn_root_line = td.line_of.get(cur.turn_open_uuid)
        turn_uuid = cur.turn_open_uuid

        # (a) Assistant with one or more tool_use parts. Register each
        # tool_use id → assistant uuid, mark the assistant as
        # ``<tool>``-wrapped, and place it as a direct child of the
        # turn (the umbrella around it lives at the listing layer).
        if rec.get('type') == 'assistant':
            msg = rec.get('message') or {}
            content = msg.get('content') if isinstance(msg, dict) else None
            has_tool_use = False
            if isinstance(content, list):
                for p in content:
                    if (isinstance(p, dict)
                            and p.get('type') == 'tool_use'
                            and p.get('id')):
                        cur.tool_owner[p['id']] = uuid
                        if uuid:
                            td.assistant_has_tool_use.add(uuid)
                            td.tool_use_name_of.setdefault(
                                uuid, p.get('name') or 'tool')
                        has_tool_use = True
            if has_tool_use:
                td.turn_direct[turn_uuid].append(rec)
                td.parent_id_of[n] = f'{path}#tool:{n}'
                if turn_root_line is not None:
                    td.tool_to_turn_root_line[n] = turn_root_line
                    dirty.add(f'{path}#prompt:{turn_root_line}')
                if _is_turn_close(rec):
                    cur.turn_open_uuid = None
                    cur.tool_owner = {}
                return dirty

        # (b) Tool-child resolution: tool_result / hook attachment /
        # sourceToolUseID back-pointers.
        owner = _resolve_tool_owner(rec, cur.tool_owner)

        if owner is not None:
            owner_line = td.line_of.get(owner)
            td.tool_children.setdefault(owner, []).append(rec)
            if owner_line is not None:
                td.parent_id_of[n] = f'{path}#tool:{owner_line}'
                dirty.add(f'{path}#tool:{owner_line}')
            # Subagent-link check: a tool_result whose
            # toolUseResult.agentId resolves an agent jsonl on disk.
            _maybe_link_subagent(td, rec, owner, sub_dir, path)
        else:
            td.turn_direct[turn_uuid].append(rec)
            if turn_root_line is not None:
                td.parent_id_of[n] = f'{path}#prompt:{turn_root_line}'
                dirty.add(f'{path}#prompt:{turn_root_line}')

        if _is_turn_close(rec):
            cur.turn_open_uuid = None
            cur.tool_owner = {}
        return dirty

    # --- outside any turn: span member.
    if cur.span_start is None:
        cur.span_start = n
        # Initialise a live-shared span records list so further
        # appends from this same call AND from future tail ticks are
        # both visible to the umbrella's preview without a copy step.
        td.span_records[n] = []
        td.roots_in_order.append({
            'kind': 'span', 'start': n,
            'records': td.span_records[n],
        })
        dirty.add(path)   # new root-level span umbrella
    span_start = cur.span_start
    td.span_records[span_start].append(rec)
    td.parent_id_of[n] = f'{path}#span:{span_start}'
    dirty.add(f'{path}#span:{span_start}')
    return dirty


def _resolve_tool_owner(rec, tool_owner):
    """Look up the assistant_uuid that this record back-points at, or None."""
    # (0) Explicit assistant-uuid back-pointer (subagent jsonls stamp
    # every tool-result user record with the owning assistant turn's
    # uuid). Strongest signal — bypasses the tool_owner indirection.
    asst = rec.get('sourceToolAssistantUUID')
    if asst:
        return asst
    # (1) user tool_result content: tool_use_id back-pointer.
    msg = rec.get('message')
    if isinstance(msg, dict):
        content = msg.get('content')
        if isinstance(content, list):
            for p in content:
                if (isinstance(p, dict)
                        and p.get('type') == 'tool_result'):
                    tu = p.get('tool_use_id')
                    if tu in tool_owner:
                        return tool_owner[tu]
    # (2) attachment with toolUseID — hook outputs.
    if rec.get('type') == 'attachment':
        att = rec.get('attachment')
        if isinstance(att, dict):
            tu = att.get('toolUseID')
            if tu in tool_owner:
                return tool_owner[tu]
    # (3) records with explicit back-pointer fields.
    tu = rec.get('sourceToolUseID')
    if tu in tool_owner:
        return tool_owner[tu]
    return None


def _maybe_link_subagent(td, rec, owner_uuid, sub_dir, path):
    """If ``rec`` is a tool_result that resolves a subagent jsonl, link it.

    Inspects the owner assistant's tool_use parts to find the matching
    Agent/Task call and records the join via ``td.agent_link`` plus the
    ``agent_to_assistant_line`` shortcut. No-op if anything mismatches.
    """
    msg = rec.get('message')
    if not isinstance(msg, dict):
        return
    content = msg.get('content')
    if not isinstance(content, list):
        return
    asst = td.by_uuid.get(owner_uuid)
    if asst is None:
        return
    amsg = asst.get('message') or {}
    if not isinstance(amsg, dict):
        return
    acontent = amsg.get('content') or []
    if not isinstance(acontent, list):
        return
    for cp in content:
        if not (isinstance(cp, dict) and cp.get('type') == 'tool_result'):
            continue
        tu_id = cp.get('tool_use_id')
        if not tu_id:
            continue
        for ap in acontent:
            if not (isinstance(ap, dict)
                    and ap.get('type') == 'tool_use'
                    and ap.get('id') == tu_id
                    and ap.get('name') in ('Agent', 'Task')):
                continue
            tur = rec.get('toolUseResult')
            agent_id = (tur.get('agentId')
                        if isinstance(tur, dict) else None)
            if not agent_id:
                continue
            agent_path = os.path.join(sub_dir, f'agent-{agent_id}.jsonl')
            if not os.path.isfile(agent_path):
                continue
            td.agent_link[tu_id] = {
                'agent_id': agent_id,
                'agent_path': agent_path,
                'assistant_uuid': owner_uuid,
            }
            asst_line = td.line_of.get(owner_uuid)
            if asst_line is not None:
                td.agent_to_assistant_line[agent_id] = asst_line


def _resolve_path_for_bust(item_id):
    """Map an id shape to the .jsonl path whose ``_TreeData`` it depends on.

    Returns ``None`` when ``item_id`` doesn't reference per-file scanned
    state (project dirs, unparseable ids).
    """
    if not isinstance(item_id, str):
        return None
    # Subagent boundary: ``<sess>#agent:<aid>`` → subagent's own jsonl.
    if '#agent:' in item_id:
        sess, _, aid = item_id.partition('#agent:')
        if not aid:
            return None
        agent_path = os.path.join(_subagents_dir(sess), f'agent-{aid}.jsonl')
        return agent_path if os.path.isfile(agent_path) else None
    # Any other ``<path>#...`` id resolves to ``<path>``.
    if '#' in item_id:
        path = item_id.partition('#')[0]
        return path if path.endswith('.jsonl') and os.path.isfile(path) else None
    # Bare .jsonl path.
    if item_id.endswith('.jsonl') and os.path.isfile(item_id):
        return item_id
    return None


def _bust_caches_for(item_id):
    """Drop cached ``_TreeData`` + ``_TailState`` for one file's tree.

    Used by ``get_children(..., reload=True)`` to refresh a single
    subtree without disturbing siblings. No-op for ids that don't
    resolve to a per-file ``_TreeData`` (project dirs, unparseable ids).
    """
    path = _resolve_path_for_bust(item_id)
    if path is None:
        return
    _TREE_CACHE.pop(path, None)
    _TAIL_STATE.pop(path, None)


def _scan_tree(path):
    """Return cached ``_TreeData`` for ``path``; bulk-scan on cache miss.

    Cache invalidation is explicit (``get_children(id, reload=True)``
    drops the entry; ``get_children(None, reload=True)`` clears
    everything). The live-tail worker keeps the cached ``td`` in
    sync with file growth — no time-based check needed. A bulk scan
    on cache miss bootstraps ``_TAIL_STATE`` from the file's current
    end so the tail resumes from the exact byte where this scan stopped.
    """
    cached = _TREE_CACHE.get(path)
    if cached is not None:
        return cached

    td = _TreeData()
    cur = _ScanCursor()
    sub_dir = _subagents_dir(path)
    try:
        f = open(path, 'r', encoding='utf-8', errors='replace')
    except OSError:
        _TREE_CACHE[path] = td
        return td
    # Use readline() (not ``for line in f``) so ``f.tell()`` is legal —
    # the iterator protocol disables tell() to protect its read-ahead
    # buffer. We need tell() to record byte offsets per line for the
    # live-tail worker's resume point.
    last_full_offset = 0
    n = 0
    with f:
        while True:
            line = f.readline()
            if not line:
                break
            had_nl = line.endswith('\n')
            if not had_nl:
                # Incomplete trailing line — leave offset at its start
                # so the tail picks it up when more bytes arrive.
                break
            stripped = line.rstrip('\n')
            if not stripped.strip():
                td.records.append(None)
            else:
                try:
                    rec = json.loads(stripped)
                except json.JSONDecodeError:
                    rec = None
                if not isinstance(rec, dict):
                    td.records.append(None)
                else:
                    td.records.append(rec)
                    _fold_record(td, cur, rec, n, path, sub_dir)
            last_full_offset = f.tell()
            # Sentinel pattern: each appended ``f.tell()`` becomes the
            # start of the next line. After N complete lines,
            # ``line_offsets`` has N+1 entries, and the length of line
            # k is ``line_offsets[k+1] - line_offsets[k]``.
            td.line_offsets.append(last_full_offset)
            n += 1

    # Stash the byte offset + scan cursor + last-seen size for the
    # live-tail worker. The worker resumes from exactly the byte the
    # bulk scan stopped at, with the same open-turn / open-span state.
    _TAIL_STATE[path] = _TailState(
        byte_offset=last_full_offset,
        last_size=last_full_offset,
        start_line=n,
        cursor=cur,
        error=False,
    )
    _TREE_CACHE[path] = td
    return td


def _read_new_records(path):
    """Read newly-appended records since the last call.

    The single source of truth for both tree-mode and flat-mode live
    tail. When ``_TREE_CACHE`` has an entry, the parsed records are
    also folded into ``td`` via ``_fold_record`` (so tree-mode
    umbrellas, parent_id_of, agent_link, etc. stay current) and the
    set of umbrella parents whose visible child list grew is
    returned. Flat mode ignores the dirty set and consumes
    ``records`` directly.

    Returns ``(records, dirty_parents)``:
      * ``records`` — ``[(line_no, rec_or_None), ...]`` in file order.
        ``rec`` is ``None`` for blank lines and non-dict JSON.
      * ``dirty_parents`` — set of umbrella ids whose visible child
        list grew. Empty when no ``_TREE_CACHE`` entry exists.

    Best-effort, per the design:

      * ``([], set())`` when state is missing, the error flag is set,
        the size hasn't advanced, or the per-file lock is held.
      * Sets the error flag on first malformed complete-line JSON or
        on size shrink (truncation / rotation). Records collected
        before the failure are still returned.
    """
    tail = _TAIL_STATE.get(path)
    if tail is None or tail.error:
        return ([], set())
    try:
        size = os.path.getsize(path)
    except OSError:
        return ([], set())
    if size < tail.last_size:
        # Truncation / rotation — our offset is stale; refuse to tail
        # until the user re-reads (``get_children(None)`` clears the
        # state on Ctrl-R / refresh).
        tail.error = True
        return ([], set())
    if size == tail.last_size:
        return ([], set())

    if not tail.lock.acquire(blocking=False):
        # Contention with ``_scan_tree``'s blocking acquire. Best-
        # effort: bail and retry on the next tick.
        return ([], set())
    new_records = []
    dirty = set()
    try:
        td = _TREE_CACHE.get(path)   # ``td`` or None for flat-only paths
        sub_dir = _subagents_dir(path)
        try:
            f = open(path, 'r', encoding='utf-8', errors='replace')
        except OSError:
            return ([], set())
        with f:
            f.seek(tail.byte_offset)
            # Starting line number: prefer ``td.records``-based count
            # (tree-mode invariant); fall back to ``tail.start_line``
            # which we track for flat-only files.
            n = len(td.records) if td is not None else tail.start_line
            while True:
                line = f.readline()
                if not line:
                    break
                if not line.endswith('\n'):
                    # Incomplete trailing line — leave the offset at
                    # its start. The tail picks it up next tick once
                    # more bytes have been appended.
                    break
                stripped = line.rstrip('\n')
                rec = None
                if stripped.strip():
                    try:
                        rec = json.loads(stripped)
                    except json.JSONDecodeError:
                        # First malformed complete line latches the
                        # error flag. Anything we already read this
                        # tick still flows back to the caller.
                        tail.error = True
                        break
                    if not isinstance(rec, dict):
                        rec = None
                new_records.append((n, rec))
                if td is not None:
                    td.records.append(rec)
                    if rec is not None:
                        dirty |= _fold_record(td, cur=tail.cursor,
                                              rec=rec, n=n,
                                              path=path, sub_dir=sub_dir)
                tail.byte_offset = f.tell()
                # Sentinel pattern: append the end-of-line position
                # so ``line_offsets[n+1] - line_offsets[n]`` always
                # gives line n's length. Done both for the cached
                # ``td`` (tree mode) and on flat-only paths via the
                # ``records`` list above; the invariant is
                # ``len(td.line_offsets) == len(td.records) + 1``.
                if td is not None:
                    td.line_offsets.append(tail.byte_offset)
                n += 1
        # Keep ``tail.start_line`` in sync for flat-only paths; tree
        # mode reads it back from ``td.records`` on the next call.
        if td is None:
            tail.start_line = n
        tail.last_size = size
    finally:
        tail.lock.release()
    return (new_records, dirty)


def _item_to_upsert_kwargs(item):
    """Extract Item fields + custom attrs into kwargs for ``upsert``.

    ``upsert`` accepts arbitrary keyword args: declared dataclass
    fields map to ``Item.__init__`` kwargs, anything else lands as
    ``setattr`` on the freshly-built Item (mirrors ``to_item``).
    Iterating ``vars(item)`` picks up both the declared fields and
    the recipe-specific attrs (kind, line_no, row_bg, …) without
    enumerating each one by name.
    """
    out = {}
    for k, v in vars(item).items():
        if k == 'id':
            continue
        out[k] = v
    return out


def _push_tail_diffs(b, dirty_parents):
    """Apply ``update_data`` patches for every dirty umbrella's new kids.

    For each parent id whose child list grew during the fold step, we
    compare the live ``get_children(parent)`` output against what the
    framework already has cached and ``upsert`` only the new entries.
    Parents not yet expanded by the user are skipped — their children
    will be fetched the normal way once expansion happens. Called on
    the main thread via ``Browser.update_data`` (thread-safe).
    """
    if not dirty_parents:
        return
    ops = []
    for parent_id in dirty_parents:
        # Under voice-only filter, a tail append (e.g., a voice record
        # joining a previously-machinery-only ``#span:`` umbrella) can
        # cross the parent into voice-bearing. Reveal the parent first,
        # in the same batch as its new children. Skip when the parent
        # isn't in our index (yet to be upserted) — it'll be built with
        # the right ``hidden`` from the builder.
        parent_item = b.get_item(parent_id)
        if (
            parent_item is not None
            and getattr(parent_item, 'hidden', False)
            and _passes_filter(parent_id)
        ):
            ops.append(mod(parent_id, hidden=False))
        cached = b.cached_children(parent_id)
        if cached is None:
            continue
        existing_ids = {it.id for it in cached}
        try:
            fresh = get_children(parent_id)
        except Exception:
            continue
        for child in fresh:
            if child.id in existing_ids:
                continue
            ops.append(upsert(child.id, parent_id,
                              **_item_to_upsert_kwargs(child)))
    if ops:
        b.update_data(ops)


def _tail_worker(b):
    """Background loop: every 5s, tail the cursor's file once.

    Best-effort and single-threaded — one file per tick, the file
    being the one the cursor currently sits in (per the flat/tree
    rule encoded in ``_cursor_tail_path``). Reads new bytes via the
    shared ``_read_new_records`` step, then dispatches mode-specific
    push:

      * Tree mode consumes the ``dirty_parents`` set returned by the
        fold step (each parent umbrella's child list grew).
      * Flat mode consumes the raw ``records`` list and emits one
        ``upsert`` per new line, positioned after the last subagent
        row.

    Stopped via the module-level ``_TAIL_STOP`` event when ``main``
    exits. Marked daemon as a backstop.
    """
    while not _TAIL_STOP.is_set():
        try:
            path = _resolve_tail_path_from_browser(b)
            if path is not None:
                _maybe_bootstrap_tail_state(path)
                records, dirty = _read_new_records(path)
                if records or dirty:
                    if _TREE_MODE:
                        _push_tail_diffs(b, dirty)
                    else:
                        _push_flat_inserts(b, path, records)
                    # Bust the preview cache for the file so the
                    # session-card preview re-renders even when the
                    # cursor stayed parked on a row above the
                    # changed listing.
                    b.post(lambda p=path: _bust_preview_for_path(b, p))
        except Exception:
            # Best-effort: a malformed cursor row / get_children
            # blowup must not kill the worker. Swallow silently;
            # the next tick gets a clean shot.
            pass
        _TAIL_STOP.wait(timeout=5.0)


def _maybe_bootstrap_tail_state(path):
    """Populate ``_TAIL_STATE[path]`` if missing.

    Tree mode bootstraps via ``_scan_tree`` (already wired). Flat
    mode never calls ``_scan_tree`` so the entry would otherwise
    never appear — we lazy-init here. ``last_size=0`` is deliberate:
    the framework may have a cached children list from before the
    worker started observing this file (e.g. the file grew after
    the initial get_children call but before the worker's first
    tick on it). Forcing the first post-bootstrap tick to see
    ``size > 0`` triggers the read that syncs the cache.
    """
    if path in _TAIL_STATE:
        return
    _TAIL_STATE[path] = _TailState(
        byte_offset=0, last_size=0, start_line=0,
        cursor=_ScanCursor(), error=False,
    )


def _push_flat_inserts(b, path, records):
    """Flat-mode push: build Items for new records and insert them.

    The flat-mode listing renders messages newest-first, so each new
    file record belongs **before** the rest of the message rows but
    **after** the trailing subagent group (which
    ``_list_session_children`` pins to the top). ``where=('after',
    None, last_sub_idx)`` with ``last_sub_idx = -1`` (no subagents)
    collapses to position 0 via the int-ref edge rule.

    Iterating new rows in reverse (oldest of the new batch first)
    leaves the freshest record at the head of the new group. The
    whole batch goes through one ``update_data`` call so the
    framework's cursor anchor runs exactly once at the end and
    holding ↑/↓ doesn't see the cursor jump.
    """
    if not records:
        return
    existing = b.cached_children(path)
    if existing is None:
        return
    existing_ids = {it.id for it in existing}

    last_sub_idx = -1
    for i, it in enumerate(existing):
        if isinstance(it.id, str) and '#agent:' in it.id:
            last_sub_idx = i
    where = ('after', None, last_sub_idx)

    ops = []
    for n, rec in reversed(records):
        if rec is None:
            continue
        item_id = f'{path}#{n}'
        if item_id in existing_ids:
            continue
        kind = _kind_of(rec)
        fields = {
            'title': _oneline(_summarise_message(rec)),
            'tag': kind,
            'tag_style': _TAG_STYLE_FOR_KIND.get(kind, ''),
            'has_children': False,
            'hidden': not _passes_filter(item_id),
            'kind': 'message',
            'line_no': n,
            'session_path': path,
            'message_kind': kind,
        }
        if _is_voice(rec):
            bg = _ROW_BG_FOR_KIND.get(kind)
            if bg is not None:
                fields['row_bg'] = bg
        ops.append(upsert(item_id, path, where=where, **fields))
    if ops:
        b.update_data(ops)


def _bust_preview_for_path(b, path):
    """Drop cached preview text for ``path`` and force a re-fetch.

    Runs on the main thread (via ``Browser.post``). For the cursor's
    row or any descendant of ``path``, calls ``invalidate_preview``
    which re-fetches *without* resetting view state — a user who
    pinned the view to the bottom (Shift-End) keeps following the
    tail as the umbrella's preview grows. For non-cursor paths the
    cache is dropped so the next visit re-fetches.
    """
    cur_id = b.preview_item_id
    if cur_id == path or (isinstance(cur_id, str)
                          and cur_id.startswith(path + '#')):
        b.invalidate_preview(cur_id)
    else:
        b.drop_preview_cache(path)


def _resolve_tail_path_from_browser(b):
    """Return the file the cursor's current row maps to, or None.

    Reads the cursor + visible-list through a one-off Context so
    the scope_root row's id participates too — a freshly-launched
    recipe that hasn't moved the cursor still resolves a tail path.
    """
    try:
        from browse_tui import Context
        ctx = Context(b)
        vis = ctx.visible_items
        if not vis:
            return None
        idx = ctx.cursor_index
        if not (0 <= idx < len(vis)):
            return None
        item, _kind = vis[idx]
        item_id = item.id if item is not None else None
        return _cursor_tail_path(item_id)
    except Exception:
        return None


def _cursor_tail_path(item_id):
    """Resolve the .jsonl path the tailer should watch for ``item_id``.

    Mode-dependent for the subagent group row:

      * Tree mode: ``<sess>#agent:<aid>`` reflects activity in the
        parent session's tree, so tail the parent.
      * Flat mode: ``<sess>#agent:<aid>`` IS the subagent's listing
        (drill-into row), so tail the subagent jsonl.

    Other id shapes: take the path prefix. Returns ``None`` if the
    resolved path isn't a readable ``.jsonl``.
    """
    if not isinstance(item_id, str):
        return None
    if '#agent:' in item_id:
        sess, _, aid = item_id.partition('#agent:')
        if _TREE_MODE:
            if isinstance(sess, str) and sess.endswith('.jsonl') and os.path.isfile(sess):
                return sess
            return None
        agent_path = os.path.join(_subagents_dir(sess),
                                  f'agent-{aid}.jsonl')
        return agent_path if os.path.isfile(agent_path) else None
    path = item_id.partition('#')[0] if '#' in item_id else item_id
    if (isinstance(path, str)
            and path.endswith('.jsonl')
            and os.path.isfile(path)):
        return path
    return None


def _last_voice_id(jsonl_path):
    """Return ``<jsonl>#<n>`` id of the most-recent voice record, or None.

    "Voice" matches ``_is_voice`` (user prompt or assistant text). Walks
    records in REVERSE file order so the latest wins. Used for the
    cursor-on-open and the t-toggle landing point.
    """
    td = _scan_tree(jsonl_path)
    for n in range(len(td.records) - 1, -1, -1):
        rec = td.records[n]
        if rec is not None and _is_voice(rec):
            return f'{jsonl_path}#{n}'
    return None


def _list_tree_roots(jsonl_path):
    """Tree-mode listing for a session: root-level rows in file order.

    Each entry is either a ``<prompt>`` umbrella (one per turn) or a
    ``<system>`` umbrella collapsing a contiguous run of metadata
    records. The first message is no longer also the expandable node —
    that's the umbrella's job.

    Subagent files whose dispatch site lives in this session's main
    thread render inline under their dispatching assistant turn (via
    ``td.agent_link`` / ``agent_to_assistant_line``). Orphan subagent
    files — those with no matching ``Agent`` / ``Task`` ``tool_use.id``
    in the main thread — would otherwise vanish, so we surface them
    here at the top, mirroring flat-view placement.
    """
    td = _scan_tree(jsonl_path)
    out = []
    for orphan in _orphan_subagents_for_session(jsonl_path, td):
        out.append(orphan)
    for entry in td.roots_in_order:
        if entry['kind'] == 'turn':
            line = entry['line']
            rec = entry['rec']
            out.append(_prompt_umbrella_item(jsonl_path, line, rec, td))
        else:   # 'span'
            out.append(_span_umbrella_item(
                jsonl_path, entry['start'], entry['records'],
            ))
    return out


def _orphan_subagents_for_session(jsonl_path, td):
    """Return subagent items whose dispatch isn't wired to the main thread.

    Diffs the on-disk subagent set against ``td.agent_link`` (built by
    ``_maybe_link_subagent`` during scan). Unmatched files come back
    tagged ``orphan · …`` and dimmed so the user can see they aren't
    wired into the session's turn graph.
    """
    subs = _list_subagents_for_session(jsonl_path)
    if not subs:
        return []
    linked = {info.get('agent_id') for info in td.agent_link.values()}
    out = []
    for item in subs:
        if item.agent_id in linked:
            continue
        item.tag = (f'{item.agent_type} · {item.line_count} msg · orphan · '
                    f'{_human_time(item.mtime)}')
        item.tag_style = 'dim'
        item.is_orphan = True
        out.append(item)
    return out


def _list_prompt_children(jsonl_path, turn_root_line):
    """Children of a ``<prompt>`` umbrella.

    Returns the turn root user voice as a leaf, followed by each turn
    member in file order. Assistant members carrying a ``tool_use`` are
    wrapped in their own ``<tool:Name>`` umbrella (always, even if no
    tool_result has arrived yet — the umbrella shape stays stable as
    the transcript grows).
    """
    td = _scan_tree(jsonl_path)
    if not (0 <= turn_root_line < len(td.records)):
        return []
    rec = td.records[turn_root_line]
    if rec is None:
        return []
    uuid = rec.get('uuid')
    out = []
    # 1) The turn root itself, as a leaf — visible at the top of the
    # expansion so the user prompt content is readable at the same
    # indent as the assistant replies that follow. Keeps its
    # ``row_bg`` voice stripe; the user's voice deserves the marker
    # whether or not it happens to be folded under an umbrella.
    leaf = _tree_item(jsonl_path, rec, td)
    if leaf is not None:
        out.append(leaf)
    # 2) Each turn member.
    if uuid is None:
        return out
    for child in td.turn_direct.get(uuid, []):
        cuuid = child.get('uuid')
        if cuuid in td.assistant_has_tool_use:
            cline = td.line_of.get(cuuid)
            if cline is None:
                continue
            out.append(_tool_umbrella_item(jsonl_path, cline, child, td))
        else:
            it = _tree_item(jsonl_path, child, td)
            if it is not None:
                out.append(it)
    return out


def _list_tool_children(jsonl_path, assistant_line):
    """Children of a ``<tool>`` umbrella.

    Returns the assistant tool_use record as a leaf, then every paired
    tool_result / hook attachment in file order, and finally a
    ``<subagent>`` umbrella for each resolvable Agent/Task dispatch. The
    umbrella exists even when no tool_result has arrived yet so the
    shape is stable across in-flight transcripts.
    """
    td = _scan_tree(jsonl_path)
    if not (0 <= assistant_line < len(td.records)):
        return []
    rec = td.records[assistant_line]
    if rec is None:
        return []
    uuid = rec.get('uuid')
    out = []
    # 1) Assistant tool_use record as a leaf. Keeps its ``row_bg``
    # voice stripe if the assistant has text content (mixed text +
    # tool_use case) — same reasoning as the prompt umbrella's first
    # leaf: voice markers belong on voice rows, regardless of nesting.
    leaf = _tree_item(jsonl_path, rec, td)
    if leaf is not None:
        out.append(leaf)
    # 2) Paired tool_children (tool_result, hook attachments, …).
    for child in td.tool_children.get(uuid, []):
        it = _tree_item(jsonl_path, child, td)
        if it is not None:
            out.append(it)
    # 3) Subagent pseudo-rows for Agent/Task tool_uses with a
    # resolvable transcript.
    msg = rec.get('message') or {}
    if isinstance(msg, dict):
        content = msg.get('content') or []
        if isinstance(content, list):
            for p in content:
                if (isinstance(p, dict)
                        and p.get('type') == 'tool_use'
                        and p.get('name') in ('Agent', 'Task')):
                    link = td.agent_link.get(p.get('id'))
                    if link:
                        out.append(_subagent_pseudo_item(
                            jsonl_path,
                            link['agent_id'], link['agent_path'],
                        ))
    return out


def _list_span_records(jsonl_path, start_line):
    """Children of a ``<system>`` umbrella: the records of one span."""
    td = _scan_tree(jsonl_path)
    out = []
    for rec in td.span_records.get(start_line, []):
        it = _tree_item(jsonl_path, rec, td)
        if it is not None:
            out.append(it)
    return out


def _tree_item(jsonl_path, rec, td):
    """Build a leaf list-row ``Item`` for ``rec`` in tree mode.

    Always ``has_children=False`` — wrapping into ``<prompt>`` / ``<tool>``
    umbrellas is the listing layer's job (``_list_prompt_children`` /
    ``_list_tool_children``). This builder produces the leaf
    content-row that appears **inside** an umbrella's expansion.
    """
    n = td.line_of.get(rec.get('uuid'))
    if n is None:
        for i, r in enumerate(td.records):
            if r is rec:
                n = i
                break
    if n is None:
        return None
    kind = _kind_of(rec)

    item_id = f'{jsonl_path}#{n}'
    item = Item(
        id=item_id,
        title=_oneline(_summarise_message(rec)),
        tag=_row_tag(kind, rec),
        tag_style=_TAG_STYLE_FOR_KIND.get(kind, ''),
        has_children=False,
        hidden=not _passes_filter(item_id, td),
    )
    item.kind = 'message'
    item.line_no = n
    item.session_path = jsonl_path
    item.message_kind = kind
    if _is_voice(rec):
        bg = _ROW_BG_FOR_KIND.get(kind)
        if bg is not None:
            item.row_bg = bg
    return item


def _prompt_umbrella_item(jsonl_path, turn_root_line, rec, td):
    """``<prompt>`` umbrella wrapping one turn.

    Id shape: ``<jsonl>#prompt:<turn_root_line>``. Children are the turn
    root user voice (as a leaf) followed by every turn member, with each
    assistant-with-tool_use member further wrapped in a ``<tool>``
    umbrella. The umbrella's title prefix mirrors the existing
    ``<system>`` precedent so the kind tag reads consistently across all
    umbrella rows.
    """
    summary = _oneline(_summarise_message(rec))
    uuid = rec.get('uuid')
    members = td.turn_direct.get(uuid, []) if uuid else []
    # Count of direct children visible when expanded: the user voice
    # itself + each member (tool-using members collapse into one row).
    n_replies = len(members)
    item_id = f'{jsonl_path}#prompt:{turn_root_line}'
    item = Item(
        id=item_id,
        title=f'<prompt>  {summary}',
        tag=f'{n_replies} replies' if n_replies else 'no reply yet',
        tag_style='dim',
        has_children=True,
        hidden=not _passes_filter(item_id, td),
    )
    item.kind = 'prompt'
    item.line_no = turn_root_line
    item.session_path = jsonl_path
    item.message_kind = _kind_of(rec)
    # Voice stripe — the umbrella visually IS the user prompt at the
    # turn level. Matches the leaf user-msg row's stripe so the two
    # adjacent rows read as one voice block.
    if _is_voice(rec):
        bg = _ROW_BG_FOR_KIND.get(item.message_kind)
        if bg is not None:
            item.row_bg = bg
    return item


def _tool_umbrella_item(jsonl_path, assistant_line, rec, td):
    """``<tool:Name>`` umbrella wrapping one tool-execution group.

    Id shape: ``<jsonl>#tool:<assistant_line>``. Children are the
    dispatching assistant itself (leaf), the paired ``tool_result`` +
    hook attachments, and a ``<subagent>`` umbrella for Agent/Task
    dispatches with a resolvable subagent transcript on disk. The tool
    name in the prefix is the **first** ``tool_use`` part's name.
    """
    summary = _oneline(_summarise_message(rec))
    uuid = rec.get('uuid')
    tool_name = td.tool_use_name_of.get(uuid, 'tool')
    item_id = f'{jsonl_path}#tool:{assistant_line}'
    item = Item(
        id=item_id,
        title=f'<tool:{tool_name}>  {summary}',
        tag='tool_use',
        tag_style=_TAG_STYLE_FOR_KIND.get('tool_use', ''),
        has_children=True,
        hidden=not _passes_filter(item_id, td),
    )
    item.kind = 'tool'
    item.line_no = assistant_line
    item.session_path = jsonl_path
    item.message_kind = _kind_of(rec)
    item.tool_name = tool_name
    if _is_voice(rec):
        bg = _ROW_BG_FOR_KIND.get(item.message_kind)
        if bg is not None:
            item.row_bg = bg
    return item


def _span_umbrella_item(jsonl_path, start_line, records):
    """Synthetic ``<system>`` row collapsing a metadata span.

    Id shape: ``<jsonl>#span:<start_line>``. ``get_children`` routes
    that id to ``_list_span_records`` which returns the span's records
    as flat children. Title shows the count + dominant types so the
    row's still informative when collapsed.
    """
    from collections import Counter
    type_counts = Counter()
    for r in records:
        if not isinstance(r, dict):
            continue
        t = r.get('type', '?')
        if t == 'attachment':
            att = r.get('attachment') or {}
            sub = att.get('type', '') if isinstance(att, dict) else ''
            type_counts[f'att:{sub}'] += 1
        elif t == 'system':
            sub = r.get('subtype', '')
            type_counts[f'sys:{sub}' if sub else 'system'] += 1
        else:
            type_counts[t] += 1
    types_summary = ', '.join(
        f'{n}× {t}' if n > 1 else t
        for t, n in type_counts.most_common(4)
    )
    if len(type_counts) > 4:
        types_summary += ', …'

    has_voice = any(
        isinstance(r, dict) and _is_voice(r) for r in records
    )
    item = Item(
        id=f'{jsonl_path}#span:{start_line}',
        title=f'<system>  {types_summary}',
        tag=f'{len(records)} records',
        tag_style='dim',
        has_children=len(records) > 0,
        hidden=_FILTER_VOICE_ONLY and not has_voice,
    )
    item.kind = 'span'
    item.span_start = start_line
    item.span_count = len(records)
    item.session_path = jsonl_path
    return item


def _subagent_pseudo_item(parent_jsonl, agent_id, agent_path):
    """Single-row Item representing a subagent under an assistant row.

    Same fields as the rows produced by ``_list_subagents_for_session``
    so the existing preview/edit handlers Just Work — only the parent
    in the tree changes.
    """
    sub_dir = _subagents_dir(parent_jsonl)
    meta = _read_subagent_meta(
        os.path.join(sub_dir, f'agent-{agent_id}.meta.json'),
    )
    agent_type = meta.get('agentType') or 'agent'
    description = meta.get('description') or ''
    body = description or f'agent {agent_id}'
    title = f'<subagent>  {body}'
    try:
        st = os.stat(agent_path)
        mtime = st.st_mtime
    except OSError:
        mtime = 0
    try:
        with open(agent_path, 'rb') as f:
            count = sum(1 for _ in f)
    except OSError:
        count = 0
    item = Item(
        id=f'{parent_jsonl}#agent:{agent_id}',
        title=title,
        tag=f'{agent_type} · {count} msg · {_human_time(mtime)}',
        tag_style='magenta',
        has_children=count > 0,
        hidden=False,   # subagent umbrellas are always visible
    )
    item.kind = 'subagent'
    item.agent_id = agent_id
    item.agent_type = agent_type
    item.agent_description = description
    item.session_path = parent_jsonl
    item.subagent_path = agent_path
    item.line_count = count
    item.mtime = mtime
    # Voice stripe: same colour as top-of-list and orphan subagent rows
    # so the inline tree-mode placement reads as voice too.
    bg = _ROW_BG_FOR_KIND.get('subagent')
    if bg is not None:
        item.row_bg = bg
    return item


def _preview_message(path, n):
    """Per-line preview for a leaf message: classify + dispatch + chrome.

    Each renderer returns a body str with ANSI inlined. The chrome
    footer (uuid, cwd, timestamp, …) is uniform and appended here. In
    the new umbrella tree model leaves don't have children, so the
    preview no longer concatenates anything extra — the umbrella's own
    preview is where multi-child concatenation lives.
    """
    obj = _read_jsonl_line(path, n)
    if obj is None:
        return ''
    kind = _classify(obj)
    body = _RENDERERS.get(kind, _render_unknown)(obj)
    chrome = _fmt_chrome(obj)
    return body + ('\n' + chrome if chrome else '')


def _scope_card_path(item_id):
    """Return the on-disk .jsonl whose scope card should prepend the
    preview, or None if ``item_id`` doesn't anchor a synthetic top row.

    Two id shapes earn the card: the bare ``.jsonl`` path (top row in
    the project's session list, or when ``--file`` opens a transcript
    directly) and a ``<sess>#agent:<aid>`` row whose preview is
    composed from the subagent's own jsonl.
    """
    if isinstance(item_id, str) and '#agent:' in item_id:
        sess, _, aid = item_id.partition('#agent:')
        if not aid:
            return None
        agent_path = os.path.join(_subagents_dir(sess), f'agent-{aid}.jsonl')
        return agent_path if os.path.isfile(agent_path) else None
    if (isinstance(item_id, str) and item_id.endswith('.jsonl')
            and os.path.isfile(item_id)):
        return item_id
    return None


def _fmt_scope_card(path, td):
    """One-block header identifying the file backing the synthetic top row.

    Pulls sessionId / entrypoint / cwd / gitBranch / slug from the
    first record that has them (every Claude record carries the
    stamps). Subagent variant additionally lists agentId, agentType
    and description from the sibling meta.json. Returns a string
    ready to prepend to the cascade body.
    """
    rec = next((r for r in td.records if isinstance(r, dict)), None) or {}
    is_sub = False
    parent = os.path.dirname(path)
    if os.path.basename(parent) == 'subagents':
        fname = os.path.basename(path)
        if fname.startswith('agent-') and fname.endswith('.jsonl'):
            meta_path = os.path.join(parent, fname[:-len('.jsonl')]
                                     + '.meta.json')
            if os.path.isfile(meta_path):
                is_sub = True
    rows = []
    rows.append(('path', path))
    if is_sub:
        agent_id = os.path.basename(path)[len('agent-'):-len('.jsonl')]
        meta = _read_subagent_meta(os.path.join(
            os.path.dirname(path), f'agent-{agent_id}.meta.json',
        ))
        rows.append(('agentId', agent_id))
        if meta.get('agentType'):
            rows.append(('agentType', meta['agentType']))
        if meta.get('description'):
            rows.append(('description', meta['description']))
    if rec.get('sessionId'):
        rows.append(('sessionId', rec['sessionId']))
    if rec.get('entrypoint'):
        rows.append(('entrypoint', rec['entrypoint']))
    if rec.get('cwd'):
        rows.append(('cwd', rec['cwd']))
    if rec.get('gitBranch'):
        rows.append(('gitBranch', rec['gitBranch']))
    if rec.get('slug'):
        rows.append(('slug', rec['slug']))
    n_lines = sum(1 for r in td.records if r is not None)
    rows.append(('lines', str(n_lines)))
    if td.voice_count is None:
        td.voice_count = sum(
            1 for r in td.records if isinstance(r, dict) and _is_voice(r)
        )
    rows.append(('voice', str(td.voice_count)))
    try:
        st = os.stat(path)
        rows.append(('mtime', _human_time(st.st_mtime)))
    except OSError:
        pass
    label = 'browse-claude (subagent)' if is_sub else 'browse-claude'
    w = max(len(k) for k, _ in rows)
    body = '\n'.join(
        f'   {MUTE}{k.ljust(w)}:{RESET} {v}' for k, v in rows
    )
    return f'{_rule(label, BLUE)}\n{body}\n{_rule()}'


def _preview_umbrella(item_id):
    """Recursive same-file body dump of an umbrella row's leaves.

    Walks the umbrella's descendants in document order, rendering
    each leaf's body with a bright-yellow ``── kind ──`` rule. Nested
    umbrellas in the same file are followed transparently (so a
    ``<prompt>`` preview includes every line of every ``<tool>``
    block it contains, plus any ``<system>`` span members folded
    into the turn).

    Subagent-group rows render as a compact stub (type + description)
    — we never drill into the subagent's own jsonl from a parent's
    preview. The user can scope into the subagent group separately
    if they want its content.

    Per-leaf renderer errors are caught and surfaced as a red error
    stub so one bad row doesn't blank the entire preview.

    Side effects (added in #424):
      * Children discovered during the descent that aren't yet in the
        framework's cache are eager-pushed via one batched
        ``_BROWSER.update_data(ops)`` call. Subsequent recompositions
        (and a user's first expand) reuse those entries without
        re-running ``get_children``.
      * Each leaf record's rendered body is cached on its Item via a
        per-leaf ``_BROWSER.set_preview(cid, text)`` call. Since #431
        ``set_preview`` routes through the post queue (FIFO), so
        every write lands — the umbrella's own composed preview is
        still cached by the framework via the standard worker return
        path (no recipe-side ``set_preview`` needed for the top-level
        id).
    """
    parts = []
    ops = []
    leaf_previews = {}
    card_path = _scope_card_path(item_id)
    if card_path is not None:
        try:
            td = _scan_tree(card_path)
            parts.append(_fmt_scope_card(card_path, td))
        except Exception as e:
            parts.append(_rule(f'error in scope card: {e}', RED))
    _collect_umbrella_preview(item_id, parts, ops, leaf_previews)
    if _BROWSER is not None:
        # One batched push per top-level invocation. Thread-safe:
        # ``update_data`` schedules the apply onto the main thread.
        # The post queue is FIFO so this lands before the leaf-preview
        # writes below — leaves we just discovered will be in
        # ``_items_by_id`` by the time their preview write runs.
        if ops:
            _BROWSER.update_data(ops)
        for cid, text in leaf_previews.items():
            _BROWSER.set_preview(cid, text)
    return '\n\n'.join(parts)


def _collect_umbrella_preview(item_id, parts, ops, leaf_previews):
    """Append rendered bodies for ``item_id``'s descendants to ``parts``.

    ``ops`` is an accumulator of ``upsert`` tuples for the framework
    push API. The top-level caller flushes the batch once after the
    whole descent completes. When ``_BROWSER`` exposes children for
    ``item_id`` via ``cached_children``, no upserts are staged for that
    subtree (the framework already has them).

    ``leaf_previews`` is an ``{id: rendered_text}`` accumulator for
    per-leaf preview-cache writes. The top-level caller iterates the
    dict and calls ``set_preview`` per leaf — each call queues its
    own main-thread closure via the post queue (FIFO).
    """
    # Read-path: prefer the framework's cached children if available.
    # ``cached_children`` returns None when the parent hasn't been
    # fetched yet (or when we're running outside a real Browser, e.g.
    # in unit tests). A non-None list — even empty — is authoritative.
    children = None
    cached = None
    if _BROWSER is not None:
        try:
            cached = _BROWSER.cached_children(item_id)
        except Exception:
            cached = None
    if cached is not None:
        children = cached
    else:
        try:
            children = get_children(item_id)
        except Exception as e:
            parts.append(_rule(f'error listing {item_id}', RED)
                         + f'\n{type(e).__name__}: {e}')
            return
        # Stage upserts so subsequent recursion / expansion sees the
        # children without re-running ``get_children``. The framework's
        # ``upsert`` op is a no-op if the child id is already present
        # with matching parent + fields, but checking via
        # ``items_by_id`` first lets us skip the work entirely.
        if _BROWSER is not None:
            try:
                index = _BROWSER.items_by_id
            except Exception:
                index = None
            for child in children:
                cid = getattr(child, 'id', None)
                if not isinstance(cid, str):
                    continue
                if index is not None and cid in index:
                    continue
                ops.append(upsert(cid, item_id,
                                  **_item_to_upsert_kwargs(child)))
    for child in children:
        cid = getattr(child, 'id', None)
        if not isinstance(cid, str):
            continue
        # Honour the recipe's voice-only filter: a hidden child (e.g.,
        # a non-voice-bearing ``#tool:`` umbrella, or a tool_result
        # leaf) is invisible in the list and shouldn't bleed into the
        # parent's preview either.
        if getattr(child, 'hidden', False):
            continue
        try:
            if '#agent:' in cid:
                # Subagent boundary — never drill into another file's
                # records from a parent's preview. The dispatching
                # Agent / Task tool_use + matching tool_result already
                # live in the parent file and render through the
                # normal leaf path under the dispatching turn, so we
                # don't even emit a stub — would just duplicate that
                # pair.
                continue
            if '#prompt:' in cid or '#tool:' in cid or '#span:' in cid:
                # Same-file umbrella — recurse so the user sees every
                # underlying line, not just the umbrella's first
                # leaf.
                _collect_umbrella_preview(cid, parts, ops, leaf_previews)
                continue
            if '#' not in cid:
                continue
            cpath, _, lineno = cid.rpartition('#')
            n = _parse_int(lineno)
            if n is None:
                continue
            # Per-record preview cache on Item: skip the JSONL read +
            # body render when the framework already has a non-empty
            # cached preview for this leaf. The umbrella's own preview
            # gets cached by the framework's worker return path, but
            # each leaf only lands in the cache once *we* compose
            # something with it.
            cached_leaf = None
            if _BROWSER is not None:
                try:
                    cached_leaf = _BROWSER.get_cached_preview(cid)
                except Exception:
                    cached_leaf = None
            if cached_leaf:
                parts.append(cached_leaf)
                continue
            rendered = _render_record_with_rule(cpath, n)
            if rendered is not None:
                parts.append(rendered)
                # Cache the leaf render so the next recomposition
                # (tail tick, sibling umbrella's recursion, collapse
                # + re-expand, …) is a cheap dict lookup. Accumulated
                # here and flushed by the top-level caller via per-leaf
                # ``set_preview`` calls (queued onto the main thread via
                # the framework's FIFO post queue, since #431).
                if _BROWSER is not None:
                    leaf_previews[cid] = rendered
        except Exception as e:
            parts.append(_rule(f'error rendering child {cid}', RED)
                         + f'\n{type(e).__name__}: {e}')


def _render_record_with_rule(path, n):
    """Read one record, render its body, prefix with a bright-yellow rule."""
    obj = _read_jsonl_line(path, n)
    if obj is None or not isinstance(obj, dict):
        return None
    kind = _classify(obj)
    body = _RENDERERS.get(kind, _render_unknown)(obj)
    return _rule(kind, YELLOW) + '\n' + body


def _parse_int(s):
    """Tolerant int parser; returns None on failure."""
    try:
        return int(s)
    except (TypeError, ValueError):
        return None


# ---- actions -------------------------------------------------------------


def _resolve_path(item):
    """Resolve the cursor row to the file you want $EDITOR to open.

    * message id (``<path>#<line>``): return ``<path>``.
    * subagent group id (``<sess>#agent:<aid>``): return the agent's
      ``.jsonl`` file (subagents have their own transcript on disk).
    * project / session id: return the id verbatim — it's the path.
    """
    if item is None:
        return None
    iid = item.id
    if not isinstance(iid, str):
        return None
    if '#agent:' in iid:
        session_path, _, suffix = iid.partition('#agent:')
        if not suffix:
            return session_path
        return os.path.join(
            _subagents_dir(session_path), f'agent-{suffix}.jsonl',
        )
    if '#' in iid:
        iid, _, _ = iid.rpartition('#')
    return iid


def _current_view_targets(ctx):
    """Pick the items the ``V`` / ``E`` actions should operate on.

    Falls back through:
      1. The explicit selection (``ctx.targets`` when something is
         selected with space-bar).
      2. The cursor's item.
      3. The scope_root row — so ``V`` / ``E`` work even when the
         cursor sits on the synthetic top row of an opened file.

    Returns ``[]`` when nothing resolves.
    """
    targets = list(ctx.targets) if ctx.cursor is not None else []
    if targets:
        return targets
    rows = ctx.visible_items
    if rows and 0 <= ctx.cursor_index < len(rows):
        return [rows[ctx.cursor_index][0]]
    return []


def _gather_line_source(items):
    """Group items into ``{path: [line_no, ...]}`` for byte extraction.

    Each input item is classified by id shape:

      * ``<path>#<n>`` (message leaf) → ``(path, n)`` recorded.
      * Umbrella ids (``#prompt:`` / ``#tool:`` / ``#span:``) → recurse
        through the umbrella's same-file descendants and record each
        leaf's line. ``#agent:`` boundaries are NOT crossed —
        subagents live in their own ``.jsonl`` files.
      * ``<sess>#agent:<aid>`` (subagent group row) → the subagent's
        own ``.jsonl`` is the "whole file" to open.
      * Bare ``.jsonl`` / project path → "whole path".

    Returns ``(per_line, whole_paths)`` where ``per_line`` is the
    grouping dict (lines kept in document order) and ``whole_paths``
    is a list of ``(path, item)`` tuples for non-line targets.
    """
    per_line = {}
    whole_paths = []
    for item in items:
        iid = getattr(item, 'id', None)
        if not isinstance(iid, str):
            continue
        if '#agent:' in iid:
            sess, _, aid = iid.partition('#agent:')
            agent_path = os.path.join(
                _subagents_dir(sess), f'agent-{aid}.jsonl',
            )
            whole_paths.append((agent_path, item))
            continue
        if '#prompt:' in iid or '#tool:' in iid or '#span:' in iid:
            # Recurse through the umbrella's same-file leaves.
            path = iid.partition('#')[0]
            same_file_lines = _gather_umbrella_lines(iid)
            if same_file_lines:
                per_line.setdefault(path, []).extend(same_file_lines)
            else:
                # Defensive: empty umbrella → fall back to opening
                # the file as a whole rather than silently doing
                # nothing.
                whole_paths.append((path, item))
            continue
        if '#' in iid:
            path, _, suffix = iid.rpartition('#')
            try:
                n = int(suffix)
            except ValueError:
                # Synthetic ids like ``#__truncated__`` — open the
                # underlying file as a whole.
                whole_paths.append((path, item))
                continue
            per_line.setdefault(path, []).append(n)
            continue
        whole_paths.append((iid, item))
    # Pre-select pass: dedupe + sort each file's lines into
    # canonical (file) order. Multi-target invocations (umbrella +
    # one of its children, or two umbrellas with overlapping
    # contents) collapse to one entry per leaf in document order —
    # no surprises when ``_write_line_excerpts`` walks the list.
    for path in per_line:
        per_line[path] = sorted(set(per_line[path]))
    return per_line, whole_paths


def _gather_umbrella_lines(item_id):
    """Return [line_no, ...] for every leaf message under ``item_id``.

    Walks the umbrella's children recursively in document order via
    ``get_children`` (the same listing helper that builds the
    displayed tree). Nested umbrellas in the SAME file are followed
    transparently; ``#agent:`` boundaries are NOT crossed — the
    subagent's records live in a different ``.jsonl`` and the user
    can drill into that group row separately if they want them.
    """
    out = []
    _walk_umbrella_lines(item_id, out)
    return out


def _walk_umbrella_lines(item_id, out):
    """Append leaf line numbers under ``item_id`` to ``out`` in order."""
    try:
        children = get_children(item_id)
    except Exception:
        return
    for child in children:
        cid = getattr(child, 'id', None)
        if not isinstance(cid, str):
            continue
        if '#agent:' in cid:
            # Subagent boundary — content is in a different file.
            continue
        if '#prompt:' in cid or '#tool:' in cid or '#span:' in cid:
            _walk_umbrella_lines(cid, out)
            continue
        if '#' in cid:
            _, _, suffix = cid.rpartition('#')
            try:
                n = int(suffix)
            except ValueError:
                continue
            out.append(n)


def _write_line_excerpts(per_line):
    """Extract specific lines from one-or-more files into a temp .jsonl.

    Uses ``_TREE_CACHE[path].line_offsets`` for O(1) seek + read —
    no whole-file scan. Returns the temp path (caller is responsible
    for unlinking it after the external tool exits) or ``None`` if
    nothing could be extracted.
    """
    import tempfile
    written_any = False
    tmp = tempfile.NamedTemporaryFile(
        'wb', suffix='.jsonl', delete=False,
    )
    try:
        # ``per_line`` is already pre-selected (deduped + sorted) by
        # ``_gather_line_source`` — iterate as-is.
        for path, line_nos in per_line.items():
            cached = _TREE_CACHE.get(path)
            if cached is None:
                continue
            offsets = cached.line_offsets
            try:
                f = open(path, 'rb')
            except OSError:
                continue
            with f:
                for n in line_nos:
                    if not (0 <= n < len(offsets) - 1):
                        continue
                    start = offsets[n]
                    end = offsets[n + 1]
                    if end <= start:
                        continue
                    f.seek(start)
                    chunk = f.read(end - start)
                    if not chunk:
                        continue
                    tmp.write(chunk)
                    if not chunk.endswith(b'\n'):
                        tmp.write(b'\n')
                    written_any = True
    finally:
        tmp.close()
    if not written_any:
        try:
            os.unlink(tmp.name)
        except OSError:
            pass
        return None
    return tmp.name


def _run_source_command(ctx, cmd_env_var, default_cmd):
    """Shared body of ``V`` / ``E``: resolve targets, dispatch external tool.

    Strategy:
      * All targets are message ids on the SAME file → extract just
        those lines to a temp .jsonl and open that.
      * All targets are message ids spanning multiple files → same,
        concatenated into one temp file.
      * Anything else (umbrella, subagent group, session, project) →
        open the resolved path directly. With multiple non-message
        targets we open just the first; mixing per-line + per-path
        in one external invocation isn't a sensible UX.
    """
    targets = _current_view_targets(ctx)
    if not targets:
        return
    per_line, whole_paths = _gather_line_source(targets)
    cmd = _split_cmd(os.environ.get(cmd_env_var) or default_cmd)

    # All-message-targets path: extract bytes from line_offsets.
    if per_line and not whole_paths:
        tmp_path = _write_line_excerpts(per_line)
        if tmp_path is None:
            ctx.error('could not extract line bytes (cache missing?)')
            return
        try:
            ctx.run_external(cmd + [tmp_path])
        finally:
            try:
                os.unlink(tmp_path)
            except OSError:
                pass
        return

    # Single non-message target (or mixed): open the first resolved
    # path. Covers cursor-on-session, cursor-on-scope_root, cursor-on-
    # umbrella, and cursor-on-project use cases.
    if whole_paths:
        path, _item = whole_paths[0]
        if not path or not os.path.exists(path):
            ctx.error(f'no such path: {path!r}')
            return
        ctx.run_external(cmd + [path])
        return


def _action_edit_source(ctx):
    """``E`` — open the source for the cursor row (or selection) in $EDITOR.

    Message rows (single or multi-selected) extract just their lines
    via ``_TreeData.line_offsets`` into a temp .jsonl. Session /
    subagent / umbrella / project rows open their underlying file
    or directory in $EDITOR directly.

    Separate from the framework's built-in ``e`` (which opens the
    *preview text* in $EDITOR with edits discarded). This one
    operates on the on-disk source.
    """
    _run_source_command(ctx, 'EDITOR', 'vim')


def _action_view_source(ctx):
    """``V`` — page the source for the cursor row (or selection) in $PAGER.

    Same target-resolution rules as ``E``. Pairs with the framework's
    built-in ``v`` (which pages the rendered *preview* — useful when
    the preview is multi-screen) versus this which is the raw
    transcript bytes.
    """
    _run_source_command(ctx, 'PAGER', 'less -R')


def _split_cmd(s):
    """Shell-split a command env var like ``less -R`` or ``bat --paging=always``."""
    import shlex
    return shlex.split(s)


def _resolve_md_pager():
    """Return the resolved markdown-pager command, or None.

    Order: ``$MD2ANSI`` (shell-split), then ``md2ansi | less -RS`` if
    both binaries are on PATH. Recipes that want a different fallback
    can set ``$MD2ANSI`` to anything — including a piped chain like
    ``md2ansi | less -R``, which we shell out via ``bash -c`` so the
    pipe works.
    """
    import shlex
    import shutil
    env_cmd = os.environ.get('MD2ANSI')
    if env_cmd:
        if '|' in env_cmd or '<' in env_cmd or '>' in env_cmd:
            # User-supplied pipeline — hand to a shell so the pipe runs.
            return ['bash', '-c', f'{env_cmd} "$0"']
        return shlex.split(env_cmd)
    if shutil.which('md2ansi') and shutil.which('less'):
        return ['bash', '-c', 'md2ansi "$0" | less -RS']
    if shutil.which('md2ansi'):
        return ['md2ansi']
    return None


def _action_md_preview(ctx):
    """``m`` — view the preview through a markdown-to-ANSI renderer.

    Resolves the renderer via ``_resolve_md_pager``. Reads the cursor
    row's preview (synchronously via ``get_preview`` if not cached),
    writes it verbatim to a temp .md file, and runs the renderer on
    it. Same plumbing as ``v``'s ``less -R``: the preview text is
    handed off as-is; whatever ANSI it carries is the renderer's
    problem to handle (or pass through).
    """
    import tempfile
    cmd = _resolve_md_pager()
    if cmd is None:
        ctx.message('no markdown renderer found ($MD2ANSI / md2ansi)')
        return

    item = ctx.cursor
    if item is None:
        return
    text = ctx.get_cached_preview(item.id)
    if text is None:
        try:
            text = get_preview(item.id)
        except Exception as e:
            ctx.error(f'preview: {type(e).__name__}: {e}')
            return
    if text is None:
        ctx.message('No preview available')
        return

    tmp = tempfile.NamedTemporaryFile(
        'w', suffix='.md', delete=False,
        encoding='utf-8', errors='surrogateescape',
    )
    try:
        tmp.write(text)
        tmp.close()
        ctx.run_external(cmd + [tmp.name])
    finally:
        try:
            os.unlink(tmp.name)
        except OSError:
            pass


def _action_toggle_md(ctx):
    """Toggle md2ansi rendering of user/assistant voice content."""
    global _MD_COLOR
    _MD_COLOR = not _MD_COLOR
    ctx.drop_preview_cache()
    ctx.message(f'voice rendering: {"colored" if _MD_COLOR else "raw"}')


def _action_show_id(ctx):
    """Surface the cursor row's id on the info bar (handy for debugging)."""
    if ctx.cursor is None:
        return
    ctx.message(f'id: {ctx.cursor.id}')


def _jump_to_voice(ctx, direction):
    """Move the cursor to the next/prev row with a row-bg highlight.

    "Voice" rows are user prompts and assistant text replies — the
    speech-only rows ``_is_voice`` marks via ``row_bg``. Direction
    matches the list ordering — ``+1`` walks down (older messages,
    since the list is newest-first), ``-1`` walks up (newer).

    Walks the *visible* item list, not the on-disk tree. That means
    jumps cross expanded subtree boundaries naturally — if two
    sessions are expanded in the same project view, J keeps walking
    past the end of one session's messages into the next session's.
    Collapsed subtrees are simply skipped (their voice rows aren't
    visible); the user can expand them with ``Right`` first if they
    want to navigate inside.
    """
    rows = ctx.visible_items
    if not rows:
        return
    start = ctx.cursor_index
    rng = (range(start + 1, len(rows)) if direction > 0
           else range(start - 1, -1, -1))
    for i in rng:
        item, kind = rows[i]
        if kind != 'normal':
            continue
        if getattr(item, 'row_bg', None) is not None:
            ctx.cursor_to(item.id)
            return
    ctx.message('no more voice messages this way')


def _action_next_voice(ctx):
    """Jump cursor down to the next user/assistant text row."""
    _jump_to_voice(ctx, +1)


def _action_prev_voice(ctx):
    """Jump cursor up to the previous user/assistant text row."""
    _jump_to_voice(ctx, -1)


def _latest_voice_among_children(item_id):
    """Latest voice id among the **direct** children of ``item_id``.

    Single-level: returns the id of the latest (last-in-listing-order)
    voice row that would become visible if ``item_id`` were expanded.
    Does NOT recurse into grandchildren. Returns ``None`` if there is
    no voice at this level, or the id doesn't resolve.

    Implemented in terms of ``get_children`` so the umbrella structure
    is honoured uniformly — ``<prompt>`` umbrellas advertise themselves
    as voice via ``row_bg``, ``<tool>`` umbrellas only do so if the
    assistant has text content, regular leaf voice rows match too.
    """
    if not isinstance(item_id, str):
        return None
    children = get_children(item_id)
    latest = None
    for it in children:
        if getattr(it, 'row_bg', None) is not None:
            latest = it.id
    return latest


def _outer_subagent_group_id(path):
    """If ``path`` is a subagent's ``.jsonl``, return its outer-row id.

    Subagent transcripts live at::

        <project_dir>/<parent_session_id>/subagents/agent-<aid>.jsonl

    and the parent session shows them as collapsible rows with id
    ``<parent_session_path>#agent:<aid>``. That outer row is the
    framework-visible parent of every record inside the subagent —
    if it isn't expanded, none of the subagent's records are
    reachable. Used by ``_ancestor_ids_for`` to prepend it to the
    chain so cursor preservation works across t-toggle from anywhere
    inside a subagent.
    """
    if not isinstance(path, str):
        return None
    parent_dir = os.path.dirname(path)
    if os.path.basename(parent_dir) != 'subagents':
        return None
    sess_dir = os.path.dirname(parent_dir)
    sess_path = sess_dir + '.jsonl'
    if not os.path.isfile(sess_path):
        return None
    name = os.path.basename(path)
    if not name.startswith('agent-') or not name.endswith('.jsonl'):
        return None
    aid = name[len('agent-'):-len('.jsonl')]
    return f'{sess_path}#agent:{aid}'


def _ancestor_ids_for(item_id):
    """Return ids of every ancestor of ``item_id`` (root → direct parent).

    Walks the tree built in ``_scan_tree``. Every leaf in the displayed
    tree is wrapped in at least one umbrella (``<prompt>`` / ``<tool>``
    / ``<system>``), so the chain consists exclusively of umbrella ids
    and subagent-group ids — never of raw message ids.

    Crosses file boundaries:

      * Records inside a subagent's ``.jsonl`` walk up through their
        in-file umbrellas, then across to the
        ``<parent_session_path>#agent:<aid>`` subagent group row, then
        further into that group's own ancestors (its dispatching
        ``<tool:Task>`` umbrella and that umbrella's containing
        ``<prompt>``).
      * Top-level umbrellas inside a subagent jsonl still nest under
        the outer subagent group — same prepend rule.

    Without this full walk a t-toggle from inside a subagent (where
    refresh wiped the cached children) can't reach the outer chain,
    leaves it un-expanded, and cursor_to fails to find the target row
    in the visible list.
    """
    if not isinstance(item_id, str) or '#' not in item_id:
        return []

    # Subagent group: parent is the ``<tool:Task>`` umbrella in the
    # outer session (the assistant that dispatched is wrapped in its
    # own tool umbrella in the new model).
    if '#agent:' in item_id:
        parent_session_path, _, aid = item_id.partition('#agent:')
        if not os.path.isfile(parent_session_path):
            return []
        ptd = _scan_tree(parent_session_path)
        asst_line = ptd.agent_to_assistant_line.get(aid)
        if asst_line is None:
            return []
        parent_id = f'{parent_session_path}#tool:{asst_line}'
        return _ancestor_ids_for(parent_id) + [parent_id]

    # ``<tool>`` umbrella: parent is the containing ``<prompt>``.
    if '#tool:' in item_id:
        path, _, suffix = item_id.partition('#tool:')
        n = _parse_int(suffix)
        if n is None or not os.path.isfile(path):
            return []
        td = _scan_tree(path)
        turn_line = td.tool_to_turn_root_line.get(n)
        if turn_line is None:
            # Orphan tool umbrella (shouldn't happen in practice).
            outer = _outer_subagent_group_id(path)
            return (_ancestor_ids_for(outer) + [outer]
                    if outer is not None else [])
        parent_id = f'{path}#prompt:{turn_line}'
        return _ancestor_ids_for(parent_id) + [parent_id]

    # ``<prompt>`` umbrella: top-level in its file, but cross to outer
    # subagent chain if the file is a subagent jsonl.
    if '#prompt:' in item_id:
        path, _, _ = item_id.partition('#prompt:')
        outer = _outer_subagent_group_id(path)
        if outer is None:
            return []
        return _ancestor_ids_for(outer) + [outer]

    # ``<system>`` span umbrella: same shape as ``<prompt>`` — top-level
    # in its file, unless the file is a subagent jsonl.
    if '#span:' in item_id:
        path, _, _ = item_id.partition('#span:')
        outer = _outer_subagent_group_id(path)
        if outer is None:
            return []
        return _ancestor_ids_for(outer) + [outer]

    # Regular message id (leaf): look up its parent umbrella, then walk
    # up from there.
    path, _, lineno = item_id.rpartition('#')
    n = _parse_int(lineno)
    if n is None or not os.path.isfile(path):
        return []
    td = _scan_tree(path)
    parent_id = td.parent_id_of.get(n)
    if parent_id is None:
        # Orphan leaf — likely a top-level metadata record that the
        # scan didn't wrap in a span. Still cross to outer subagent.
        outer = _outer_subagent_group_id(path)
        return (_ancestor_ids_for(outer) + [outer]
                if outer is not None else [])
    return _ancestor_ids_for(parent_id) + [parent_id]


def _chain_expand_then_cursor(b, ancestor_ids, target_id):
    """Sequentially expand ``ancestor_ids`` (root → leaf), then ``cursor_to``.

    Each ``expand`` resolves only after its children are cached, which
    is exactly when the next ``expand`` can read them. Without this
    chaining the expands fire in parallel, the cursor_to runs before
    any of them populate the visible list, and cursor_to no-ops
    (leaving the cursor on the scope_root). Used for cursor-on-open
    and the t-toggle's walk-up-and-expand path.
    """
    if not ancestor_ids:
        b.cursor_to(target_id)
        return
    def _step(i):
        if i >= len(ancestor_ids):
            b.cursor_to(target_id)
            return
        b.expand(ancestor_ids[i], autoscroll=True).then(lambda: _step(i + 1))
    _step(0)


def _action_tree_right(ctx):
    """Right-arrow override: expand + jump to latest voice in tree mode.

    Flat mode: replicate the framework default (collapsed row → expand;
    already-expanded row → step into first child). Tree mode: same,
    but after expanding a node, walk down to the latest voice inside
    that subtree and land the cursor there. Reads better than leaving
    the cursor on the now-expanded parent row.
    """
    cur = ctx.cursor
    if cur is None:
        return
    expanded = ctx.state.expanded
    expandable = getattr(cur, 'has_children', False)

    # Flat mode (or any non-tree-mode situation): emulate the default
    # ``_nav_right`` — expand collapsed, step-into for already-expanded.
    if not _TREE_MODE or not expandable:
        if expandable and cur.id not in expanded:
            ctx.expand(cur.id, autoscroll=True)
            return
        # Step into first child if cursor's next visible row is deeper.
        try:
            vis = ctx.visible_items
        except AttributeError:
            return
        idx = ctx.cursor_index
        if (expandable
                and 0 <= idx < len(vis) - 1):
            # ctx.visible_items returns (item, kind) tuples; the
            # depth-comparison live in the framework's state. We don't
            # have direct depth access here, so just nudge cursor one
            # row down — the framework's expand-then-render guarantees
            # the next row is the first child.
            ctx.cursor_to(vis[idx + 1][0].id)
        return

    target_id = cur.id
    if target_id in expanded:
        # Already expanded — jump to the latest voice one level down.
        # User can press Right again to drill further; no auto-deep-dive.
        latest = _latest_voice_among_children(target_id)
        if latest and latest != target_id:
            ctx.cursor_to(latest)
        return

    # Collapsed expandable row: expand, then cursor to the latest voice
    # among the newly-visible direct children. Single level — drilling
    # further is user-driven. ``autoscroll=True`` parks the framework's
    # scroll-to-fit goal so the parent row stays visible while the
    # subtree slides into view; the subsequent ``cursor_to`` then moves
    # the cursor to the latest voice without scrolling the parent off
    # the top.
    def _land():
        latest = _latest_voice_among_children(target_id)
        if latest is not None and latest != target_id:
            ctx.cursor_to(latest)
    ctx.expand(target_id, autoscroll=True).then(_land)


def _action_toggle_tree(ctx):
    """Flip flat ↔ tree view; preserve cursor on the same message id.

    Flat→tree: the cursor's message may end up several levels deep
    inside a turn-root that's collapsed by default. Walk the ``parentUuid``
    chain from the target up to root, add each ancestor to the
    framework's ``expanded`` set, then ``refresh()`` (which refetches the
    root + every expanded parent) and ``cursor_to`` the original id.

    Tree→flat: messages are direct children of the session in flat mode,
    so no ancestors to expand — refresh + cursor_to is enough.
    """
    global _TREE_MODE
    target_id = None
    cur = ctx.cursor
    if cur is not None:
        target_id = cur.id

    _TREE_MODE = not _TREE_MODE
    ctx.message(f"view: {'tree' if _TREE_MODE else 'flat'}")

    # Compute ancestor chain BEFORE refresh (we need a stable read of
    # the file; refresh doesn't touch the on-disk content).
    ancestors = _ancestor_ids_for(target_id) if target_id else []

    pending = ctx.refresh()
    if target_id:
        # After refresh wipes the cache, chain ancestor expands → cursor.
        # Same reasoning as cursor-on-open: cursor_to needs the row to
        # be visible, which requires each ancestor's children to be
        # cached, which is only guaranteed when each expand's Pending
        # resolves before the next runs.
        pending.then(
            lambda: _chain_expand_then_cursor(
                ctx.browser, ancestors, target_id,
            )
        )


def _action_toggle_filter(ctx):
    """Flip voice-only filter on/off using framework ``hidden`` flags.

    Iterates every currently-loaded ``Item`` and emits a single
    ``mod(id, hidden=...)`` batch with one op per row whose target
    visibility differs from its current one. Items not yet loaded
    (children of collapsed umbrellas) get their ``hidden`` set on
    next expansion — the builders consult the live
    ``_FILTER_VOICE_ONLY`` global.

    Cursor migration on filter-on is handled entirely by the
    framework's post-``apply_ops`` hide-displacement hook (walks back
    to the nearest still-visible row, falls back to the first
    visible). Selection state is preserved as-is; ``ctrl-A``
    (``_select_all_visible``) is already WYSIWYG.
    """
    global _FILTER_VOICE_ONLY
    _FILTER_VOICE_ONLY = not _FILTER_VOICE_ONLY
    ops = []
    for item in ctx.all_items():
        want_hidden = not _passes_filter(item.id)
        if bool(getattr(item, 'hidden', False)) != want_hidden:
            ops.append(mod(item.id, hidden=want_hidden))
    if ops:
        ctx.update_data(ops)
    # Umbrella previews compose from non-hidden children, so every
    # cached preview is potentially stale after a filter flip. Drop
    # every cached entry; ``drop_preview_cache`` will kick the worker
    # for the current preview cursor and flag a redraw, preserving
    # view state (a user pinned to the tail keeps following).
    ctx.drop_preview_cache()
    ctx.message(
        f"voice-only filter: {'on' if _FILTER_VOICE_ONLY else 'off'}"
    )


