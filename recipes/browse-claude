#!/usr/bin/env -S browse-tui --run-py
"""browse-claude — Claude Code project / session / message browser.

Lazily walks ``~/.claude/projects/<encoded-path>/<session>.jsonl`` files,
exposing a four-level hierarchy:

  level 0: projects    (the encoded-path subdirs of ~/.claude/projects)
  level 1: sessions    (the .jsonl files within a project)
  level 2: messages    (records within a session)
       OR  subagents   (when the session has dispatched subagents)
  level 3: subagent messages (records within a subagent .jsonl)

Subagents live on disk at
``~/.claude/projects/<encoded-cwd>/<session-id>/subagents/agent-<id>.jsonl``,
optionally accompanied by an ``agent-<id>.meta.json`` describing the
``agentType`` and ``description``. ``<encoded-cwd>`` is derived from the
cwd at dispatch time (every ``/`` and ``.`` becomes ``-``), so a session
that runs inside a git worktree stores its subagents under the worktree's
project dir — NOT necessarily the dir holding the main ``<session>.jsonl``.
The legacy co-located layout is just the special case where the cwd never
left the project root. Either way they appear as sibling rows alongside
the session's top-level messages — pick one to drill into its own
transcript. See ``_candidate_subagents_dirs`` / ``_resolve_agent_jsonl``
for the cross-project-dir lookup.

Identifiers are kept simple and dispatchable purely by shape:
  * project ids are absolute paths to the project directory.
  * session ids are absolute paths to the .jsonl file.
  * message ids are ``'<session_path>#<line_number>'`` strings — this
    holds for both top-level session messages (where ``<session_path>``
    is the main jsonl) and subagent messages (where it's the
    ``agent-<id>.jsonl`` path). The shape collapse means $EDITOR
    actions and message previews work uniformly across both.
  * subagent group ids are ``'<session_path>#agent:<agent_id>'`` —
    distinct shape so ``get_children`` can route them to the subagent's
    own line listing.

Phase-3 simplifications (intentionally out of scope):
  * No delete-session action — too dangerous with no undo.
  * No inotify watch — refresh is manual via ctrl-r.
  * Message lists are capped at 1000 entries per session by default —
    large sessions truncate so the UI stays responsive. Override the
    cap with ``-n NUMBER``. Full content is reachable via the ``e``
    action which opens the underlying ``.jsonl`` in $EDITOR.
"""

import datetime
import json
import os
import re
import sys
import threading

from browse_tui import (
    Action, Browser, BrowserConfig, Item, mod, set_preview_op,
    upsert, visible_items,
)

# Optional md2ansi_lib plugin — colors user/assistant voice content inline.
try:
    from md2ansi_lib import md2ansi as _md2ansi_fn
    if not callable(_md2ansi_fn):
        _md2ansi_fn = None
except Exception:
    _md2ansi_fn = None

# Optional md_doc plugin — turns a message's markdown (its inline content and
# the ``.md`` files it references) into a navigable document subtree. The
# import is guarded exactly like ``md2ansi`` above: when it fails (the sibling
# recipe / its ``md2ansi_lib`` dep isn't importable) ``_md_doc`` is ``None`` and
# the WHOLE feature degrades to a no-op — no message row gains markdown
# children, detection never fires, and ``#md:`` routing is dead code. Every
# other behaviour is unchanged.
try:
    import md_doc as _md_doc
except Exception:
    _md_doc = None

_MD_COLOR = _md2ansi_fn is not None  # default on when available
_BROWSER = None  # set in main() — used for preview-width lookup


def _md_voice(text):
    """Run voice text through md2ansi when colored mode is on."""
    if not _MD_COLOR or _md2ansi_fn is None or not text:
        return text
    try:
        width = (_BROWSER.preview_width if _BROWSER else 0) or 80
        return _md2ansi_fn(text, line_width=width)
    except Exception:
        return text


CLAUDE_ROOT = os.path.join(
    os.environ.get('HOME', os.path.expanduser('~')), '.claude', 'projects',
)

# Cap on messages enumerated per session in flat mode (tree mode is
# uncapped since it only lists umbrellas at the top level). 0 means
# "no cap" — the default after we unified flat with tree mode in #475;
# the framework's virtualised list pane handles 30k+ rows fine. The
# ``-n NUMBER`` argv flag still works as an explicit override for
# users who want a safety valve on truly pathological transcripts.
_MESSAGE_LIMIT = 0


# ---- ANSI palette --------------------------------------------------------
#
# Renderers below splice these into f-strings directly. To re-theme,
# change the constants. To turn color off, ``_init_color()`` zeroes them
# (which makes every f'{COLOR}…{RESET}' a no-op).
#
# 256-color codes chosen to read on a dark background; tweak if you live
# on a light terminal. browse-tui's preview pane learned to pass ANSI
# through in #240; older builds will sanitize these to '?'.

RESET = '\x1b[0m'
BOLD  = '\x1b[1m'
DIM   = '\x1b[2m'
ITAL  = '\x1b[3m'

RED     = '\x1b[38;5;167m'
GREEN   = '\x1b[38;5;108m'
YELLOW  = '\x1b[38;5;179m'
BLUE    = '\x1b[38;5;110m'
MAGENTA = '\x1b[38;5;176m'
CYAN    = '\x1b[38;5;109m'
GRAY    = '\x1b[38;5;244m'
MUTE    = '\x1b[38;5;240m'
WHITE   = '\x1b[38;5;253m'


def _init_color():
    """Disable ANSI when ``NO_COLOR`` is set or stdout isn't a tty.

    ``FORCE_COLOR`` overrides both. Idempotent — once a constant has
    been zeroed it stays zeroed for the process.
    """
    if os.environ.get('FORCE_COLOR'):
        return
    if os.environ.get('NO_COLOR') or not sys.stdout.isatty():
        g = globals()
        for n in ('RESET', 'BOLD', 'DIM', 'ITAL',
                  'RED', 'GREEN', 'YELLOW', 'BLUE', 'MAGENTA', 'CYAN',
                  'GRAY', 'MUTE', 'WHITE'):
            g[n] = ''


def _pop_limit_arg(default):
    """Pop ``-n NUMBER`` (or ``-n=NUMBER``) out of ``sys.argv`` and return it.

    Removed before Browser.run() and the recipe's positional parsing
    see argv. Falls back to ``default`` if absent or non-int.
    """
    i = 1
    while i < len(sys.argv):
        a = sys.argv[i]
        if a == '-n' and i + 1 < len(sys.argv):
            try:
                n = int(sys.argv[i + 1])
            except ValueError:
                i += 1
                continue
            del sys.argv[i:i + 2]
            return n
        if a.startswith('-n='):
            try:
                n = int(a[3:])
            except ValueError:
                i += 1
                continue
            del sys.argv[i]
            return n
        i += 1
    return default


def _pop_value(name, conv=str):
    """Pop ``--name VALUE`` (or ``--name=VALUE``) and return the value.

    Returns ``None`` if the flag is absent. Returns the sentinel
    ``False`` if the flag is present but the value can't be converted
    via ``conv`` — letting the caller report a useful error.
    """
    eq_prefix = f'{name}='
    i = 1
    while i < len(sys.argv):
        a = sys.argv[i]
        if a == name and i + 1 < len(sys.argv):
            raw = sys.argv[i + 1]
            del sys.argv[i:i + 2]
            try:
                return conv(raw)
            except (ValueError, TypeError):
                return False
        if a.startswith(eq_prefix):
            raw = a[len(eq_prefix):]
            del sys.argv[i]
            try:
                return conv(raw)
            except (ValueError, TypeError):
                return False
        i += 1
    return None


def _pop_flag(name):
    """Pop the bare flag ``--name`` and return ``True`` if it was present."""
    i = 1
    while i < len(sys.argv):
        if sys.argv[i] == name:
            del sys.argv[i]
            return True
        i += 1
    return False


# ---- helpers --------------------------------------------------------------


def _decode_project_path(name):
    """Convert a Claude-encoded directory name back to a real path.

    Claude Code names a project directory by replacing every ``/`` in
    the original cwd with ``-``, so ``/home/ubuntu/sandvault/src`` becomes
    ``-home-ubuntu-sandvault-src``. We invert that for the display title
    and collapse the user's HOME prefix to ``~`` so the column stays
    readable (``~/sandvault/src`` rather than ``/home/ubuntu/sandvault/src``).

    Names that don't start with ``-`` are returned verbatim — better to
    show *something* than to crash on an unexpected layout.
    """
    if not name.startswith('-'):
        return name
    p = '/' + name[1:].replace('-', '/')
    home = os.environ.get('HOME') or os.path.expanduser('~')
    if home and p == home:
        return '~'
    if home and p.startswith(home + '/'):
        return '~' + p[len(home):]
    return p


def _human_time(epoch):
    """Compact relative-time formatter (``2m ago``, ``3d ago``, …)."""
    if not epoch:
        return ''
    delta = datetime.datetime.now().timestamp() - epoch
    if delta < 0:
        return 'just now'
    if delta < 60:
        return f'{int(delta)}s ago'
    if delta < 3600:
        return f'{int(delta // 60)}m ago'
    if delta < 86400:
        return f'{int(delta // 3600)}h ago'
    return f'{int(delta // 86400)}d ago'


def _trim(s, n):
    """Strip surrounding whitespace and truncate, preserving inner newlines.

    Replaces the older ``' '.join(s.split())[:n]`` pattern that flattened
    all whitespace. We want multi-line strings (user prompts, agent
    responses, diffs, file contents) to render as multiple lines in the
    session preview rather than one mashed-together blob. Callers that
    must produce a single-line title (the message-list rows) collapse
    further on top of this with ``_oneline``.
    """
    if not isinstance(s, str):
        s = str(s) if s is not None else ''
    return s.strip()[:n]


def _oneline(s):
    """Collapse all whitespace runs to a single space.

    Used for row titles in the message list — the browser renders each
    Item.title on one line, so embedded ``\\n`` would either get
    sanitised or break the row layout.
    """
    return ' '.join(s.split())


def _pid_alive(pid):
    """True iff a process with PID ``pid`` is currently alive.

    ``PermissionError`` (signalling a process owned by another user)
    counts as alive — we can see it via ``kill -0`` semantics.
    """
    if not isinstance(pid, int) or pid <= 0:
        return False
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    return True


# Populated by ``_scan_running_sessions`` at startup; indexed by
# sessionId → {pid, cwd, status, …} read from ``~/.claude/sessions/*.json``.
_RUNNING_INDEX = {}
_RUNNING_ONLY = False   # --running flag — filter to live sessions only.


def _claude_sessions_dir():
    """Sibling of CLAUDE_ROOT that holds per-PID live-session metadata."""
    return os.path.join(
        os.environ.get('HOME', os.path.expanduser('~')),
        '.claude', 'sessions',
    )


def _scan_running_sessions():
    """Refresh ``_RUNNING_INDEX`` from on-disk session metadata.

    Each running ``claude`` process writes ``~/.claude/sessions/<pid>.json``
    with at least ``{sessionId, pid, cwd, status}``. We keep only those
    whose pid is currently alive — stale files from crashed processes
    silently disappear.
    """
    _RUNNING_INDEX.clear()
    sdir = _claude_sessions_dir()
    if not os.path.isdir(sdir):
        return
    try:
        names = os.listdir(sdir)
    except OSError:
        return
    for name in names:
        if not name.endswith('.json'):
            continue
        path = os.path.join(sdir, name)
        try:
            with open(path, 'r', encoding='utf-8', errors='replace') as f:
                data = json.load(f)
        except (OSError, json.JSONDecodeError):
            continue
        if not isinstance(data, dict):
            continue
        pid = data.get('pid')
        sid = data.get('sessionId')
        if not isinstance(pid, int) or not isinstance(sid, str):
            continue
        if not _pid_alive(pid):
            continue
        _RUNNING_INDEX[sid] = data


def _find_session_by_id(sid):
    """Return the absolute .jsonl path for ``sid``, or ``None``.

    Linear scan across project dirs — there's no central index. Each
    project directory contains its own ``<sid>.jsonl`` files; the same
    session id never appears in two project dirs simultaneously, so the
    first hit wins.
    """
    if not isinstance(sid, str) or not sid:
        return None
    if not os.path.isdir(CLAUDE_ROOT):
        return None
    target = f'{sid}.jsonl'
    try:
        names = os.listdir(CLAUDE_ROOT)
    except OSError:
        return None
    for project in names:
        proj_dir = os.path.join(CLAUDE_ROOT, project)
        candidate = os.path.join(proj_dir, target)
        if os.path.isfile(candidate):
            return candidate
    return None


def _find_session_by_pid(pid):
    """Return the .jsonl path for the live session owned by ``pid``."""
    if not isinstance(pid, int) or pid <= 0:
        return None
    path = os.path.join(_claude_sessions_dir(), f'{pid}.json')
    try:
        with open(path, 'r', encoding='utf-8', errors='replace') as f:
            data = json.load(f)
    except (OSError, json.JSONDecodeError):
        return None
    if not isinstance(data, dict):
        return None
    return _find_session_by_id(data.get('sessionId'))


# ---- get_children: dispatches by id shape --------------------------------
#
# The Browser passes the raw item id back into ``get_children``. We use the
# id's shape (None / dir-path / file-path / ``'…#N'`` / ``'…#agent:NAME'``)
# to pick the right enumeration without threading any extra state through.
#
# Order matters: subagent-group ids (``'<sess>#agent:<id>'``) end with
# ``.jsonl`` only on the prefix and contain ``'#agent:'``, so we test for
# that shape before the plain-jsonl branch.


def get_children(item_id, *, reload=False):
    # ``reload=True`` is the framework's explicit "this is a refresh,
    # not an initial fetch" signal — see ``_do_refresh`` in 040-state.py
    # and ticket #407. Honour it at every id shape so the framework can
    # refresh a single subtree (one session file's tree, one subagent's
    # tree, or the entire root) without disturbing the rest.
    #
    # Granularity:
    #   * ``None``                — full wipe (root refresh / Ctrl-R).
    #   * ``<jsonl>``             — bust just that file's _TreeData.
    #   * ``<jsonl>#prompt/tool/span/…`` — bust the containing file's
    #     _TreeData; one umbrella's children are derived from indexes
    #     in the same file's TreeData so anything narrower is moot.
    #   * ``<jsonl>#agent:<aid>`` — bust the subagent's file too.
    #   * project dir            — nothing to bust (no _TreeData).
    if reload and item_id is not None:
        _bust_caches_for(item_id)
    if item_id is None:
        # ``get_children(None)`` fires on initial load AND on
        # ``ctx.refresh()`` / Ctrl-R. The framework distinguishes the
        # two via ``reload=True`` — only an explicit refresh wipes
        # ``_TREE_CACHE`` / ``_TAIL_STATE``. Initial-load callers leave
        # ``reload`` at the default — typical startup sequence already
        # ran ``_scan_tree`` for the user's scope before the root
        # listing fires, and we don't want to throw that work away.
        if reload:
            _TREE_CACHE.clear()
            _TAIL_STATE.clear()
            # Drop the shared markdown parse cache too, so a root Ctrl-R
            # re-reads any referenced ``.md`` files edited on disk. (A
            # per-file ``_bust_caches_for`` can't reach these — they live
            # outside the session tree — so the full wipe is the right
            # granularity.) No-op when md_doc isn't importable.
            if _md_doc is not None:
                _md_doc.clear_cache()
        return _list_projects()
    if isinstance(item_id, str) and '#agent:' in item_id:
        # Tree mode views the subagent .jsonl as its own tree, recursing
        # into _list_tree_roots. Flat mode lists its lines newest-first.
        if _TREE_MODE:
            session_path, _, suffix = item_id.partition('#agent:')
            if not suffix:
                return []
            agent_path = _resolve_agent_jsonl(session_path, suffix)
            if not os.path.isfile(agent_path):
                return []
            return _list_tree_roots(agent_path)
        return _list_subagent_messages(item_id)
    if isinstance(item_id, str) and '#prompt:' in item_id:
        # ``<jsonl>#prompt:<turn_root_line>`` — turn umbrella.
        if _TREE_MODE:
            path, _, suffix = item_id.partition('#prompt:')
            try:
                n = int(suffix)
            except ValueError:
                return []
            return _list_prompt_children(path, n)
        return []
    if isinstance(item_id, str) and '#tool:' in item_id:
        # ``<jsonl>#tool:<assistant_line>`` — tool-execution umbrella.
        if _TREE_MODE:
            path, _, suffix = item_id.partition('#tool:')
            try:
                n = int(suffix)
            except ValueError:
                return []
            return _list_tool_children(path, n)
        return []
    if isinstance(item_id, str) and '#span:' in item_id:
        # ``<jsonl>#span:<start>`` — synthetic <system> umbrella in tree
        # mode. Children are the records of that span.
        if _TREE_MODE:
            path, _, suffix = item_id.partition('#span:')
            try:
                start = int(suffix)
            except ValueError:
                return []
            return _list_span_records(path, start)
        return []
    if isinstance(item_id, str) and _md_doc is not None and '#md:' in item_id:
        # ``<base>#md:…`` — a node inside a message's markdown document
        # subtree (inline doc, file doc, or heading). Built lazily and
        # authoritatively here; mode-agnostic (works in tree AND flat). Dead
        # code when ``_md_doc is None`` (the gate above never let a ``#md:``
        # id be created, so this never fires either way).
        return _md_subtree_children(item_id)
    if isinstance(item_id, str) and '#' in item_id:
        # Regular message id ``<path>#<n>``. When ``md_doc`` is present, a
        # message gains markdown children (its inline document + referenced
        # ``.md`` files) — built lazily here, mode-agnostic. Otherwise it is a
        # leaf in tree mode (umbrellas own all the expansion) and flat mode
        # never had children for these.
        if _md_doc is not None:
            return _md_message_children(item_id)
        return []
    if isinstance(item_id, str) and item_id.endswith('.jsonl') and os.path.isfile(item_id):
        if _TREE_MODE:
            # Tree mode: subagents live inline under their assistant rows,
            # not as a separate prelude at the session level.
            return _list_tree_roots(item_id)
        return _list_session_children(item_id)
    if isinstance(item_id, str) and os.path.isdir(item_id):
        return _list_sessions(item_id)
    # Anything else (unknown) — return empty.
    return []


def _list_projects():
    if not os.path.isdir(CLAUDE_ROOT):
        return []
    out = []
    for name in os.listdir(CLAUDE_ROOT):
        full = os.path.join(CLAUDE_ROOT, name)
        if not os.path.isdir(full):
            continue
        # Project mtime = max(.jsonl mtime) inside it, NOT the dir mtime.
        # Directory mtime only changes on file create/delete/rename — it
        # doesn't update when an existing session is appended to. Using
        # dir mtime would freeze the ordering as soon as a project's
        # session set stabilises, even while the user is actively
        # talking to one of the existing sessions.
        latest = 0.0
        sessions = 0
        running = 0
        try:
            for n in os.listdir(full):
                if not n.endswith('.jsonl'):
                    continue
                sessions += 1
                sid = n[:-len('.jsonl')]
                if sid in _RUNNING_INDEX:
                    running += 1
                try:
                    m = os.stat(os.path.join(full, n)).st_mtime
                except OSError:
                    continue
                if m > latest:
                    latest = m
        except OSError:
            pass
        # --running: hide projects with no live sessions.
        if _RUNNING_ONLY and not running:
            continue
        tag = f'{sessions} sess · {_human_time(latest)}'
        if running:
            tag = f'{running}/{sessions} live · {_human_time(latest)}'
        item = Item(
            id=full,
            title=_real_project_path(full),
            tag=tag,
            tag_style=('green' if running else 'dim'),
            has_children=sessions > 0,
        )
        item.kind = 'project'
        item.encoded_name = name
        item.session_count = sessions
        item.running_count = running
        item.mtime = latest
        out.append(item)
    # Most-recently-active project first — matches what people actually
    # want to look at when opening the browser cold.
    out.sort(key=lambda it: -it.mtime)
    return out


def _list_sessions(project_dir):
    out = []
    try:
        names = os.listdir(project_dir)
    except OSError:
        return []
    for name in names:
        if not name.endswith('.jsonl'):
            continue
        full = os.path.join(project_dir, name)
        try:
            st = os.stat(full)
        except OSError:
            continue
        # Line count is a fast O(file-size) proxy for message count and
        # subsumes the "is this session non-empty?" check we need for
        # has_children. Cheaper than json-parsing every line just to count.
        try:
            with open(full, 'rb') as f:
                count = sum(1 for _ in f)
        except OSError:
            count = 0
        sid = name[:-len('.jsonl')]
        running_meta = _RUNNING_INDEX.get(sid)
        # --running: hide sessions whose claude process isn't alive.
        if _RUNNING_ONLY and not running_meta:
            continue
        n_subs = _count_subagents(full)
        tag = f'{count} msg'
        if n_subs:
            tag += f' · {n_subs} sub'
        tag += f' · {_human_time(st.st_mtime)}'
        if running_meta:
            tag = f'pid {running_meta["pid"]} · ' + tag
        item = Item(
            id=full,
            title=sid,
            # When this session becomes the current scope, show the
            # full filesystem path on the synthetic scope-header row
            # (the listing-pane title stays short — the session id).
            # Matches the display you get when opening the session
            # directly from the command line.
            scope_title=full,
            tag=tag,
            tag_style=('green' if running_meta else 'dim'),
            has_children=count > 0 or n_subs > 0,
            # A bare session row anchors a whole other file — a
            # self-contained foreign subtree. ``boundary`` is what the
            # migrated ``_is_cross_file_id`` reads to render the cheap
            # metadata card until the row is committed (scoped/expanded),
            # and what stops a recursive expand from walking the whole
            # transcript in one go.
            boundary=True,
        )
        item.kind = 'session'
        item.line_count = count
        item.subagent_count = n_subs
        item.mtime = st.st_mtime
        item.pid = running_meta['pid'] if running_meta else None
        item.status = running_meta.get('status') if running_meta else None
        out.append(item)
    out.sort(key=lambda it: -it.mtime)
    return out


# ---- subagent discovery --------------------------------------------------
#
# Claude Code stores each session's subagent transcripts at
# ``<project_dir>/<session_id>/subagents/agent-<agent_id>.jsonl``,
# optionally with an adjacent ``agent-<agent_id>.meta.json`` containing
# ``{agentType, description}``. We surface them as sibling rows of the
# top-level messages so a session list reads as one flat timeline of
# what happened in that session — main-thread messages interleaved
# with the subagent groups it dispatched.


def _subagents_dir(session_jsonl_path):
    """Return the ``<session_id>/subagents`` dir path for a session's .jsonl.

    Doesn't check existence — caller decides what to do if it's absent.
    """
    base, _ = os.path.splitext(session_jsonl_path)
    return os.path.join(base, 'subagents')


# After a Claude Code update, a session that enters a git worktree stores
# its subagent transcripts under the project dir derived from the *cwd at
# dispatch time* — not the project dir holding the session .jsonl. So the
# co-located ``<session>/subagents`` dir (the legacy layout) is no longer
# the only place to look. The helpers below resolve subagents across both
# the legacy co-located dir AND every cwd-derived dir the session touched.


def _encode_project_path(cwd):
    """Encode a cwd into its Claude project-dir name.

    Forward of ``_decode_project_path``: Claude Code names a project dir
    by replacing every ``/`` and ``.`` in the cwd with ``-`` (so e.g.
    ``/home/u/proj/.worktrees/wt`` → ``-home-u-proj--worktrees-wt``).
    ``_decode_project_path`` is lossy (it can't tell a ``-`` apart from a
    ``/`` or ``.``), so we encode directly here rather than inverting it.
    """
    return cwd.replace('/', '-').replace('.', '-')


# Cache distinct-cwd scans by (path, size, mtime) so repeated listings
# (count + enumerate + drill-in) don't re-read the file.
_SESSION_CWDS_CACHE = {}
_CWD_RE = re.compile(rb'"cwd"\s*:\s*"([^"]*)"')


def _session_cwds(session_jsonl_path):
    """Return the set of distinct ``cwd`` strings recorded in a session.

    Cheap single-pass regex over the raw bytes (no JSON parse). Cached by
    ``(path, size, mtime)`` so we read each session file at most once per
    on-disk revision.
    """
    try:
        st = os.stat(session_jsonl_path)
    except OSError:
        return set()
    key = (session_jsonl_path, st.st_size, st.st_mtime)
    cached = _SESSION_CWDS_CACHE.get(key)
    if cached is not None:
        return cached
    cwds = set()
    try:
        with open(session_jsonl_path, 'rb') as f:
            for m in _CWD_RE.finditer(f.read()):
                try:
                    cwds.add(m.group(1).decode('utf-8'))
                except UnicodeDecodeError:
                    continue
    except OSError:
        cwds = set()
    _SESSION_CWDS_CACHE[key] = cwds
    return cwds


def _collapse_home(path):
    """Collapse a leading ``$HOME`` to ``~`` for display (else verbatim)."""
    if not path:
        return path
    home = os.environ.get('HOME') or os.path.expanduser('~')
    if home and path == home:
        return '~'
    if home and path.startswith(home + '/'):
        return '~' + path[len(home):]
    return path


def _real_project_cwd(project_dir):
    """The true cwd a Claude project directory was encoded from, or ``None``.

    Reads the ``cwd`` recorded in the project's sessions (via the
    ``_session_cwds`` byte-regex scan) rather than inverting the dir name —
    ``_decode_project_path`` is lossy because it can't tell a real ``-``
    from an encoded ``/``/``.``. We prefer a cwd that round-trips back to
    this directory (``_encode_project_path(cwd) == basename``): that pins
    the canonical cwd even for a worktree session whose records carry extra
    dispatch cwds, and is order-independent. Lacking an exact match we
    return any recorded cwd (sorted for determinism), and ``None`` only
    when no session here carries a readable ``cwd`` (e.g. an empty dir).
    """
    try:
        names = sorted(
            n for n in os.listdir(project_dir) if n.endswith('.jsonl')
        )
    except OSError:
        return None
    base = os.path.basename(project_dir.rstrip('/'))
    fallback = None
    for name in names:
        cwds = _session_cwds(os.path.join(project_dir, name))
        for cwd in sorted(cwds):
            if _encode_project_path(cwd) == base:
                return cwd
            if fallback is None:
                fallback = cwd
    return fallback


def _real_project_path(project_dir):
    """Display path for a project dir, hyphen-faithful, HOME→``~`` collapsed.

    The accurate counterpart to ``_decode_project_path``: derives the path
    from a session's recorded ``cwd`` (see ``_real_project_cwd``) so a real
    hyphen in a directory name survives instead of being mangled into ``/``.
    Falls back to the lossy name-decode only when no session here carries a
    readable ``cwd`` (an empty project dir), so we always show *something*.
    """
    cwd = _real_project_cwd(project_dir)
    if cwd:
        return _collapse_home(cwd)
    return _decode_project_path(os.path.basename(project_dir.rstrip('/')))


def _session_cwd_and_root(session_jsonl_path):
    """``(cwd, project_root)`` for a session — the resolver's path anchors.

    ``cwd`` is the session's recorded working directory (its containing
    project dir's ``_real_project_cwd``; ``None`` if unreadable).
    ``project_root`` is the git root above ``cwd`` (nearest ``.git``
    ancestor) when one exists, else the session's real project directory —
    the actual filesystem path (not HOME-collapsed), so callers can
    ``os.path.join`` against it. Both fall back gracefully: an unreadable
    session yields ``(None, <lossy decoded project dir>)``.

    Consumed by the markdown reference resolver to anchor relative ``.md``
    references against the right roots.
    """
    project_dir = os.path.dirname(session_jsonl_path)
    cwd = _real_project_cwd(project_dir)
    if cwd:
        root = _md_doc.find_git_root(cwd) or cwd
        return cwd, root
    # No readable cwd (e.g. an empty project dir): best-effort root from the
    # lossy dir-name decode, expanded to a real absolute path so callers can
    # join against it.
    decoded = _decode_project_path(os.path.basename(project_dir.rstrip('/')))
    return None, os.path.expanduser(decoded)


def _candidate_subagents_dirs(session_jsonl_path):
    """Ordered, deduped, existing-only subagent dirs for a session.

    Legacy co-located dir first (so the common non-worktree case keeps
    today's behaviour and stays the first match), then one
    ``<CLAUDE_ROOT>/<encode(cwd)>/<sid>/subagents`` per distinct session
    cwd (where a worktree session's subagents actually land).
    """
    sid = os.path.basename(os.path.splitext(session_jsonl_path)[0])
    seen = set()
    out = []

    def _add(d):
        if d in seen:
            return
        seen.add(d)
        if os.path.isdir(d):
            out.append(d)

    _add(_subagents_dir(session_jsonl_path))
    for cwd in _session_cwds(session_jsonl_path):
        _add(os.path.join(
            CLAUDE_ROOT, _encode_project_path(cwd), sid, 'subagents'))
    return out


def _resolve_agent_jsonl(session_jsonl_path, agent_id):
    """Path to ``agent-<id>.jsonl``, searching all candidate dirs.

    Returns the first existing match across candidate dirs. When none
    exist, falls back to the legacy co-located path STRING (not checked
    for existence) so callers' ``os.path.isfile`` guards behave exactly
    as before for a truly-absent agent.
    """
    name = f'agent-{agent_id}.jsonl'
    for d in _candidate_subagents_dirs(session_jsonl_path):
        p = os.path.join(d, name)
        if os.path.isfile(p):
            return p
    return os.path.join(_subagents_dir(session_jsonl_path), name)


def _count_subagents(session_jsonl_path):
    """Cheap count of distinct subagent .jsonl files for one session.

    Fast path: the legacy co-located dir is checked first and, when it
    holds any agents, returned directly without scanning session cwds.
    Only when it's absent/empty do we fall back to the cwd-derived dirs
    (the worktree-relocated layout), deduping agent ids across them.
    """
    def _agent_ids(sub_dir):
        try:
            return {
                n[len('agent-'):-len('.jsonl')]
                for n in os.listdir(sub_dir)
                if n.startswith('agent-') and n.endswith('.jsonl')
            }
        except OSError:
            return set()

    colocated = _agent_ids(_subagents_dir(session_jsonl_path))
    if colocated:
        return len(colocated)
    ids = set()
    for sub_dir in _candidate_subagents_dirs(session_jsonl_path):
        ids |= _agent_ids(sub_dir)
    return len(ids)


def _read_subagent_meta(meta_path):
    """Return ``{agentType, description}`` from a subagent meta.json or ``{}``."""
    try:
        with open(meta_path, 'r', encoding='utf-8', errors='replace') as f:
            data = json.load(f)
    except (OSError, json.JSONDecodeError):
        return {}
    if not isinstance(data, dict):
        return {}
    return data


def _list_subagents_for_session(session_jsonl_path):
    """Enumerate subagent group items for one session.

    Each subagent gets one row whose id encodes both the parent session
    and the agent id, so ``get_children`` can route it without needing
    to remember any per-row state.
    """
    out = []
    seen_ids = set()
    for sub_dir in _candidate_subagents_dirs(session_jsonl_path):
        try:
            names = os.listdir(sub_dir)
        except OSError:
            continue
        for name in names:
            if not (name.startswith('agent-') and name.endswith('.jsonl')):
                continue
            agent_id = name[len('agent-'):-len('.jsonl')]
            # Dedup across dirs: the first candidate (legacy co-located)
            # wins so the common case is untouched.
            if agent_id in seen_ids:
                continue
            agent_path = os.path.join(sub_dir, name)
            try:
                st = os.stat(agent_path)
            except OSError:
                continue
            seen_ids.add(agent_id)
            try:
                with open(agent_path, 'rb') as f:
                    count = sum(1 for _ in f)
            except OSError:
                count = 0
            # Read meta from the SAME dir the agent file was found in.
            meta = _read_subagent_meta(
                os.path.join(sub_dir, f'agent-{agent_id}.meta.json'),
            )
            agent_type = meta.get('agentType') or 'agent'
            description = meta.get('description') or ''
            # Title surfaces the description (what the agent was asked to
            # do) since the agent_id is opaque. Falls back to the id for
            # agents without a meta file.
            title = description or f'agent {agent_id}'
            item = Item(
                id=f'{session_jsonl_path}#agent:{agent_id}',
                title=title,
                tag=f'{agent_type} · {count} msg · {_human_time(st.st_mtime)}',
                tag_style='magenta',
                has_children=count > 0,
                # Subagent transcripts live in their own .jsonl — a
                # self-contained foreign subtree. ``boundary`` stops
                # recursive/multi-expansion at the group row and keeps
                # the agent's lines out of a parent's preview cascade
                # (the attribute ``_is_cross_file_id`` / ``_walk_umbrella``
                # consult instead of the old ``'#agent:' in id`` shape
                # test). Orphan rows inherit it via this builder.
                boundary=True,
            )
            item.kind = 'subagent'
            item.agent_id = agent_id
            item.agent_type = agent_type
            item.agent_description = description
            item.session_path = session_jsonl_path
            item.subagent_path = agent_path
            item.line_count = count
            item.mtime = st.st_mtime
            # Voice stripe: the dispatching assistant call is voice, so
            # the subagent umbrella that represents it carries the
            # assistant-row background colour.
            bg = _ROW_BG_FOR_KIND.get('subagent')
            if bg is not None:
                item.row_bg = bg
            out.append(item)
    # Newest-first ordering matches the rest of the recipe.
    out.sort(key=lambda it: -it.mtime)
    return out


def _list_session_children(jsonl_path):
    """Return subagent groups + top-level messages for a session.

    Subagents come first (most users want to see what was dispatched
    before scrolling through hundreds of main-thread messages).
    Sessions without any subagents render exactly as before.
    """
    subs = _list_subagents_for_session(jsonl_path)
    msgs = _list_messages(jsonl_path)
    return subs + msgs


def _list_subagent_messages(item_id):
    """Children for a subagent group: the lines of its .jsonl."""
    session_path, _, suffix = item_id.partition('#agent:')
    if not suffix:
        return []
    agent_id = suffix
    agent_path = _resolve_agent_jsonl(session_path, agent_id)
    if not os.path.isfile(agent_path):
        return []
    return _list_messages(agent_path)


def _list_messages(jsonl_path, limit=None):
    """List messages in **chronological** order (oldest first).

    Matches tree-mode ordering so the cursor-jump-to-latest-voice and
    the t-toggle don't visually flip the conversation on the user.

    Reads from the cached ``_TREE_CACHE[jsonl_path].records`` so we
    don't re-walk the whole file on every navigation. ``_scan_tree``
    populates the cache the first time we visit the path (and
    bootstraps ``_TAIL_STATE`` so the live-tail worker can resume
    from where the scan stopped). Empty/invalid lines (``None`` in
    ``records``) are skipped without surfacing a fake row — the
    ``V`` action can still extract their raw bytes via
    ``line_offsets`` if the user wants to inspect them.

    ``limit`` truncates from the **start** of the file (so the user
    keeps the most recent messages — they're scrolling toward the
    tail anyway). ``limit=0`` (the default after #475) disables
    truncation entirely.
    """
    if limit is None:
        limit = _message_limit
    if not os.path.isfile(jsonl_path):
        return [Item(
            id=f'__err__:{jsonl_path}',
            title=f'[error] no such file: {jsonl_path}',
            tag='err',
            tag_style='red',
        )]
    td = _scan_tree(jsonl_path)
    total = len(td.records)
    truncated = bool(limit) and total > limit
    start = total - limit if truncated else 0

    out = []
    if truncated:
        older = start
        out.append(Item(
            id=f'{jsonl_path}#__truncated__',
            title=f'({older} older entries hidden; press e to view file)',
            tag='…',
            tag_style='dim',
        ))
    for n in range(start, total):
        obj = td.records[n]
        if obj is None:
            continue
        kind = _kind_of(obj)
        item_id = f'{jsonl_path}#{n}'
        item = Item(
            id=item_id,
            title=_oneline(_summarise_message(obj)),
            tag=_row_tag(kind, obj),
            tag_style=_TAG_STYLE_FOR_KIND.get(kind, ''),
            # Optimistic markdown-subtree detection — see ``_tree_item``. The
            # feature is mode-agnostic, so flat-mode rows gain the same arrow;
            # ``get_children`` returns the document nodes regardless of mode.
            has_children=_md_has_children(obj),
            hidden=not _passes_filter(item_id, td),
        )
        item.kind = 'message'
        item.line_no = n
        item.session_path = jsonl_path
        item.message_kind = kind
        # Stripe rows that carry actual *speech* — the user typing, or
        # the assistant's text reply. Tool calls (assistant tool_use)
        # and tool results (user tool_result) are machinery, not voice,
        # so they keep the default no-bg look even though their record
        # type is user/assistant.
        if _is_voice(obj):
            bg = _ROW_BG_FOR_KIND.get(kind)
            if bg is not None:
                item.row_bg = bg
        out.append(item)

    return out


# ---- message classification + summary ------------------------------------
#
# Claude Code .jsonl files mix several record shapes:
#   1. ``type=last-prompt``     — bookmark for the most recent prompt.
#   2. ``type=permission-mode`` — permission-mode change events.
#   3. ``type=user``            — user turn (string or content-list).
#   4. ``type=assistant``       — assistant turn (always content-list).
#   5. anything else            — fall back to ``message``.
#
# The summary is one line, capped at 80 chars, and is intentionally lossy:
# the preview pane shows the full pretty-printed JSON, so we optimise the
# title for fast visual scanning.


_TAG_STYLE_FOR_KIND = {
    # Conversation
    'user':                'cyan',
    'assistant':           'green',
    'attachment':          'blue',
    'system':              'gray',
    'tool_use':            'yellow',
    'tool_result':         'yellow',
    # Inter-agent voice: leader → worker SendMessage (send) and the
    # worker → leader task-notification reply (reply).
    'agent-send':          'green',
    'agent-reply':         'cyan',
    # Bookmarks / state changes
    'last-prompt':         'magenta',
    'permission-mode':     'yellow',
    'pr-link':             'blue',
    'mode':                'red',
    'speculation-accept':  'green',
    'queue-operation':     'cyan',
    # Bookkeeping (folded into card; kept dim in the row list)
    'ai-title':                   'dim',
    'custom-title':               'dim',
    'tag':                        'dim',
    'agent-name':                 'dim',
    'agent-color':                'dim',
    'agent-setting':              'dim',
    'task-summary':               'dim',
    'summary':                    'dim',
    'file-history-snapshot':      'dim',
    'attribution-snapshot':       'dim',
    'content-replacement':        'dim',
    'worktree-state':             'dim',
    'marble-origami-commit':      'dim',
    'marble-origami-snapshot':    'dim',
    'progress':                   'dim',
}


# Row-background highlights for the conversational pulse — applied via
# ``item.row_bg`` so the framework's _write_segments paints the whole
# row (incl. trailing pad) in the colour. Subtle 256-colour cells
# chosen to read on dark terminals without overpowering the foreground:
#   235 = #262626 (near-black neutral) for user prompts
#    17 = #00005f (deep blue)           for assistant responses
_ROW_BG_FOR_KIND = {
    'user':            235,
    'assistant':        17,
    # ``queue-operation`` is the user typing more prompts while Claude
    # is mid-turn — they're voice, just delivered out-of-band. Same
    # stripe as a normal user voice so they read as "human still
    # talking" even though they slot into the open turn rather than
    # opening a new one.
    'queue-operation': 235,
    # Subagent umbrella rows: the dispatching assistant ``Agent`` /
    # ``Task`` call IS voice (it's how the assistant tells the
    # subagent what to do), so the umbrella inherits the assistant
    # stripe. Applies both to inline-wired umbrellas and to orphans
    # surfaced at the top of tree view.
    'subagent':         17,
    # Outbound leader→worker SendMessage — the darkest green in the 256
    # cube (22, #005f00), so the inter-agent voice channel reads distinct
    # from the human (235) and the leader's own assistant turns (17).
    # >>> OVERRIDEN WITH DARK BLUE
    'agent-send':       17, #22,
    # Inbound worker→leader task-notification reply — the darkest cyan
    # (23, #005f5f): a sibling of the send stripe so the two halves of
    # the channel read together but split by direction. The whole point
    # of the kind: redirect the reply off the human stripe.
    # >>> OVERRIDEN WITH DARK BLUE
    'agent-reply':      17, #23,
}


def _is_voice(obj):
    """True iff this record carries actual *speech* (text content).

    The conversational stripe should highlight only what the user or
    assistant literally *said*. A user record whose content is just a
    tool_result wrapper, or an assistant record whose only content is
    a tool_use call, is machinery — kind/tag already calls it out, we
    don't want to dye those rows. ``queue-operation`` records also
    count as voice (the user typed something while Claude was working).

    ``AskUserQuestion`` is the one tool that *is* dialog: the assistant's
    tool_use is the question itself, and the user's tool_result is the
    answer. Both halves count as voice — detected structurally by tool
    name and by the ``{questions, answers}`` shape on ``toolUseResult``.
    ``SendMessage`` (leader → worker) is the same case for the outbound
    half: the assistant's tool_use *is* the message, so it counts as
    voice. Its ``{success, message}`` delivery ack is just a status
    receipt, not voice.
    """
    t = obj.get('type')
    if t == 'queue-operation':
        return bool((obj.get('content') or '').strip())
    if t not in ('user', 'assistant'):
        return False
    msg = obj.get('message') if isinstance(obj.get('message'), dict) else {}
    content = msg.get('content', '')
    if isinstance(content, str):
        return bool(content.strip())
    if isinstance(content, list):
        for p in content:
            if not isinstance(p, dict):
                continue
            pt = p.get('type')
            if pt == 'text' and (p.get('text') or '').strip():
                return True
            if pt == 'tool_use' and p.get('name') in (
                    'AskUserQuestion', 'SendMessage'):
                return True
        if t == 'user':
            tur = obj.get('toolUseResult')
            if isinstance(tur, dict) and 'questions' in tur and 'answers' in tur:
                return True
        return False
    return False


def _passes_filter(item_id, td=None):
    """True iff ``item_id`` should be visible under the current filter.

    Used by every Item builder to derive ``hidden`` and by the live-tail
    worker to detect when a hidden umbrella has crossed the
    voice-bearing threshold. Returns True unconditionally when
    ``_FILTER_VOICE_ONLY`` is off — callers pass through the same
    predicate in both states.

    Predicate body when the filter is on:
      * voice leaf (``<path>#<n>``)  → ``_is_voice(td.records[n])``
      * ``#prompt:N``               → True (turns open at a user voice)
      * ``#tool:N``                 → ``_is_voice(td.records[N])`` (the
                                       mixed text+tool_use case passes)
      * ``#span:N``                 → any voice record in the span
      * ``#agent:...``              → True (subagent umbrella; always
                                       shown — we don't peek into other
                                       files at filter time)
      * unparseable / synthetic id  → True (be permissive; framework
                                       error rows and ``__truncated__``
                                       stay visible)
    """
    if not _FILTER_VOICE_ONLY:
        return True
    if not isinstance(item_id, str) or '#' not in item_id:
        return True
    path, _, suffix = item_id.rpartition('#')
    if suffix.startswith('agent:'):
        return True
    if td is None:
        td = _TREE_CACHE.get(path)
    if td is None:
        return True
    if suffix.startswith('prompt:'):
        return True
    if suffix.startswith('tool:'):
        try:
            n = int(suffix[len('tool:'):])
        except ValueError:
            return True
        if 0 <= n < len(td.records):
            rec = td.records[n]
            if isinstance(rec, dict):
                # Voice if the underlying assistant carries text, OR
                # the tool_use dispatches a resolvable subagent (same
                # rule that gives the umbrella its row stripe in
                # ``_tool_umbrella_item``) — the voice marker
                # propagates up from the subagent through the
                # ``<tool:Agent>`` umbrella, and so should the filter.
                if _is_voice(rec):
                    return True
                return _tool_umbrella_wraps_subagent(rec, td)
        return True
    if suffix.startswith('span:'):
        try:
            n = int(suffix[len('span:'):])
        except ValueError:
            return True
        for rec in td.span_records.get(n, []):
            if isinstance(rec, dict) and _is_voice(rec):
                return True
        return False
    try:
        n = int(suffix)
    except ValueError:
        return True
    if 0 <= n < len(td.records):
        rec = td.records[n]
        if isinstance(rec, dict):
            return _is_voice(rec)
    return True


def _kind_of(obj):
    """Best-effort classifier for one JSONL record.

    Most records map to their raw ``type`` / message role. Two
    refinements for the inter-agent voice channel: an assistant record
    whose salient content is a ``SendMessage`` tool_use is the leader
    voicing a worker (``agent-send``); a ``user`` record that is a
    ``<task-notification>`` is the worker's reply back (``agent-reply``).
    Both drive their own stripe + tag style — without this, the reply
    would inherit the human stripe and be mis-attributed.
    """
    if _is_send_message(obj):
        return 'agent-send'
    if _is_task_notification(obj):
        return 'agent-reply'
    t = obj.get('type')
    if t:
        return t
    msg = obj.get('message') or {}
    if isinstance(msg, dict) and msg.get('role'):
        return msg['role']
    return 'message'


def _row_tag(kind, rec):
    """Row tag for ``rec``.

    Adds ``· <attributionAgent>`` to assistant rows inside subagent
    transcripts so the user can see which sub-type produced the turn
    (e.g. ``assistant · general-purpose``). Other record kinds get the
    bare kind label.
    """
    attr = rec.get('attributionAgent') if isinstance(rec, dict) else None
    if attr and kind == 'assistant':
        return f'{kind} · {attr}'
    return kind


def _summarise_message(obj):
    """One-line summary of a JSONL entry, capped at 400 chars.

    Per-type formatters peel off the salient field without re-parsing
    the record — every input field comes from ``obj`` directly so this
    stays O(line) inside ``_list_messages``.
    """
    t = obj.get('type', '')

    # Metadata records — surface the salient field.
    if t == 'last-prompt':
        prompt = _trim(obj.get('lastPrompt', ''), 5000)
        return f'last-prompt: {prompt}' if prompt else 'last-prompt'
    if t == 'permission-mode':
        return f'permission-mode: {obj.get("permissionMode", "")}'
    if t == 'mode':
        return f'mode: {obj.get("mode", "")}'
    if t == 'ai-title':
        return f'ai-title: {obj.get("aiTitle", "")}'
    if t == 'custom-title':
        return f'custom-title: {obj.get("customTitle", "")}'
    if t == 'tag':
        return f'tag: {obj.get("tag", "")}'
    if t == 'agent-name':
        return f'agent-name: {obj.get("agentName", "")}'
    if t == 'agent-color':
        return f'agent-color: {obj.get("agentColor", "")}'
    if t == 'agent-setting':
        return f'agent-setting: {obj.get("agentSetting", "")}'
    if t == 'task-summary':
        s = _trim(obj.get('summary', ''), 5000)
        return f'task-summary: {s}'
    if t == 'summary':
        s = _trim(obj.get('summary', ''), 5000)
        return f'summary: {s}'
    if t == 'pr-link':
        return f'PR {obj.get("prRepository", "")}#{obj.get("prNumber", "")}'
    if t == 'worktree-state':
        ws = obj.get('worktreeSession')
        if ws is None:
            return 'worktree: (exited)'
        if isinstance(ws, dict):
            return (f'worktree: {ws.get("worktreePath", "")}'
                    f' @ {ws.get("worktreeBranch", "")}')
        return 'worktree-state'
    if t == 'speculation-accept':
        ms = obj.get('timeSavedMs', 0)
        return f'speculation-accept: +{ms/1000:.1f}s saved'
    if t == 'queue-operation':
        c = _trim(obj.get('content', ''), 5000)
        return f'queue {obj.get("operation", "?")}: {c}'
    if t == 'file-history-snapshot':
        snap = obj.get('snapshot') or {}
        n = len(snap) if isinstance(snap, dict) else '?'
        return (f'file-history-snapshot: {n} files'
                + (' (update)' if obj.get('isSnapshotUpdate') else ''))
    if t == 'attribution-snapshot':
        states = obj.get('fileStates') or {}
        return f'attribution-snapshot: {len(states)} files'
    if t == 'content-replacement':
        rep = obj.get('replacements') or []
        return f'content-replacement: {len(rep)} blocks'
    if t == 'marble-origami-commit':
        s = _trim(obj.get('summary', ''), 5000)
        return f'collapse-commit: {s}'
    if t == 'marble-origami-snapshot':
        return f'collapse-snapshot: {len(obj.get("staged") or [])} staged'
    if t == 'progress':
        d = obj.get('data') or {}
        dt = d.get('type', '?') if isinstance(d, dict) else '?'
        return f'progress: {dt}'

    # System events.
    if t == 'system':
        sub = obj.get('subtype', '')
        if sub == 'turn_duration':
            ms = obj.get('durationMs', 0)
            return f'⏱ turn {ms/1000:.2f}s · {obj.get("messageCount", 0)} msgs'
        if sub == 'api_error':
            return f'‼ api_error'
        if sub == 'local_command':
            cmd = _trim(obj.get('content') or obj.get('command', ''), 5000)
            return f'$ {cmd}' if cmd else 'local_command'
        return f'system: {sub}' if sub else 'system'

    # Attachment — pick the most salient field per subtype.
    if t == 'attachment':
        a = obj.get('attachment') if isinstance(obj.get('attachment'), dict) else {}
        sub = a.get('type', '?')
        if sub == 'file':
            return f'📎 file: {a.get("displayPath", a.get("filename", ""))}'
        if sub == 'queued_command':
            p = _trim(a.get('prompt', ''), 5000)
            return f'📥 queued: {p}'
        if sub == 'hook_success':
            ok = a.get('exitCode', 0) == 0
            return (f'{"✓" if ok else "✗"} hook {a.get("hookName", "?")} '
                    f'({a.get("hookEvent", "?")})')
        if sub == 'hook_additional_context':
            return f'+ ctx from {a.get("hookName", "?")}'
        if sub == 'task_reminder':
            return f'🔔 reminder ({a.get("itemCount", 0)})'
        if sub == 'skill_listing':
            return f'📚 skills: {a.get("skillCount", 0)}'
        if sub == 'mcp_instructions_delta':
            return (f'mcp Δ: +{len(a.get("addedNames") or [])}'
                    f' -{len(a.get("removedNames") or [])}')
        if sub == 'deferred_tools_delta':
            return (f'tools Δ: +{len(a.get("addedNames") or [])}'
                    f' -{len(a.get("removedNames") or [])}')
        if sub == 'date_change':
            return f'📅 date: {a.get("newDate", "?")}'
        if sub == 'diagnostics':
            n = len(a.get('files') or [])
            return f'diagnostics: {n} files'
        if sub == 'command_permissions':
            return f'allowed: {", ".join(a.get("allowedTools") or [])}'
        if sub == 'ultrathink_effort':
            return '🧠 ultrathink'
        return f'📎 {sub}'

    # User / assistant — peek into content for salient fragment.
    msg = obj.get('message') if isinstance(obj.get('message'), dict) else {}
    role = msg.get('role') or obj.get('role') or t or ''
    content = msg.get('content', obj.get('content', ''))

    # Assistant with only tool_use parts → format as the tool call.
    if role == 'assistant' and isinstance(content, list):
        only_tool = [p for p in content
                     if isinstance(p, dict) and p.get('type') == 'tool_use']
        any_text = any(isinstance(p, dict) and p.get('type') == 'text'
                       and (p.get('text') or '').strip()
                       for p in content)
        if only_tool and not any_text:
            tu = only_tool[0]
            name = tu.get('name', '?')
            inp = tu.get('input') or {}
            extra = _tool_use_one_line(name, inp)
            return f'🔧 {name}({extra})' if extra else f'🔧 {name}'

    # User with tool_result → distinct prefix + a glance at the output.
    if role == 'user' and isinstance(content, list):
        for p in content:
            if isinstance(p, dict) and p.get('type') == 'tool_result':
                return f'↳ tool_result: {_tool_result_one_line(obj, p)}'

    # Inbound worker→leader reply — a one-liner off the parsed fields
    # rather than dumping the raw ``<task-notification>`` XML wrapper.
    if role == 'user' and _is_task_notification(obj):
        d = _parse_task_notification(_extract_text(content))
        bits = [b for b in (d['task_id'], d['status'], d['summary']) if b]
        return '← ' + ' · '.join(bits) if bits else '← task-notification'

    text = _extract_text(content)
    text = _trim(text, 5000)
    if obj.get('isMeta') and role:
        role = f'{role}/meta'
    if role:
        return f'{role}: {text}' if text else role
    return text or '(empty)'


def _tool_use_one_line(name, inp):
    """Compact one-line summary of a tool's input for the row title."""
    if name == 'Bash':
        return _trim(inp.get('command', ''), 5000)
    if name in ('Read', 'Edit', 'Write'):
        return inp.get('file_path', '')
    if name == 'Grep':
        return f'/{inp.get("pattern", "")}/'
    if name == 'Glob':
        return inp.get('pattern', '')
    if name in ('Agent', 'Task'):
        return inp.get('subagent_type', '?')
    if name == 'Skill':
        return inp.get('skill', '?')
    if name == 'SendMessage':
        recipient, summary, _ = _send_message_fields(inp)
        return f'→ {recipient}: {summary}'
    return ''


def _tool_result_one_line(obj, part):
    """One-liner peek at a tool_result for the row title."""
    tur = obj.get('toolUseResult')
    if isinstance(tur, dict):
        if 'stdout' in tur:
            return _trim(tur.get('stdout', ''), 5000) or '(no output)'
        if 'numFiles' in tur:
            return f'{tur["numFiles"]} files'
        if 'agentType' in tur:
            return f'{tur["agentType"]} → {tur.get("status", "?")}'
        if 'taskId' in tur:
            sc = tur.get('statusChange') or {}
            return f'#{tur["taskId"]} {sc.get("from", "?")}→{sc.get("to", "?")}'
        if 'commandName' in tur:
            return tur['commandName']
    if isinstance(tur, str):
        return _trim(tur, 5000)
    # Fall back to the raw content text.
    content = part.get('content')
    if isinstance(content, str):
        return _trim(content, 5000)
    if isinstance(content, list):
        for p in content:
            if isinstance(p, dict) and p.get('type') == 'text':
                return _trim(p.get('text', ''), 5000)
    return ''


def _extract_text(content):
    """Pull the first useful text fragment out of a content payload.

    Claude Code stores message content in three flavours:
      * a bare string — return as-is.
      * a list of parts, each a dict with ``type=text|thinking|
        tool_use|tool_result`` — return the first ``text`` part's text,
        falling back to a ``[<type>]`` placeholder for non-text parts so
        the user can at least see *what* the message contained.
      * anything else — best-effort ``str()``.
    """
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        for part in content:
            if not isinstance(part, dict):
                continue
            ptype = part.get('type')
            if ptype == 'text':
                return part.get('text', '') or ''
            if ptype == 'thinking':
                # Thinking blocks are usually long; show a marker so the
                # user knows the turn was a thinking-only step before any
                # tool_use parts.
                continue
            if ptype == 'tool_use':
                name = part.get('name', '?')
                return f'[tool_use {name}]'
            if ptype == 'tool_result':
                return f'[tool_result]'
        # Nothing matched — describe the shape rather than the content.
        return f'<{len(content)} parts>'
    if content is None:
        return ''
    return str(content)


# ---- markdown document subtrees (md_doc integration) ---------------------
#
# When ``md_doc`` is importable, a message that contains markdown headings OR
# references existing ``.md`` files on disk becomes expandable into a document
# subtree: an inline ``markdown`` document node plus one node per referenced
# file, each drillable into its own heading tree, recursively. Detection is a
# cheap regex gate run at item-build time (optimistic — it may over-trigger);
# the authoritative tree is built lazily on expand in ``get_children`` and
# self-heals a stale arrow via ``_on_children_loaded``. Ids use the ``#md:``
# codec in ``md_doc`` so routing stays a ``'#md:' in item_id`` substring test.
# The whole section is a no-op when ``_md_doc is None``.


def _message_md_text(rec):
    """The message's markdown text: every ``text`` part + any ``tool_result``
    text, joined with blank lines.

    This is the inline document's source — what ``md_doc.build_doc_tree`` /
    ``md_heading_trigger`` scan for headings. Unlike ``_extract_text`` (which
    returns the *first* useful fragment for a one-line summary), this collects
    ALL prose: every ``type=='text'`` content part, plus the textual body of
    any ``type=='tool_result'`` part (its ``content`` string, or the ``text``
    of its content sub-parts). ``thinking`` and ``tool_use`` parts are skipped
    — they aren't the message's authored markdown. A bare-string ``content`` is
    returned verbatim. Returns ``''`` for a record with no text.
    """
    msg = rec.get('message') if isinstance(rec, dict) else None
    content = msg.get('content') if isinstance(msg, dict) else None
    if isinstance(content, str):
        return content
    if not isinstance(content, list):
        return ''
    chunks = []
    for part in content:
        if not isinstance(part, dict):
            continue
        ptype = part.get('type')
        if ptype == 'text':
            t = part.get('text', '') or ''
            if t:
                chunks.append(t)
        elif ptype == 'tool_result':
            inner = part.get('content')
            if isinstance(inner, str):
                if inner:
                    chunks.append(inner)
            elif isinstance(inner, list):
                for sub in inner:
                    if isinstance(sub, dict) and sub.get('type') == 'text':
                        t = sub.get('text', '') or ''
                        if t:
                            chunks.append(t)
    return '\n\n'.join(chunks)


def _iter_str_leaves(obj):
    """Yield every ``str`` leaf reachable in a nested dict/list ``obj``.

    A short-circuit-friendly depth-first walk over the record's structure —
    the detection gate's cheap alternative to ``json.dumps(rec)``. Dict values
    and list elements are descended; keys are skipped (a JSON key is never a
    document path). The caller can stop pulling at the first match, so a record
    whose first text part already names a ``.md`` file never walks the rest.
    """
    if isinstance(obj, str):
        yield obj
    elif isinstance(obj, dict):
        for v in obj.values():
            yield from _iter_str_leaves(v)
    elif isinstance(obj, list):
        for v in obj:
            yield from _iter_str_leaves(v)


def _record_has_md_ref(rec):
    """True iff any string leaf of ``rec`` contains a ``.md`` reference token.

    Short-circuiting: walks ``rec``'s string leaves (``_iter_str_leaves``) and
    stops at the FIRST ``.md`` hit via ``md_doc.find_md_refs`` — far cheaper
    than serialising the whole record. No ``os.stat`` here (detection is
    optimistic; existence is checked lazily on expand, and a dead token
    self-heals). Sees ``Write``/``Read``/``Edit`` tool paths and prose alike.
    """
    if _md_doc is None:
        return False
    for s in _iter_str_leaves(rec):
        if _md_doc.find_md_refs(s):
            return True
    return False


def _md_has_children(rec):
    """Detection gate: should this message row carry an expansion arrow?

    ``True`` when ``md_doc`` is present AND the message either has a markdown
    heading (``md_heading_trigger`` over its extracted text) or references a
    ``.md`` file anywhere in the record (``_record_has_md_ref``). Pure regex,
    no disk I/O — intentionally *optimistic* (a ``#`` inside a code fence, or a
    ``.md`` token that doesn't resolve, both trigger here and self-heal on the
    first expand). A no-op (``False``) when ``_md_doc is None``.
    """
    if _md_doc is None:
        return False
    if _md_doc.md_heading_trigger(_message_md_text(rec)):
        return True
    return _record_has_md_ref(rec)


def _md_ref_label(abspath, cwd, project_root):
    """Display label for a referenced ``.md`` file, against a single anchor.

    Rendered relative to ONE common anchor so a flat sibling list reads cleanly
    without ``../`` noise: relative to ``project_root`` if the file is inside
    it, else relative to ``cwd`` if inside it, else a ``~``-collapsed absolute
    path. The label lives on the ``Item`` (never in the id — the id is
    abspath-canonical).
    """
    for anchor in (project_root, cwd):
        if anchor and (abspath == anchor or abspath.startswith(anchor.rstrip('/') + '/')):
            return os.path.relpath(abspath, anchor)
    return _collapse_home(abspath)


# Heading level (1..6) → row tag / colour style, matching browse-md's map
# (h1 loud red at the top, cycling down to a muted gray h6).
_MD_HEADING_STYLE = {
    1: 'red', 2: 'yellow', 3: 'green', 4: 'blue', 5: 'magenta', 6: 'gray',
}


def _md_heading_item(base, abspaths, node):
    """Map an ``md_doc`` heading ``MdNode`` to a tree-row ``Item``.

    Id = ``compose_md_id(base, abspaths, node.line_offset)`` — selecting the
    heading by its line within the chain's last document. ``has_children`` is
    authoritative (we already have the parsed node), so heading rows never need
    self-heal. ``boundary`` is left ``False`` — a heading is same-document
    structure, not a foreign subtree.
    """
    item = Item(
        id=_md_doc.compose_md_id(base, abspaths, line_offset=node.line_offset),
        title=node.title,
        tag=f'h{node.level}',
        tag_style=_MD_HEADING_STYLE.get(node.level, ''),
        has_children=bool(node.children),
    )
    item.kind = 'md-heading'
    item.md_level = node.level
    return item


def _md_file_item(base, abspaths, label):
    """Map a referenced ``.md`` file to a document tree-row ``Item``.

    ``abspaths`` is the full chain ending in this file (so the id nests under
    its referrer). ``has_children`` is optimistically ``True`` — we have not
    read the file yet; it self-heals on expand if the file has no headings and
    no further refs. ``boundary=True`` marks it a self-contained foreign
    subtree so recursive/multi-expansion stops at it.
    """
    item = Item(
        id=_md_doc.compose_md_id(base, abspaths),
        title=label,
        tag='md',
        tag_style='blue',          # cross-file / attachment hue (vs dim inline)
        has_children=True,         # optimistic; self-heals on expand
        boundary=True,
    )
    item.kind = 'md-doc'
    item.md_abspath = abspaths[-1]
    return item


def _md_resolved_refs(text, doc_dir, cwd, project_root):
    """Resolve the ``.md`` refs in ``text`` to existing abspaths.

    Returns a list of ``(abspath, label)`` pairs: each captured token resolved
    via ``md_doc.resolve_md_ref`` (existing-only — unresolved tokens dropped),
    deduped by abspath (first occurrence wins), and sorted by label so the flat
    sibling list reads stably. ``doc_dir`` is the referencing document's own
    directory (``cwd`` for the inline document, ``dirname(file)`` for a file).
    """
    seen = set()
    out = []
    for captured in _md_doc.find_md_refs(text):
        abspath = _md_doc.resolve_md_ref(
            captured, doc_dir=doc_dir, cwd=cwd, project_root=project_root)
        if abspath is None or abspath in seen:
            continue
        seen.add(abspath)
        out.append((abspath, _md_ref_label(abspath, cwd, project_root)))
    out.sort(key=lambda pair: pair[1])
    return out


def _md_message_children(base):
    """Children of a markdown message row ``<base>`` (``<session>#<n>``).

    The authoritative build (lazy, on expand): an inline ``markdown`` document
    node (only when the message's own text actually parses to ≥1 heading) plus
    one ``[md]`` node per *existing* ``.md`` file referenced ANYWHERE in the
    record — prose or tool path — deduped by abspath and sorted by label. A
    ref that appears in the inline text surfaces here as a message-level
    sibling, not under the ``markdown`` node (which stays a pure heading index);
    this yields one unified list of every file the message references directly
    under it. Returns ``[]`` when neither holds (the optimistic detection arrow
    then self-heals).
    """
    path = base.partition('#')[0]
    suffix = base.rpartition('#')[2]
    try:
        n = int(suffix)
    except ValueError:
        return []
    rec = _read_jsonl_line(path, n)
    if rec is None:
        return []

    out = []
    # Inline document node — only when the message's own text has a heading.
    text = _message_md_text(rec)
    if _md_doc.build_doc_tree(text):
        inline = Item(
            id=_md_doc.compose_md_id(base, []),
            title='markdown',
            tag='md',
            tag_style='dim',       # muted same-file index (vs blue file docs)
            has_children=True,     # confirmed ≥1 heading
            boundary=False,        # inline content is same-file, not foreign
        )
        inline.kind = 'md-doc'
        out.append(inline)

    # File document nodes — every existing ``.md`` ref in the whole record.
    cwd, project_root = _session_cwd_and_root(path)
    doc_dir = cwd or project_root
    # Gather refs across the record's string leaves (prose + tool paths), in
    # document order, then resolve/dedup/sort uniformly via the file's text
    # path. We feed the concatenated leaves so one ``find_md_refs`` pass and
    # one dedup cover the whole record.
    record_text = '\n'.join(_iter_str_leaves(rec))
    for abspath, label in _md_resolved_refs(
            record_text, doc_dir, cwd or '', project_root or ''):
        out.append(_md_file_item(base, [abspath], label))
    return out


def _md_chain_doc(base, abspaths):
    """Resolve a ``#md:`` chain's *last* document to ``(text, doc_tree)``.

    The chain's terminal document is what both the subtree build and the
    preview route operate on: a non-empty ``abspaths`` ends in a referenced
    file (read + parsed once via ``md_doc.get_doc``'s process-wide cache); an
    empty chain is the message's own inline content (``_message_md_text`` of the
    ``<base>`` record, parsed with ``build_doc_tree``). Returns ``(None, None)``
    when the document is unreadable / the base id has no valid line number — the
    callers treat that as "no children / empty preview".
    """
    if abspaths:
        try:
            return _md_doc.get_doc(abspaths[-1])
        except OSError:
            return None, None
    suffix = base.rpartition('#')[2]
    try:
        n = int(suffix)
    except ValueError:
        return None, None
    rec = _read_jsonl_line(base.partition('#')[0], n)
    if rec is None:
        return None, None
    text = _message_md_text(rec)
    return text, _md_doc.build_doc_tree(text)


def _md_subtree_children(item_id):
    """Children for a ``#md:`` node — the lazy, authoritative build.

    Routes on the parsed id shape (``md_doc.parse_md_id`` → ``(base, abspaths,
    line_offset)``):

      * **heading** (``line_offset`` set) → the sub-headings nested under it
        (walk the chain's last document tree to the node at ``line_offset``,
        return its children as heading rows). No reference children — refs live
        at the document level, not under a heading.
      * **inline document** (``abspaths == []``, no ``line_offset``) → the
        top-level heading rows of the message's inline text. Its refs already
        surface at the message level above, so none are added here.
      * **file document** (``abspaths`` non-empty, no ``line_offset``) → the
        top-level heading rows of that file PLUS a ``[md]`` node per existing
        ``.md`` ref in THAT file's own text (resolved against the file's own
        directory), nested onto the chain. Recursion (file → file) falls out of
        this uniform rule; expand-in-place, no cycle/alias detection.

    File text + tree come from ``md_doc.get_doc`` (process-wide cache). Returns
    ``[]`` for an unreadable/heading-less document (self-heals the arrow).
    """
    base, abspaths, line_offset = _md_doc.parse_md_id(item_id)
    path = base.partition('#')[0]

    text, doc_tree = _md_chain_doc(base, abspaths)
    if doc_tree is None:
        return []

    # Heading node → its nested sub-headings (no ref children).
    if line_offset is not None:
        node = _md_doc.node_at_line(doc_tree, line_offset)
        if node is None:
            return []
        return [_md_heading_item(base, abspaths, ch) for ch in node.children]

    # Document node → top-level headings, then (file docs only) ref children.
    out = [_md_heading_item(base, abspaths, node) for node in doc_tree]
    if abspaths:
        cwd, project_root = _session_cwd_and_root(path)
        doc_dir = os.path.dirname(abspaths[-1])
        for ref_abspath, label in _md_resolved_refs(
                text, doc_dir, cwd or '', project_root or ''):
            out.append(_md_file_item(base, abspaths + [ref_abspath], label))
    return out


def _preview_md_node(item_id):
    """Preview body for a ``#md:`` document or heading node.

    Reads ONLY the node's own document — never a cross-item cascade:

      * **document node** (no ``line_offset``) → that document's full text:
        the message's inline content (empty chain) or the referenced file's
        text (``md_doc.get_doc`` cache).
      * **heading node** (``…#<lineoffset>``) → just that heading's section,
        sliced ``text[byte_offset : byte_offset + byte_size]`` from the cached
        ``doc_tree`` (the boundary rule includes the heading's own sub-sections
        and stops at the next sibling-or-shallower heading).

    Both are rendered through ``_md_voice`` — md2ansi when the ``_MD_COLOR``
    toggle is on, raw text otherwise — which already falls back to the raw
    string if md2ansi raises. Returns ``''`` for an unreadable document or a
    line offset that matches no heading.
    """
    base, abspaths, line_offset = _md_doc.parse_md_id(item_id)
    text, doc_tree = _md_chain_doc(base, abspaths)
    if text is None:
        return ''
    if line_offset is None:
        return _md_voice(text)
    node = _md_doc.node_at_line(doc_tree, line_offset)
    if node is None:
        return ''
    return _md_voice(text[node.byte_offset:node.byte_offset + node.byte_size])


# ---- preview rendering ---------------------------------------------------
#
# Per-line preview is built by:
#
#     parse JSONL line  ->  _classify(obj) -> renderer key
#                       ->  _RENDERERS[key](obj) -> body str
#                       ->  body + _fmt_chrome(obj)
#
# Renderers are flat free functions. Each takes the parsed obj and
# returns a ready-to-display string with ANSI inlined via the palette
# constants above. No abstractions: changing a color means editing the
# constant; adding a type means writing _render_X and registering it.


# Color associated with the row tag for each kind (mirrors what the row
# title uses, but applied inside the preview header). Single source of
# truth for the kind→color decision.
_KIND_HEADER_COLOR = {
    'user':            CYAN,
    'assistant':       GREEN,
    'attachment':      BLUE,
    'system':          GRAY,
    'last-prompt':     MAGENTA,
    'permission-mode': YELLOW,
    'pr-link':         BLUE,
    'mode':            RED,
    'speculation-accept': GREEN,
    'queue-operation': CYAN,
}

_STOP_COLOR = {
    'end_turn':      GREEN,
    'tool_use':      YELLOW,
    'max_tokens':    RED,
    'stop_sequence': MUTE,
    'pause_turn':    YELLOW,
}

_PERM_COLOR = {
    'default':           MUTE,
    'plan':              BLUE,
    'acceptEdits':       YELLOW,
    'bypassPermissions': RED,
}


def _read_jsonl_line(path, n):
    """Return the parsed object for line ``n`` of ``path`` or ``None``.

    Serves from ``_TREE_CACHE[path].records[n]`` when the file has
    been scanned (every read path now triggers ``_scan_tree``), so
    previews are O(1) dict lookups rather than O(file_size) line
    iterations. Falls back to a one-off file read for paths the
    scanner hasn't visited yet (rare — covers transient setups).
    ``None`` for missing files, out-of-range lines, blank lines, and
    lines whose JSON failed to parse — re-parsing wouldn't change
    the answer, and the caller surfaces an empty preview either way.
    """
    cached = _TREE_CACHE.get(path)
    if cached is not None:
        if 0 <= n < len(cached.records):
            return cached.records[n]
        return None
    # Fallback: file not yet scanned. Cheaper than a full scan when
    # all we need is one line, but should be hit only at startup
    # races / unusual paths.
    try:
        with open(path, 'r', encoding='utf-8', errors='replace') as f:
            for i, line in enumerate(f):
                if i == n:
                    line = line.rstrip('\n')
                    if not line.strip():
                        return None
                    try:
                        return json.loads(line)
                    except json.JSONDecodeError:
                        return None
    except OSError:
        return None
    return None


_METADATA_TYPES = frozenset([
    'summary', 'ai-title', 'custom-title', 'last-prompt', 'task-summary',
    'tag', 'agent-name', 'agent-color', 'agent-setting', 'pr-link',
    'mode', 'permission-mode', 'worktree-state', 'content-replacement',
    'file-history-snapshot', 'attribution-snapshot', 'speculation-accept',
    'queue-operation', 'marble-origami-commit', 'marble-origami-snapshot',
    'progress',
])


def _classify(obj):
    """Map a parsed JSONL record to a renderer key."""
    if not isinstance(obj, dict):
        return 'unknown'
    t = obj.get('type')
    if t == 'user':       return 'user'
    if t == 'assistant':  return 'assistant'
    if t == 'attachment': return 'attachment'
    if t == 'system':     return 'system'
    if t in _METADATA_TYPES:
        return 'metadata'
    return 'unknown'


# ---- per-record renderers ------------------------------------------------


def _render_user(obj):
    """User turn: plain prompt, tool_result, or synthetic meta entry."""
    msg = obj.get('message') if isinstance(obj.get('message'), dict) else {}
    content = msg.get('content', '')
    is_meta = bool(obj.get('isMeta'))

    # Tool-result branch — an item in content has type=='tool_result'.
    if isinstance(content, list):
        for part in content:
            if isinstance(part, dict) and part.get('type') == 'tool_result':
                return _render_tool_result(obj, part)

    # Inbound worker→leader reply — a small header + the ``<result>``
    # markdown, instead of dumping the raw XML wrapper as a prompt.
    if _is_task_notification(obj):
        return _render_task_notification(_extract_text(content))

    head = f'{WHITE}{BOLD}▶ user{RESET}'
    chips = []
    if is_meta:
        chips.append(f'{MUTE}[meta]{RESET}')
    pmode = obj.get('permissionMode')
    if pmode:
        chips.append(f'{_PERM_COLOR.get(pmode, MUTE)}[{pmode}]{RESET}')
    out = ['  '.join([head] + chips)]
    out.append('')
    out.append(_user_body_text(content))
    return '\n'.join(out)


def _user_body_text(content):
    """Render the textual portion of a user content payload."""
    if isinstance(content, str):
        return _md_voice(content)
    if isinstance(content, list):
        chunks = []
        for part in content:
            if not isinstance(part, dict):
                continue
            t = part.get('type')
            if t == 'text':
                chunks.append(part.get('text', '') or '')
            # tool_result handled in _render_tool_result; tool_use not
            # expected on a user record.
        return _md_voice('\n\n'.join(c for c in chunks if c))
    return str(content) if content is not None else ''


def _render_task_notification(text):
    """Inbound worker→leader reply: a status/summary/output-file header
    then the ``<result>`` rendered as markdown via ``_md_voice``."""
    d = _parse_task_notification(text)
    head = f'{CYAN}{BOLD}← task-notification{RESET}'
    if d['task_id']:
        head += f'  {MUTE}{d["task_id"]}{RESET}'
    out = [head]
    if d['status']:
        out.append(f'{MUTE}status:{RESET} {d["status"]}')
    if d['summary']:
        out.append(f'{MUTE}summary:{RESET} {d["summary"]}')
    if d['output_file']:
        out.append(f'{MUTE}output:{RESET} {d["output_file"]}')
    if d['result']:
        out.append('')
        out.append(_md_voice(d['result']))
    return '\n'.join(out)


def _render_assistant(obj):
    """Assistant turn: text / thinking / tool_use parts in source order.

    The ``message.usage`` block (input / output / cache tokens) is
    emitted by ``_fmt_chrome`` so all per-message metadata stays in
    one place.
    """
    msg = obj.get('message') if isinstance(obj.get('message'), dict) else {}
    parts = msg.get('content') if isinstance(msg.get('content'), list) else []
    model = msg.get('model', '?')
    stop  = msg.get('stop_reason') or ''

    # ⏺ matches Claude Code's own BLACK_CIRCLE convention for assistant
    # turns (src/constants/figures.ts). User turns keep ▶ for visual
    # contrast at a glance.
    head = f'{WHITE}{BOLD}⏺ assistant{RESET}  {MAGENTA}{model}{RESET}'
    if stop:
        head += f'  {_STOP_COLOR.get(stop, MUTE)}[{stop}]{RESET}'
    out = [head, '']

    for part in parts:
        if not isinstance(part, dict):
            continue
        t = part.get('type')
        if t == 'text':
            out.append(_md_voice(part.get('text', '') or ''))
            out.append('')
        elif t == 'thinking':
            text = part.get('thinking', '') or ''
            if not text.strip():
                continue   # signature-only/empty thinking — silent skip
            out.append(_rule('thinking'))
            out.append(f'{GRAY}{ITAL}{text}{RESET}')
            out.append('')
        elif t == 'tool_use':
            out.append(_fmt_tool_use_part(part))
            out.append('')

    return '\n'.join(out).rstrip() + '\n'


def _rule(title='', color=None):
    """A '── title ──' separator line. Default colour is MUTE.

    Pass ``color=YELLOW`` (or any palette constant) to make a rule
    pop — used by the tree-mode preview cascade to clearly mark the
    boundary between the cursor row's content and each of its
    appended children.
    """
    bar = '─' * max(0, 60 - len(title) - 4)
    body = f'── {title} {bar}' if title else '─' * 60
    return f'{color or MUTE}{body}{RESET}'


# ---- tool_use rendering --------------------------------------------------


def _fmt_tool_use_part(part):
    """One ``tool_use`` content part — header + per-tool body."""
    name = part.get('name', '?')
    inp  = part.get('input') or {}
    head = f'{YELLOW}{BOLD}🔧 {name}{RESET}'

    formatter = _TOOL_USE_FORMATTERS.get(name)
    body = formatter(inp) if formatter else _fmt_tool_use_default(inp)
    if not body:
        return head
    return head + '\n' + body


def _fmt_tool_use_default(inp):
    """JSON dump of the tool input, dimmed."""
    if not inp:
        return ''
    try:
        text = json.dumps(inp, indent=2, ensure_ascii=False)
    except (TypeError, ValueError):
        text = str(inp)
    return f'{GRAY}{text}{RESET}'


def _fmt_tool_use_bash(inp):
    cmd = inp.get('command', '')
    desc = inp.get('description', '')
    timeout = inp.get('timeout')
    bg = inp.get('run_in_background')
    out = []
    if desc:
        out.append(f'{MUTE}# {desc}{RESET}')
    out.append(f'{WHITE}$ {cmd}{RESET}')
    extras = []
    if timeout: extras.append(f'timeout={timeout}ms')
    if bg:      extras.append('background')
    if extras:
        out.append(f'{MUTE}({" ".join(extras)}){RESET}')
    return '\n'.join(out)


def _fmt_tool_use_read(inp):
    path = inp.get('file_path', '')
    offset = inp.get('offset')
    limit = inp.get('limit')
    suffix = ''
    if offset is not None or limit is not None:
        suffix = f'  {MUTE}[{offset or 0}..+{limit or "eof"}]{RESET}'
    return f'{CYAN}{path}{RESET}{suffix}'


def _fmt_tool_use_edit(inp):
    path = inp.get('file_path', '')
    old = inp.get('old_string', '')
    new = inp.get('new_string', '')
    out = [f'{CYAN}{path}{RESET}']
    if inp.get('replace_all'):
        out.append(f'{MUTE}(replace_all){RESET}')
    if old or new:
        out.append(_rule('change'))
        for line in old.splitlines() or ['']:
            out.append(f'{RED}- {line}{RESET}')
        for line in new.splitlines() or ['']:
            out.append(f'{GREEN}+ {line}{RESET}')
    return '\n'.join(out)


def _fmt_tool_use_write(inp):
    path = inp.get('file_path', '')
    content = inp.get('content', '')
    return f'{CYAN}{path}{RESET}\n{GRAY}{content}{RESET}'


def _fmt_tool_use_grep(inp):
    pattern = inp.get('pattern', '')
    path = inp.get('path') or '.'
    out = [f'{WHITE}/{pattern}/{RESET}  {MUTE}in{RESET} {CYAN}{path}{RESET}']
    extras = []
    for k in ('glob', 'type', 'output_mode', '-i', '-n', 'multiline', 'head_limit'):
        if k in inp:
            extras.append(f'{k}={inp[k]}')
    if extras:
        out.append(f'{MUTE}{"  ".join(extras)}{RESET}')
    return '\n'.join(out)


def _fmt_tool_use_glob(inp):
    pattern = inp.get('pattern', '')
    path = inp.get('path') or '.'
    return f'{WHITE}{pattern}{RESET}  {MUTE}in{RESET} {CYAN}{path}{RESET}'


def _fmt_tool_use_agent(inp):
    subtype = inp.get('subagent_type', '?')
    desc = inp.get('description', '')
    prompt = inp.get('prompt', '')
    head = (prompt.splitlines()[0] if prompt else '').strip()
    out = [f'{MAGENTA}{subtype}{RESET}  {MUTE}—{RESET} {desc}']
    if head:
        out.append('')
        out.append(head[:400])
    return '\n'.join(out)


def _fmt_tool_use_skill(inp):
    skill = inp.get('skill', '?')
    args = inp.get('args', '')
    return f'{MAGENTA}{skill}{RESET}' + (f'  {MUTE}args:{RESET} {args}' if args else '')


def _fmt_ask_user_question(questions, answers=None, annotations=None):
    """Render an AskUserQuestion payload as markdown.

    Shared by both directions: the tool_use side passes ``answers=None``;
    the tool_result side passes ``answers``/``annotations`` from
    ``toolUseResult``. Output is plain markdown — the caller pipes it
    through ``_md_voice`` so md2ansi (when available) colors it like
    other voice content.
    """
    if not isinstance(questions, list) or not questions:
        return ''
    answers = answers if isinstance(answers, dict) else {}
    annotations = annotations if isinstance(annotations, dict) else {}
    blocks = []
    for q in questions:
        if not isinstance(q, dict):
            continue
        qtext = q.get('question', '')
        blocks.append(_fmt_aq_one(q, answers.get(qtext), annotations.get(qtext)))
    return '\n\n'.join(b for b in blocks if b)


def _fmt_aq_one(q, answer, annotation):  # noqa: ARG001 — annotation reserved
    """Render one question + its options as a markdown block.

    ``answer`` is the user's pick (string or list for multiSelect, or
    None on the tool_use side). Options whose label matches the answer
    flip to a filled glyph. Any answer that doesn't match a known label
    is surfaced separately as ``**Other:** "..."``.
    """
    text = q.get('question', '?')
    header = q.get('header', '')
    multi = bool(q.get('multiSelect'))
    options = q.get('options') or []

    if answer is None:
        selected = set()
    elif isinstance(answer, list):
        selected = {a for a in answer if isinstance(a, str)}
    elif isinstance(answer, str):
        selected = {answer}
    else:
        selected = set()
    option_labels = {o.get('label') for o in options if isinstance(o, dict)}
    other_answers = [a for a in selected if a not in option_labels]

    glyph_off, glyph_on = ('☐', '☑') if multi else ('◯', '●')
    head = f'**{header}:** {text}' if header else f'**{text}**'
    lines = [head, '']
    for i, opt in enumerate(options, 1):
        if not isinstance(opt, dict):
            continue
        label = opt.get('label', '?')
        desc = opt.get('description', '') or ''
        glyph = glyph_on if label in selected else glyph_off
        lines.append(f'{i}. {glyph} **{label}**')
        if desc:
            for ln in desc.splitlines():
                lines.append(f'   {ln}')
        preview = opt.get('preview', '') or ''
        if preview:
            lines.append('')
            lines.append('   ```')
            for ln in preview.splitlines():
                lines.append(f'   {ln}')
            lines.append('   ```')
    for other in other_answers:
        lines.append('')
        lines.append(f'**Other:** "{other}"')
    return '\n'.join(lines)


def _fmt_tool_use_ask_user_question(inp):
    return _md_voice(_fmt_ask_user_question(inp.get('questions')))


def _send_message_fields(inp):
    """``(recipient, summary, message)`` from a ``SendMessage`` input.

    The tool duplicates its fields: prefer ``recipient``/``message``,
    fall back to ``to``/``content``. ``summary`` is a short label.
    """
    inp = inp if isinstance(inp, dict) else {}
    recipient = inp.get('recipient') or inp.get('to') or '?'
    summary = inp.get('summary', '')
    message = inp.get('message')
    if not message:
        message = inp.get('content', '')
    return recipient, summary, message


def _is_send_message(rec):
    """True iff ``rec`` is an assistant record whose salient content is a
    ``SendMessage`` tool_use (mirrors the AskUserQuestion voice branch)."""
    if not isinstance(rec, dict):
        return False
    msg = rec.get('message') if isinstance(rec.get('message'), dict) else {}
    if (rec.get('type') or msg.get('role')) != 'assistant':
        return False
    content = msg.get('content')
    if not isinstance(content, list):
        return False
    for p in content:
        if (isinstance(p, dict) and p.get('type') == 'tool_use'
                and p.get('name') == 'SendMessage'):
            return True
    return False


_TASK_NOTIFY_PREFIX = '<task-notification>'

# Map the wrapper's hyphenated tags onto the dict keys we surface.
_TASK_NOTIFY_TAGS = {
    'task-id': 'task_id',
    'tool-use-id': 'tool_use_id',
    'output-file': 'output_file',
    'status': 'status',
    'summary': 'summary',
    'result': 'result',
}


def _parse_task_notification(text):
    """Peel a ``<task-notification>`` wrapper into its tagged fields.

    Returns ``{task_id, tool_use_id, output_file, status, summary,
    result}`` — every key present, missing tags resolving to ``''``.
    ``result`` is kept as raw markdown (rendered later via ``_md_voice``).
    A single non-greedy regex per tag, not a full XML parse: the payload
    is machine-emitted with a fixed shape and ``result`` is free-form
    markdown that would choke a strict parser.
    """
    text = text or ''
    out = {v: '' for v in _TASK_NOTIFY_TAGS.values()}
    for tag, key in _TASK_NOTIFY_TAGS.items():
        m = re.search(rf'<{tag}>(.*?)</{tag}>', text, re.DOTALL)
        if m:
            out[key] = m.group(1).strip()
    return out


def _is_task_notification(rec):
    """True iff ``rec`` is a ``user`` record whose text content is a
    ``<task-notification>`` wrapper (the worker→leader inbound reply).

    Mirrors ``_is_send_message`` for the outbound half: detection is by
    the wrapper prefix on the record's text content, tolerant of the
    bare-string and single-text-part content shapes.
    """
    if not isinstance(rec, dict):
        return False
    msg = rec.get('message') if isinstance(rec.get('message'), dict) else {}
    if (rec.get('type') or msg.get('role')) != 'user':
        return False
    text = _extract_text(msg.get('content', ''))
    return text.lstrip().startswith(_TASK_NOTIFY_PREFIX)


def _fmt_tool_use_send_message(inp):
    """Outbound leader→worker message: header line + markdown body."""
    recipient, summary, message = _send_message_fields(inp)
    head = f'{BOLD}→ {recipient}{RESET}'
    if summary:
        head += f'  {MUTE}·{RESET} {summary}'
    out = [head]
    if message:
        out.append('')
        out.append(_md_voice(message))
    return '\n'.join(out)


_TOOL_USE_FORMATTERS = {
    'Bash':             _fmt_tool_use_bash,
    'Read':             _fmt_tool_use_read,
    'Edit':             _fmt_tool_use_edit,
    'Write':            _fmt_tool_use_write,
    'Grep':             _fmt_tool_use_grep,
    'Glob':             _fmt_tool_use_glob,
    'Agent':            _fmt_tool_use_agent,
    'Task':             _fmt_tool_use_agent,
    'Skill':            _fmt_tool_use_skill,
    'AskUserQuestion':  _fmt_tool_use_ask_user_question,
    'SendMessage':      _fmt_tool_use_send_message,
}


# ---- tool_result rendering -----------------------------------------------


def _render_tool_result(obj, part):
    """User record carrying a tool_result content part.

    Header derived from the part; body dispatched on the toolUseResult
    shape (the structured record Claude Code stashes alongside the raw
    content for the renderer).
    """
    is_error = bool(part.get('is_error'))
    tu_id = part.get('tool_use_id', '')
    tur = obj.get('toolUseResult')

    head = f'{WHITE}{BOLD}↳ tool_result{RESET}'
    if is_error:
        head += f'  {RED}[error]{RESET}'
    if tu_id:
        head += f'  {MUTE}id={tu_id[:8]}{RESET}'
    out = [head, '']

    body = _fmt_tool_use_result(tur, part.get('content'))
    if body:
        out.append(body)
    return '\n'.join(out).rstrip() + '\n'


def _fmt_tool_use_result(tur, raw_content):
    """Pick a shape-specific formatter for ``toolUseResult``."""
    if tur is None:
        return _fmt_tur_raw_content(raw_content)
    if isinstance(tur, str):
        return tur
    if not isinstance(tur, dict):
        return str(tur)
    keys = set(tur.keys())
    if {'stdout', 'stderr', 'interrupted'}.issubset(keys):
        return _fmt_tur_bash(tur)
    if 'structuredPatch' in keys:
        return _fmt_tur_edit(tur)
    if tur.get('type') == 'text' and 'file' in keys:
        return _fmt_tur_read(tur)
    if 'numMatches' in keys or ('matches' in keys and 'query' in keys):
        return _fmt_tur_grep_or_search(tur)
    if {'filenames', 'numFiles'}.issubset(keys) and 'numLines' not in keys:
        return _fmt_tur_glob(tur)
    if {'filenames', 'numFiles', 'numLines'}.issubset(keys):
        return _fmt_tur_grep_content(tur)
    if 'statusChange' in keys and 'taskId' in keys:
        return _fmt_tur_task_update(tur)
    if 'task' in keys and len(keys) == 1:
        return _fmt_tur_task_dump(tur)
    if 'agentId' in keys and 'agentType' in keys:
        return _fmt_tur_subagent(tur)
    if 'commandName' in keys and 'success' in keys:
        return _fmt_tur_skill(tur)
    # SendMessage delivery ack — shape is exactly ``{success, message}``.
    # Checked after skill (whose ack adds ``commandName``) so the exact
    # key-set match here doesn't shadow it.
    if keys == {'success', 'message'}:
        return _fmt_tur_send_message(tur)
    if 'questions' in keys and 'answers' in keys:
        return _fmt_tur_ask_user_question(tur)
    return _fmt_tur_default(tur)


def _fmt_tur_raw_content(content):
    if isinstance(content, str):
        return content
    if isinstance(content, list):
        chunks = []
        for p in content:
            if isinstance(p, dict) and p.get('type') == 'text':
                chunks.append(p.get('text', '') or '')
        return '\n'.join(chunks)
    return ''


def _fmt_tur_bash(tur):
    out = []
    if tur.get('interrupted'):
        out.append(f'{RED}{BOLD}[interrupted]{RESET}')
    bg = tur.get('backgroundTaskId')
    if bg:
        out.append(f'{MUTE}background task: {bg}{RESET}')
    persisted = tur.get('persistedOutputPath')
    if persisted:
        size = tur.get('persistedOutputSize', '?')
        out.append(f'{MUTE}persisted: {size}B → {persisted}{RESET}')
    stdout = tur.get('stdout', '')
    stderr = tur.get('stderr', '')
    if stdout:
        out.append(stdout.rstrip())
    if stderr:
        if stdout:
            out.append('')
        out.append(_rule('stderr'))
        out.append(f'{RED}{stderr.rstrip()}{RESET}')
    return '\n'.join(out)


def _fmt_tur_edit(tur):
    """Edit/Write result — show the structured patch as a unified diff."""
    patch = tur.get('structuredPatch')
    out = []
    if tur.get('userModified'):
        out.append(f'{YELLOW}[user-modified]{RESET}')
    if isinstance(patch, list):
        for hunk in patch:
            if not isinstance(hunk, dict):
                continue
            old_start = hunk.get('oldStart', '?')
            new_start = hunk.get('newStart', '?')
            out.append(f'{MUTE}@@ -{old_start} +{new_start} @@{RESET}')
            for line in hunk.get('lines') or []:
                if line.startswith('+'):   out.append(f'{GREEN}{line}{RESET}')
                elif line.startswith('-'): out.append(f'{RED}{line}{RESET}')
                else:                      out.append(f'{MUTE}{line}{RESET}')
    elif tur.get('content'):
        # Write tool — no patch, just the new content.
        out.append(f'{CYAN}{tur.get("filePath", "")}{RESET}')
        out.append(f'{GRAY}{tur["content"]}{RESET}')
    return '\n'.join(out)


def _fmt_tur_read(tur):
    f = tur.get('file') or {}
    out = [f'{CYAN}{f.get("filePath", "")}{RESET}  '
           f'{MUTE}{f.get("numLines", "?")} lines{RESET}']
    content = f.get('content', '')
    if content:
        out.append('')
        out.append(content.rstrip())
    return '\n'.join(out)


def _fmt_tur_glob(tur):
    out = [f'{MUTE}{tur.get("numFiles", 0)} files'
           f'{(" — truncated" if tur.get("truncated") else "")}{RESET}']
    for n in tur.get('filenames') or []:
        out.append(f'{CYAN}{n}{RESET}')
    return '\n'.join(out)


def _fmt_tur_grep_content(tur):
    """Grep with content output mode."""
    head = f'{MUTE}{tur.get("numFiles", 0)} files · {tur.get("numLines", 0)} lines{RESET}'
    if tur.get('appliedLimit'):
        head += f'  {YELLOW}[limit applied]{RESET}'
    out = [head, '']
    if tur.get('content'):
        out.append(tur['content'].rstrip())
    return '\n'.join(out)


def _fmt_tur_grep_or_search(tur):
    """Grep count mode or ToolSearch result."""
    if 'query' in tur and 'matches' in tur:
        # ToolSearch
        out = [f'{MUTE}query:{RESET} {WHITE}{tur["query"]}{RESET}',
               f'{MUTE}deferred tools:{RESET} {tur.get("total_deferred_tools", "?")}',
               '']
        for m in tur.get('matches') or []:
            if isinstance(m, dict):
                out.append(f'{YELLOW}{m.get("name", "?")}{RESET}  '
                           f'{MUTE}{m.get("description", "")}{RESET}')
        return '\n'.join(out)
    return f'{MUTE}{tur.get("numFiles", 0)} files · ' \
           f'{tur.get("numMatches", 0)} matches{RESET}'


def _fmt_tur_task_update(tur):
    sc = tur.get('statusChange') or {}
    fields = tur.get('updatedFields')
    head = f'{MUTE}task {RESET}{WHITE}#{tur.get("taskId", "?")}{RESET}'
    if sc:
        head += f'  {sc.get("from", "?")} → {GREEN if tur.get("success") else RED}{sc.get("to", "?")}{RESET}'
    out = [head]
    # ``updatedFields`` shape varies across CC versions: a dict
    # ``{field: new_value}`` on older builds, a list ``[field_name, ...]``
    # on newer ones. Render either without assuming one shape.
    if isinstance(fields, dict):
        for k, v in fields.items():
            out.append(f'{MUTE}{k}:{RESET} {v}')
    elif isinstance(fields, list) and fields:
