    """SendMessage delivery ack: compact ``✓ delivered · <message>`` /
    ``✗ <message>`` with the trailing ``Output: /tmp/…`` path trimmed."""
    ok = bool(tur.get('success'))
    message = tur.get('message', '') or ''
    # The ack message tails with an "Output: /tmp/…/tasks/<id>.output"
