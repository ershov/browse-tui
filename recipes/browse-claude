def _fmt_attach_plan_mode_exit(a):
    exists = a.get('planExists')
    arrow = f'{RED}→{RESET}'
    out = [f'{YELLOW}⇆ mode{RESET}  {arrow} exit plan mode']
    path = a.get('planFilePath')
    if path:
        kept = 'kept' if exists else 'discarded'
