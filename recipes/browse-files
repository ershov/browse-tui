#!/bin/bash
# browse-files — fzf-like single-directory file picker with preview.
# Usage: browse-files [DIR]   (DIR defaults to ".")
# Prints the selected path on stdout (default --on-enter print-exit).
set -euo pipefail

case "${1:-}" in
    -h|--help)
        cat <<'EOF'
browse-files — fzf-like single-directory file picker with preview.

Usage: browse-files [DIR]
  DIR    Directory to list. Defaults to the current directory.

Prints the selected path on stdout. Pipe-friendly:
  EDITOR=vi $(browse-files .)
EOF
        exit 0
        ;;
esac

# Locate the browse-tui binary: PATH first, else sibling of this script.
BIN="$(command -v browse-tui || true)"
[ -n "$BIN" ] && [ -x "$BIN" ] || \
    BIN="$(dirname "$(realpath "$0")")/../browse-tui"

DIR="${1:-.}"

exec "$BIN" \
    --title "browse-files: $DIR" \
    --root-cmd "ls -1A '$DIR'" \
    --input tsv --fields id \
    --preview-cmd '[[ -d "'"$DIR"'/$TUI_ID" ]] && ls -lA --color=always "'"$DIR"'/$TUI_ID" || head -1000 "'"$DIR"'/$TUI_ID" 2>/dev/null' \
    --print-format "$DIR/{id}"
