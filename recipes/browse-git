#!/usr/bin/env -S browse-tui --run-py
"""browse-git — drill from recent commits into changed files into diffs.

Three levels:

  level 0: recent commits        (``git log --oneline -n 1000``)
  level 1: files changed         (``git show --name-only <sha>``)
  level 2: per-file unified diff (``git show <sha> -- <path>``)

The level-0 commit cap defaults to 1000; pass ``-n NUMBER`` to
override.

Identifiers are dispatched by shape:
  * commit ids look like ``<sha>`` (no colon)
  * file ids look like ``<sha>:<path>`` (one colon, sha is the prefix)
  * preview at level 2 = the unified diff for that file in that commit.

Demonstrates: subprocess-driven hierarchy, three levels via id-shape
dispatch, large preview text, and graceful degradation when ``git`` is
absent or the cwd isn't a repo.
"""

import shutil
import subprocess
import sys

from browse_tui import Browser, BrowserConfig, Item


_LOG_LIMIT = 10000


def _pop_limit_arg(default):
    """Pop ``-n NUMBER`` (or ``-n=NUMBER``) out of ``sys.argv`` and return it.

    Removed before Browser.run() sees the argv so the recipe's own knob
    doesn't leak into the help-flag auto-detect or the recipe's other
    positional parsing. Falls back to ``default`` if the flag is absent
    or its value isn't an int.
    """
    i = 1
    while i < len(sys.argv):
        a = sys.argv[i]
        if a == '-n' and i + 1 < len(sys.argv):
            try:
                n = int(sys.argv[i + 1])
            except ValueError:
                i += 1
                continue
            del sys.argv[i:i + 2]
            return n
        if a.startswith('-n='):
            try:
                n = int(a[3:])
            except ValueError:
                i += 1
                continue
            del sys.argv[i]
            return n
        i += 1
    return default


def _run_git(*args):
    """Run ``git args…``; return CompletedProcess (returncode + stdout/err).

    Uses ``check=False`` so the recipe can branch on ``returncode``
    rather than raise. Errors surface as Items / preview text.
    """
    return subprocess.run(['git'] + list(args), check=False,
                          capture_output=True, text=True)


def _err_item(msg):
    """Return a single non-expandable error Item to render in the list."""
    return [Item(id='__error__', title=msg, tag='err', tag_style='red')]


def get_children(item_id, *, reload=False):
    if not shutil.which('git'):
        return _err_item('git CLI not found on PATH')

    if item_id is None:
        # Verify we're inside a git working tree.
        rc = _run_git('rev-parse', '--is-inside-work-tree')
        if rc.returncode != 0:
            return _err_item('not a git repository (or git not available)')
        result = _run_git('log', '--oneline', '-n', str(_log_limit))
        if result.returncode != 0:
            return _err_item(f'git log failed: {result.stderr.strip()}')
        items = []
        for line in result.stdout.splitlines():
            parts = line.split(None, 1)
            if not parts:
                continue
            sha = parts[0]
            msg = parts[1] if len(parts) > 1 else ''
            item = Item(id=sha, title=msg, tag=sha[:7],
                        tag_style='yellow', has_children=True)
            items.append(item)
        return items

    if isinstance(item_id, str) and item_id != '__error__' and ':' not in item_id:
        # Commit sha -> changed files.
        result = _run_git('show', '--name-only', '--format=', item_id)
        if result.returncode != 0:
            return _err_item(f'git show failed: {result.stderr.strip()}')
        items = []
        for path in result.stdout.splitlines():
            path = path.strip()
            if not path:
                continue
            items.append(Item(id=f'{item_id}:{path}', title=path,
                              has_children=False))
        return items

    # Files (level 2) and __error__ have no children.
    return []


def get_preview(item_id):
    if item_id is None or item_id == '__error__':
        return ''
    if not isinstance(item_id, str):
        return ''
    if ':' in item_id:
        # File-in-commit -> unified diff for just that path.
        sha, _, path = item_id.partition(':')
        result = _run_git('show', sha, '--', path)
        return result.stdout if result.returncode == 0 else result.stderr
    # Commit -> stat + message.
    result = _run_git('show', '--stat', item_id)
    return result.stdout if result.returncode == 0 else result.stderr


_HELP_INTRO_TMPL = """\
browse-git — drill from recent commits into changed files into diffs.

Usage: browse-git [-n NUMBER]
  -n NUMBER  Cap the recent-commit list to this many entries
             (default: {default}).

Three levels: a recent ``git log -n {limit}``; the files changed in the
selected commit; and the per-file unified diff for that commit.
Read-only — preview shows the diff (or stat / message at level 0).\
"""


_log_limit = _LOG_LIMIT


def main():
    global _log_limit
    _log_limit = _pop_limit_arg(_LOG_LIMIT)
    sys.exit(Browser(BrowserConfig(
        title='browse-git',
        get_children=get_children,
        get_preview=get_preview,
        help_intro=_HELP_INTRO_TMPL.format(default=_LOG_LIMIT, limit=_log_limit),
    )).run())


if __name__ == '__main__':
    main()
