def context_menu_ref(ctx, item_id):
    """``(label, token)`` rows for a ``('ref', name)`` cursor row.

    The full branch toolkit; no hotkey hints (none duplicate a keybinding).
    Delete uses ``branch -d`` (safe delete — git refuses an unmerged branch)
    behind a confirm.
    """
    return [
        ('Checkout', 'ref.checkout'),
        ('Merge into HEAD', 'ref.merge'),
        ('Rebase HEAD onto this', 'ref.rebase'),
        ('Create branch from here…', 'ref.branch'),
        ('Delete branch', 'ref.delete'),
    ]


# -- status entry ('status', xy, path) --------------------------------------


def _cm_status_stage(ctx, xy, path):
    _git_action(ctx, ['add', '--', path], ok_msg=f'staged {path}')


def _cm_status_unstage(ctx, xy, path):
    _git_action(ctx, ['restore', '--staged', '--', path],
                ok_msg=f'unstaged {path}')


def _cm_status_discard(ctx, xy, path):
    # Irreversible — strong confirm (default No). An untracked file (``??``)
    # has nothing to restore from the index, so it's removed outright; a
    # tracked change is reverted to HEAD's content.
    if xy == '??':
        _git_action(ctx, ['clean', '-f', '--', path],
                    ok_msg=f'removed untracked {path}',
                    confirm_msg=f'Delete untracked file {path}? '
                                'This cannot be undone.', strong=True)
    else:
        _git_action(ctx, ['checkout', '--', path],
                    ok_msg=f'discarded changes in {path}',
                    confirm_msg=f'Discard changes in {path}? '
                                'This cannot be undone.', strong=True)


def _cm_status_diff(ctx, xy, path):
    # Reuse the recipe's status diff-plan (staged / worktree / untracked) and
    # page each section, so the menu Diff matches the preview pane.
    plan = _status_diff_plan(xy, path)
    multi = len(plan) > 1
    sections = []
    for header, argv in plan:
        raw = _git_color(*argv)
        if not raw.strip():
            continue
        body = _colorize_diff(raw)
        sections.append(f'── {header} ──\n{body}' if multi else body)
    text = '\n\n'.join(sections)
    if not text.strip():
        ctx.flash(f'no diff for {path}')
        return
    ctx.page(text, lang='diff')


def _cm_status_open_dir(ctx, xy, path):
    """Open the file's containing directory in browse-fs.

    The path is repo-root relative, so resolve it against the work-tree root
    (matching ``E`` / the launcher path resolve) before taking its dirname; a
    missing ``browse-fs`` on PATH surfaces via ``run_external``'s own error.
    """
    root = _repo_root()
    abspath = os.path.join(root, path) if root else path
    ctx.run_external(['browse-fs', os.path.dirname(abspath) or '.'],
                     keep_screen=True)


def context_menu_status(ctx, item_id):
    """``(label, token)`` rows for a ``('status', xy, path)`` cursor row.

    "Edit in $EDITOR" duplicates the ``E`` action → ``(E)`` hint. Stage /
    Unstage are both always offered (a two-sided ``MM`` entry is both staged
    and unstaged); the underlying git command is a no-op for the side that
    doesn't apply, which git reports cleanly.
    """
    return [
        ('Stage', 'status.stage'),
        ('Unstage', 'status.unstage'),
        ('Discard changes', 'status.discard'),
        ('Edit in $EDITOR (E)', 'status.edit'),
        ('Diff', 'status.diff'),
        ('Open containing dir in browse-fs', 'status.opendir'),
    ]


