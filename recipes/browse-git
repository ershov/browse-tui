def _classify_positionals():
    """Sort the leftover positionals into ``_revs`` / ``_paths``.

    Everything after a literal ``--`` is an unconditional pathspec.
    Otherwise an arg that names an existing path is a pathspec; an arg
    that ``git rev-parse`` confirms as a commit is a rev; anything else
    is fatal (stderr + exit 2). Leftover flag-like tokens (``-h`` /
    ``--help``) before the ``--`` are skipped so the framework's help
    auto-detect still fires.

    Scans ``recipe_argv()`` so the framework's ``--tty`` flag and its
    value are dropped first — otherwise a ``--tty /dev/pts/N`` device
    path would be misclassified as a pathspec (or fail as an unknown
    rev). ``_pop_repo_dir`` may already have removed a leading repo-dir
    positional from ``sys.argv``; ``recipe_argv()`` reads ``sys.argv``
    live, so that removal is honoured here.
    """
    args = recipe_argv()
    if '--' in args:
        cut = args.index('--')
        head, tail = args[:cut], args[cut + 1:]
        _paths.extend(tail)
    else:
        head = args
    for arg in head:
        if arg.startswith('-'):
            continue
        if os.path.exists(arg):
            _paths.append(arg)
            continue
        rc = _run_git('rev-parse', '--verify', '--quiet', f'{arg}^{{commit}}')
        if rc.returncode == 0:
            _revs.append(arg)
            continue
        sys.stderr.write(f'browse-git: unknown path or revision: {arg}\n')
        sys.exit(2)


def _window_title():
    """Title reflecting the active mode and any positional rev/path filter.

    There is no runtime retitle API, so the filter is baked into the
    construction-time title — e.g. ``browse-git [commits: src/ HEAD~5]``.
    ``--all`` shows as the literal ``--all`` token (not the every-branch
    list it expands to). Modes other than ``commits`` don't take a filter,
    so only the mode is shown for them. Stdin mode shows the sniffed kind.
    """
    if _STDIN_KIND is not None:
        return f'browse-git [stdin: {_STDIN_KIND}]'
    parts = (['--all'] if _all_branches else []) + _revs + _paths
    if _mode == 'commits' and parts:
        return f'browse-git [{_mode}: {" ".join(parts)}]'
    return f'browse-git [{_mode}]'


def main():
    global _browser, _log_limit, _mode, _tree_mode, _all_branches
    # ``browse-git -`` ingests git output from stdin (explicit ``-`` only —
    # the bare form never reads stdin). It names the whole data source, so
    # it combines with nothing: any other argument or flag is a usage
    # error. The repo preconditions below are skipped — piped input needs
    # neither git on PATH nor a work tree. The remaining argv plumbing
    # (flag pops, the positional classifier) is inert on a lone ``-``.
    # ``recipe_argv()`` drops the framework's ``--tty`` flag (and its
    # value) first, so a ``-`` that is the VALUE of ``--tty -`` (UI over
    # the std streams, consumed by Browser.run()) is gone and only a
    # genuine stdin ``-`` is left to match here.
    args = recipe_argv()
    # Auto-detect a piped/redirected stdin: when fd 0 is not a tty and the
    # user didn't already type ``-``, synthesize it so a bare
    # ``git diff | browse-git`` ingests the piped output without the
    # explicit token. An interactive tty stdin leaves ``args`` untouched
    # (the bare repo modes never read stdin). The synthesized ``-`` then
    # flows through the same logic below: a lone ``-`` ingests stdin (and
    # skips the repo preconditions); ``- ARG`` (a piped run that still names
    # a rev/path/flag) hits the combine error. Inject into the positional
    # list only — flags still compose via the pops further down. A help
    # request is exempt: ``git diff | browse-git --help`` must still reach
    # ``Browser.run()``'s -h/--help auto-detect, not trip the combine error.
    if ('-' not in args and not os.isatty(0)
            and not any(a in ('-h', '--help') for a in sys.argv[1:])):
        args.append('-')
    if '-' in args:
        if args != ['-']:
            sys.stderr.write('browse-git: - (stdin) cannot be combined '
                             'with other arguments or flags\n')
            sys.exit(2)
        _ingest_stdin()
    # git presence + a work tree are preconditions — fail fast before the
    # TUI launches rather than surfacing an in-list error row. Skip the
    # checks when a help token is present so ``--help`` still reaches
    # Browser.run()'s help auto-detect even outside a repo.
    elif not any(a in ('-h', '--help') for a in sys.argv[1:]):
        if not shutil.which('git'):
            sys.stderr.write('browse-git: git not found on PATH\n')
            sys.exit(2)
        # A leading directory positional pointing at another repo redirects
        # the cwd into it (before the work-tree check below) so the recipe
        # browses THAT repo rather than failing when launched from outside.
        _pop_repo_dir()
        if _run_git('rev-parse', '--is-inside-work-tree').returncode != 0:
            sys.stderr.write('browse-git: not inside a git work tree\n')
            sys.exit(2)

    _log_limit = _pop_limit_arg(_LOG_LIMIT)
    requested_mode = _pop_mode_flag()
    _tree_mode = _pop_tree_arg(_tree_mode)
    _all_branches = _pop_all_arg()
    _classify_positionals()
    if requested_mode is not None:
        _mode = requested_mode

    actions = [
        Action('`', 'Switch view mode', switch_mode, 'none'),
        Action('t', 'Toggle commit graph (--tree)', toggle_tree, 'none'),
        # Detail-display modes — the leading column set (see ``_LEAD_FIELDS``).
        Action('1', 'Display: subject only', lambda c: _set_display_mode(c, 1), 'none'),
        Action('2', 'Display: sha + subject', lambda c: _set_display_mode(c, 2), 'none'),
        Action('3', 'Display: sha/author/date', lambda c: _set_display_mode(c, 3), 'none'),
        Action('E', 'Edit working-tree file in $EDITOR', edit_file, 'cursor'),
    ]
    if _md2ansi_fn is not None:
        actions.append(
            Action('m', 'Toggle md2ansi message coloring', toggle_md, 'none'))

    b = Browser(BrowserConfig(
        title=_window_title(),
        show_children_pane=False,
        get_children=get_children,
        get_preview=get_preview,
        format_row_content=git_row_content,
        actions=actions,
        on_enter=on_enter,
        on_resize=_on_resize,
        # Right-click (or the backslash / F1 keys) on a row opens a menu keyed
        # to the cursor's git-object KIND — checkout / branch / tag / reset on
        # a commit, view / diff / blame on a file, merge / rebase on a ref,
        # stage / discard on a status entry, apply / drop on a stash, etc.,
        # plus a shared Switch-mode entry. See ``on_context_menu``.
        on_context_menu=on_context_menu,
        show_ids='never',
        help_usage=_HELP_USAGE_TMPL.format(
            default=_LOG_LIMIT,
            mode_flags=', '.join('--' + m for m in _MODES)),
        help_intro=_HELP_INTRO,
    ))
    _browser = b
    # Piped-diff mode wraps the file rows under one synthetic ``('sdiff',)``
    # umbrella (a stats row); auto-expand it before the run loop so the file
    # rows are visible immediately — the same posted-expand the single-doc
    # convention uses (a ``b.expand`` issued before ``run()``). Other stdin
    # kinds / repo modes have no umbrella and start as before.
    if _STDIN_KIND == 'diff':
        b.expand(('sdiff',))
    sys.exit(b.run())


if __name__ == '__main__':
    main()
