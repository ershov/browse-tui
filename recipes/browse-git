#!/usr/bin/env -S browse-tui --run-py
"""browse-git — a tig-like browser over a git repository.

Five view modes, switchable by ``--mode NAME`` at launch, by the
backtick (`` ` ``) key at runtime, or auto-selected from positional
arguments:

  commits   recent ``git log`` — drill commit -> changed files -> diff
  status    ``git status`` working-tree entries

In commits mode the log is preceded by up to four synthetic working-change
rows — ``Untracked changes`` / ``Tracked changes`` / ``Staged changes`` /
``Conflicts`` — each shown only when non-empty and drillable into its
files. They honor the same path filter and appear only on an unscoped log
(no positional rev).
  reflog    ``git reflog`` entries
  branches  branches / remotes / tags via ``git for-each-ref``
  stash     ``git stash list``

Every row id is a tagged tuple whose first element is a short string
``kind`` tag, so dispatch is a flat ``id[0]`` match with direct field
access — never a hex-vs-word heuristic or substring scan:

  ('commit', sha)            a commit          -> changed files
  ('file', sha, path)        a file in a commit (leaf) -> per-file diff
  ('ref', refname)           a branch/remote/tag -> commits on that ref
  ('status', xy, path)       a working-tree entry (leaf) -> staged/worktree diff
  ('wc', bucket)             a status group (untracked/tracked/staged/conflicts)
  ('stash', n[, path])       a stash (n int), or a file in one
  ('reflog', n, sha)         a reflog entry (n int) -> changed files
  ('filler', ns, n)          an inert tree-mode connector row (meta; no children)
  ('status_clean',)          the "working tree clean" sentinel (no children)
  ('stash_none',)            the "no stashes" sentinel (no children)
  ('err',)                   an error row (no children)

Because path / refname ride as their own tuple field, a path or ref
containing ':' or '/' is never ambiguous — there is no string to
re-split.

Commit rows render in columns — a yellow short-sha, a dim author and a
dim relative date — followed by the branch / remote / tag refs parsed
from ``%D`` as colored chips (HEAD + local branch, remote, ``tag:``) and
the subject last. Reflog rows keep the older chip layout (short-sha tag
+ selector / relative-date / decoration chips); file rows carry their
A/M/D/R status letter as a colored tag.

Previews honour ANSI: ``git`` emits color via ``-c color.ui=always``
and per-file diffs are rendered through ``delta`` when it is on PATH
(otherwise the git-colored diff is shown verbatim). Commit messages can
be md2ansi-colored when ``md2ansi_lib`` is importable (toggle with
``m``).

Keys: Enter flips expand/collapse of the cursor row; `` ` `` opens the
mode picker; ``t`` toggles the commit-graph column (``--tree``); ``m``
toggles md2ansi message coloring (when available); ``E`` edits the real
working-tree file for file/status rows in $EDITOR; the built-in ``v`` /
``e`` page / edit the preview text.

By default (toggle off with ``--no-tree`` or the ``t`` key) the commit log has a
tig-style graph column: ``git log --graph`` does all the lane assignment
and its art is glyph-substituted and rendered after the date column, with
its connector-only FILLER lines kept as inert blank rows so the lanes line
up. The flag scopes the commit log (commits mode + the ref drill-down).

Read-only with respect to history — the only mutation is ``E``'s
working-tree edit.

In commits mode ``--all`` spans the log over every local branch (git
log's ``--branches``) — equivalent to ``browse-git $(git branch
--format='%(refname:short)')`` — instead of only HEAD's history.

Usage:
  browse-git [<dir>] [-n NUMBER] [--mode NAME] [--no-tree] [--all] [<revs>…] [-- <paths>…]
"""

import os
import re
import shutil
import subprocess
import sys

from browse_tui import (
    Action, Browser, BrowserConfig, Item,
    cell_ljust, default_row_content, sanitize_ansi, style,
)

# Optional md2ansi_lib plugin — gates md2ansi coloring of commit messages.
try:
    from md2ansi_lib import md2ansi as _md2ansi_fn
    if not callable(_md2ansi_fn):
        _md2ansi_fn = None
except Exception:
    _md2ansi_fn = None

_MD_COLOR = _md2ansi_fn is not None  # default on when available

_LOG_LIMIT = 1000
_MODES = ('commits', 'status', 'reflog', 'branches', 'stash')

# Glyph substitution for ``git log --graph`` art (tree mode). Maps git's
# ASCII art to box-drawing / dot glyphs: every node ('*') becomes the same
# dot so git's connectors — not the node shape — convey merges. Built once
# as a str.translate table (see ``_graph_translate``). The art carries git's
# own ANSI colour (``--color=always``), so the substitution is applied only
# to the plain-text runs *between* SGR sequences (see ``_graph_translate`` /
# ``_SGR_RE``) — never to a byte inside an ``\e[…m`` escape.
_GRAPH_GLYPHS = {
    '*': '•',     # commit node           -> bullet (U+2022)
    '|': '│',     # vertical lane         -> box vertical (U+2502)
    #'/': '╱',     # ascending diagonal    -> light up-right diag (U+2571)
    #'\\': '╲',    # descending diagonal   -> light down-right diag (U+2572)
    #'_': '─',     # horizontal connector  -> box horizontal (U+2500)
    '_': '▁',     # horizontal connector  -> lower eights block
}
_GRAPH_TABLE = str.maketrans(_GRAPH_GLYPHS)

# A complete SGR sequence ``\e[ <params> m``. The param class ``[^@-~]*``
# exactly mirrors the kept-set of the framework ``sanitize_ansi`` (a CSI whose
# final byte is ``m``), so EVERY sequence that survives sanitise is matched
# here — not just the ``[0-9;]`` params real git emits. ``_graph_translate``
# splits on this pattern to glyph-substitute the plain runs while passing each
# SGR token through verbatim — guaranteeing no substitution lands inside an
# escape and no colour run is split.
_SGR_RE = re.compile(r'\x1b\[[^@-~]*m')

# Module-level state, all set in main() before the Browser launches.
_log_limit = _LOG_LIMIT
_mode = 'commits'
_tree_mode = True  # --tree / 't' — render git's commit graph as a column (default on)
_browser = None  # set in main() — used for preview-width lookup
_revs = []       # positional revisions scoping commits mode
_paths = []      # positional pathspecs scoping commits mode
_all_branches = False  # --all — span the commits log over every local branch


# ---- argv helper ---------------------------------------------------------


def _pop_limit_arg(default):
    """Pop ``-n NUMBER`` (or ``-n=NUMBER``) out of ``sys.argv`` and return it.

    Removed before Browser.run() sees the argv so the recipe's own knob
    doesn't leak into the help-flag auto-detect or the positional
    classification below. Falls back to ``default`` if the flag is
    absent or its value isn't an int.
    """
    i = 1
    while i < len(sys.argv):
        a = sys.argv[i]
        if a == '-n' and i + 1 < len(sys.argv):
            try:
                n = int(sys.argv[i + 1])
            except ValueError:
                i += 1
                continue
            del sys.argv[i:i + 2]
            return n
        if a.startswith('-n='):
            try:
                n = int(a[3:])
            except ValueError:
                i += 1
                continue
            del sys.argv[i]
            return n
        i += 1
    return default


def _pop_mode_arg():
    """Pop ``--mode NAME`` (or ``--mode=NAME``) out of ``sys.argv``.

    Returns the chosen mode name, or ``None`` if the flag is absent. An
    unknown mode name is fatal (stderr + exit 2) — the user asked for a
    view that doesn't exist.
    """
    i = 1
    while i < len(sys.argv):
        a = sys.argv[i]
        value = None
        if a == '--mode' and i + 1 < len(sys.argv):
            value = sys.argv[i + 1]
            del sys.argv[i:i + 2]
        elif a.startswith('--mode='):
            value = a.split('=', 1)[1]
            del sys.argv[i]
        else:
            i += 1
            continue
        if value not in _MODES:
            sys.stderr.write(
                f'browse-git: unknown mode {value!r}; '
                f'choose one of {", ".join(_MODES)}\n')
            sys.exit(2)
        return value
    return None


def _pop_tree_arg(default):
    """Pop the ``--tree`` / ``--no-tree`` toggle out of ``sys.argv``.

    Returns ``True`` for ``--tree``, ``False`` for ``--no-tree``, or
    ``default`` when neither appears. Every occurrence is removed (so the
    flag never leaks into the positional classifier) and the LAST one wins,
    so ``--tree --no-tree`` resolves to off. Mirrors ``_pop_mode_arg``'s
    in-place argv editing.
    """
    chosen = default
    i = 1
    while i < len(sys.argv):
        a = sys.argv[i]
        if a == '--tree':
            chosen = True
            del sys.argv[i]
        elif a == '--no-tree':
            chosen = False
            del sys.argv[i]
        else:
            i += 1
    return chosen


def _pop_all_arg():
    """Pop the ``--all`` flag out of ``sys.argv``; return ``True`` if present.

    ``--all`` spans the commits-mode log over every local branch — equivalent
    to launching ``browse-git $(git branch --format='%(refname:short)')``,
    realised as ``git log --branches`` (see ``_commits_root``) so it also
    stays correct on a detached HEAD, where that branch-name expansion would
    feed a bogus ``(HEAD detached …)`` token to the positional classifier.
    Every occurrence is removed (so the flag never reaches the positional
    classifier or ``Browser.run()``); mirrors ``_pop_tree_arg``'s in-place
    argv editing.
    """
    found = False
    i = 1
    while i < len(sys.argv):
        if sys.argv[i] == '--all':
            found = True
            del sys.argv[i]
        else:
            i += 1
    return found


def _pop_repo_dir():
    """Honor a leading directory positional that points at another repo.

    ``browse-git <dir>`` should browse the repo at ``<dir>`` even when the
    cwd is unrelated (or not a repo at all). If the first non-flag
    positional is a directory whose git work tree differs from the cwd's,
    ``chdir`` into that tree and drop the arg from ``sys.argv`` so it isn't
    re-read as a pathspec by ``_classify_positionals``. All later git
    invocations then run against the new cwd.

    A directory that is a *subdir of the current repo* resolves to the same
    toplevel, so it's left in place to keep working as a pathspec filter.
    Runs before the precondition check so launching from outside a repo
    still works. Only the leading positional is considered; trailing dir
    args stay pathspecs.
    """
    i = 1
    while i < len(sys.argv):
        a = sys.argv[i]
        if a == '--':
            return
        if a.startswith('-'):
            i += 1
            continue
        if not os.path.isdir(a):
            return
        top = _run_git('-C', a, 'rev-parse', '--show-toplevel')
        if top.returncode != 0:
            return
        cwd_top = _run_git('rev-parse', '--show-toplevel')
        if cwd_top.returncode == 0 and cwd_top.stdout == top.stdout:
            return
        os.chdir(top.stdout.strip())
        del sys.argv[i]
        return


# ---- subprocess + colorization helpers -----------------------------------


def _run_git(*args):
    """Run ``git args…``; return CompletedProcess (returncode + stdout/err).

    Uses ``check=False`` so the recipe can branch on ``returncode``
    rather than raise. Errors surface as Items / preview text.
    """
    return subprocess.run(['git'] + list(args), check=False,
                          capture_output=True, text=True)


def _git_color(*args):
    """Return colored output of ``git -c color.ui=always <args>``.

    Forces SGR even though stdout is a pipe; used for ``show --stat``,
    per-file diffs, and ref summaries whose color should always be present
    regardless of the ``delta`` fallback path.

    Prefers stdout whenever it's non-empty, only falling back to stderr
    when stdout is empty. This keeps ``git diff --no-index`` working: that
    command exits non-zero whenever the files differ (always, for
    ``/dev/null`` vs a real file) yet still writes the diff to stdout, so a
    plain ``rc == 0`` gate would discard a perfectly good untracked diff.
    """
    result = _run_git('-c', 'color.ui=always', *args)
    return result.stdout or result.stderr


def _colorize_diff(raw):
    """Render an already-git-colored diff for the preview pane.

    Contract: ``raw`` is the diff text produced *once* by the caller,
    already SGR-colored (e.g. via ``_git_color('show', …)`` which runs
    with ``color.ui=always``). When ``delta`` is on PATH the text is
    piped through it for terminal-native rendering; ``delta`` parses the
    colored diff and re-emits its own SGR. When ``delta`` is absent the
    git-colored ``raw`` is returned unchanged — so either path yields
    ANSI-bearing text and the caller never has to generate the diff
    twice.

    ``--no-gitconfig`` ignores the user's theme and suppresses the OSC-8
    hyperlink emission the preview pane can't render; ``--paging never``
    stops delta spawning a pager off-tty; ``--width`` matches the pane
    (read from the module-level ``_browser`` since ``get_preview`` gets
    no ``ctx``).
    """
    if shutil.which('delta'):
        width = (_browser.preview_width if _browser else 0) or 80
        proc = subprocess.run(
            ['delta', '--no-gitconfig', '--paging', 'never',
             '--width', str(width)],
            input=raw, capture_output=True, text=True, check=False)
        if proc.returncode == 0:
            return proc.stdout
        # delta failed unexpectedly — fall back to the git-colored text.
    return raw


def _md_message(text):
    """Return ``text`` md2ansi-colored when the toggle + library allow it."""
    if _MD_COLOR and _md2ansi_fn is not None and text:
        try:
            width = (_browser.preview_width if _browser else 0) or 80
            return _md2ansi_fn(text, line_width=width)
        except Exception:
            pass
    return text


def _parse_decorations(deco, remotes=None):
    """Parse a ``%D`` decoration string into ``[(text, style)]`` chips.

    ``%D`` is the bare decoration form (no surrounding parens), e.g.
    ``HEAD -> main, tag: v1.0, origin/main, feature/x``. Tokens are split
    on ``', '`` and classified:

      * ``HEAD -> name`` → a ``HEAD`` chip plus the pointed-at branch
        (``HEAD`` styled green, the branch by its own kind);
      * ``tag: name``    → yellow ``name`` chip;
      * a remote-tracking ref (leading segment is a known remote, e.g.
        ``origin/main``) → blue;
      * any other token  → a local branch, cyan (so a local branch named
        ``feature/x`` is NOT mistaken for a remote).

    ``remotes`` is the set of remote names (``{'origin'}``) used to tell a
    remote-tracking ref from a slash-bearing local branch; when ``None``
    it's looked up once via ``git remote``. ``HEAD`` alone (detached)
    yields a single green ``HEAD`` chip. An empty decoration yields no
    chips. The framework's chip styler only honours named palette styles,
    so the HEAD chip uses ``'green'`` (the palette has no bold-green
    entry).
    """
    chips = []
    deco = (deco or '').strip()
    if not deco:
        return chips
    if remotes is None:
        remotes = _git_remotes()
    for token in deco.split(', '):
        token = token.strip()
        if not token:
            continue
        if token.startswith('HEAD -> '):
            chips.append(('HEAD', 'green'))
            branch = token[len('HEAD -> '):].strip()
            if branch:
                chips.append((branch, _ref_style(branch, remotes)))
        elif token == 'HEAD':
            chips.append(('HEAD', 'green'))
        elif token.startswith('tag: '):
            chips.append((token[len('tag: '):].strip(), 'yellow'))
        else:
            chips.append((token, _ref_style(token, remotes)))
    return chips


def _ref_style(name, remotes):
    """Style a plain ref: remote-tracking refs blue, local branches cyan.

    A ref is remote-tracking when its leading path segment is one of the
    repo's remote names (``origin/main`` with ``origin`` a remote). A
    local branch carrying a ``/`` (``feature/x``) stays cyan.
    """
    head = name.split('/', 1)[0]
    return 'blue' if '/' in name and head in remotes else 'cyan'


_REMOTES_CACHE = None


def _git_remotes():
    """Return the set of configured remote names (cached for the session)."""
    global _REMOTES_CACHE
    if _REMOTES_CACHE is None:
        result = _run_git('remote')
        _REMOTES_CACHE = (
            set(result.stdout.split()) if result.returncode == 0 else set())
    return _REMOTES_CACHE


# Status letter → tag_style. Shared by the commit/reflog file lists
# (name-status letters) and status mode (porcelain XY → one letter).
_STATUS_LETTER_STYLE = {
    'A': 'green',
    'M': 'yellow',
    'D': 'red',
    'R': 'cyan',
    'C': 'cyan',
    'T': 'yellow',
    'U': 'red',
    '?': 'dim',
}


def _parse_name_status(text):
    """Parse ``git show --name-status`` output into ``[(status, path)]``.

    Each line is ``<STATUS>\\t<path>`` (add/modify/delete) or, for renames
    and copies, ``<STATUS>\\t<old>\\t<new>`` where ``STATUS`` carries a
    similarity score (``R100`` / ``C75``). Returns the single status
    letter and the path to display — the *new* path for renames/copies,
    which is also what the resulting ``('file', sha, path)`` id keys on.
    """
    rows = []
    for line in text.splitlines():
        if not line.strip():
            continue
        parts = line.split('\t')
        if len(parts) < 2:
            continue
        status = parts[0][:1]  # drop the similarity score on R/C
        path = parts[-1]       # new path for renames/copies; the path otherwise
        rows.append((status, path))
    return rows


def _parse_porcelain_z(data):
    """Parse ``git status --porcelain -z`` bytes-as-text into ``[(XY, path)]``.

    The ``-z`` form is NUL-terminated and never quotes paths, so paths with
    spaces / odd chars survive verbatim — chosen over the line-based
    ``--porcelain`` (which C-quotes such paths and uses an inline
    ``orig -> new`` arrow for renames).

    Each entry is ``XY<space><path>`` where ``XY`` is exactly the first two
    columns (either may be a space for one-sided changes — `` M``, ``M ``,
    ``MM``, ``??``…). For a rename/copy (``X`` is ``R`` or ``C``) git emits
    the entry's path then a SECOND NUL field carrying the old path; we keep
    the new path and skip the old one. Returns ``[(XY, new_path)]``.
    """
    fields = [f for f in data.split('\x00') if f != '']
    rows = []
    i = 0
    while i < len(fields):
        entry = fields[i]
        i += 1
        if len(entry) < 3:
            continue
        xy = entry[:2]
        path = entry[3:]  # column 3 is the separating space
        # Rename / copy: the next NUL field is the old path — consume it.
        if xy and xy[0] in ('R', 'C'):
            i += 1
        rows.append((xy, path))
    return rows


# Porcelain XY codes that flag an unmerged (conflicted) path. Either
# column being ``U``, or the matched-pair both-added / both-deleted forms
# (``AA`` / ``DD``), means git is mid-merge on this path — the entry is a
# conflict regardless of which side touched it.
_UNMERGED_CODES = frozenset({'DD', 'AU', 'UD', 'UA', 'DU', 'AA', 'UU'})


def _is_conflict(xy):
    """True when a porcelain ``XY`` code names an unmerged (conflicted) path.

    Conflict entries are the seven codes in ``_UNMERGED_CODES``; every
    other code is an ordinary staged / worktree / untracked change.
    """
    return xy in _UNMERGED_CODES


def _classify_worktree(rows):
    """Bucket ``_parse_porcelain_z`` rows into the four worktree groups.

    ``rows`` is the ``[(XY, path)]`` list from ``_parse_porcelain_z``.
    Returns a dict with four lists, each holding the ``(XY, path)`` tuples
    that belong to that group:

      * ``'conflicts'`` — unmerged codes (``_is_conflict``); a conflict
        lands here and ONLY here, never in staged / tracked, so a
        mid-merge path shows up once.
      * ``'untracked'`` — the ``??`` code.
      * ``'staged'``    — a non-conflict code whose ``X`` column is set
        (not a space, not ``?``).
      * ``'tracked'``   — a non-conflict code whose ``Y`` column is set
        (not a space, not ``?``).

    Staged and tracked are NOT exclusive: a two-sided code such as ``MM``
    (staged + unstaged modification) appears in BOTH lists.
    """
    buckets = {
        'untracked': [],
        'tracked': [],
        'staged': [],
        'conflicts': [],
    }
    for xy, path in rows:
        if _is_conflict(xy):
            buckets['conflicts'].append((xy, path))
            continue
        if xy == '??':
            buckets['untracked'].append((xy, path))
            continue
        x, y = xy[0], xy[1] if len(xy) > 1 else ' '
        if x not in (' ', '?'):
            buckets['staged'].append((xy, path))
        if y not in (' ', '?'):
            buckets['tracked'].append((xy, path))
    return buckets


def _status_tag(xy):
    """Pick the one-letter status tag for a porcelain ``XY`` code.

    Untracked (``??``) shows ``?``; otherwise the staged column ``X`` when
    set, else the worktree column ``Y``. Returns ``''`` for an all-space
    code (shouldn't occur in porcelain output).
    """
    if xy == '??':
        return '?'
    x, y = xy[0], xy[1] if len(xy) > 1 else ' '
    if x != ' ':
        return x
    if y != ' ':
        return y
    return ''


def _status_diff_plan(xy, path):
    """Map a porcelain ``XY`` + path to the diff command(s) to render.

    Returns a list of ``(header, argv)`` pairs — the per-file diff(s) whose
    colored output makes up the status-leaf preview:

      * conflict (an unmerged code)        → ``diff -- <path>``
      * staged (``X`` set and not ``?``)   → ``diff --cached -- <path>``
      * worktree (``Y`` set and not ``?``) → ``diff -- <path>``
      * untracked (``??``)                 → ``diff --no-index -- /dev/null <path>``

    Unmerged codes (``_is_conflict``) are handled FIRST, ahead of the
    X/Y split, so a conflicted leaf shows a single ``diff -- <path>`` —
    which git renders in combined (``--cc``) form for an unmerged path —
    rather than two empty staged/worktree sections.

    A two-sided code (``MM``) yields BOTH the staged and worktree diffs,
    each under its own header. The ``argv`` lists are the args passed to
    ``git`` (color is applied by the caller via ``_git_color``). Note the
    ``--no-index`` diff exits non-zero whenever the files differ — the
    caller must NOT gate on the return code.
    """
    if _is_conflict(xy):
        return [('conflict', ['diff', '--', path])]
    if xy == '??':
        return [('untracked', ['diff', '--no-index', '--', '/dev/null', path])]
    x, y = xy[0], xy[1] if len(xy) > 1 else ' '
    plan = []
    if x not in (' ', '?'):
        plan.append(('staged', ['diff', '--cached', '--', path]))
    if y not in (' ', '?'):
        plan.append(('unstaged', ['diff', '--', path]))
    return plan


def _status_leaf(xy, path):
    """Build one ``('status', xy, path)`` working-tree leaf Item.

    Shared by ``_status_root`` (status mode) and ``_worktree_files`` (the
    commits-mode worktree groups) so both render a working-tree entry the
    same way: a non-expandable leaf titled by its path, tagged with the
    one-letter status (``_status_tag``) colored by kind. The leaf preview
    is the staged / worktree / untracked diff chosen from the ``XY`` code.
    """
    tag = _status_tag(xy)
    return Item(id=('status', xy, path), title=path,
                tag=tag,
                tag_style=_STATUS_LETTER_STYLE.get(tag, ''),
                has_children=False)


# Worktree groups for commits mode — the ordered (bucket, label) pairs
# defining BOTH the display order of the synthetic status rows and their
# titles. Mirrors the four ``_classify_worktree`` buckets.
_WC_GROUPS = [
    ('untracked', 'Untracked changes'),
    ('tracked', 'Tracked changes'),
    ('staged', 'Staged changes'),
    ('conflicts', 'Conflicts'),
]


def _err_item(msg):
    """Return a single non-expandable error Item to render in the list."""
    return [Item(id=('err',), title=msg, tag='err', tag_style='red')]


# ---- children ------------------------------------------------------------


def get_children(item_id, *, reload=False):
    # Every id is a tagged tuple (``id[0]`` is the kind), or ``None`` for the
    # root. Routing is a flat ``id[0]`` dispatch with direct field access — no
    # substring scans, no ordering hazards.
    if item_id is None:
        return _root_children()
    if not isinstance(item_id, tuple) or not item_id:
        return []
    kind = item_id[0]
    if kind == 'commit':
        return _commit_files(item_id[1])
    if kind == 'reflog':
        # A reflog entry drills into the same file list as a commit —
        # a sha is a sha. id = ('reflog', n, sha).
        return _commit_files(item_id[2])
    if kind == 'stash' and len(item_id) == 2:
        # A stash node (('stash', n)) drills into its files; a stash file
        # leaf (('stash', n, path)) has none.
        return _stash_files(item_id[1])
    if kind == 'ref':
        # A ref drills into its commits — the shared commit-log builder
        # with the refname as the sole rev. id = ('ref', refname). The
        # ref's own id namespaces its filler ids so two drilled-in refs
        # don't collide on a shared filler counter.
        return _log_items([item_id[1]], [], ns=item_id)
    if kind == 'wc':
        # A worktree-status group drills into its files. id = ('wc',
        # bucket); scope by the same positional paths as the root.
        return _worktree_files(item_id[1], _paths)
    # file / status leaf / filler / error / sentinel rows have no children.
    return []


def _root_children():
    """Top-level rows for the active mode."""
    if _mode == 'commits':
        return _commits_root()
    if _mode == 'reflog':
        return _reflog_root()
    if _mode == 'status':
        return _status_root()
    if _mode == 'stash':
        return _stash_root()
    if _mode == 'branches':
        return _branches_root()
    return []


def _commits_root():
    """Commits-mode root = worktree status groups + the ``git log``.

    The synthetic worktree-status rows (``_worktree_groups``) are prepended
    ONLY when the log is the plain HEAD log — no positional rev and no
    ``--all``, either of which moves the log off HEAD's history, where live
    working-tree rows would be misleading. A path filter is still honored
    (passed through to both the groups and the log), so e.g. ``browse-git
    src/`` shows the working-tree changes under ``src/`` above its commit
    history.

    ``--all`` (``_all_branches``) appends git log's ``--branches`` selector
    to the revs, spanning the log over every local branch — equivalent to
    passing all branch names positionally (and unioned with any explicit
    rev). The commit portion goes through the ``_log_items`` seam so it
    honors tree mode (the ``--tree`` graph column) exactly as the ref
    drill-down does; the synthetic rows are not commits and carry no graph
    art.
    """
    revs = list(_revs)
    if _all_branches:
        revs.append('--branches')
    items = []
    if not revs:
        items.extend(_worktree_groups(_paths))
    items.extend(_log_items(revs, _paths, ns='root'))
    return items


def _log_items(revs, paths, ns):
    """Build the commit-log rows for ``revs`` / ``paths``, honouring tree mode.

    The single seam shared by commits-mode root and the branches-mode ref
    drill-down: when ``_tree_mode`` is on it routes to the ``git log
    --graph`` builder (commit rows + meta filler rows carrying the graph
    art); otherwise it calls the plain ``_commit_log_items`` so the
    tree-off output is byte-identical to before this feature.

    ``ns`` is a stable per-build namespace key (``'root'`` for the
    commits-mode log, the ref item's id for a ref drill-down) that scopes
    the graph builder's filler ids (the ``ns`` field of ``('filler', ns,
    n)``) so concurrent builds (multiple drilled-in refs) can't collide on a
    shared filler counter. It's only consulted in tree mode; the plain
    builder takes no namespace.
    """
    if _tree_mode:
        return _commit_graph_items(revs, paths, ns)
    return _commit_log_items(revs, paths)


def _worktree_status(paths):
    """``git status --porcelain -z`` rows as ``[(XY, path)]``, scoped by paths.

    Returns the parsed ``_parse_porcelain_z`` rows on success. On any git
    failure it returns ``[]`` — degrading quietly to "no worktree rows"
    rather than injecting an error row at the top of the commit log.
    """
    args = ['status', '--porcelain', '-z']
    if paths:
        args += ['--', *paths]
    result = _run_git(*args)
    if result.returncode != 0:
        return []
    return _parse_porcelain_z(result.stdout)


def _worktree_groups(paths):
    """Synthetic worktree-group rows for the commits-mode root.

    Classifies ``_worktree_status(paths)`` into the four ``_WC_GROUPS``
    buckets and emits one expandable ``('wc', bucket)`` row per NON-empty
    bucket, in ``_WC_GROUPS`` order, titled by the group label. A clean
    tree (no changes) yields ``[]`` — no rows at all.

    Each row carries empty ``col_sha`` / ``col_author`` / ``col_date``
    strings so ``git_row_content`` aligns its label under the sibling
    commit subjects (empty columns pad to the commit column widths)
    instead of rendering flush-left.
    """
    buckets = _classify_worktree(_worktree_status(paths))
    items = []
    for bucket, label in _WC_GROUPS:
        if buckets[bucket]:
            item = Item(id=('wc', bucket), title=label, has_children=True)
            # Empty leading columns so git_row_content pads them to the
            # commit column widths — the label then lines up under the
            # commit subjects rather than at the start of the row.
            item.col_sha = ''
            item.col_author = ''
            item.col_date = ''
            items.append(item)
    return items


def _worktree_files(bucket, paths):
    """Files in one worktree ``bucket`` as ``('status', xy, path)`` leaves.

    Re-runs status + classify (cheap; keeps the groups self-contained) and
    returns that bucket's ``(XY, path)`` entries as the shared
    ``_status_leaf`` items. An unknown bucket name yields ``[]``.
    """
    buckets = _classify_worktree(_worktree_status(paths))
    return [_status_leaf(xy, path) for xy, path in buckets.get(bucket, [])]


def _commit_log_items(revs, paths):
    """``git log`` rows as ``('commit', sha)`` items, rendered in columns.

    Shared by commits mode (called with the positional ``_revs`` /
    ``_paths``) and branches-mode ref drill-down (called with
    ``([refname], [])``). Each record is NUL-separated ``%H %D %an %ar %s``
    (subject is a single line, so ``splitlines()`` then ``split('\\x00')``
    is unambiguous).

    The short sha, author, and relative date are stored as ``col_sha`` /
    ``col_author`` / ``col_date`` display strings — ``git_row_content``
    renders them as aligned leading columns (commits are flat under one
    parent, so the alignment is global). The subject is the title (the
    flexible last column); ``item.chips`` carries only the ref decorations
    parsed from ``%D`` (rendered between the date column and the subject).
    """
    args = ['log', '--format=%H%x00%D%x00%an%x00%ar%x00%s', '-n',
            str(_log_limit)]
    args += list(revs)
    if paths:
        args += ['--', *paths]
    result = _run_git(*args)
    if result.returncode != 0:
        return _err_item(f'git log failed: {result.stderr.strip()}')
    items = []
    for line in result.stdout.splitlines():
        if not line:
            continue
        fields = line.split('\x00')
        if len(fields) < 5:
            continue
        sha, deco, author, reldate, subject = fields[:5]
        item = Item(id=('commit', sha), title=subject, has_children=True)
        # Column display strings (read by git_row_content via max_col_width).
        item.col_sha = sha[:7]
        item.col_author = author
        item.col_date = reldate
        item.chips = _parse_decorations(deco)
        items.append(item)
    return items


def _graph_translate(art):
    """Sanitise + glyph-substitute one line of coloured ``git log --graph`` art.

    The art carries git's native ANSI colour (``--color=always``). It is
    treated as external input and first run through the shared framework
    sanitiser :func:`sanitize_ansi`, which keeps only complete SGR colour
    sequences (``\\e[…m``) and strips every other escape — so nothing but a
    colour code can ever reach the screen.

    Glyph substitution then maps git's ASCII connectors to box-drawing / block
    glyphs via the module ``_GRAPH_TABLE`` (``*``→``•``, ``|``→``│``,
    ``_``→``▁``); the diagonals ``/`` and ``\\`` pass through unchanged. The
    substitution is ANSI-safe: ``_SGR_RE`` (whose param class matches exactly
    what ``sanitize_ansi`` keeps) splits the line into SGR tokens and the plain
    runs between them, and ``str.translate`` is applied **only** to the plain
    runs — an SGR sequence is re-emitted verbatim, so a glyph is never
    substituted for a byte inside an escape and a colour run is never split.

    Internal spacing is git's lane alignment and is preserved; only trailing
    spaces are stripped (git right-pads every art cell, and a trailing run
    carries no lane information). ``rstrip`` strips whitespace only, leaving
    any trailing reset (``\\e[m``) intact; the colour codes are zero-width, so
    width / alignment math (``cell_width`` strips escapes) is unaffected.
    """
    art = sanitize_ansi(art)
    out = []
    pos = 0
    for m in _SGR_RE.finditer(art):
        if m.start() > pos:
            out.append(art[pos:m.start()].translate(_GRAPH_TABLE))
        out.append(m.group(0))                      # SGR token, verbatim
        pos = m.end()
    if pos < len(art):
        out.append(art[pos:].translate(_GRAPH_TABLE))
    return ''.join(out).rstrip()


def _commit_graph_items(revs, paths, ns):
    """``git log --graph`` rows: commit ``('commit', sha)`` items + filler rows.

    The tree-mode counterpart to ``_commit_log_items``. ``git log --graph``
    does ALL the lane assignment and prepends its art to every output line;
    we render those lines verbatim (after sanitise + glyph substitution)
    rather than re-deriving the graph. ``--color=always`` makes git colour the
    graph drawing (and the ``%D`` decorations) with its own ANSI; the SGR uses
    ``\\e``, never ``\\x1f``, so the field split below is unaffected. The
    ``\\x1f`` (unit separator) format keeps the art — which freely contains
    spaces, colour codes and ``|`` / ``/`` — unambiguously apart from the
    commit fields:

      * ``<art>\\x1f%H\\x1f%an\\x1f%ar\\x1f%s\\x1f%D`` for a commit line —
        splitting on ``\\x1f`` yields the art then the five fields;
      * a pure-art FILLER line (``|\\``, ``|/`` …) has NO separator, so the
        split yields a single element.

    Commit lines build the same columnar Item as ``_commit_log_items`` and
    additionally carry ``col_graph`` (the sanitised, coloured, translated art).
    Filler lines become ``meta=True`` Items (``id=('filler', ns, n)`` — ``n``
    is a running counter that resets per build, ``ns`` is the caller's
    namespace key making the id globally unique across builds;
    ``has_children=False``, no ``col_sha``) carrying only ``col_graph``. A
    ``('filler', …)`` tag matches no ``get_children`` / ``get_preview`` /
    action dispatch branch, so the row stays inert on every drill-down /
    preview / action path. ``meta=True`` makes the framework skip the cursor
    over the row (preventively) and never select it. git's line order (commits
    and fillers interleaved) is preserved.
    """
    args = ['log', '--graph', '--color=always',
            '--format=\x1f%H\x1f%an\x1f%ar\x1f%s\x1f%D', '-n', str(_log_limit)]
    args += list(revs)
    if paths:
        args += ['--', *paths]
    result = _run_git(*args)
    if result.returncode != 0:
        return _err_item(f'git log failed: {result.stderr.strip()}')
    items = []
    filler_n = 0
    for line in result.stdout.splitlines():
        parts = line.split('\x1f')
        if len(parts) > 1:
            # Commit line: parts[0] is the art, the rest are H/an/ar/s/D.
            art, sha, author, reldate, subject, deco = parts[:6]
            item = Item(id=('commit', sha), title=subject, has_children=True)
            item.col_sha = sha[:7]
            item.col_author = author
            item.col_date = reldate
            item.chips = _parse_decorations(deco)
            item.col_graph = _graph_translate(art)
            items.append(item)
        else:
            # Filler line: the whole line is graph art (no commit fields).
            # ``meta=True`` -> the framework skips the cursor over it and
            # never selects it; the (ns, counter) id stays unique across builds.
            item = Item(id=('filler', ns, filler_n), title='',
                        has_children=False, meta=True)
            item.col_graph = _graph_translate(line)
            items.append(item)
            filler_n += 1
    return items


def git_row_content(item, ctx):
    """Columnar content for commit rows: sha | author | date | [graph] | subject.

    Each leading column (short sha yellow, author + relative date dim) is
    left-justified to the widest sibling value (``ctx.max_col_width`` over
    the row's parent group; commits are flat under one parent, so that is a
    global alignment) and followed by a two-space gap. In tree mode the
    commit's ``col_graph`` art follows the date column; then the ``%D``
    decoration chips, then the subject (the title) LAST so a narrow pane
    truncates the subject rather than the metadata columns.

    Commit rows and the synthetic worktree-group rows carry ``col_sha``
    (the groups leave it empty so their label aligns under the commit
    subjects); worktree-group rows have no ``col_graph``, so in tree mode
    their label simply follows the date column.

    A tree-mode FILLER row carries ``col_graph`` but no ``col_sha``: it
    renders a single blank pad spanning the sha+author+date columns (so its
    art lines up under the commit rows' graph column) followed by its art.

    Every other row kind (status/stash/ref/file/reflog and the synthetic
    error / "clean" / "no stashes" rows) carries neither and falls back to
    the framework default content — keeping their tag chips and trailing
    decorations unchanged. Only the content region is taken over; chrome
    (tree indent + ▼/▶) stays framework-owned.

    The art (``col_graph``) carries git's own ANSI colour, so it is emitted
    as a segment with **no framework fg** (``(graph, None, False)``) — git's
    SGR shows through unmodified. The per-segment writer truncates that text
    ANSI-aware and the rule-3 conditional trailing reset (``\\e[m``) keeps the
    colour from bleeding into the subject or the next pane. The colour codes
    are zero-width (``cell_width`` strips them), so the columns stay aligned.
    """
    w = ctx.max_col_width
    if getattr(item, 'col_sha', None) is None:
        graph = getattr(item, 'col_graph', None)
        if graph is None:
            return default_row_content(item, ctx)   # non-commit / synthetic row
        # Filler row: blank-pad the sha+author+date span, then the coloured
        # art (git's own SGR -> fg=None so it shows through).
        pad = (w('col_sha') + 2 + w('col_author') + 2 + w('col_date') + 2)
        return [(' ' * pad, None, False), (graph, None, False)]
    yfg, ybold = style('yellow')
    dfg, dbold = style('dim')
    segments = [
        (cell_ljust(item.col_sha, w('col_sha')) + '  ', yfg, ybold),
        (cell_ljust(item.col_author, w('col_author')) + '  ', dfg, dbold),
        (cell_ljust(item.col_date, w('col_date')) + '  ', dfg, dbold),
    ]
    # Commit graph art (tree mode) between the date column and the chips —
    # git's own ANSI colour, so fg=None lets its SGR show through. git
    # closes each coloured connector with a reset, so the appended gap space
    # is uncoloured; rule-3 adds a trailing reset besides.
    graph = getattr(item, 'col_graph', None)
    if graph is not None:
        segments.append((graph + ' ', None, False))
    # Ref decorations between the date column and the subject.
    for text, stylename in getattr(item, 'chips', None) or ():
        cfg, cbold = style(stylename)
        segments.append((f'[{text}] ', cfg, cbold))
    segments.append((item.title, None, False))    # flexible column, last
    return segments


def _reflog_root():
    """``git reflog`` rows as ``('reflog', n, sha)`` items, decorated.

    Each record is NUL-separated ``%H %gd %cr %D %gs`` (selector, relative
    date, decoration, action subject). The id carries the 0-based
    enumeration index ``n`` (an int) for uniqueness — the reflog revisits
    the same sha, so a bare ``('reflog', sha)`` would collapse duplicate
    rows.
    """
    result = _run_git(
        'reflog', '--format=%H%x00%gd%x00%cr%x00%D%x00%gs', '-n',
        str(_log_limit))
    if result.returncode != 0:
        return _err_item(f'git reflog failed: {result.stderr.strip()}')
    items = []
    for n, line in enumerate(result.stdout.splitlines()):
        row = _reflog_row(n, line)
        if row is not None:
            items.append(row)
    return items


def _reflog_row(n, line):
    """Build one reflog Item from its enumeration index + NUL record.

    Returns ``None`` for a malformed (under-filled) line. The selector
    (``%gd``, e.g. ``HEAD@{0}``) and relative date are dim chips; the
    ``%D`` decoration reuses ``_parse_decorations``.
    """
    if not line:
        return None
    fields = line.split('\x00')
    if len(fields) < 5:
        return None
    sha, selector, reldate, deco, subject = fields[:5]
    chips = [(selector, 'dim'), (reldate, 'dim')]
    chips.extend(_parse_decorations(deco))
    item = Item(id=('reflog', n, sha), title=subject,
                tag=sha[:7], tag_style='yellow', has_children=True)
    item.chips = chips
    return item


def _status_root():
    """``git status --porcelain -z`` rows as ``('status', xy, path)`` items.

    Each entry becomes a non-expandable leaf tagged by its one-letter
    status (colored by kind); the leaf preview is the staged / worktree /
    untracked diff chosen by the ``XY`` code. A clean tree yields a single
    dim, non-drillable "working tree clean" row (sentinel id
    ``('status_clean',)``).
    """
    result = _run_git('status', '--porcelain', '-z')
    if result.returncode != 0:
        return _err_item(f'git status failed: {result.stderr.strip()}')
    rows = _parse_porcelain_z(result.stdout)
    if not rows:
        return [Item(id=('status_clean',), title='working tree clean',
                     tag_style='dim', has_children=False)]
    return [_status_leaf(xy, path) for xy, path in rows]


def _stash_root():
    """``git stash list`` rows as ``('stash', n)`` items, decorated.

    Each record is NUL-separated ``%gd %cr %gs`` (selector, relative date,
    subject). An empty stash list yields a single dim, non-drillable "no
    stashes" row (sentinel id ``('stash_none',)`` — a distinct tag, so it
    never reaches the stash drill-down / preview paths).
    """
    result = _run_git('stash', 'list', '--format=%gd%x00%cr%x00%gs')
    if result.returncode != 0:
        return _err_item(f'git stash list failed: {result.stderr.strip()}')
    items = []
    for line in result.stdout.splitlines():
        row = _stash_row(line)
        if row is not None:
            items.append(row)
    if not items:
        return [Item(id=('stash_none',), title='no stashes',
                     tag_style='dim', has_children=False)]
    return items


def _stash_row(line):
    """Build one stash Item from a ``%gd %cr %gs`` NUL record.

    Returns ``None`` for a malformed (under-filled) line. The index ``n``
    is extracted from the ``%gd`` selector (``stash@{2}`` → ``2``, an int);
    the relative date is a dim chip and the selector becomes the yellow tag.
    """
    if not line:
        return None
    fields = line.split('\x00')
    if len(fields) < 3:
        return None
    selector, reldate, subject = fields[:3]
    n = _stash_index(selector)
    if n is None:
        return None
    item = Item(id=('stash', n), title=subject,
                tag=selector, tag_style='yellow', has_children=True)
    item.chips = [(reldate, 'dim')]
    return item


def _stash_index(selector):
    """Extract the 0-based index (int) from a ``stash@{n}`` selector, or None."""
    inner = selector.partition('{')[2].partition('}')[0]
    return int(inner) if inner.isdigit() else None


def _stash_files(n):
    """Files in stash ``n`` (int) as ``('stash', n, path)`` rows.

    Reuses ``git stash show --name-status stash@{n}`` + ``_parse_name_status``
    so each row carries its status-letter tag. Reached only for a real
    ``('stash', n)`` node — the "no stashes" sentinel is a distinct tag
    (``('stash_none',)``) that never routes here.
    """
    result = _run_git('stash', 'show', '--name-status', f'stash@{{{n}}}')
    if result.returncode != 0:
        return _err_item(f'git stash show failed: {result.stderr.strip()}')
    items = []
    for status, path in _parse_name_status(result.stdout):
        items.append(Item(id=('stash', n, path), title=path,
                          tag=status,
                          tag_style=_STATUS_LETTER_STYLE.get(status, ''),
                          has_children=False))
    return items


# Ref kind word → (tag style). Local branches cyan, remotes blue, tags
# yellow — matching the decoration-chip palette in `_parse_decorations`.
_REF_KIND_STYLE = {
    'branch': 'cyan',
    'remote': 'blue',
    'tag': 'yellow',
}


def _branches_root():
    """``git for-each-ref`` rows as ``('ref', short)`` items, tagged by kind.

    One call over ``refs/heads`` / ``refs/remotes`` / ``refs/tags``,
    newest-commit-first. The format emits the full ``%(refname)`` (for
    kind classification) and ``%(refname:short)`` (for display + id),
    NUL-separated. Each ref drills into that ref's commits.
    """
    result = _run_git(
        'for-each-ref', '--sort=-committerdate',
        '--format=%(refname)%00%(refname:short)',
        'refs/heads', 'refs/remotes', 'refs/tags')
    if result.returncode != 0:
        return _err_item(f'git for-each-ref failed: {result.stderr.strip()}')
    items = []
    for line in result.stdout.splitlines():
        parsed = _parse_for_each_ref_line(line)
        if parsed is None:
            continue
        kind, short = parsed
        items.append(Item(id=('ref', short), title=short,
                          tag=kind, tag_style=_REF_KIND_STYLE.get(kind, ''),
                          has_children=True))
    return items


def _parse_for_each_ref_line(line):
    """Parse a ``%(refname)%00%(refname:short)`` line → ``(kind, short)``.

    ``kind`` is classified from the FULL refname prefix:
    ``refs/heads/`` → ``branch``, ``refs/remotes/`` → ``remote``,
    ``refs/tags/`` → ``tag``. Returns ``None`` for a blank / malformed
    line or an unrecognised namespace.
    """
    if not line:
        return None
    full, sep, short = line.partition('\x00')
    if not sep:
        return None
    if full.startswith('refs/heads/'):
        kind = 'branch'
    elif full.startswith('refs/remotes/'):
        kind = 'remote'
    elif full.startswith('refs/tags/'):
        kind = 'tag'
    else:
        return None
    return (kind, short)


def _commit_files(sha):
    """Changed files in commit ``sha`` as ``('file', sha, path)`` rows.

    Uses ``--name-status`` so each row carries its A/M/D/R status letter
    in the ``tag`` chip (colored by kind). Renames/copies display the new
    path, and the ``('file', …)`` id keys on that same new path.
    """
    result = _run_git('show', '--name-status', '--format=', sha)
    if result.returncode != 0:
        return _err_item(f'git show failed: {result.stderr.strip()}')
    items = []
    for status, path in _parse_name_status(result.stdout):
        items.append(Item(id=('file', sha, path), title=path,
                          tag=status,
                          tag_style=_STATUS_LETTER_STYLE.get(status, ''),
                          has_children=False))
    return items


# ---- preview -------------------------------------------------------------


def get_preview(item_id):
    # Flat ``id[0]`` dispatch with direct field access; root (``None``) and
    # the synthetic sentinel/error tags fall through to the empty preview.
    if not isinstance(item_id, tuple) or not item_id:
        return ''
    kind = item_id[0]
    if kind == 'commit':
        return _commit_preview(item_id[1])
    if kind == 'reflog':
        # Same as a commit node — id = ('reflog', n, sha).
        return _commit_preview(item_id[2])
    if kind == 'ref':
        # A refname resolves as a commit-ish, so the commit-node preview
        # (message + show --stat) works unchanged. id = ('ref', refname).
        return _commit_preview(item_id[1])
    if kind == 'file':
        return _file_preview(item_id[1], item_id[2])
    if kind == 'status':
        # id = ('status', xy, path).
        return _status_preview(item_id[1], item_id[2])
    if kind == 'wc':
        # A worktree-status group — combined colored diff for the bucket,
        # scoped to the same positional paths. id = ('wc', bucket).
        return _worktree_preview(item_id[1], _paths)
    if kind == 'stash':
        # id = ('stash', n) node or ('stash', n, path) leaf. The "no stashes"
        # sentinel is a distinct tag, so n is always a real int here.
        if len(item_id) == 3:
            return _stash_file_preview(item_id[1], item_id[2])
        return _stash_preview(item_id[1])
    # root / err / status_clean / stash_none / filler kinds have no preview.
    return ''


def _commit_preview(sha):
    """Commit node preview = md2ansi(message) + colored ``show --stat``."""
    msg = _run_git('show', '-s', '--format=%B', sha)
    body = _md_message(msg.stdout.rstrip('\n')) if msg.returncode == 0 else ''
    stat = _git_color('show', '--stat', '--format=', sha)
    if body and stat:
        return f'{body}\n\n{stat}'
    return body or stat


def _file_preview(sha, path):
    """File leaf preview = colored per-file diff for ``path`` in ``sha``."""
    raw = _git_color('show', sha, '--', path)
    return _colorize_diff(raw)


def _status_preview(xy, path):
    """Status-leaf preview: the staged / worktree / untracked diff(s).

    The ``XY`` code selects the diff command(s) via ``_status_diff_plan``;
    each is run git-colored and piped through ``_colorize_diff``. A
    two-sided code (``MM``) shows both sections under ``── staged ──`` /
    ``── unstaged ──`` headers. The ``--no-index`` untracked diff exits
    non-zero by design, so its output is captured regardless of code.
    """
    plan = _status_diff_plan(xy, path)
    sections = []
    multi = len(plan) > 1
    for header, argv in plan:
        raw = _git_color(*argv)
        body = _colorize_diff(raw)
        if multi:
            sections.append(f'── {header} ──\n{body}')
        else:
            sections.append(body)
    return '\n\n'.join(s for s in sections if s)


def _worktree_preview(bucket, paths):
    """Combined colored diff for a worktree ``bucket``, scoped to its files.

    Computes the bucket's own paths via ``_classify_worktree`` so e.g. the
    tracked preview never pulls in staged-only files. The diff command is
    chosen by bucket:

      * ``staged``    → ``diff --cached -- <bucket paths>``
      * ``tracked``   → ``diff -- <bucket paths>``
      * ``conflicts`` → ``diff -- <bucket paths>`` (git renders unmerged
        paths in combined ``--cc`` form)
      * ``untracked`` → per file, ``diff --no-index -- /dev/null <path>``,
        concatenated (untracked files have no index entry to diff against)

    Each diff is run git-colored and piped through ``_colorize_diff``.
    Returns ``''`` for an empty bucket or an unknown name.
    """
    buckets = _classify_worktree(_worktree_status(paths))
    bucket_paths = [path for _xy, path in buckets.get(bucket, [])]
    if not bucket_paths:
        return ''
    if bucket == 'staged':
        raw = _git_color('diff', '--cached', '--', *bucket_paths)
    elif bucket in ('tracked', 'conflicts'):
        raw = _git_color('diff', '--', *bucket_paths)
    elif bucket == 'untracked':
        raw = ''.join(
            _git_color('diff', '--no-index', '--', '/dev/null', path)
            for path in bucket_paths)
    else:
        return ''
    return _colorize_diff(raw)


def _stash_preview(n):
    """Stash node preview = colored full ``stash show -p stash@{n}`` diff."""
    raw = _git_color('stash', 'show', '-p', f'stash@{{{n}}}')
    return _colorize_diff(raw)


def _stash_file_preview(n, path):
    """Stash file leaf preview = colored per-file diff in ``stash@{n}``."""
    raw = _git_color('show', f'stash@{{{n}}}', '--', path)
    return _colorize_diff(raw)


# ---- key handlers --------------------------------------------------------


def on_enter(ctx):
    """Flip expand/collapse of the cursor row; never quits, never prints.

    Leaves (rows without children) are a no-op. The decision reads
    ``ctx.state.expanded`` — the set of expanded ids in the current
    scope — so a second Enter on an open row folds it back up.
    """
    item = ctx.cursor
    if item is None or not item.has_children:
        return
    if item.id in ctx.state.expanded:
        ctx.collapse(item.id)
    else:
        # User-driven navigation — autoscroll the newly-revealed children
        # into view, matching the built-in Right-arrow handler.
        ctx.expand(item.id, autoscroll=True)


def switch_mode(ctx):
    """Backtick — pick one of the five modes, then re-list the root."""
    global _mode
    chosen = ctx.pick('mode', list(_MODES))
    if chosen is None or chosen == _mode:
        return
    _mode = chosen
    ctx.flash(f'mode: {_mode}')
    # All five modes share one root scope (and thus one ``state.expanded``
    # set); drop the previous mode's expanded ids before re-listing so the
    # refresh doesn't re-fetch / re-expand rows that don't exist here.
    ctx.collapse_all()
    ctx.refresh()


def edit_file(ctx):
    """``E`` — open the real working-tree file in $EDITOR.

    Only file/status rows map to a working-tree path; other row kinds
    (commits, refs, stashes) are a no-op. ``('file', …)`` paths are
    repo-root relative, so resolve them against the work-tree root.
    """
    item = ctx.cursor
    if item is None or not isinstance(item.id, tuple):
        return
    # ('file', sha, path) and ('status', xy, path) both carry the path at id[2].
    if item.id[0] in ('file', 'status'):
        path = item.id[2]
    else:
        return
    root = _run_git('rev-parse', '--show-toplevel')
    base = root.stdout.strip() if root.returncode == 0 else ''
    target = os.path.join(base, path) if base else path
    editor = os.environ.get('EDITOR', 'vi')
    ctx.run_external([editor, target])


def toggle_md(ctx):
    """``m`` — flip md2ansi coloring of the commit message; refresh preview."""
    global _MD_COLOR
    _MD_COLOR = not _MD_COLOR
    ctx.drop_preview_cache()
    ctx.flash(f'message coloring: {"colored" if _MD_COLOR else "raw"}')


def toggle_tree(ctx):
    """``t`` — flip the commit-graph column (``--tree``); re-list the root.

    Toggles ``_tree_mode`` and refreshes the root so the commit log is
    rebuilt through the now-current builder — adding (or dropping) git's
    graph column and the interleaved filler rows. Affects commits mode and
    the branches-mode ref drill-down; other modes ignore the flag.
    """
    global _tree_mode
    _tree_mode = not _tree_mode
    ctx.flash(f'commit graph: {"on" if _tree_mode else "off"}')
    ctx.refresh()


# ---- entry point ---------------------------------------------------------


_HELP_INTRO_TMPL = """\
browse-git — a tig-like browser over a git repository.

Usage: browse-git [<dir>] [-n NUMBER] [--mode NAME] [--no-tree] [--all] [<rev>…] [-- <path>…]
  <dir>         A leading directory in another git repo browses THAT repo
                (cwd need not be a repo). A subdir of the current repo
                stays a pathspec filter instead.
  -n NUMBER     Cap the commit / reflog list to this many entries
                (default: {default}).
  --mode NAME   Start in one of: {modes}. Default: commits.
  --no-tree     Hide git's commit-graph column in the commit log
  --tree        (default on; toggle at runtime with 't').
  --all         Span the commits log over every local branch, not just
                HEAD's history (like git log --branches).
  <rev>…        A rev / sha roots the commits log at it (git log <rev>).
  <path>…       A path filters the commits log to commits touching it.
  -- <path>…    Everything after -- is forced to be a pathspec.

Positional args are auto-classified: a leading directory that is its own
git work tree (distinct from the cwd's) selects the repo to browse; any
other arg that names an existing file or directory is a pathspec;
otherwise an arg git resolves as a commit is a rev; anything else is an
error. They scope commits mode (an explicit --mode other than commits
ignores them).

The five view modes:
  commits   recent git log; drill commit -> changed files -> per-file diff
            (an unscoped log is preceded by working-change rows — Untracked
            / Tracked / Staged / Conflicts — each shown only when non-empty,
            drillable into their files, scoped by the same path filter)
  status    working-tree entries; leaf preview = staged / worktree diff
  reflog    reflog entries; same drill-down as commits
  branches  branches / remotes / tags; drill a ref into its commits
  stash     stash entries; drill into the stash's files

Keys:
  `         open the mode picker (switch view mode at runtime)
  Enter     flip expand/collapse of the cursor row (never quits)
  t         toggle the commit-graph column (--tree) in the commit log
  E         edit the real working-tree file in $EDITOR (file/status rows)
  m         toggle md2ansi commit-message coloring (when md2ansi_lib present)
  v         (built-in) page the colored preview / diff in $PAGER
  e         (built-in) edit the preview text in $EDITOR

Previews are colorized: git emits SGR, per-file diffs go through delta
when it is installed, and commit messages are md2ansi-colored when
available. Commit rows render sha / author / date columns followed by
their ref/tag decorations and the subject.\
"""


def _classify_positionals():
    """Sort the leftover positionals into ``_revs`` / ``_paths``.

    Everything after a literal ``--`` is an unconditional pathspec.
    Otherwise an arg that names an existing path is a pathspec; an arg
    that ``git rev-parse`` confirms as a commit is a rev; anything else
    is fatal (stderr + exit 2). Leftover flag-like tokens (``-h`` /
    ``--help``) before the ``--`` are skipped so the framework's help
    auto-detect still fires.
    """
    args = sys.argv[1:]
    if '--' in args:
        cut = args.index('--')
        head, tail = args[:cut], args[cut + 1:]
        _paths.extend(tail)
    else:
        head = args
    for arg in head:
        if arg.startswith('-'):
            continue
        if os.path.exists(arg):
            _paths.append(arg)
            continue
        rc = _run_git('rev-parse', '--verify', '--quiet', f'{arg}^{{commit}}')
        if rc.returncode == 0:
            _revs.append(arg)
            continue
        sys.stderr.write(f'browse-git: unknown path or revision: {arg}\n')
        sys.exit(2)


def _window_title():
    """Title reflecting the active mode and any positional rev/path filter.

    There is no runtime retitle API, so the filter is baked into the
    construction-time title — e.g. ``browse-git [commits: src/ HEAD~5]``.
    ``--all`` shows as the literal ``--all`` token (not the every-branch
    list it expands to). Modes other than ``commits`` don't take a filter,
    so only the mode is shown for them.
    """
    parts = (['--all'] if _all_branches else []) + _revs + _paths
    if _mode == 'commits' and parts:
        return f'browse-git [{_mode}: {" ".join(parts)}]'
    return f'browse-git [{_mode}]'


def main():
    global _browser, _log_limit, _mode, _tree_mode, _all_branches
    # git presence + a work tree are preconditions — fail fast before the
    # TUI launches rather than surfacing an in-list error row. Skip the
    # checks when a help token is present so ``--help`` still reaches
    # Browser.run()'s help auto-detect even outside a repo.
    if not any(a in ('-h', '--help') for a in sys.argv[1:]):
        if not shutil.which('git'):
            sys.stderr.write('browse-git: git not found on PATH\n')
            sys.exit(2)
        # A leading directory positional pointing at another repo redirects
        # the cwd into it (before the work-tree check below) so the recipe
        # browses THAT repo rather than failing when launched from outside.
        _pop_repo_dir()
        if _run_git('rev-parse', '--is-inside-work-tree').returncode != 0:
            sys.stderr.write('browse-git: not inside a git work tree\n')
            sys.exit(2)

    _log_limit = _pop_limit_arg(_LOG_LIMIT)
    requested_mode = _pop_mode_arg()
    _tree_mode = _pop_tree_arg(_tree_mode)
    _all_branches = _pop_all_arg()
    _classify_positionals()
    if requested_mode is not None:
        _mode = requested_mode

    actions = [
        Action('`', 'Switch view mode', switch_mode, 'none'),
        Action('t', 'Toggle commit graph (--tree)', toggle_tree, 'none'),
        Action('E', 'Edit working-tree file in $EDITOR', edit_file, 'cursor'),
    ]
    if _md2ansi_fn is not None:
        actions.append(
            Action('m', 'Toggle md2ansi message coloring', toggle_md, 'none'))

    b = Browser(BrowserConfig(
        title=_window_title(),
        get_children=get_children,
        get_preview=get_preview,
        format_row_content=git_row_content,
        actions=actions,
        on_enter=on_enter,
        show_ids='never',
        help_intro=_HELP_INTRO_TMPL.format(
            default=_LOG_LIMIT, modes=', '.join(_MODES)),
    ))
    _browser = b
    sys.exit(b.run())


if __name__ == '__main__':
    main()
