def context_menu_options(ctx):
    """``(label, token)`` rows for the git context menu (pure — no modal).

    Branches on the cursor item's KIND (``id[0]``) — every row id is a tagged
    tuple, so this is a flat dispatch with direct field access. A ``.md`` /
    ``.PLAN.md`` row, a worktree-group (``wc``) row, a piped-diff row, and the
    synthetic sentinel / filler / error rows have no per-kind menu; for those
    (and a cursor on nothing) only the shared trailing rows are offered.

    Every menu ends with a shared "Run shell here" row and a ``Switch mode ▸``
    row (the latter reuses the `` ` `` mode-switch action, so its label carries
    the `` ` `` hotkey hint per the convention). The token half is dispatched
    by ``_MENU_ACTIONS`` /
    ``on_context_menu``; the kind-specific rows come from the
    ``context_menu_<kind>`` builders. A file/status/stash leaf that is also a
    markdown launcher anchor still gets its file/status/stash menu — the menu
    operates on the git object, not the launcher child.

    Stash disambiguation: ``('stash', n)`` is a stash node (stash menu);
    ``('stash', n, path)`` is a file inside a stash, which gets the file menu
    (view/diff/history/blame against the ``stash@{n}`` rev).
    """
    item_id = ctx.cursor.id if ctx.cursor else None
    rows = []
    if isinstance(item_id, tuple) and item_id:
        kind = item_id[0]
        if kind == 'commit':
            rows = context_menu_commit(ctx, item_id)
        elif kind == 'file' and len(item_id) == 3:
            rows = context_menu_file(ctx, item_id)
        elif kind == 'ref':
            rows = context_menu_ref(ctx, item_id)
        elif kind == 'status' and len(item_id) == 3:
            rows = context_menu_status(ctx, item_id)
        elif kind == 'stash' and len(item_id) == 3:
            # A file inside a stash → the file menu, against the stash rev.
            rows = context_menu_file(ctx, item_id)
        elif kind == 'stash' and len(item_id) == 2:
            rows = context_menu_stash(ctx, item_id)
        elif kind == 'reflog' and len(item_id) == 3:
            rows = context_menu_reflog(ctx, item_id)
    # Run shell here + Switch mode are available anywhere (Switch mode reuses
    # the ` action; the hint shows the backtick). Both are suppressed in stdin
    # mode, where ` itself flashes and there's no repo to drop a shell into.
    if _STDIN_KIND is None:
        rows = list(rows) + [('Run shell here', 'shell.here'),
                             ('Switch mode ▸ (`)', 'mode.switch')]
    return rows


def on_context_menu(ctx):
    """Open the git context menu and dispatch the chosen entry.

    The hook the framework fires on right-click / `` ` ``-F1: build the (pure)
    per-kind option list, open it with ``ctx.menu``, and route the chosen token
    through ``_MENU_ACTIONS`` (passing the cursor's id so each handler reads its
    own fields). A cancel (``None``) or an empty list is a no-op. The cursor id
    is re-read at dispatch time so a token always pairs with the row it came
    from.
    """
    options = context_menu_options(ctx)
    token = ctx.menu(options)
    handler = _MENU_ACTIONS.get(token)
    if handler is None:
        return
    item = ctx.cursor
    handler(ctx, item.id if item is not None else None)


