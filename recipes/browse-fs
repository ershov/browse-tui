def _read_stdin_roots():
    """Parse the newline-separated stdin path list into ``(label, abspath)``.

    One path per line; blank lines are skipped and the trailing newline
    is optional. Lines are taken verbatim otherwise — no quoting or
    escaping — so a path with spaces just works (the delimiter is the
    newline). Duplicates are dropped keeping the first occurrence (keyed
    on the verbatim line). ``label`` is the line as given (the row
    title); ``abspath`` is its cwd-resolved absolute path. Reading
    happens before the UI starts; on a tty this blocks cat-like until
    ^D (standard unix — no isatty guard).
    """
    roots = []
    seen = set()
    for line in sys.stdin.read().splitlines():
        if not line or line in seen:
            continue
        seen.add(line)
        roots.append((line, os.path.abspath(line)))
    return roots


def main():
    global _BROWSER, _STDIN_ROOTS
    # Read the recipe's own positionals via ``recipe_argv()``, which drops
    # the framework's ``--tty PATH`` / ``--tty=PATH`` flag: ``Browser.run()``
    # auto-detects it but leaves it in ``sys.argv``, so a raw scan here would
    # mistake ``browse-fs --tty -``'s value ``-`` for the stdin positional, or
    # ``--tty /dev/pts/N``'s device path for a root PATH.
    args = recipe_argv()
    # Auto-detect a piped/redirected stdin: when fd 0 is not a tty and the
    # user didn't already type ``-``, synthesize it so a bare
    # ``cmd | browse-fs`` engages stdin mode without the explicit token.
    # An interactive tty stdin leaves ``args`` untouched (bare/PATH mode).
    # The synthesized ``-`` then flows through the same logic below: a lone
    # ``-`` reads the list; ``- PATH`` (a piped run that still names a path)
    # hits the conflict error. Inject into the positional list only — flags
    # were already dropped by ``recipe_argv()``. A help request is exempt:
    # ``cmd | browse-fs --help`` must still reach ``Browser.run()``'s
    # -h/--help auto-detect, not trip the synthesized ``- + PATH`` error.
    if ('-' not in args and not os.isatty(0)
            and not any(a in ('-h', '--help') for a in sys.argv[1:])):
        args.append('-')
    # The lone ``-`` reads the root path list from stdin (spec §3.7).
    # Reading here — before ``b.run()`` / ``term_init`` — is deliberate:
    # fd 0 is still whatever the caller provided, so a pipe is consumed
    # and a tty blocks cat-like until ^D. Once ``term_init`` runs, a tty
    # fd 0 is detached and a later read would only see EOF. ``-`` cannot
    # be combined with a PATH (the two name the root in conflicting ways);
    # reject that with the usage error rather than guessing. Empty stdin
    # yields an empty root list (a clean "no items" UI, no crash).
    if '-' in args:
        if args != ['-']:
            sys.exit(f'{_USAGE}\nbrowse-fs: - (stdin) cannot be combined '
                     f'with a path argument')
        _STDIN_ROOTS = _read_stdin_roots()
        root = None
    else:
        # Bare / single-PATH mode unchanged: stdin is never touched.
        root = os.path.abspath(args[0]) if args else os.getcwd()
    actions = [
        Action('e', 'Edit cursor in $EDITOR',     edit,   'cursor'),
        Action('o', 'Open with xdg-open',         open_,  'targets'),
        Action('d', 'Delete (with confirmation)', delete, 'targets'),
    ]
    if _md2ansi_fn is not None:
        actions.append(Action('m', 'Toggle markdown coloring', toggle_md, 'none'))
    b = Browser(BrowserConfig(
        title='browse-fs',
        show_ids="never",
        show_children_pane=False,
        get_children=get_children,
        get_preview=get_preview,
        format_row_content=fs_row_content,
        root_id=root,
        actions=actions,
        on_enter=_on_enter,
        # Right-click (or the backslash / F1 keys) opens a context menu keyed
        # to the cursor row's kind: a directory (run shell / git submenu / new
        # file+dir / show path / delete), a file (edit / view / open / shell /
        # browse-md / browse-plan / mdcat / diff / show path / delete), a
        # multi-selection (delete N / open N), or a missing-path special (show
        # path only). See ``on_context_menu``.
        on_context_menu=on_context_menu,
        help_usage=_HELP_USAGE,
        help_intro=_HELP_INTRO,
    ))
    _BROWSER = b
    b.watch(mtime_watcher)
    sys.exit(b.run())


if __name__ == '__main__':
    main()
