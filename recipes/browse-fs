#!/usr/bin/env -S browse-tui --run-py
"""browse-fs — filesystem browser. Lazy os.scandir; preview = file head
or dirs-first directory listing; actions e:Edit ($EDITOR), o:Open (xdg-open), d:Delete
(with ctx.confirm); background mtime watcher refreshes changed dirs.

A right-click (or the backslash / F1 keys) opens a context menu keyed to the
cursor row's kind — a directory (run shell here, a ``git`` submenu opening
browse-git by mode when it is a repo, new file / directory, show full path,
delete), a file (edit /
view in $PAGER / open / run shell in its dir / browse-md or browse-plan / render
with mdcat / diff against a single other selected item / show full path /
delete), a multi-selection (delete N, open N in $EDITOR), or a missing-path
special (show full path only). See ``on_context_menu``.

The lone argument ``-`` reads a newline-separated list of paths from
``sys.stdin`` (one per line, blank lines skipped, duplicates dropped
keeping the first) BEFORE the UI starts and displays exactly those
entries as the root level — ``ls *.py | browse-fs -``. Each row keeps
the path verbatim as it arrived on stdin; directories among them expand
into their real children via the normal lazy listing, files preview as
usual, and a path that does not exist shows a dim ``[missing]`` row.

When stdin is a pipe or redirect (not a tty), this mode auto-engages —
the ``-`` is optional, so ``ls *.py | browse-fs`` works too. ``-`` stays
the explicit form, needed only to read stdin when stdin is a tty
(type/paste the list, end with ^D).

A markdown file row (``*.md`` / ``*.MD``) carries an expansion arrow:
opening it lists ``[md ↗]`` launcher rows — the document itself plus every
existing ``.md`` file it links to — and Enter on one opens that file in
``browse-md`` (``--root`` anchored at the project root so the document's
own links resolve). Needs the optional ``md_doc`` plugin; without it,
``*.md`` rows stay leaves.

Usage:  browse-fs [PATH | -]   # no argument ⇒ the current directory
                               # (or stdin, when piped).
"""

import os
import shutil
import stat
import subprocess
import sys
import time

from browse_tui import (
    Action, Browser, BrowserConfig, Item,
    cell_ljust, cell_rjust, default_row_content, recipe_argv, style,
)

# Probe ``delta`` once at load (not per render): the context-menu "Diff" entry
# pipes ``diff``'s output through it for terminal-native rendering when it is
# on PATH, falling back to the plain unified diff otherwise.
HAVE_DELTA = shutil.which('delta')

# Optional md2ansi_lib plugin — gates the colored *.md preview mode.
try:
    from md2ansi_lib import md2ansi as _md2ansi_fn
    if not callable(_md2ansi_fn):
        _md2ansi_fn = None
except Exception:
    _md2ansi_fn = None

_MD_COLOR = _md2ansi_fn is not None  # default on when available
_BROWSER = None  # set in main() — used for preview-width lookup

# Optional md_doc plugin — gates the markdown launcher rows: a *.md row
# expands into browse-md launcher targets (the file itself + the .md files
# it links to). Inert when md_doc isn't importable, exactly like the
# md2ansi_lib gate above — *.md rows then stay plain leaves.
try:
    import md_doc as _md_doc
except Exception:
    _md_doc = None

# File extensions that get a markdown launcher subtree.
_MD_EXTS = ('.md', '.MD')

# Stdin-list mode (the ``browse-fs -`` argument). ``main()`` reads the
# newline-separated paths from ``sys.stdin`` once, before the UI starts,
# and stores them here as a list of ``(label, abspath)`` pairs in input
# order — ``label`` is the verbatim stdin line (shown as the row title),
# ``abspath`` its cwd-resolved absolute path (the Item id / fs target).
# ``get_children(None)`` serves this list as the root level instead of
# scanning a single directory. ``None`` in every other invocation mode
# (bare / single-PATH), in which case the root is a directory path and
# nothing here is consulted.
_STDIN_ROOTS = None


def human_size(n):
    for unit in ('B', 'K', 'M', 'G', 'T'):
        if n < 1024:
            return f'{n}{unit}'
        n //= 1024
    return f'{n}P'


def _is_dir(dirent):
    try:
        return dirent.is_dir(follow_symlinks=False)
    except OSError:
        return False


def _set_columns(item, st, is_dir):
    """Attach the perms / size / mtime display columns from a stat result.

    Shared by the directory-scan rows and the stdin-list roots so both
    render identical metadata columns. ``st`` is a no-follow stat (the
    row describes the entry itself, e.g. a symlink, not its target).
    """
    # Size moved out of the `tag` chip into the col_size column; rows
    # carry no tag now (fs_row_content renders the metadata columns).
    item.col_perms = stat.filemode(st.st_mode)
    item.col_size = '' if is_dir else human_size(st.st_size)
    item.col_mtime = time.strftime('%b %d %H:%M', time.localtime(st.st_mtime))


def _stdin_root_item(label, path):
    """Build a root-level Item for one stdin-listed path.

    ``label`` is shown verbatim (the line as piped); ``path`` is its
    cwd-resolved absolute path and the Item id, so a directory expands
    via the normal path-based ``get_children`` and a file previews as
    usual. A path that does not exist (``lstat`` fails) becomes a dim
    ``[missing]`` row whose id is the tagged tuple ``('missing', label,
    path)`` — a non-``str`` id, so the e/o/d actions skip it exactly as
    they skip the error row, and ``get_preview`` surfaces the stat error
    instead of crashing. A broken symlink still ``lstat``s fine, so it
    is a normal (existing-but-broken) row, not a missing one.
    """
    try:
        st = os.lstat(path)
    except OSError as e:
        # Title stays the verbatim label; the dim ``[missing]`` tag chip
        # is the marker (the same chip convention the error row uses).
        # The id carries the path so ``get_preview`` can surface the
        # stat error (re-statted there, so a path that appeared in the
        # meantime previews normally).
        return Item(id=('missing', label, path),
                    title=label, tag='missing', tag_style='dim')
    is_dir = stat.S_ISDIR(st.st_mode)
    item = Item(id=path, title=label,
                has_children=is_dir or _md_launchable(path))
    _set_columns(item, st, is_dir)
    return item


def _md_launchable(path):
    """True if ``path`` is a markdown file we offer a browse-md launcher for.

    Pure extension check (no I/O), cheap enough to call at listing time for
    every row. Gated on ``md_doc`` being importable — absent it, the whole
    launcher feature is inert and *.md rows stay leaves.
    """
    return _md_doc is not None and isinstance(path, str) and path.endswith(_MD_EXTS)


def _project_root_for(abspath):
    """Project-root resolution base for ``abspath`` — its git root, else its dir."""
    d = os.path.dirname(abspath)
    if _md_doc is not None:
        return _md_doc.find_git_root(d) or d
    return d


def _launcher_item(parent_path, target_abspath, project_root):
    """One ``[md ↗]`` launcher row that opens ``target_abspath`` in browse-md.

    Thin wrapper over ``md_doc.launcher_row``: the id is
    ``('launch', parent_path, 'md-file', target_abspath)`` and the title is the
    target's ``md_doc.ref_label`` anchored on ``project_root``. md_doc owns the
    row shape (leaf, ``[md ↗]`` tag); browse-fs only supplies the opaque
    ``('md-file', target_abspath)`` launch spec and the label anchoring.
    """
    return _md_doc.launcher_row(parent_path, ('md-file', target_abspath),
                                _md_doc.ref_label(target_abspath, project_root))


def _md_launcher_children(path):
    """Launcher rows for a *.md file row: the file itself, then its links.

    The self-open row comes first (so a *.md row always has >=1 child — no
    empty-subtree self-heal needed), followed by one row per DISTINCT, EXISTING
    ``.md`` file the document references (``md_doc.resolve_refs``, anchored on
    the file's own directory / cwd / project root), sorted by display label —
    the self file is excluded from that list (it is already the first row). An
    unreadable file still yields the lone self-open row.
    """
    project_root = _project_root_for(path)
    rows = [_launcher_item(path, path, project_root)]
    try:
        with open(path, 'rb') as f:
            text = f.read(100 * 1024 * 1024).decode('utf-8', errors='replace')
    except OSError:
        return rows
    self_abspath = os.path.realpath(path)
    for ab, _label in _md_doc.resolve_refs(text, doc_dir=os.path.dirname(path),
                                           cwd=os.getcwd(),
                                           project_root=project_root):
        if ab == self_abspath:
            continue
        rows.append(_launcher_item(path, ab, project_root))
    return rows


def get_children(path, *, reload=False):
    # Root level in stdin-list mode (``browse-fs -``): serve the paths
    # read from stdin verbatim, in order, instead of scanning a dir.
    # Directories among them carry their real abspath id, so expanding
    # one re-enters this function with that path and lists it normally.
    if path is None and _STDIN_ROOTS is not None:
        return [_stdin_root_item(label, abspath)
                for label, abspath in _STDIN_ROOTS]
    if not path:
        path = os.getcwd()
    # A markdown file row expands into browse-md launcher rows (the file
    # itself + the .md files it links to) rather than a directory scan.
    if _md_launchable(path) and os.path.isfile(path):
        return _md_launcher_children(path)
    try:
        entries = list(os.scandir(path))
    except OSError as e:
        return [Item(id=('err', path), title=f'[error] {e}',
                     tag='err', tag_style='red')]
    entries.sort(key=lambda d: (not _is_dir(d), d.name.lower()))
    items = []
    for d in entries:
        try:
            st = d.stat(follow_symlinks=False)
        except OSError:
            continue
        is_dir = stat.S_ISDIR(st.st_mode)
        title = d.name + ('/' if is_dir else '')
        item = Item(id=d.path, title=title,
                    has_children=is_dir or _md_launchable(d.path))
        _set_columns(item, st, is_dir)
        items.append(item)
    return items


def fs_row_content(item, ctx):
    """Columnar content: perms | size | mtime | name (flexible, last).

    Each metadata column is left/right-justified to the widest sibling
    value (``ctx.max_col_width`` over the row's parent group) and rendered
    dim; the title comes LAST so a narrow pane truncates the name rather
    than the metadata. Error / synthetic rows (no ``col_perms``) fall back
    to the framework default content. Only the content region is taken
    over — chrome (tree indent + ▼/▶) stays framework-owned.
    """
    if getattr(item, 'col_perms', None) is None:
        return default_row_content(item, ctx)    # error/synthetic row
    w = ctx.max_col_width
    dfg, dbold = style('dim')
    return [
        (cell_ljust(item.col_perms, w('col_perms')) + '  ', dfg, dbold),
        (cell_rjust(item.col_size,  w('col_size'))  + '  ', dfg, dbold),
        (cell_ljust(item.col_mtime, w('col_mtime')) + '  ', dfg, dbold),
        (item.title, None, False),        # flexible column, last
    ]


def _dir_listing(path):
    """Plain-text directory listing matching the children view ordering.

    Directories first, then files, sorted case-insensitively by name
    (the same ``(not _is_dir, name.lower())`` key ``get_children`` uses),
    with a ``/`` suffix on directory names. Capped at ~200 entries. This
    is just the preview pane — no perms/size/mtime columns.
    """
    entries = sorted(os.scandir(path),
                     key=lambda d: (not _is_dir(d), d.name.lower()))
    return '\n'.join(d.name + ('/' if _is_dir(d) else '')
                     for d in entries[:200])


def get_preview(path):
    if isinstance(path, tuple) and path[0] == 'err':
        return path[1]
    if isinstance(path, tuple) and path[0] == 'missing':
        # ('missing', label, abspath): a stdin-listed path that does not
        # exist. Show the verbatim label and the underlying stat error.
        _, label, abspath = path
        try:
            os.lstat(abspath)
            return label  # raced into existence between list and preview
        except OSError as e:
            return f'{label}\n\n[missing] {e}'
    if isinstance(path, tuple) and path and path[0] == 'launch':
        # ('launch', parent, 'md-file', target): show what would open — the
        # target file, rendered through the same path as a normal file row.
        return get_preview(path[3])
    try:
        if os.path.isdir(path):
            return _dir_listing(path)
        with open(path, 'rb') as f:
            text = f.read(100 * 1024 * 1024).decode('utf-8', errors='replace')
    except OSError as e:
        return f'[error] {e}'
    if _MD_COLOR and _md2ansi_fn is not None and path.endswith(_MD_EXTS):
        try:
            width = (_BROWSER.preview_width if _BROWSER else 0) or 80
            return _md2ansi_fn(text, line_width=width)
        except Exception:
            pass
    return text


def toggle_md(ctx):
    global _MD_COLOR
    _MD_COLOR = not _MD_COLOR
    ctx.drop_preview_cache()
    ctx.flash(f'md preview: {"colored" if _MD_COLOR else "raw"}')


def edit(ctx):
    # Only real entries have a str (path) id; the synthetic error row's id
    # is a tuple — acting on it is a no-op rather than a bogus argv.
    if not isinstance(ctx.cursor.id, str):
        return
    editor = os.environ.get('EDITOR', 'vi')
    ctx.run_external([editor, ctx.cursor.id])


def _on_enter(ctx):
    """Enter dispatch: launch on a ``[md ↗]`` launcher row, else edit (the default).

    A launcher row carries a ``('launch', parent, 'md-file', target)`` id —
    Enter opens its target file in browse-md via ``md_doc.launch`` (which owns
    the embedding flags + handoff). ``--root`` is anchored at the target's
    project root (git root, else its own directory) so links inside the opened
    document resolve the same way they do here. Every other row keeps browse-fs's
    original Enter behaviour (edit the cursor in ``$EDITOR``).
    """
    cur = ctx.cursor
    if cur is None:
        return
    if isinstance(cur.id, tuple) and cur.id and cur.id[0] == 'launch':
        target = cur.id[3]
        _md_doc.launch(ctx, path=target, roots=(_project_root_for(target),))
        return
    edit(ctx)


def open_(ctx):
    for it in ctx.targets:
        if not isinstance(it.id, str):     # skip the synthetic error row
            continue
        ctx.run_external(['xdg-open', it.id])


def delete(ctx):
    # Skip non-path (tuple) ids — only real filesystem entries are deletable.
    targets = [it for it in ctx.targets if isinstance(it.id, str)]
    if not targets:
        return
    label = targets[0].id if len(targets) == 1 else f'{len(targets)} items'
    if not ctx.confirm(f'delete {label}?', [('&Yes', True), ('&No', False)]):
        return
    for it in targets:
        try:
            (os.rmdir if os.path.isdir(it.id) else os.remove)(it.id)
        except OSError as e:
            ctx.error(f'{it.id}: {e}')
            return
    ctx.refresh()


# ---- context menu --------------------------------------------------------
#
# Following the committed convention (browse-procs / git / claude / md / plan):
# a PURE ``context_menu_options(ctx)`` builds the ``(label, token)`` rows by the
# CURSOR ITEM'S KIND (opening no modal, so it is unit-testable), a flat
# ``{token: handler}`` table (``_MENU_ACTIONS``) dispatches the chosen token,
# and a thin ``on_context_menu(ctx)`` ties the two together. Rows that duplicate
# a keybinding carry a LITERAL hotkey hint (menus don't parse ``&``): e (Edit /
# Enter), o (Open with default app), d (Delete). The ``m`` markdown toggle is a
# global preview knob (not a per-item action), so it is left to the keybinding
# and gets no menu row. Destructive deletes reuse the existing ``delete``
# handler's confirm; non-visible values (paths) pop up via ``ctx.alert`` — there
# is NO clipboard. A file row also surfaces *.md / .PLAN.md launches plus the
# shared directory actions (``_dir_actions``), which there act on the file's
# PARENT — the directory being listed; the ``git`` submenu appears only for a
# repo directory (the cursor dir, or a file's repo parent). The menu is
# read-only-friendly:
# a missing external tool surfaces via ``run_external``'s own error rather than
# crashing (browse-tui swallows ``on_context_menu`` exceptions besides).


# Git view modes browse-git accepts via ``--mode NAME`` (its verified
# ``<dir> --mode`` interface), as ``(submenu_label, mode)``. Shown only when the
# directory is a git repo, nested under a single ``git`` submenu row: the chosen
# entry launches ``browse-git <dir> --mode NAME`` on that directory.
_DIR_GIT_MODES = [
    ('commits',  'commits'),
    ('branches', 'branches'),
    ('status',   'status'),
    ('stashes',  'stash'),
    ('reflog',   'reflog'),
]

_PLAN_BASENAME = '.PLAN.md'


def _is_git_repo(path):
    """True iff ``path`` is inside a git work tree (``find_git_root`` hits).

    Reuses md_doc's ``.git``-walk (a worktree's ``.git`` file counts), so the
    ``git`` submenu lights up for both a plain repo and a worktree — matching
    browse-claude's same-named gate. ``False`` when md_doc is unavailable (the
    ``git`` row then never appears) or ``path`` is falsy.
    """
    return bool(path) and _md_doc is not None and _md_doc.find_git_root(path) is not None


def _editor_argv():
    """The user's editor as an argv prefix — ``$EDITOR`` (shell-split), else ``vi``."""
    import shlex
    return shlex.split(os.environ.get('EDITOR') or '') or ['vi']


def _pager_argv():
    """The user's pager as an argv prefix — ``$PAGER`` (shell-split), else ``less -R``."""
    import shlex
    return shlex.split(os.environ.get('PAGER') or '') or ['less', '-R']


def _str_targets(ctx):
    """The selected/cursor target Items with a real (``str`` path) id.

    Mirrors the filter the e/o/d handlers apply: the synthetic ``missing`` /
    ``err`` / ``launch`` rows have tuple ids, so they are dropped — the menu's
    multi-target Delete / Open reuse this so they never feed a tuple to argv.
    """
    return [it for it in ctx.targets if isinstance(it.id, str)]


def _selected_other_path(ctx, path):
    """The single OTHER selected path, or ``None`` — gates the "Diff" entry.

    Enabled only when exactly one selected row OTHER than the cursor's carries a
    real (``str``) path id. None, or two-plus others (ambiguous), yields
    ``None`` and the Diff entry is omitted.
    """
    others = [it.id for it in ctx.selected
              if isinstance(it.id, str) and it.id != path]
    return others[0] if len(others) == 1 else None


# -- shared handlers --------------------------------------------------------


def _target_dir(path):
    """The directory a ``dir.*`` action operates on, given the cursor's path.

    The directory actions (``_dir_actions``) are offered on BOTH a directory
    cursor and a file cursor, where they act on the directory being listed: the
    dir itself for a directory cursor, the file's PARENT for a file cursor. Their
    handlers all receive the cursor row's ``path``; this collapses the two cases
    so the same ``dir.*`` handler threads the right directory either way — the
    dir verbatim, else the file's parent (``'.'`` for a bare basename). This
    mirrors the original ``file.shell`` ``os.path.dirname(p) or '.'`` rule and is
    what keeps the dir-cursor tokens unchanged (the token says WHICH action; the
    cursor says WHICH directory).
    """
    return path if os.path.isdir(path) else (os.path.dirname(path) or '.')


def _run_shell(ctx, cwd):
    """Open an interactive ``$SHELL`` with ``cwd`` as the working directory.

    For a directory row ``cwd`` is the directory itself; for a file row it is
    the file's parent directory. ``ctx.run_external`` has no ``cwd`` knob, so
    the directory change rides in a shell-string command (which it runs via
    ``sh -c``): ``cd <dir> && exec <$SHELL> -l -i``. ``exec`` replaces the
    wrapping ``sh`` with the user's shell so signals / the exit code pass
    through naturally; ``-i`` makes it interactive and ``-l`` a login shell, so
    it loads the same startup files (``~/.bash_profile`` / ``~/.profile``) as
    the user's normal terminal and thus their real prompt — a plain ``-i``
    non-login shell reads only ``~/.bashrc`` and so misses any PS1 set up only
    on login. ``$SHELL`` defaults to ``sh`` and may itself carry args
    (``bash --login``), which the shell-string honours verbatim — appending
    `` -l -i`` after it is correct (and harmless if ``--login`` is redundant).
    The ``cd`` still wins: it runs in the wrapping ``sh`` before ``exec``, and
    the login startup doesn't change directory. The shell inherits the terminal
    (a normal interactive child), so no ``keep_screen``.
    """
    import shlex
    shell = os.environ.get('SHELL') or 'sh'
    ctx.run_external(f'cd {shlex.quote(cwd)} && exec {shell} -l -i')


def _new_file(ctx, dir_path):
    """Prompt for a name and create an empty file under ``dir_path``, then refresh.

    ``open(..., 'x')`` fails if the file already exists; that and a permission
    error surface via ``ctx.error`` rather than crashing. A cancel / blank name
    is a no-op. On success the directory is refreshed so the new row shows.
    """
    name = ctx.input('New file name: ')
    if name is None or not name.strip():
        return
    target = os.path.join(dir_path, name.strip())
    try:
        with open(target, 'x'):
            pass
    except OSError as e:
        ctx.error(f'{target}: {e}')
        return
    ctx.refresh()


def _new_dir(ctx, dir_path):
    """Prompt for a name and ``mkdir`` it under ``dir_path``, then refresh.

    ``os.mkdir`` fails if the directory already exists; that and a permission
    error surface via ``ctx.error``. A cancel / blank name is a no-op.
    """
    name = ctx.input('New directory name: ')
    if name is None or not name.strip():
        return
    target = os.path.join(dir_path, name.strip())
    try:
        os.mkdir(target)
    except OSError as e:
        ctx.error(f'{target}: {e}')
        return
    ctx.refresh()


def _open_browse_git(ctx, dir_path, mode):
    """Launch ``browse-git <dir> --mode NAME`` (another browse-tui recipe)."""
    ctx.run_external(['browse-git', dir_path, '--mode', mode], keep_screen=True)


def _open_git_menu(ctx, dir_path):
    """Open the second-level ``git`` mode submenu, then launch browse-git.

    The ``git`` Level-1 row's handler: re-invoke ``ctx.menu`` with the
    ``_DIR_GIT_MODES`` rows — each a ``(submenu_label, mode)`` pair, so the chosen
    token IS the mode — (the framework runs sequential submenus within one
    ``on_context_menu`` fire, as browse-git's Reset ▸ does) and, on a non-``None``
    choice, open ``browse-git <dir> --mode NAME``. A cancel (``None``) is a no-op.
    """
    mode = ctx.menu(_DIR_GIT_MODES)
    if mode is not None:
        _open_browse_git(ctx, dir_path, mode)


def _view_pager(ctx, path):
    """Page ``path`` in ``$PAGER`` (the file's contents — the View entry)."""
    ctx.run_external(_pager_argv() + [path])


def _render_mdcat(ctx, path):
    """Render a markdown file through ``mdcat`` and page it (the Render entry).

    ``mdcat <file> | less -RS`` when both are present (so a long render is
    scrollable), else bare ``mdcat`` (which pages itself on a tty), else an
    error. A missing tool surfaces via ``run_external`` / ``ctx.error``.
    """
    if shutil.which('mdcat') and shutil.which('less'):
        ctx.run_external(['bash', '-c', 'mdcat "$0" | less -RS', path])
    elif shutil.which('mdcat'):
        ctx.run_external(['mdcat', path])
    else:
        ctx.error('mdcat not found on PATH')


def _browse_md(ctx, path):
    """Open a markdown file in browse-md (another browse-tui recipe)."""
    ctx.run_external(['browse-md', path], keep_screen=True)


def _browse_plan(ctx, path):
    """Open a ``.PLAN.md`` file in browse-plan (another browse-tui recipe)."""
    ctx.run_external(['browse-plan', '-f', path], keep_screen=True)


def _edit_targets(ctx):
    """Open every selected real-path target in ``$EDITOR`` in one invocation.

    Most editors accept multiple files on one command line, so the whole
    selection opens at once. The synthetic (tuple-id) rows are filtered out via
    ``_str_targets``; nothing to edit is a no-op.
    """
    paths = [it.id for it in _str_targets(ctx)]
    if paths:
        ctx.run_external(_editor_argv() + paths)


def _diff_selected(ctx, path):
    """Page a diff of the cursor path vs the single OTHER selected path.

    Gated by ``_selected_other_path`` — reached only when exactly one other real
    path is selected. Runs ``diff -u OTHER CURSOR`` and pipes it through
    ``delta`` when on PATH (terminal-native rendering), else pages the plain
    unified diff. ``diff`` exits non-zero whenever the files differ, so the exit
    code is NOT gated on; identical files (empty output) flash instead of paging
    an empty pager. A spawn failure surfaces via ``ctx.error``.
    """
    other = _selected_other_path(ctx, path)
    if other is None:
        ctx.flash('select exactly one other item to diff against')
        return
    try:
        result = subprocess.run(['diff', '-u', other, path],
                                capture_output=True, text=True)
    except OSError as e:
        ctx.error(f'diff: {e}')
        return
    text = result.stdout
    if not text.strip():
        ctx.flash(f'no differences between {os.path.basename(other)} '
                  f'and {os.path.basename(path)}')
        return
    if HAVE_DELTA:
        try:
            delta = subprocess.run(['delta', '--no-gitconfig', '--paging', 'never'],
                                   input=text, capture_output=True, text=True)
            if delta.returncode == 0:
                text = delta.stdout
        except OSError:
            pass  # fall back to the plain unified diff
    ctx.page(text, lang='diff')


# -- per-kind menu builders -------------------------------------------------


def _dir_actions(dir_path):
    """``(label, token)`` rows for the NON-destructive actions on ``dir_path``.

    The directory-related actions a browse-fs row can offer: Run-shell-here, the
    ``git`` submenu (only when ``dir_path`` is a repo), and New file / New
    directory (created IN ``dir_path``). Shared by a directory cursor (where
    ``dir_path`` is the cursor dir) and a file cursor (where ``dir_path`` is the
    file's PARENT — the directory being listed), so the same actions operate on
    whichever directory is in play.

    ``dir_path`` here gates the ``git`` row (``_is_git_repo``); the chosen row's
    handler re-derives the same directory from the cursor via ``_target_dir`` (so
    the token stays a plain string, and the dir-cursor tokens are unchanged).
    Destructive Delete / "Show full path" are NOT here — those are row-kind
    specific and stay with the per-kind builder.
    """
    rows = [('Run shell here', 'dir.shell')]
    if _is_git_repo(dir_path):
        rows.append(('git ▸', 'dir.git'))
    rows.extend([
        ('New file…', 'dir.newfile'),
        ('New directory…', 'dir.newdir'),
    ])
    return rows


def context_menu_dir(ctx, path):
    """``(label, token)`` rows for a directory cursor row.

    The shared directory actions (``_dir_actions`` — Run-shell-here, the ``git``
    submenu when a repo, New file / New directory), then Show full path and Delete
    (reusing the ``d`` handler's confirm → ``(d)`` hint). "Show full path" is
    ALWAYS offered for a path row — the row title is cell-cut WITHOUT an ellipsis
    when the pane is narrow, so a pop-up is the reliable way to read a long path
    (and a redundant pop-up of a short path is harmless); the recipe can't
    cheaply detect render-time truncation, so always-show beats a fragile
    heuristic.
    """
    rows = list(_dir_actions(path))
    rows.extend([
        ('Show full path', 'dir.path'),
        ('Delete (d)', 'delete'),
    ])
    return rows


def context_menu_file(ctx, path):
    """``(label, token)`` rows for a file cursor row.

    Edit / Open / Delete reuse the e / o / d handlers, so their rows carry the
    literal hotkey hint. View pages the file in ``$PAGER``. A ``.PLAN.md`` file
    gains a browse-plan row; any ``*.md`` file gains a browse-md row plus a
    Render-with-mdcat row. "Diff against selected" appears only when exactly one
    OTHER item is selected (``_selected_other_path``). "Show full path" is always
    offered (see ``context_menu_dir``). Delete here removes the FILE.

    The shared directory actions (``_dir_actions``) are appended, acting on the
    file's PARENT — the directory being listed. That folds in Run-shell-here
    (which therefore appears exactly once, no standalone file row), the ``git``
    submenu when the parent is a repo, and New file / New directory created in
    that parent. The parent's Delete / Show-full-path are deliberately NOT
    appended: Delete on a file row deletes the file, and the parent directory
    must never be offered for deletion from a file cursor.
    """
    rows = [
        ('Edit in $EDITOR (e)', 'file.edit'),
        ('View in $PAGER', 'file.view'),
        ('Open with default app (o)', 'file.open'),
    ]
    if os.path.basename(path) == _PLAN_BASENAME:
        rows.append(('Browse in browse-plan', 'file.plan'))
    if path.endswith(_MD_EXTS):
        rows.append(('Browse in browse-md', 'file.md'))
        rows.append(('Render with mdcat', 'file.mdcat'))
    if _selected_other_path(ctx, path) is not None:
        rows.append(('Diff against selected', 'file.diff'))
    rows.extend([
        ('Show full path', 'file.path'),
        ('Delete (d)', 'delete'),
    ])
    rows.extend(_dir_actions(os.path.dirname(path) or '.'))
    return rows


def context_menu_multi(ctx):
    """``(label, token)`` rows for a multi-row selection.

    Reuses the ``d`` delete handler (its confirm already operates on the whole
    selection — the label just shows the count) and an "Open N in $EDITOR" row
    over the same targets. The count is the number of REAL (str-path) targets.
    """
    n = len(_str_targets(ctx))
    return [
        (f'Delete {n} items (d)', 'delete'),
        (f'Open {n} in $EDITOR', 'multi.edit'),
    ]


# ---- menu dispatch + the hook --------------------------------------------
#
# ``_MENU_ACTIONS`` maps every token a ``context_menu_*`` builder can emit to
# its handler ``(ctx, path)`` — a single uniform signature; ``path`` is the
# cursor row's path (``None`` for a multi-select / specials menu, where the
# handler reads ``ctx.targets`` itself). The e / o / d / m handlers (``edit`` /
# ``open_`` / ``delete`` / ``toggle_md``) are reused directly so the menu's
# Edit / Open / Delete / toggle rows stay single-sourced with the keybindings.


_MENU_ACTIONS = {
    # directory actions (``_dir_actions``) — offered on a directory cursor AND a
    # file cursor; ``_target_dir`` re-derives WHICH dir from the cursor's path
    # (the dir itself, else the file's parent), so one handler serves both.
    'dir.shell':       lambda c, p: _run_shell(c, _target_dir(p)),
    'dir.git':         lambda c, p: _open_git_menu(c, _target_dir(p)),
    'dir.newfile':     lambda c, p: _new_file(c, _target_dir(p)),
    'dir.newdir':      lambda c, p: _new_dir(c, _target_dir(p)),
    # directory-row only — the cursor path IS the dir here.
    'dir.path':        lambda c, p: c.alert(p, title='path'),
    # file
    'file.edit':       lambda c, p: edit(c),
    'file.view':       lambda c, p: _view_pager(c, p),
    'file.open':       lambda c, p: open_(c),
    'file.plan':       lambda c, p: _browse_plan(c, p),
    'file.md':         lambda c, p: _browse_md(c, p),
    'file.mdcat':      lambda c, p: _render_mdcat(c, p),
    'file.diff':       lambda c, p: _diff_selected(c, p),
    'file.path':       lambda c, p: c.alert(p, title='path'),
    # multi-select
    'multi.edit':      lambda c, p: _edit_targets(c),
    # missing special — only Show full path (its path is id[2]).
    'missing.path':    lambda c, p: c.alert(p, title='path'),
    # shared (file + dir + multi) — the existing d delete handler / confirm.
    'delete':          lambda c, p: delete(c),
}


def context_menu_options(ctx):
    """``(label, token)`` rows for the browse-fs context menu (pure — no modal).

    Branches on the cursor row's KIND. A multi-row selection (>1 real target)
    wins first — Delete N / Open N. Otherwise a single cursor: a ``str`` id is a
    real path, dispatched to the directory or file builder by ``os.path.isdir``;
    a tuple id is a synthetic row — a ``missing`` row offers only "Show full
    path" (its path is ``id[2]``), and an ``err`` / ``launch`` row offers
    nothing (no file/dir actions on a non-existent or launcher path). Returns
    ``[]`` when there is no cursor, so the hook opens nothing.
    """
    cur = ctx.cursor
    if cur is None:
        return []
    # Multi-row selection: the count-labelled Delete / Open rows take over.
    if len(_str_targets(ctx)) > 1:
        return context_menu_multi(ctx)
    item_id = cur.id
    if isinstance(item_id, str):
        if os.path.isdir(item_id):
            return context_menu_dir(ctx, item_id)
        return context_menu_file(ctx, item_id)
    # Synthetic rows: a missing path can still show its full path; an err /
    # launch row gets no file/dir actions.
    if isinstance(item_id, tuple) and item_id and item_id[0] == 'missing':
        return [('Show full path', 'missing.path')]
    return []


def on_context_menu(ctx):
    """Open the browse-fs context menu and dispatch the chosen entry.

    The hook the framework fires on right-click / `` ` ``-F1: build the (pure)
    per-kind option list, open it with ``ctx.menu``, and route the chosen token
    through ``_MENU_ACTIONS``. Each handler is passed the cursor row's path (the
    ``str`` id, or a ``missing`` row's ``id[2]``; ``None`` for a multi-select /
    err / launch cursor — those handlers read ``ctx.targets`` themselves). A
    cancel (``None``) or an empty list is a no-op.
    """
    token = ctx.menu(context_menu_options(ctx))
    handler = _MENU_ACTIONS.get(token)
    if handler is None:
        return
    cur = ctx.cursor
    cid = cur.id if cur is not None else None
    if isinstance(cid, str):
        path = cid
    elif isinstance(cid, tuple) and cid and cid[0] == 'missing':
        path = cid[2]
    else:
        path = None
    handler(ctx, path)


def mtime_watcher(browser):
    """Poll mtime of each currently-cached directory; refresh on change.

    Works unchanged in stdin-list mode (``browse-fs -``): the root key
    there is ``None`` (not a directory), so it is skipped by the
    ``isinstance(d, str)`` guard below and the stdin root list itself is
    not polled — there is no single directory backing it. Real
    directories expanded from that list have ordinary path ids, so they
    are watched naturally once their children are cached. No new watcher
    machinery is added for the stdin roots.
    """
    last = {}
    while True:
        time.sleep(1.0)
        for d in browser.cached_parents():
            if not isinstance(d, str):
                continue
            try:
                m = os.stat(d).st_mtime
            except OSError:
                continue
            if d in last and last[d] != m:
                browser.refresh(d)
            last[d] = m


