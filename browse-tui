    if isinstance(x, Item):
        return x
    if isinstance(x, str):
        return Item(id=x)
    if isinstance(x, tuple):
        if not 1 <= len(x) <= 6:
            raise TypeError(
                f'to_item: tuple must have 1-6 elements, got {len(x)}'
            )
        return Item(*x)
    if isinstance(x, dict):
        if 'id' not in x:
            raise TypeError("to_item: dict must contain 'id' key")
